<template>
  <div class="panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <PageTitle
      icon="fa-search-plus"
      :title="'Tag 통합 분석 및 속성 비교' + (manualProjNo ? ` [ ${manualProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 ms-auto me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Project No</span>
            <input
              type="text"
              class="form-control form-control-sm custom-input-width"
              v-model="manualProjNo"
              @change="onProjectChange"
              placeholder="예: TE1002"
            />
          </label>
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-nowrap">조회 키워드</span>
            <textarea
              class="form-control form-control-sm custom-input-width"
              style="height: 31px; resize: none"
              v-model="searchKeywordRef"
              placeholder="Tag No (공백/엔터 구분)"
            ></textarea>
          </label>
          <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="ms-2 ps-3 border-start d-flex align-items-center gap-2">
            <span class="fw-bold text-success text-nowrap"><i class="fa-search"></i> 결과 필터</span>
            <input
              type="text"
              class="form-control form-control-sm border-success custom-input-width"
              v-model="localFilterQuery"
              @input="onFilterInput"
              placeholder="결과 내 검색"
            />
          </div>
          <div class="ms-1 d-flex align-items-center gap-2">
            <span class="fw-bold text-primary text-nowrap"><i class="fa-columns"></i> 컬럼 필터</span>
            <textarea
              class="form-control form-control-sm border-primary custom-input-width"
              style="height: 31px; resize: none"
              v-model="columnFilterQuery"
              placeholder="표시할 컬럼명"
            ></textarea>
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-heading p-0 m-0">
      <BasicToolBar
        :showCreate="false"
        :showMultiCreate="false"
        :showSave="false"
        :showDelete="true"
        :isDisabledDeleteBtn="isDisabledDeleteBtn"
        @delete="onDelete"
      />
    </div>

    <div class="panel-body flex-grow-1 overflow-hidden m-0 p-0 h-100">
      <ag-grid-vue
        v-bind="gridBindProps"
        class="ag-theme-alpine w-100 h-100"
        @grid-ready="onGridReady"
        @selection-changed="onSelectionChanged"
        @cell-clicked="onCellClicked"
      />
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window shadow-lg">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge shadow-sm" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">
              {{ selectedRow?.Source }}
            </span>
            <span class="fw-bold text-white">Detail View: {{ selectedRow?.TAG_NO }}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-xs btn-outline-light" @click="isJsonMode = !isJsonMode">
              {{ isJsonMode ? 'Table View' : 'JSON View' }}
            </button>
            <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
          </div>
        </div>
        <div class="modal-body-content">
          <div v-if="isJsonMode" class="json-wrapper">
            <pre class="json-content"><code>{{ JSON.stringify(selectedRow, null, 2) }}</code></pre>
          </div>
          <div v-else class="modal-grid-container ag-theme-alpine">
            <ag-grid-vue v-bind="modalGridBindProps" class="w-100 h-100" />
          </div>
        </div>
      </div>
    </div>

    <div v-if="showClassModal" class="custom-modal-overlay" @click.self="closeClassModal">
      <div class="custom-modal-window shadow-lg" style="width: 850px; height: 65%">
        <div class="modal-header-dark" style="background: #334155">
          <div class="d-flex align-items-center gap-2">
            <i class="fa fa-info-circle text-info"></i>
            <span class="fw-bold text-white">Class Info: {{ clickedClassId }}</span>
          </div>
          <button @click="closeClassModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-3">
          <div class="alert alert-info py-2 mb-3 border-0 shadow-sm" style="background-color: #f0f7ff">
            <i class="fa fa-external-link me-2"></i><b>Register No</b>를 클릭하면 새 탭으로 열립니다.
          </div>
          <div class="modal-grid-container ag-theme-alpine shadow-sm">
            <ag-grid-vue
              style="width: 100%; height: 100%"
              :columnDefs="classModalColDefs"
              :rowData="classModalData"
              :defaultColDef="{ resizable: true, sortable: true, filter: true }"
              @cell-clicked="onClassGridCellClicked"
              :headerHeight="40"
              :rowHeight="38"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, watch, onMounted } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import { storeToRefs } from 'pinia'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sortBy } from 'lodash-es'
import { useAppMenuStore } from '@/stores/app-menu'
import { sAlert } from '@/utils/messages/alert-common'
import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

// AG Grid Enterprise
import 'ag-grid-enterprise'

const router = useRouter()
const route = useRoute()
const appMenu = useAppMenuStore()
const { currentProjNo, currentEpId } = storeToRefs(appMenu)

const gridApi = shallowRef()
const manualProjNo = ref('')
const searchKeywordRef = ref('')
const localFilterQuery = ref('')
const columnFilterQuery = ref('')
const rawDataList = ref([])
const dynamicAttCols = ref([])
const dynamicRemainingCols = ref([])
const isDisabledDeleteBtn = ref(true)

const showModal = ref(false)
const selectedRow = ref(null)
const isJsonMode = ref(false)
const showClassModal = ref(false)
const classModalData = ref([])
const clickedClassId = ref('')

// 하이라이트 렌더러
const highlightRenderer = p => {
  const val = p.value === null || p.value === undefined ? '' : String(p.value)
  if (!val || !localFilterQuery.value.trim()) return val
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k)
  let text = val
  kws.forEach(kw => {
    const escapedKw = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    text = text.replace(new RegExp(`(${escapedKw})`, 'gi'), `<mark class="filter-highlight">$1</mark>`)
  })
  return text
}

// 1. 조회 로직
const onSearch = async () => {
  const pNo = manualProjNo.value?.trim() || currentProjNo.value
  if (!pNo) return sAlert.Warning(`Project No를 입력하세요.`)
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
    let combined = []

    for (const key of searchKeys) {
      const payload = { ProjectNo: pNo, Keyword: key }
      const [p, w] = await Promise.allSettled([
        axiosWrapper.post('/api/Data/SearchPublishData', payload),
        axiosWrapper.post('/api/Data/SearchWorkingData', payload),
      ])
      if (p.status === 'fulfilled' && p.value) {
        const data = Array.isArray(p.value) ? p.value : [p.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Published' })))
      }
      if (w.status === 'fulfilled' && w.value) {
        const data = Array.isArray(w.value) ? w.value : [w.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Working' })))
      }
    }

    const allAttIds = new Set()
    const allKeys = new Set()
    const fixedKeys = ['Source', 'DELETED', 'TAG_IDX', 'TAG_NO', 'EP_ID', 'CLS_ID', 'ATTRIBUTES', '_id']

    combined.forEach(item => {
      ;(item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
      Object.keys(item).forEach(k => { if (!fixedKeys.includes(k) && typeof item[k] !== 'object') allKeys.add(k) })
    })

    const processedData = combined.map(item => {
      const flatItem = { ...item }
      allAttIds.forEach(id => {
        const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
        flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
      })
      return flatItem
    })

    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id, field: `ATT_${id}`, minWidth: 130, headerClass: 'att-column-header',
      cellRenderer: highlightRenderer,
      cellStyle: p => ({ background: '#fff9db', color: p.value === 'null' ? '#adb5bd' : '#000' }),
    }))

    dynamicRemainingCols.value = Array.from(allKeys).sort().map(k => ({ 
      headerName: k, field: k, minWidth: 150, cellRenderer: highlightRenderer 
    }))

    rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
  } catch (err) {
    sAlert.Error('조회 실패')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// 2. 셀 클릭 이벤트 (상세보기 & 클래스 링크)
const onCellClicked = async p => {
  const colId = p.column.getColId()
  const pNo = manualProjNo.value?.trim() || currentProjNo.value
  
  if (colId === 'Source') {
    selectedRow.value = p.data
    showModal.value = true
    isJsonMode.value = false
  } else if (colId === 'CLS_ID' && p.value) {
    clickedClassId.value = p.value
    try {
      if (gridApi.value) gridApi.value.setGridOption('loading', true)
      const res = await axiosWrapper.post('/api/Register/GetByClassIDs', {
        ContainDeleted: false, ProjectNo: pNo, ClassIDs: [p.value],
      })
      classModalData.value = Array.isArray(res) ? res : [res]
      showClassModal.value = true
    } catch (e) {
      sAlert.Error('Class 정보 로드 실패')
    } finally {
      if (gridApi.value) gridApi.value.setGridOption('loading', false)
    }
  }
}

// 3. 메인 그리드 바인딩 설정 (Enterprise + Line 스타일)
const gridBindProps = computed(() => {
  const fixedCols = [
    {
      headerName: 'Source', field: 'Source', width: 130, pinned: 'left',
      checkboxSelection: true, headerCheckboxSelection: true,
      cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'}; color:white; width:100%">${p.value}</span>`,
    },
    {
      field: 'DELETED', headerName: 'Deleted', width: 90, pinned: 'left',
      cellRenderer: p => p.value ? `<span class="badge bg-danger w-100">True</span>` : `<span class="badge bg-secondary w-100">False</span>`,
    },
    { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'TAG_IDX', headerName: 'TAG_IDX', width: 120, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'EP_ID', headerName: 'EP ID', width: 120, pinned: 'left', cellRenderer: highlightRenderer },
    {
      field: 'CLS_ID', headerName: 'Class', width: 150, pinned: 'left',
      cellRenderer: highlightRenderer,
      cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd', fontWeight: 'bold' },
    },
  ]

  const colFilterKws = columnFilterQuery.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
  const filteredAtts = colFilterKws.length ? dynamicAttCols.value.filter(c => colFilterKws.some(kw => c.headerName.toLowerCase().includes(kw))) : dynamicAttCols.value
  const filteredRems = colFilterKws.length ? dynamicRemainingCols.value.filter(c => colFilterKws.some(kw => c.headerName.toLowerCase().includes(kw))) : dynamicRemainingCols.value

  return {
    columnDefs: [...fixedCols, ...filteredAtts, ...filteredRems],
    rowData: rawDataList.value,
    defaultColDef: {
      sortable: true, filter: 'agTextColumnFilter', resizable: true,
      floatingFilter: true, // 상단 필터바
    },
    rowSelection: 'multiple',
    suppressRowClickSelection: true,
    pagination: true,
    paginationPageSize: 100,
    loadingOverlayComponent: AggridLoadingOverlay,
    // Enterprise 전용 설정
    enableRangeSelection: true,
    sideBar: { toolPanels: ['columns', 'filters'], defaultToolPanel: '' },
    statusBar: { statusPanels: [{ statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'left' }] },
    // 그리드 선(Lines)을 보이기 위한 설정
    rowHeight: 35,
    headerHeight: 40,
  }
})

// 4. 기타 함수들 (모달 제어, 삭제 등)
const closeModal = () => { showModal.value = false; selectedRow.value = null; }
const closeClassModal = () => { showClassModal.value = false; classModalData.value = []; }

const onClassGridCellClicked = p => {
  if (p.column.getColId() === 'TYPE_ID' && p.value) {
    const routeData = router.resolve({
      path: '/register-mapping-setup',
      query: { reg_type_id: p.data.TYPE_ID, proj_no: manualProjNo.value || currentProjNo.value, ep_id: p.data.EP_ID || currentEpId.value },
    })
    window.open(routeData.href, '_blank')
  }
}

const onGridReady = p => { gridApi.value = p.api }
const onSelectionChanged = () => { if (gridApi.value) isDisabledDeleteBtn.value = gridApi.value.getSelectedNodes().length === 0 }
const onFilterInput = () => { if (gridApi.value) gridApi.value.onFilterChanged() }

// 상세 보기용 그리드 설정
const modalGridBindProps = computed(() => {
  if (!selectedRow.value) return {}
  const rows = []
  Object.entries(selectedRow.value).forEach(([k, v]) => {
    if (k !== 'ATTRIBUTES' && !k.startsWith('ATT_') && k !== 'Source') rows.push({ category: 'System', key: k, value: v ?? '-' })
  })
  ;(selectedRow.value.ATTRIBUTES || []).forEach(a => rows.push({ category: 'Attribute', key: a.ATT_ID, value: a.VALUE ?? 'null' }))
  return {
    columnDefs: [
      { headerName: 'Category', field: 'category', width: 120, cellStyle: { fontWeight: 'bold', background: '#f8f9fa' } },
      { headerName: 'Property', field: 'key', width: 220 },
      { headerName: 'Value', field: 'value', flex: 1, cellStyle: p => ({ color: p.value === 'null' ? '#adb5bd' : '#000' }) },
    ],
    rowData: rows,
    headerHeight: 35, rowHeight: 32,
  }
})

onMounted(() => {
  manualProjNo.value = route.query.proj_no || currentProjNo.value
})

const onProjectChange = () => {
  router.replace({ query: { ...route.query, proj_no: manualProjNo.value } })
}

const onDelete = async () => {
  const nodes = gridApi.value?.getSelectedNodes() || []
  if (!nodes.length) return sAlert.Warning('항목을 선택해주세요.')
  if (!confirm(`${nodes.length}건을 삭제하시겠습니까?`)) return
  try {
    gridApi.value.setGridOption('loading', true)
    for (const n of nodes) {
      const url = n.data.Source === 'Published' ? '/api/Admin/Tool/DeletePublishedData' : '/api/Admin/Tool/DeleteWorkingData'
      await axiosWrapper.post(url, { ProjectNo: manualProjNo.value || currentProjNo.value, TagIdx: n.data.TAG_IDX })
    }
    sAlert.Success('삭제 완료'); await onSearch()
  } catch (e) { sAlert.Error('삭제 실패') }
}
</script>

