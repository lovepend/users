            <span class="fw-bold text-primary text-nowrap">검사할 Tag No</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary"
              style="width: 250px"
              v-model="tagNoForValidator"
              placeholder="검증할 태그 번호 입력"
            />
          </label>
          <button class="btn btn-xs btn-info shadow-sm" @click="showPasteModal = true">
            <i class="fa fa-paste me-1"></i>엑셀 붙여넣기
          </button>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100 overflow-hidden">
      <div class="row m-0 h-100">
        <div class="col-md-5 p-0 border-end h-100 d-flex flex-column">
          <div class="panel-heading bg-light border-bottom px-3 py-2">
            <div class="d-flex justify-content-between align-items-center">
              <span class="fw-bold"><i class="fa fa-list-ol me-2"></i>1. 규칙 설정</span>
              <button class="btn btn-xs btn-success" @click="addRule">
                <i class="fa fa-plus"></i> 규칙 추가
              </button>
            </div>
          </div>
          <div class="flex-grow-1 overflow-auto p-0">
            <table class="table table-sm table-hover mb-0 custom-table">
              <thead class="table-light sticky-top">
                <tr>
                  <th class="text-center" width="50">No</th>
                  <th width="80">구분자</th>
                  <th>정규식 (Regex)</th>
                  <th width="40"></th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center align-middle text-muted small">#{{ index + 1 }}</td>
                  <td>
                    <input type="text" v-model="rule.delimiter" class="form-control form-control-xs text-center font-monospace" placeholder="없음" />
                  </td>
                  <td>
                    <input type="text" v-model="rule.regex" class="form-control form-control-xs font-monospace" placeholder="예: ^[A-Z]+$" />
                  </td>
                  <td class="text-center">
                    <button @click="removeRule(index)" class="btn btn-link btn-xs text-danger p-0"><i class="fa fa-times"></i></button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="col-md-7 p-0 h-100 d-flex flex-column bg-light">
          <div class="panel-heading bg-light border-bottom px-3 py-2">
            <span class="fw-bold"><i class="fa fa-search me-2"></i>2. 유효성 분석 결과</span>
          </div>
          
          <div class="p-3 flex-grow-1 overflow-auto">
            <div :class="['alert d-flex align-items-center shadow-sm mb-3', isTagNoValid ? 'alert-success border-success' : 'alert-danger border-danger']">
              <i :class="['fa fa-2x me-3', isTagNoValid ? 'fa-check-circle text-success' : 'fa-times-circle text-danger']"></i>
              <div>
                <h5 class="alert-heading mb-1 fw-bold">{{ isTagNoValid ? '검증 통과' : '검증 실패' }}</h5>
                <div class="small font-monospace opacity-75">Full Pattern: {{ combinedRegexDisplay }}</div>
              </div>
            </div>

            <div class="card shadow-sm border-0">
              <div class="card-header bg-white py-2 fw-bold text-secondary small">구성요소별 매칭 상세</div>
              <div class="card-body p-0">
                <table class="table table-sm mb-0">
                  <thead class="bg-light small text-uppercase">
                    <tr>
                      <th class="ps-3" width="100">구성요소</th>
                      <th>추출된 값</th>
                      <th class="text-center" width="70">구분자</th>
                      <th class="text-center" width="70">내용</th>
                      <th class="text-center" width="80">결과</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr v-for="(part, index) in tagParts" :key="index">
                      <td class="ps-3 text-muted small">규칙 #{{ index + 1 }}</td>
                      <td class="fw-bold">{{ part.matchedValue === '' ? '(빈값)' : part.matchedValue || '-' }}</td>
                      <td class="text-center">
                        <span v-if="part.hasDelimiterRule" :class="part.isDelimiterValid ? 'text-success' : 'text-danger fw-bold'">{{ part.isDelimiterValid ? 'OK' : 'ERR' }}</span>
                        <span v-else class="text-muted">-</span>
                      </td>
                      <td class="text-center">
                        <span :class="part.isContentValid ? 'text-success' : 'text-danger fw-bold'">{{ part.isContentValid ? 'OK' : 'ERR' }}</span>
                      </td>
                      <td class="text-center">
                        <span :class="['badge w-100', part.isValid ? 'bg-success' : 'bg-danger']">{{ part.isValid ? 'PASS' : 'FAIL' }}</span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div v-if="!isTagNoValid" class="mt-3 alert alert-warning border-0 shadow-sm py-2">
              <i class="fa fa-exclamation-triangle me-2"></i>
              <strong>분석 의견:</strong> 입력된 태그 번호가 정의된 정규식 규칙 및 구분자와 일치하지 않습니다.
            </div>
          </div>
        </div>
      </div>
    </div>

    <div v-if="showPasteModal" class="custom-modal-overlay" @click.self="showPasteModal = false">
      <div class="custom-modal-window shadow-lg" style="width: 500px; height: 500px;">
        <div class="modal-header-dark bg-primary">
          <span class="fw-bold text-white"><i class="fa fa-paste me-2"></i>엑셀 데이터 붙여넣기</span>
          <button @click="showPasteModal = false" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-3">
          <p class="small text-muted mb-2">엑셀에서 [구분자], [정규식] 열을 복사해 붙여넣으세요.</p>
          <textarea v-model="pasteData" class="form-control flex-grow-1 font-monospace mb-3" placeholder="구분자 [Tab] 정규식..."></textarea>
          <div class="d-flex justify-content-end gap-2">
            <button @click="applyPasteData" class="btn btn-primary btn-sm px-4">데이터 적용</button>
            <button @click="showPasteModal = false" class="btn btn-secondary btn-sm">닫기</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed } from 'vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

const manualProjNo = ref('')
const tagNoForValidator = ref('AA-11-BB-2222-C')
const showPasteModal = ref(false)
const pasteData = ref('')
const tagRules = ref([
  { delimiter: '', regex: '^[A-Z]{2}$' },
  { delimiter: '-', regex: '^[0-9]{2}$' },
  { delimiter: '-', regex: '^[A-Z]{2}$' },
  { delimiter: '-', regex: '^[0-9]{4}$' },
  { delimiter: '-', regex: '^[A-Z]{1}$' },
])

const canBeEmpty = (regexStr) => {
  try {
    return new RegExp(`^(${regexStr.replace(/^\^|\$/g, '')})$`).test('')
  } catch { return false }
}

const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0

  for (let i = 0; i < tagRules.value.length; i++) {
    const rule = tagRules.value[i]
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null
    const hasDelim = delim !== ''

    if (hasDelim) {
      if (currentStr.substring(cursor).startsWith(delim)) {
        cursor += delim.length
        dOk = true
      } else {
        dOk = canBeEmpty(rule.regex)
      }
    }

    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) {
        matchedVal = matcher[1]
        cursor += matchedVal.length
        cOk = true
      } else if (canBeEmpty(rule.regex)) {
        matchedVal = ''
        cOk = true
      }
    } catch { cOk = false }

    results.push({
      hasDelimiterRule: hasDelim,
      isDelimiterValid: dOk,
      isContentValid: cOk,
      matchedValue: matchedVal,
      isValid: dOk && cOk,
    })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  const allPartsPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPartsPass) return false
  let usedLen = 0
  tagParts.value.forEach((p, i) => {
    if (p.hasDelimiterRule && p.isDelimiterValid) {
      if (tagNoForValidator.value.substring(usedLen).startsWith(tagRules.value[i].delimiter)) {
        usedLen += tagRules.value[i].delimiter.length
      }
    }
    if (p.matchedValue) usedLen += p.matchedValue.length
  })
  return usedLen === (tagNoForValidator.value || '').length
})

const applyPasteData = () => {
  if (!pasteData.value.trim()) return
  const rows = pasteData.value.split('\n')
  const newRules = rows.map(row => {
    const cols = row.split('\t')
    let delim = cols[0] ? cols[0].trim() : ''
    let regex = cols[1] ? cols[1].trim() : ''
    if (cols.length === 1 && delim.includes('^')) {
      regex = delim
      delim = ''
    }
    return { delimiter: delim, regex: regex }
  }).filter(r => r.delimiter || r.regex)

  if (newRules.length) tagRules.value = newRules
  showPasteModal.value = false
  pasteData.value = ''
}

const combinedRegexDisplay = computed(() =>
  tagRules.value.map(r => (r.delimiter ? `[${r.delimiter}]` : '') + `(${r.regex.replace(/^\^|\$/g, '')})`).join('')
)

const addRule = () => tagRules.value.push({ delimiter: '', regex: '' })
const removeRule = (i) => tagRules.value.splice(i, 1)

defineOptions({ name: 'TagValidatorIntegratedUI' })
</script>

