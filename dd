<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-check-double" :title="'Tag 규격 유효성 검사 (Enterprise)'">
      <template #actions>
        <div class="d-flex align-items-center me-2">
          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">프로젝트</span>
            <select class="form-select form-select-sm fw-bold" style="width: 160px;" v-model="selectedProjNo" @change="onProjectChange">
              <option value="">프로젝트 선택 (전체)</option>
              <option v-for="proj in projectList" :key="proj.PROJ_NO" :value="proj.PROJ_NO">
                {{ proj.PROJ_NO }}
              </option>
            </select>
          </div>

          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">타입</span>
            <select class="form-select form-select-sm" style="width: 180px;" v-model="selectedTypeId" @change="applyTagTypeRules" :disabled="!tagTypes.length">
              <option value="">타입 선택</option>
              <option v-for="type in tagTypes" :key="type.TYPE_ID" :value="type.TYPE_ID">
                {{ type.TYPE_ID }}
              </option>
            </select>
          </div>

          <div class="d-flex align-items-center px-2">
            <span class="fw-bold me-2 text-nowrap text-primary" style="font-size: 12px;">Tag No</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary fw-bold font-monospace"
              style="width: 280px;"
              v-model="tagNoForValidator"
              placeholder="검증할 Tag No 입력..."
            />
          </div>
        </div>

        <div class="btn-group me-2">
          <button class="btn btn-default btn-xs shadow-sm" @click="fetchTagTypes">
            <i class="fa fa-sync me-1 text-primary"></i>갱신
          </button>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100 overflow-hidden">
      <div class="row m-0 h-100">
        <div class="col-md-5 p-0 border-end h-100 d-flex flex-column bg-white">
          <div class="panel-heading bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-primary small"><i class="fa fa-list-ol me-2"></i>LNK_CODE 규칙 목록</span>
            <span class="badge bg-primary">{{ tagRules.length }}개 규칙</span>
          </div>
          <div class="flex-grow-1 overflow-hidden">
            <ag-grid-vue
              v-bind="leftGridOptions"
              class="ag-theme-alpine w-100 h-100"
              @grid-ready="onLeftGridReady"
            />
          </div>
        </div>

        <div class="col-md-7 p-0 h-100 d-flex flex-column bg-light border-start">
          <div class="panel-heading bg-white border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-secondary small"><i class="fa fa-vial me-2"></i>검증 상세 분석</span>
            <span :class="['badge', isTagNoValid ? 'bg-success' : 'bg-danger']">
              {{ isTagNoValid ? 'VALID' : 'INVALID' }}
            </span>
          </div>
          <div class="flex-grow-1 overflow-hidden">
            <ag-grid-vue
              v-bind="rightGridOptions"
              class="ag-theme-alpine w-100 h-100"
              @grid-ready="onRightGridReady"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import PageTitle from '@/components/toolBar/PageTitle.vue'
import { AgGridVue } from 'ag-grid-vue3'

// Enterprise 전용 모듈 임포트 (프로젝트 환경에 따라 다를 수 있음)
import 'ag-grid-enterprise'

/** 상태 관리 **/
const projectList = ref([])
const selectedProjNo = ref('')
const tagTypes = ref([])
const selectedTypeId = ref('')
const tagRules = ref([])
const tagNoForValidator = ref('AA-1-BB-2222-C')

const leftGridApi = shallowRef()
const rightGridApi = shallowRef()

/** 1. 데이터 로드 로직 **/
const fetchProjects = async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/GetList')
    projectList.value = res || []
  } catch (e) { console.error(e) }
}

const onProjectChange = () => {
  selectedTypeId.value = ''
  tagRules.value = []
  fetchTagTypes()
}

const fetchTagTypes = async () => {
  if (!selectedProjNo.value) return
  try {
    const res = await axiosWrapper.post('/api/TagType/Get', {
      ProjectNo: selectedProjNo.value,
      ContainDeleted: false
    })
    tagTypes.value = res || []
  } catch (e) { console.error(e) }
}

const applyTagTypeRules = () => {
  const target = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (target && target.LNK_CODE) {
    tagRules.value = target.LNK_CODE.map(item => ({
      attId: item.ATT_ID,
      delimiter: item.DL_VAL || '',
      regex: item.REG_EXPS || '^.*$'
    }))
  } else {
    tagRules.value = []
  }
}

/** 2. 실시간 검증 엔진 (Computed) **/
const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0

  for (let i = 0; i < tagRules.value.length; i++) {
    const rule = tagRules.value[i]
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null

    // 구분자 검사
    if (delim) {
      if (currentStr.substring(cursor).startsWith(delim)) {
        cursor += delim.length
        dOk = true
      } else {
        dOk = new RegExp(`^(${pureRegex})$`).test('') // 정규식이 빈값 허용하면 패스
      }
    }

    // 값 매칭
    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) {
        matchedVal = matcher[1]
        cursor += matchedVal.length
        cOk = true
      } else if (new RegExp(`^(${pureRegex})$`).test('')) {
        matchedVal = ''
        cOk = true
      }
    } catch { cOk = false }

    results.push({
      attId: rule.attId,
      matchedValue: matchedVal,
      delimiter: delim,
      isDelimiterValid: dOk,
      isContentValid: cOk,
      isValid: dOk && cOk
    })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPass) return false
  
  // 전체 문자열 소비 확인
  let totalLen = 0
  tagParts.value.forEach((p, i) => {
    if (p.delimiter && p.isDelimiterValid) {
       if (tagNoForValidator.value.substring(totalLen).startsWith(p.delimiter)) totalLen += p.delimiter.length
    }
    if (p.matchedValue) totalLen += p.matchedValue.length
  })
  return totalLen === (tagNoForValidator.value || '').length
})

/** 3. AG Grid Enterprise 설정 (왼쪽: 규칙 목록) **/
const leftGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 110, pinned: 'left', filter: 'agSetColumnFilter' },
    { headerName: 'Delim', field: 'delimiter', width: 80, cellStyle: { textAlign: 'center', fontWeight: 'bold', color: '#0d6efd' }, filter: 'agSetColumnFilter' },
    { headerName: 'Regex Pattern', field: 'regex', flex: 1, cellClass: 'font-monospace text-muted small', filter: 'agTextColumnFilter' }
  ],
  rowData: tagRules.value,
  defaultColDef: { sortable: true, resizable: true, floatingFilter: true },
  enableRangeSelection: true, // Enterprise 기능
  sideBar: 'filters' // 우측 필터 사이드바 활성화
}))

/** 4. AG Grid Enterprise 설정 (오른쪽: 검증 결과) **/
const rightGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 120, pinned: 'left' },
    { headerName: 'Extracted Value', field: 'matchedValue', flex: 1, 
      cellClass: 'fw-bold font-monospace',
      valueFormatter: p => p.value === '' ? '(Empty)' : p.value 
    },
    { headerName: 'Delim', field: 'isDelimiterValid', width: 80, cellRenderer: p => p.value ? '✅' : '❌' },
    { headerName: 'Pattern', field: 'isContentValid', width: 80, cellRenderer: p => p.value ? '✅' : '❌' },
    { 
      headerName: 'Status', 
      field: 'isValid', 
      width: 100,
      cellRenderer: p => `<span class="badge ${p.value ? 'bg-success' : 'bg-danger'} w-100">${p.value ? 'PASS' : 'FAIL'}</span>`
    }
  ],
  rowData: tagParts.value,
  defaultColDef: { sortable: true, resizable: true },
  statusBar: { // Enterprise 하단 상태바
    statusPanels: [
      { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'left' }
    ]
  }
}))

/** Grid API Ready **/
const onLeftGridReady = p => { leftGridApi.value = p.api }
const onRightGridReady = p => { rightGridApi.value = p.api }

onMounted(() => {
  fetchProjects()
})

defineOptions({ name: 'TagValidatorEnterprise' })
</script>

