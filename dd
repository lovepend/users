<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-sliders"
      :title="'프로젝트별 속성 비교 분석' + (selectedProjects.length ? ` [선택됨: ${selectedProjects.length}건]` : '')"
    >
      </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue v-bind="gridOptions" @grid-ready="onGridReady" />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
// ... (기존 import 유지) ...

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const columnDefs = computed(() => {
  // 💡 [Enterprise 핵심] 멀티 필터 설정
  // 상단은 텍스트 검색(미니필터 연동), 하단은 체크박스 리스트
  const multiFilterParams = {
    filters: [
      {
        filter: 'agTextColumnFilter',
        filterParams: { buttons: ['reset'], debounceMs: 200 } // 입력 즉시 반영을 위해 apply 버튼 제외
      },
      {
        filter: 'agSetColumnFilter',
        filterParams: { buttons: ['reset'], refreshValuesOnIncrementalUpdate: true }
      }
    ]
  }

  const cols = [
    { 
      headerName: 'Condition', field: 'CONDITION', width: 120, pinned: 'left',
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams,
      cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) 
    },
    { 
      headerName: 'Attribute ID', field: 'ATT_ID', width: 150, pinned: 'left', 
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams 
    },
    { 
      headerName: 'Description', field: 'DESC', width: 250, pinned: 'left', tooltipField: 'DESC', 
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams 
    },
    { 
      headerName: 'Type', field: 'VAL_TYPE', width: 120, pinned: 'left', 
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams 
    },
  ]

  // 동적 프로젝트 컬럼
  dynamicCols.value.forEach(proj => {
    cols.push({ 
      headerName: proj, field: proj, minWidth: 120,
      filter: 'agMultiColumnFilter',
      filterParams: {
        filters: [
          { filter: 'agTextColumnFilter' },
          { filter: 'agSetColumnFilter', filterParams: { valueFormatter: (p) => p.value === true ? '데이터 있음' : '데이터 없음' } }
        ]
      },
      cellRenderer: params => params.value === true ? `<span class="text-success"><i class="fa fa-circle" style="font-size: 8px;"></i></span>` : `<span class="text-muted">-</span>`,
      cellStyle: { textAlign: 'center' }
    })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  style: 'width: 100%; height: 100%',
  class: 'ag-theme-custom',
  
  // 1. 피벗 모드 및 사이드바 제거 (false 설정)
  sideBar: false, 

  // 2. 상태바 설정 (우측 정렬)
  statusBar: {
    statusPanels: [
      { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'right' },
      { statusPanel: 'agSelectedRowCountComponent', align: 'right' }
    ]
  },

  // 3. 기본 컬럼 정의
  defaultColDef: { 
    sortable: true, 
    resizable: true,
    floatingFilter: true, // 헤더 아래 미니 필터 항상 노출
    flex: 1,
    minWidth: 100
  },

  // Enterprise 기능 활용
  enableRangeSelection: true,
  suppressRowClickSelection: true,
  
  // (생략: 기존의 isExternalFilterPresent, doesExternalFilterPass 외부 필터 로직 유지)
}))

const onGridReady = (p) => { gridApi.value = p.api }
</script>

<style scoped>
/* 미니 필터 칸을 활성 상태처럼 보이게 강조 */
:deep(.ag-floating-filter-input) {
  background-color: #fff !important;
}
:deep(.ag-floating-filter-body input) {
  cursor: text !important;
  border-bottom: 1px solid #eee;
}
:deep(.ag-floating-filter-body input:focus) {
  border-bottom: 2px solid #007bff;
}

/* 상태바 폰트 및 여백 */
:deep(.ag-status-bar) {
  font-weight: 600;
  padding-right: 20px;
}
</style>
