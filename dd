<template>
  <div class="panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Project</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
                style="width: 250px"
              >
                <span class="text-truncate">{{ selectedProjNo || '프로젝트를 선택하세요' }}</span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 300px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 검색..."
                    @click.stop
                  />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="d-flex align-items-center w-100" style="cursor: pointer" @click="selectProject(proj.PROJ_NO)">
                    <span class="text-truncate">
                      <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                      <small class="text-muted ms-1">({{ proj.DESC }})</small>
                    </span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Type</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
                style="width: 250px"
                :disabled="!tagTypes.length"
              >
                <span class="text-truncate">{{ selectedTypeId || '타입을 선택하세요' }}</span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 300px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="typeSearchKeyword"
                    placeholder="타입 검색..."
                    @click.stop
                  />
                </li>
                <li v-for="type in filteredTagTypes" :key="type.TYPE_ID" class="dropdown-item px-2 py-1">
                  <label class="d-flex align-items-center w-100" style="cursor: pointer" @click="selectType(type.TYPE_ID)">
                    <span class="fw-bold">{{ type.TYPE_ID }}</span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2 ms-2">
            <span class="fw-bold text-primary text-nowrap">Tag No</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary fw-bold font-monospace"
              style="width: 350px;"
              v-model="tagNoForValidator"
              placeholder="검증할 Tag No 입력..."
            />
          </div>
        </div>
        <panel-toolbar />
      </div>
    </div>

    <div class="panel-body m-0 p-0 flex-grow-1 overflow-hidden">
      <div class="row m-0 h-100">
        <div class="col-md-6 p-0 h-100 border-end d-flex flex-column bg-white">
          <div class="grid-header bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark small"><i class="fa fa-edit me-2 text-primary"></i>LNK_CODE 규격 에디터</span>
            <small class="text-muted text-uppercase" style="font-size: 10px;">Editable Grid</small>
          </div>
          <div class="flex-grow-1">
            <ag-grid-vue
              v-bind="leftGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onLeftGridReady"
              @cell-value-changed="onRuleChanged"
            />
          </div>
        </div>

        <div class="col-md-6 p-0 h-100 d-flex flex-column bg-white">
          <div class="grid-header bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark small"><i class="fa fa-search me-2 text-success"></i>실시간 분석 리포트</span>
            <span :class="['badge shadow-sm px-3', isTagNoValid ? 'bg-success' : 'bg-danger']" style="font-size: 11px;">
              {{ isTagNoValid ? 'VALID' : 'INVALID' }}
            </span>
          </div>
          <div class="flex-grow-1">
            <ag-grid-vue
              v-bind="rightGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onRightGridReady"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { AgGridVue } from 'ag-grid-vue3'
import 'ag-grid-enterprise'

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjNo = ref('')

const tagTypes = ref([])
const typeSearchKeyword = ref('')
const selectedTypeId = ref('')

const tagRules = ref([])
const tagNoForValidator = ref('AA-1-BB-2222-C')

const leftGridApi = shallowRef()
const rightGridApi = shallowRef()

// --- 프로젝트/타입 필터링 및 선택 로직 (참조 코드 구조) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})

const filteredTagTypes = computed(() => {
  const kw = typeSearchKeyword.value.trim().toLowerCase()
  return tagTypes.value.filter(t => t.TYPE_ID.toLowerCase().includes(kw))
})

const selectProject = (projNo) => {
  selectedProjNo.value = projNo
  projectSearchKeyword.value = '' 
  onProjectChange()
}

const selectType = (typeId) => {
  selectedTypeId.value = typeId
  typeSearchKeyword.value = ''
  applyTagTypeRules()
}

// --- API ---
const fetchProjects = async () => {
  const res = await axiosWrapper.get('/api/Project/GetList')
  projectList.value = Array.isArray(res) ? res : []
}

const onProjectChange = async () => {
  selectedTypeId.value = ''
  tagRules.value = []
  const res = await axiosWrapper.post('/api/TagType/Get', { ProjectNo: selectedProjNo.value, ContainDeleted: false })
  tagTypes.value = Array.isArray(res) ? res : []
}

const applyTagTypeRules = () => {
  const target = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (target && target.LNK_CODE) {
    tagRules.value = target.LNK_CODE.map(item => ({
      attId: item.ATT_ID,
      delimiter: item.DL_VAL || '',
      regex: item.REG_EXPS || '^.*$'
    }))
  }
}

// --- 그리드 동기화 및 검증 로직 ---
const onRuleChanged = () => {
  const updatedData = []
  leftGridApi.value.forEachNode(node => updatedData.push(node.data))
  tagRules.value = [...updatedData]
}

const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0

  for (let rule of tagRules.value) {
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null

    if (delim && delim !== '') {
      if (currentStr.substring(cursor).startsWith(delim)) {
        cursor += delim.length
        dOk = true
      } else {
        dOk = new RegExp(`^(${pureRegex})$`).test('')
      }
    }

    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) {
        matchedVal = matcher[1]
        cursor += matchedVal.length
        cOk = true
      } else if (new RegExp(`^(${pureRegex})$`).test('')) {
        matchedVal = ''; cOk = true
      }
    } catch { cOk = false }

    results.push({
      attId: rule.attId,
      matchedValue: matchedVal || '',
      delimiter: delim || '',
      isValid: dOk && cOk
    })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPass) return false
  let totalLen = 0
  tagParts.value.forEach((p) => {
    if (p.delimiter && tagNoForValidator.value.substring(totalLen).startsWith(p.delimiter)) totalLen += p.delimiter.length
    if (p.matchedValue) totalLen += p.matchedValue.length
  })
  return totalLen === tagNoForValidator.value.length
})

// --- AG Grid Options ---
const leftGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 130, pinned: 'left' },
    { headerName: 'Delim', field: 'delimiter', width: 90, editable: true, cellStyle: { backgroundColor: '#fffbe6', textAlign: 'center', fontWeight: 'bold' } },
    { headerName: 'RegEx (Edit)', field: 'regex', flex: 1, editable: true, cellClass: 'font-monospace', cellStyle: { backgroundColor: '#fffbe6' } }
  ],
  rowData: tagRules.value,
  defaultColDef: { resizable: true, sortable: true },
  sideBar: false,
}))

const rightGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 130 },
    { headerName: 'Value', field: 'matchedValue', flex: 1, cellClass: 'fw-bold font-monospace text-primary' },
    { headerName: 'Result', field: 'isValid', width: 100, cellRenderer: p => p.value ? '<b class="text-success">OK</b>' : '<b class="text-danger">ERR</b>' }
  ],
  rowData: tagParts.value,
  defaultColDef: { resizable: true },
}))

const onLeftGridReady = p => { leftGridApi.value = p.api }
const onRightGridReady = p => { rightGridApi.value = p.api }

onMounted(fetchProjects)
</script>

