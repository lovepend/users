<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-square-check"
      :title="'Tag List 및 Attributes 정보' + (currentProjNo ? ` [ ${currentProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-2 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-500">Keyword</span>
            <input
              type="text"
              placeholder="Input Keyword"
              class="form-control form-control-sm p-1"
              style="min-height: 1rem"
              v-model="searchKeywordRef"
            />
          </label>
          <button class="btn btn-xs btn-primary" @click="onSearch">Search</button>
        </div>
        <div class="form-check form-switch m-0">
          <label class="form-check-label text-dark user-select-none cursor-pointer">
            <input class="form-check-input" type="checkbox" v-model="isWorkingRef" />
            {{ isWorkingLabel }}
          </label>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>
    <div class="panel-body m-0 p-0 h-100">
      <Splitter class="h-100">
        <SplitterPanel :size="55" :minSize="10">
          <div class="panel m-0 p-0 h-100">
            <div class="panel-heading p-0 m-0">
              <div class="w-100 h-100">
                <BasicToolBar
                  @delete-data="deleteSelectedData"
                  :showCreate="false"
                  :showMultiCreate="false"
                  :showDelete="isShowDeleteBtn"
                  :isDisabledDeleteBtn="isDisabledDeleteBtn"
                  :showSave="false"
                  :isDisabledSaveBtn="false"
                />
              </div>
            </div>
            <div class="panel-body overflow-hidden m-0 p-0 h-100">
              <ag-grid-vue v-bind="gridBindTagProps" v-on="gridOnCommonProps('Tag')" />
            </div>
          </div>
        </SplitterPanel>
        <SplitterPanel :size="45">
          <div class="panel m-0 p-0 h-100">
            <div class="panel-body overflow-hidden m-0 p-0 h-100">
              <ag-grid-vue v-bind="gridBindAttProps" v-on="gridOnCommonProps('Att')" />
            </div>
          </div>
        </SplitterPanel>
      </Splitter>
    </div>
  </div>
</template>

<script setup>
  // Library - Common
  import { ref, watch, shallowRef, onBeforeMount, computed } from 'vue'
  import { useRoute } from 'vue-router'
  import { storeToRefs } from 'pinia'

  // Library - Layout
  import Splitter from 'primevue/splitter'
  import SplitterPanel from 'primevue/splitterpanel'

  // Store
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppAuthenticationStore } from '@/stores/app-authentication'
  import { useAppMenuStore } from '@/stores/app-menu'

  // Library - AG Grid
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
  import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'

  // Helpers
  import { sAlert, sToast } from '@/utils/messages/alert-common'
  import * as _ from 'lodash-es'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import axios from 'axios'

  // Custom Component
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'

  const route = useRoute()
  const appPermission = useAppPermissionStore()
  const authStore = useAppAuthenticationStore() // 💡 사용자 정보 스토어 추가

  const { isSetupAdmin } = storeToRefs(appPermission)
  const { currentProjNo } = storeToRefs(useAppMenuStore())
  const { user } = storeToRefs(authStore) // 💡 로그인된 유저 ID 참조용

  const registerListRef = ref([])
  const statusBar_Atts = ref()

  const isShowCreateBtn = ref(isSetupAdmin.value)
  const isShowMultiCreateBtn = ref(true)
  const isShowDeleteBtn = ref(isSetupAdmin.value)
  const isDisabledDeleteBtn = ref(true)
  const isShowSaveBtn = ref(isSetupAdmin.value)
  const isDisabledSaveBtn = ref(true)

  const searchKeywordRef = ref('')
  const isWorkingRef = ref(false)
  const isWorkingLabel = ref('Published')
  const isDisabledDeleteSubBtn = ref(true)
  const showAddAttr = ref(true)
  const allTagDataList = ref([])

  const selectedCdLst = computed({
    get: () => route.query?.cl_id,
    set: newValue => null,
  })

  watch(isWorkingRef, newVal => {
    isWorkingLabel.value = newVal ? 'Working' : 'Published'
    tagAttListRef.value = []
    if (gridApi_TagData.value) getData()
  })

  const onSearch = () => {
    tagAttListRef.value = []
    if (gridApi_TagData.value) getData()
  }

  onBeforeMount(() => {
    if (sAlert?.isVisible()) sAlert.close()
    statusBar_Atts.value = {
      statusPanels: [
        { statusPanel: 'agTotalRowCountComponent' },
        { statusPanel: 'agFilteredRowCountComponent' },
        { statusPanel: 'agSelectedRowCountComponent' },
        {
          statusPanel: 'AgDetailStatusBar',
          statusPanelParams: { customStyle: { 'background-color': '#e4dbe9' } },
          align: 'left',
        },
      ],
    }
  })

  watch(currentProjNo, () => {
    getData()
    selectedTagData.value = null
    firstGridDataModel.value = null
    firstGridDataModel2.value = null
    if (context.value) context.value = { customKey: 'Tag Idx : ', customValue: '' }
  })

  const gridApi_TagData = shallowRef()
  const gridApi_Atts = shallowRef()
  const themeClass = 'ag-theme-custom'
  const getRowId = params => params.data.Id
  const context = ref()

  const tagDataListRef = ref(null)
  const tagAttListRef = ref(null)
  const selectedTagData = ref(null)
  const firstGridDataModel = ref(null)
  const firstGridDataModel2 = ref(null)
  let changedCells = []

  /************************************
   * 💡 GET DATA - 이 부분에 헤더 로직을 반영했습니다.
   ***********************************/
  const getData = async () => {
    tagDataListRef.value = []
    changedCells = []
    tagAttListRef.value = []

    if (!currentProjNo.value) {
      sAlert.Warning(`Project를 선택해주세요`)
      return
    }

    gridApi_TagData.value.setGridOption('loading', true)

    let url = isWorkingRef.value ? `/api/Admin/Tool/GetWorkingData` : `/api/Admin/Tool/GetPublishedData`

    try {
      // 💡 axiosWrapper.post의 3번째 인자로 headers를 추가했습니다.
      const jsonData = await axiosWrapper.post(
        url,
        {
          ProjectNo: currentProjNo.value,
          Keyword: searchKeywordRef.value.trim(),
        },
        {
          headers: {
            'Projectno': currentProjNo.value,     // 헤더에 프로젝트 번호 반영
            'Ep_id': user.value?.EpId || ''     // 헤더에 로그인 유저 ID 반영
          }
        }
      )

      if (_.isEmpty(jsonData)) {
        tagDataListRef.value = []
        gridApi_TagData.value.setGridOption('loading', false)
        return
      }

      allTagDataList.value = jsonData
      tagDataListRef.value = jsonData.filter(item => !item.DELETED)
      firstGridDataModel.value = _.cloneDeep(tagDataListRef.value)
      
    } catch (error) {
      gridApi_TagData.value.setGridOption('loading', false)
      tagDataListRef.value = []
      if (!(error instanceof axios.AxiosError)) {
        sAlert.Warning('Failed to get Tag Data : ' + error.message)
      }
    }
    gridApi_TagData.value.setGridOption('loading', false)
  }

  // ... (이후 getTagDataAttList, Grid Events 등 나머지 원본 코드와 동일) ...
  // (생략된 부분은 주신 원본 코드의 로직을 그대로 사용하시면 됩니다.)
</script>
