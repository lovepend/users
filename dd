<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-check-double" :title="'Tag 규격 유효성 검사'">
      <template #actions>
        <div class="d-flex align-items-center me-2">
          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">프로젝트</span>
            <select class="form-select form-select-sm fw-bold" style="width: 160px;" v-model="selectedProjNo" @change="onProjectChange">
              <option value="">프로젝트 선택</option>
              <option v-for="proj in projectList" :key="proj.PROJ_NO" :value="proj.PROJ_NO">
                {{ proj.PROJ_NO }}
              </option>
            </select>
          </div>

          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">타입</span>
            <select class="form-select form-select-sm" style="width: 180px;" v-model="selectedTypeId" @change="applyTagTypeRules" :disabled="!tagTypes.length">
              <option value="">타입 선택</option>
              <option v-for="type in tagTypes" :key="type.TYPE_ID" :value="type.TYPE_ID">
                {{ type.TYPE_ID }}
              </option>
            </select>
          </div>

          <div class="d-flex align-items-center px-2">
            <span class="fw-bold me-2 text-nowrap text-primary" style="font-size: 12px;">Tag No</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary fw-bold font-monospace"
              style="width: 250px;"
              v-model="tagNoForValidator"
              placeholder="검증할 Tag No 입력"
            />
          </div>
        </div>

        <div class="btn-group me-2">
          <button class="btn btn-default btn-xs shadow-sm" @click="fetchTagTypes">
            <i class="fa fa-sync me-1 text-primary"></i>타입 갱신
          </button>
          <button class="btn btn-default btn-xs shadow-sm" @click="showPasteModal = true">
            <i class="fa fa-paste me-1 text-info"></i>수동 규칙
          </button>
        </div>
        
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100 overflow-hidden">
      <div class="row m-0 h-100">
        <div class="col-md-5 p-0 border-end h-100 d-flex flex-column bg-white">
          <div class="panel-heading bg-light border-bottom px-3 py-2">
            <span class="fw-bold text-primary small"><i class="fa fa-cog me-2"></i>적용 규격 (LNK_CODE)</span>
          </div>
          <div class="flex-grow-1 overflow-auto">
            <table class="table table-sm table-hover mb-0 custom-table">
              <thead class="table-light sticky-top">
                <tr>
                  <th class="text-center" width="80">ATT_ID</th>
                  <th width="70" class="text-center">구분자</th>
                  <th>정규식 (REG_EXPS)</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center align-middle font-monospace small bg-light text-secondary">{{ rule.attId }}</td>
                  <td class="text-center align-middle fw-bold text-primary">{{ rule.delimiter || '(없음)' }}</td>
                  <td class="align-middle font-monospace text-muted small" style="word-break: break-all;">{{ rule.regex }}</td>
                </tr>
                <tr v-if="tagRules.length === 0">
                  <td colspan="3" class="text-center py-5 text-muted small">
                    <i class="fa fa-info-circle me-1"></i> 프로젝트와 타입을 선택하세요.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="col-md-7 p-0 h-100 d-flex flex-column bg-light border-start">
          <div class="p-3 flex-grow-1 overflow-auto">
            <div v-if="tagRules.length" :class="['alert d-flex align-items-center shadow-sm mb-3', isTagNoValid ? 'alert-success border-success' : 'alert-danger border-danger']">
              <i :class="['fa fa-2x me-3', isTagNoValid ? 'fa-check-circle text-success' : 'fa-times-circle text-danger']"></i>
              <div>
                <h5 class="alert-heading mb-1 fw-bold">{{ isTagNoValid ? '검증 통과' : '검증 실패' }}</h5>
                <div class="small font-monospace opacity-75">{{ tagNoForValidator }}</div>
              </div>
            </div>

            <div class="card shadow-sm border-0" v-if="tagRules.length">
              <div class="card-header bg-white py-2 fw-bold text-secondary small">구조 분석 결과</div>
              <div class="card-body p-0">
                <table class="table table-sm mb-0">
                  <thead class="bg-light small">
                    <tr>
                      <th class="ps-3" width="120">Attribute</th>
                      <th>추출 값</th>
                      <th class="text-center" width="70">구분자</th>
                      <th class="text-center" width="70">패턴</th>
                      <th class="text-center" width="80">결과</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr v-for="(part, index) in tagParts" :key="index">
                      <td class="ps-3 small text-muted font-monospace">{{ tagRules[index]?.attId }}</td>
                      <td class="fw-bold font-monospace text-dark">{{ part.matchedValue === '' ? '(빈값)' : part.matchedValue || '-' }}</td>
                      <td class="text-center">
                        <i v-if="part.hasDelimiterRule" :class="part.isDelimiterValid ? 'fa fa-check text-success' : 'fa fa-times text-danger'"></i>
                        <span v-else class="text-muted">-</span>
                      </td>
                      <td class="text-center">
                        <span :class="part.isContentValid ? 'text-success fw-bold' : 'text-danger fw-bold'">{{ part.isContentValid ? 'OK' : 'ERR' }}</span>
                      </td>
                      <td class="text-center">
                        <span :class="['badge w-100', part.isValid ? 'bg-success' : 'bg-danger']" style="font-size: 0.65rem;">{{ part.isValid ? 'PASS' : 'FAIL' }}</span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div v-if="showPasteModal" class="custom-modal-overlay" @click.self="showPasteModal = false">
      <div class="custom-modal-window shadow-lg" style="width: 500px; height: 400px;">
        <div class="modal-header-dark bg-primary p-2 px-3 d-flex justify-content-between">
          <span class="fw-bold text-white small">수동 규칙 설정</span>
          <button @click="showPasteModal = false" class="btn btn-xs btn-link text-white p-0">✕</button>
        </div>
        <div class="p-3 d-flex flex-column h-100">
          <textarea v-model="pasteData" class="form-control font-monospace flex-grow-1 mb-3 small" placeholder="구분자 [Tab] 정규식..."></textarea>
          <div class="d-flex justify-content-end gap-2">
            <button @click="applyPasteData" class="btn btn-primary btn-sm">적용</button>
            <button @click="showPasteModal = false" class="btn btn-secondary btn-sm">닫기</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import PageTitle from '@/components/toolBar/PageTitle.vue'

/** 상태 변수 **/
const projectList = ref([])      // 프로젝트 목록 (API에서 가져옴)
const selectedProjNo = ref('')   // 선택된 프로젝트
const tagTypes = ref([])         // 해당 프로젝트의 Tag Type들
const selectedTypeId = ref('')   // 선택된 타입
const tagRules = ref([])         // 최종 적용될 규칙 (LNK_CODE)
const tagNoForValidator = ref('AA-1-BB-2222-C')
const showPasteModal = ref(false)
const pasteData = ref('')

/** 1. 프로젝트 목록 로드 (마운트 시) **/
const fetchProjects = async () => {
  try {
    // 프로젝트 속성 비교 시 사용했던 것과 동일한 API 활용 (경로는 프로젝트에 맞게 수정)
    const res = await axiosWrapper.get('/api/Project/GetList') 
    projectList.value = res || []
  } catch (error) {
    console.error("프로젝트 목록 로드 실패:", error)
  }
}

/** 2. 프로젝트 변경 시 Tag Type 목록 조회 **/
const onProjectChange = () => {
  selectedTypeId.value = ''
  tagRules.value = []
  fetchTagTypes()
}

const fetchTagTypes = async () => {
  if (!selectedProjNo.value) return
  try {
    // 요청하신 페이로드 형식 준수
    const payload = {
      ProjectNo: selectedProjNo.value,
      ContainDeleted: false
    }
    const res = await axiosWrapper.post('/api/TagType/Get', payload)
    tagTypes.value = res || []
  } catch (error) {
    console.error("Tag Type 로드 실패:", error)
  }
}

/** 3. 타입 선택 시 LNK_CODE 매핑 **/
const applyTagTypeRules = () => {
  const target = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (target && target.LNK_CODE) {
    tagRules.value = target.LNK_CODE.map(item => ({
      attId: item.ATT_ID,
      delimiter: item.DL_VAL || '',
      regex: item.REG_EXPS || '^.*$'
    }))
  } else {
    tagRules.value = []
  }
}

/** [검증 로직 영역] **/
const canBeEmpty = (regexStr) => {
  try {
    const r = regexStr.replace(/^\^|\$/g, '')
    return new RegExp(`^(${r})$`).test('')
  } catch { return false }
}

const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0
  for (let i = 0; i < tagRules.value.length; i++) {
    const rule = tagRules.value[i]
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null
    if (delim) {
      if (currentStr.substring(cursor).startsWith(delim)) { cursor += delim.length; dOk = true; }
      else { dOk = canBeEmpty(rule.regex); }
    }
    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) { matchedVal = matcher[1]; cursor += matchedVal.length; cOk = true; }
      else if (canBeEmpty(rule.regex)) { matchedVal = ''; cOk = true; }
    } catch { cOk = false }
    results.push({ hasDelimiterRule: !!delim, isDelimiterValid: dOk, isContentValid: cOk, matchedValue: matchedVal, isValid: dOk && cOk })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPartsPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPartsPass) return false
  let usedLen = 0
  tagParts.value.forEach((p, i) => {
    if (p.hasDelimiterRule && p.isDelimiterValid) {
      if (tagNoForValidator.value.substring(usedLen).startsWith(tagRules.value[i].delimiter)) usedLen += tagRules.value[i].delimiter.length
    }
    if (p.matchedValue) usedLen += p.matchedValue.length
  })
  return usedLen === (tagNoForValidator.value || '').length
})

const applyPasteData = () => {
  const rows = pasteData.value.split('\n').map((row, idx) => {
    const cols = row.split('\t')
    return { attId: `S_${idx+1}`, delimiter: cols[0]?.trim() || '', regex: cols[1]?.trim() || '^.*$' }
  }).filter(r => r.delimiter || r.regex)
  if (rows.length) tagRules.value = rows
  showPasteModal.value = false
}

onMounted(() => {
  fetchProjects()
})

defineOptions({ name: 'TagValidatorFinal' })
</script>

