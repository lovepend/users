<template>
  <div class="panel panel-expandable m-0 p-0 h-100 d-flex flex-column">
    <PageTitle icon="fa-check-double" :title="'Tag 규격 유효성 검사 (Live Editor)'">
      <template #actions>
        <div class="d-flex align-items-center me-2">
          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">프로젝트</span>
            <div class="dropdown">
              <input 
                type="text" 
                class="form-control form-control-sm fw-bold dropdown-toggle" 
                style="width: 180px;" 
                v-model="selectedProjNo"
                @input="filterProjects"
                data-bs-toggle="dropdown"
                placeholder="프로젝트 검색..."
              />
              <ul class="dropdown-menu shadow w-100" style="max-height: 300px; overflow-y: auto;">
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO">
                  <a class="dropdown-item small" href="javascript:;" @click="selectProject(proj.PROJ_NO)">
                    {{ proj.PROJ_NO }}
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center px-2 border-end">
            <span class="fw-bold me-2 text-nowrap" style="font-size: 12px;">타입</span>
            <div class="dropdown">
              <input 
                type="text" 
                class="form-control form-control-sm dropdown-toggle" 
                style="width: 200px;" 
                v-model="selectedTypeId"
                @input="filterTypes"
                :disabled="!tagTypes.length"
                data-bs-toggle="dropdown"
                placeholder="타입 검색..."
              />
              <ul class="dropdown-menu shadow w-100" style="max-height: 300px; overflow-y: auto;">
                <li v-for="type in filteredTagTypes" :key="type.TYPE_ID">
                  <a class="dropdown-item small" href="javascript:;" @click="selectType(type.TYPE_ID)">
                    {{ type.TYPE_ID }}
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center px-2">
            <span class="fw-bold me-2 text-nowrap text-primary" style="font-size: 12px;">Tag No</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary fw-bold font-monospace"
              style="width: 300px;"
              v-model="tagNoForValidator"
            />
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 flex-grow-1 overflow-hidden bg-light">
      <div class="row m-0 h-100">
        <div class="col-md-6 p-0 h-100 border-end d-flex flex-column bg-white">
          <div class="panel-heading bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark small"><i class="fa fa-edit me-2"></i>규격 에디터 (수정 시 즉시 테스트)</span>
            <span class="text-muted" style="font-size: 10px;">* 값을 클릭하여 직접 수정하세요</span>
          </div>
          <div class="flex-grow-1">
            <ag-grid-vue
              v-bind="leftGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onLeftGridReady"
              @cell-value-changed="onRuleChanged"
            />
          </div>
        </div>

        <div class="col-md-6 p-0 h-100 d-flex flex-column bg-white">
          <div class="panel-heading bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark small"><i class="fa fa-chart-pie me-2"></i>실시간 분석 결과</span>
            <span :class="['badge shadow-sm px-3', isTagNoValid ? 'bg-success' : 'bg-danger']" style="font-size: 12px;">
              {{ isTagNoValid ? 'PASS' : 'FAIL' }}
            </span>
          </div>
          <div class="flex-grow-1">
            <ag-grid-vue
              v-bind="rightGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onRightGridReady"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import PageTitle from '@/components/toolBar/PageTitle.vue'
import { AgGridVue } from 'ag-grid-vue3'
import 'ag-grid-enterprise'

/** 상태 관리 **/
const projectList = ref([])
const filteredProjectList = ref([])
const selectedProjNo = ref('')

const tagTypes = ref([])
const filteredTagTypes = ref([])
const selectedTypeId = ref('')

const tagRules = ref([]) // 좌측 그리드 데이터
const tagNoForValidator = ref('AA-1-BB-2222-C')

const leftGridApi = shallowRef()
const rightGridApi = shallowRef()

/** UI 이벤트: 프로젝트/타입 선택기 **/
const filterProjects = () => {
  filteredProjectList.value = projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(selectedProjNo.value.toLowerCase()))
}
const selectProject = (projNo) => {
  selectedProjNo.value = projNo
  onProjectChange()
}
const filterTypes = () => {
  filteredTagTypes.value = tagTypes.value.filter(t => t.TYPE_ID.toLowerCase().includes(selectedTypeId.value.toLowerCase()))
}
const selectType = (typeId) => {
  selectedTypeId.value = typeId
  applyTagTypeRules()
}

/** API 통신 **/
const fetchProjects = async () => {
  const res = await axiosWrapper.get('/api/Project/GetList')
  projectList.value = res || []
  filteredProjectList.value = [...projectList.value]
}

const onProjectChange = async () => {
  selectedTypeId.value = ''
  tagRules.value = []
  const res = await axiosWrapper.post('/api/TagType/Get', { ProjectNo: selectedProjNo.value, ContainDeleted: false })
  tagTypes.value = res || []
  filteredTagTypes.value = [...tagTypes.value]
}

const applyTagTypeRules = () => {
  const target = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (target && target.LNK_CODE) {
    tagRules.value = target.LNK_CODE.map(item => ({
      attId: item.ATT_ID,
      delimiter: item.DL_VAL || '',
      regex: item.REG_EXPS || '^.*$'
    }))
  }
}

/** 에디터 수정 시 강제 갱신 **/
const onRuleChanged = () => {
  // 그리드의 수정된 데이터를 tagRules에 다시 동기화하여 computed(tagParts)가 작동하게 함
  const updatedData = []
  leftGridApi.value.forEachNode(node => updatedData.push(node.data))
  tagRules.value = [...updatedData]
}

/** 분석 로직 **/
const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0

  for (let rule of tagRules.value) {
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null

    if (delim && delim !== '') {
      if (currentStr.substring(cursor).startsWith(delim)) {
        cursor += delim.length
        dOk = true
      } else {
        dOk = new RegExp(`^(${pureRegex})$`).test('')
      }
    }

    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) {
        matchedVal = matcher[1]
        cursor += matchedVal.length
        cOk = true
      } else if (new RegExp(`^(${pureRegex})$`).test('')) {
        matchedVal = ''; cOk = true
      }
    } catch { cOk = false }

    results.push({
      attId: rule.attId,
      matchedValue: matchedVal || '',
      delimiter: delim || '',
      isValid: dOk && cOk
    })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPass) return false
  
  let totalLen = 0
  tagParts.value.forEach((p) => {
    if (p.delimiter && tagNoForValidator.value.substring(totalLen).startsWith(p.delimiter)) totalLen += p.delimiter.length
    if (p.matchedValue) totalLen += p.matchedValue.length
  })
  return totalLen === tagNoForValidator.value.length
})

/** AG Grid 설정 **/
const leftGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 120, pinned: 'left' },
    { headerName: '구분자', field: 'delimiter', width: 90, editable: true, cellStyle: { backgroundColor: '#fffbe6', fontWeight: 'bold', textAlign: 'center' } },
    { headerName: '정규식 (수정가능)', field: 'regex', flex: 1, editable: true, cellClass: 'font-monospace', cellStyle: { backgroundColor: '#fffbe6' } }
  ],
  rowData: tagRules.value,
  defaultColDef: { resizable: true, sortable: true },
  sideBar: false, // 우측 필터창 제거
  suppressMenuHide: true
}))

const rightGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 110 },
    { headerName: '추출값', field: 'matchedValue', flex: 1, cellClass: 'fw-bold font-monospace text-primary' },
    { headerName: '결과', field: 'isValid', width: 90, cellRenderer: p => p.value ? '<span class="text-success">OK</span>' : '<span class="text-danger fw-bold">ERR</span>' }
  ],
  rowData: tagParts.value,
  defaultColDef: { resizable: true },
}))

const onLeftGridReady = p => { leftGridApi.value = p.api }
const onRightGridReady = p => { rightGridApi.value = p.api }

onMounted(fetchProjects)
</script>

