<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-sliders"
      :title="'프로젝트별 속성 비교 분석' + (selectedProjects.length ? ` [선택됨: ${selectedProjects.length}건]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 ms-auto me-2">
          
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button 
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-input-width text-start d-flex justify-content-between align-items-center bg-white" 
                type="button" 
                data-bs-toggle="dropdown" 
                data-bs-auto-close="outside"
              >
                <span>{{ selectedProjects.length > 0 ? `${selectedProjects.length}개 선택됨` : '프로젝트를 선택/입력하세요' }}</span>
              </button>
              
              <ul class="dropdown-menu p-0 shadow-sm" style="width: 280px;">
                <li class="p-2 border-bottom bg-light">
                  <textarea
                    class="form-control form-control-sm mb-1 custom-scrollbar"
                    rows="2"
                    v-model="manualProjectInput"
                    placeholder="예: TEST1001, TEST1002&#10;(공백, 콤마, 줄바꿈 구분)"
                    style="resize: none; font-size: 0.85rem;"
                  ></textarea>
                  <div class="d-flex justify-content-between align-items-center text-muted" style="font-size: 0.75rem;">
                    <span>입력 시 자동 체크됩니다.</span>
                    <button class="btn btn-link btn-sm p-0 text-decoration-none" @click="clearProjects">초기화</button>
                  </div>
                </li>
                
                <div style="max-height: 250px; overflow-y: auto;" class="p-2 custom-scrollbar">
                  <li v-if="projectList.length === 0" class="text-muted text-center py-2 fs-7">
                    데이터가 없습니다.
                  </li>
                  <li v-for="proj in projectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1 rounded">
                    <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer;">
                      <input 
                        class="form-check-input me-2 mt-0" 
                        type="checkbox" 
                        :value="proj.PROJ_NO" 
                        v-model="selectedProjects"
                      >
                      <span class="text-truncate">{{ proj.PROJ_NO }} <small class="text-muted">({{ proj.DESC }})</small></span>
                    </label>
                  </li>
                </div>
              </ul>
            </div>
          </div>

          <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch" :disabled="selectedProjects.length === 0">
            <i class="fa fa-search me-1"></i>비교 조회
          </button>

          <div class="ms-2 border-start ps-3 d-flex align-items-center gap-2">
            <span class="fw-bold text-success text-nowrap">속성 필터</span>
            <input
              type="text"
              class="form-control form-control-sm border-success custom-input-width"
              v-model="attributeFilter"
              placeholder="ATT_ID 또는 DESC 검색"
            />
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue
            v-bind="gridOptions"
            @grid-ready="onGridReady"
          />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

// --- State ---
// 현재 접속한 EP_ID (실제 프로젝트 환경에 맞게 Store나 Session에서 가져오도록 매핑하세요)
const currentEpId = ref('YOUR_CURRENT_EP_ID') 

const projectList = ref([]) // 전체 프로젝트 리스트
const selectedProjects = ref([]) // 체크된 PROJ_NO 배열
const manualProjectInput = ref('') // 텍스트 입력창 상태
const attributeFilter = ref('')

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

/**
 * 🔄 양방향 연동 로직 (텍스트 입력 <-> 체크박스)
 */
// 1. 텍스트 입력 시 -> 체크박스 자동 선택
watch(manualProjectInput, (newVal) => {
  // 공백, 콤마, 줄바꿈으로 문자열 분리 및 빈 값 제거
  const inputArr = newVal.split(/[,\s\n]+/).map(s => s.trim()).filter(Boolean)
  const validSet = new Set()
  
  inputArr.forEach(inputProj => {
    // 대소문자 구분 없이 리스트에 존재하는 프로젝트인지 확인
    const matched = projectList.value.find(p => p.PROJ_NO.toUpperCase() === inputProj.toUpperCase())
    if (matched) validSet.add(matched.PROJ_NO)
  })

  // 선택된 프로젝트 배열 업데이트
  selectedProjects.value = Array.from(validSet)
})

// 2. 체크박스 클릭 시 -> 텍스트 입력창 업데이트
watch(selectedProjects, (newVal) => {
  const currentInputSet = new Set(manualProjectInput.value.split(/[,\s\n]+/).map(s => s.trim().toUpperCase()).filter(Boolean))
  const selectedSet = new Set(newVal.map(v => v.toUpperCase()))

  // 사용자가 타이핑 중일 때 텍스트가 강제 초기화되며 커서가 튀는 현상을 막기 위해,
  // 실제 항목 구성이 다를 때(체크박스를 마우스로 직접 클릭했을 때)만 텍스트를 갱신합니다.
  const isSame = currentInputSet.size === selectedSet.size && [...currentInputSet].every(x => selectedSet.has(x))
  
  if (!isSame) {
    manualProjectInput.value = newVal.join(', ')
  }
})

// 선택 초기화 함수
const clearProjects = () => {
  manualProjectInput.value = ''
  selectedProjects.value = []
}

/**
 * 🚀 초기 데이터 로드 (Project List)
 */
onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = res.filter(p => p.USE_YN) || []
  } catch (error) {
    console.error('Project List Load Error:', error)
    sAlert.Error('프로젝트 목록을 불러오지 못했습니다.')
  }
})

/**
 * 🔍 데이터 조회 버튼 클릭
 */
const onSearch = async () => {
  if (selectedProjects.value.length === 0) {
    return sAlert.Warning('최소 하나 이상의 프로젝트를 선택하세요.')
  }
  
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    // 💡 변경점: EP_ID와 PROJ_NO를 함께 Payload로 전송
    const fetchPromises = selectedProjects.value.map(projNo => 
      axiosWrapper.post('/api/Attributes/Get', { 
        EP_ID: currentEpId.value, 
        PROJ_NO: projNo 
      }).catch(() => [])
    )
    
    const results = await Promise.all(fetchPromises)
    
    // Pivot 데이터 구조화
    const attrMap = new Map()

    results.forEach((projectData, index) => {
      const currentProjNo = selectedProjects.value[index]
      if (!Array.isArray(projectData)) return

      projectData.forEach(attr => {
        if (!attrMap.has(attr.ATT_ID)) {
          const baseRow = {
            ATT_ID: attr.ATT_ID,
            DESC: attr.DESC,
            VAL_TYPE: attr.VAL_TYPE
          }
          selectedProjects.value.forEach(p => baseRow[p] = false)
          attrMap.set(attr.ATT_ID, baseRow)
        }
        attrMap.get(attr.ATT_ID)[currentProjNo] = true
      })
    })

    // Condition(Pass/Diff) 계산
    const processedData = Array.from(attrMap.values()).map(row => {
      const existCount = selectedProjects.value.filter(p => row[p] === true).length
      row.CONDITION = (existCount === selectedProjects.value.length) ? 'Pass' : 'Diff'
      return row
    })

    dynamicCols.value = selectedProjects.value
    gridRowData.value = processedData
    
  } catch (e) {
    console.error('Attribute Load Error:', e)
    sAlert.Error('속성 데이터를 가져오는 중 오류가 발생했습니다.')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

/**
 * 🎨 셀 렌더링 - 존재 여부에 따른 표시
 */
const existCellRenderer = (params) => {
  if (params.value === true) {
    return `<span class="text-primary fw-bold"><i class="fa fa-circle text-success fs-8 me-1"></i> O</span>`
  }
  return `<span class="text-muted">-</span>`
}

/**
 * 📊 컬럼 정의 (Computed)
 */
const columnDefs = computed(() => {
  const cols = [
    {
      headerName: 'Condition',
      field: 'CONDITION',
      width: 110,
      pinned: 'left',
      cellStyle: p => ({
        color: p.value === 'Diff' ? '#dc3545' : '#198754',
        fontWeight: 'bold',
        textAlign: 'center',
        backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8'
      })
    },
    { headerName: 'Attribute ID', field: 'ATT_ID', width: 150, pinned: 'left', filter: 'agTextColumnFilter' },
    { headerName: 'Description', field: 'DESC', width: 200, pinned: 'left', filter: 'agTextColumnFilter', tooltipField: 'DESC' },
    { headerName: 'Type', field: 'VAL_TYPE', width: 120, pinned: 'left' },
  ]

  // 동적 프로젝트 컬럼 추가
  dynamicCols.value.forEach(proj => {
    cols.push({
      headerName: proj,
      field: proj,
      minWidth: 120,
      cellRenderer: existCellRenderer,
      cellStyle: p => ({
        textAlign: 'center',
        backgroundColor: p.value === false ? '#fff1f0' : 'transparent'
      })
    })
  })

  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  style: 'width: 100%; height: 100%',
  class: 'ag-theme-custom',
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { 
    sortable: true, 
    resizable: true,
  },
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: (node) => {
    const kw = attributeFilter.value.toLowerCase()
    const attId = String(node.data.ATT_ID || '').toLowerCase()
    const desc = String(node.data.DESC || '').toLowerCase()
    return attId.includes(kw) || desc.includes(kw)
  }
}))

const onGridReady = p => {
  gridApi.value = p.api
}
</script>

