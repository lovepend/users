<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-sliders"
      :title="'프로젝트별 속성 비교 분석' + (selectedProjects.length ? ` [선택됨: ${selectedProjects.length}건]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 ms-auto me-2">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 300px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 번호/명 검색..."
                    @click.stop
                  />
                </li>

                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold" style="cursor: pointer">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :checked="isAllSelected"
                      :indeterminate="isIndeterminate"
                      @change="toggleAllSelection"
                    />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                
                <li v-if="filteredProjectList.length === 0" class="text-muted text-center py-2 fs-7">
                  검색 결과가 없습니다.
                </li>
                
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :value="proj.PROJ_NO"
                      v-model="selectedProjects"
                    />
                    <span class="text-truncate"
                      >{{ proj.PROJ_NO }} <small class="text-muted">({{ proj.DESC }})</small></span
                    >
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch" :disabled="selectedProjects.length === 0">
            <i class="fa fa-search me-1"></i>비교 조회
          </button>

          <div class="ms-2 border-start ps-3 d-flex align-items-center gap-2">
            <span class="fw-bold text-success text-nowrap">속성 필터</span>
            <input
              type="text"
              class="form-control form-control-sm border-success custom-input-width"
              v-model="attributeFilter"
              placeholder="ATT_ID 또는 DESC 검색"
            />
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue v-bind="gridOptions" @grid-ready="onGridReady" />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

const route = useRoute()

// --- State ---
const projectList = ref([]) 
const projectSearchKeyword = ref('') 
const selectedProjects = ref([]) 
const attributeFilter = ref('')

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')
const urlProjNo = computed(() => route.query.project_no || '')

/**
 * 프로젝트 리스트 필터링
 */
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  if (!kw) return projectList.value
  return projectList.value.filter(p => 
    (p.PROJ_NO && p.PROJ_NO.toLowerCase().includes(kw)) || 
    (p.DESC && p.DESC.toLowerCase().includes(kw))
  )
})

/**
 * 💡 전체 선택 상태 로직
 */
const isAllSelected = computed(() => {
  return filteredProjectList.value.length > 0 && 
         filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO))
})

const isIndeterminate = computed(() => {
  const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
})

const toggleAllSelection = (e) => {
  const checked = e.target.checked
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  
  if (checked) {
    // 현재 필터링된 항목들을 모두 추가 (중복 제거)
    selectedProjects.value = [...new Set([...selectedProjects.value, ...filteredIds])]
  } else {
    // 현재 필터링된 항목들만 선택에서 제외
    selectedProjects.value = selectedProjects.value.filter(id => !filteredIds.includes(id))
  }
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', {
      headers: { 'Projectno': urlProjNo.value, 'Ep_id': urlEpId.value }
    })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (error) {
    console.error('Project List Load Error:', error)
  }
})

const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const fetchPromises = selectedProjects.value.map(projNo =>
      axiosWrapper.post('/api/Attributes/Get', 
        { "ContainDeleted": false, "ProjectNo": projNo }, 
        { headers: { 'Projectno': projNo, 'Ep_id': urlEpId.value } }
      ).catch(() => [])
    )

    const results = await Promise.all(fetchPromises)
    const attrMap = new Map()

    results.forEach((projectData, index) => {
      const currentProjNoStr = selectedProjects.value[index]
      if (!Array.isArray(projectData)) return

      projectData.forEach(attr => {
        if (!attrMap.has(attr.ATT_ID)) {
          const baseRow = { ATT_ID: attr.ATT_ID, DESC: attr.DESC, VAL_TYPE: attr.VAL_TYPE }
          selectedProjects.value.forEach(p => (baseRow[p] = false))
          attrMap.set(attr.ATT_ID, baseRow)
        }
        attrMap.get(attr.ATT_ID)[currentProjNoStr] = true
      })
    })

    const processedData = Array.from(attrMap.values()).map(row => {
      const existCount = selectedProjects.value.filter(p => row[p] === true).length
      row.CONDITION = existCount === selectedProjects.value.length ? 'Pass' : 'Diff'
      return row
    })

    dynamicCols.value = [...selectedProjects.value]
    gridRowData.value = processedData
  } catch (e) {
    sAlert.Error('데이터 조회 중 오류가 발생했습니다.')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

const existCellRenderer = params => {
  if (params.value === true) {
    return `<span class="text-success fw-bold"><i class="fa fa-circle me-1" style="font-size: 8px;"></i>O</span>`
  }
  return `<span class="text-muted">-</span>`
}

const columnDefs = computed(() => {
  const cols = [
    { 
      headerName: 'Condition', field: 'CONDITION', width: 120, pinned: 'left', filter: 'agTextColumnFilter',
      cellStyle: p => ({ 
        color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', 
        backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' 
      }) 
    },
    { headerName: 'Attribute ID', field: 'ATT_ID', width: 150, pinned: 'left', filter: 'agTextColumnFilter' },
    { headerName: 'Description', field: 'DESC', width: 200, pinned: 'left', filter: 'agTextColumnFilter', tooltipField: 'DESC' },
    { headerName: 'Type', field: 'VAL_TYPE', width: 120, pinned: 'left' },
  ]
  dynamicCols.value.forEach(proj => {
    cols.push({ 
      headerName: proj, field: proj, minWidth: 120, cellRenderer: existCellRenderer, 
      cellStyle: { textAlign: 'center' } 
    })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  style: 'width: 100%; height: 100%',
  class: 'ag-theme-custom',
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, resizable: true },
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const kw = attributeFilter.value.toLowerCase()
    return String(node.data.ATT_ID || '').toLowerCase().includes(kw) || String(node.data.DESC || '').toLowerCase().includes(kw)
  },
}))

const onGridReady = p => { gridApi.value = p.api }
</script>

<style scoped>
/* 💡 선택된 프로젝트가 많아도 버튼 높이가 깨지지 않도록 조정 */
.custom-project-dropdown {
  width: 300px !important;
  max-width: 300px;
  overflow: hidden;
}
.custom-input-width { width: 250px !important; }
.fs-7 { font-size: 0.85rem; }
.dropdown-menu input { border-radius: 4px; }
</style>
