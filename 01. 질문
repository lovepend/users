              style="width: 100%; height: 100%"
              :columnDefs="classModalColDefs"
              :rowData="classModalData"
              :defaultColDef="{ resizable: true, sortable: true, filter: true, floatingFilter: true }"
              @cell-clicked="onClassGridCellClicked"
