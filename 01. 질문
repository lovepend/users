{
  field: 'INOUT',
  headerName: 'In/Out',
  suppressHeaderMenuButton: true,
  editable: params => {
    return projectPermissions.value.some(
      el => isProjectAdmin.value || (el.EP_ID === selectedRegEp.value && el.Role === 'Manager')
    )
  },
  flex: 0.8,
  cellEditor: 'agRichSelectCellEditor',
  cellEditorParams: function (params) {
    return {
      values: ['BOTH', 'IN', 'OUT'],
      valueListGap: 5,
      allowTyping: true,
      filterList: true,
      highlightMatch: true,
      valueListMaxHeight: 220,
      focusOnOpen: true,

      // 👇 콤보 리스트 내부 아이템들의 '글자'와 '배경'을 실시간으로 감시해서 스타일을 입힙니다.
      cellRenderer: function(rendererParams) {
        const container = document.createElement('div');
        container.innerText = rendererParams.value;
        container.style.padding = '4px 8px';
        container.style.width = '100%';
        container.style.height = '100%';
        
        // [핵심] ag-Grid가 이 아이템을 위아래 키로 포커싱하면 부모 엘리먼트에 클래스가 붙습니다.
        // 그 변화를 실시간으로 캐치하기 위해 타이밍을 살짝 주어 감지하고 색상을 반전시킵니다.
        setTimeout(() => {
          const parentRow = container.closest('.ag-rich-select-row');
          if (parentRow) {
            // 초기 기본 글자색 지정 (글자가 파묻히지 않게 명시)
            container.style.color = '#333333'; 

            // 부모 행(Row)에 마우스가 올라가거나, 키보드로 선택(포커스)되었는지 감시하는 인터벌
            const colorCheckInterval = setInterval(() => {
              // 엘리먼트가 화면에서 사라지면 체크 중지
              if (!document.body.contains(container)) {
                clearInterval(colorCheckInterval);
                return;
              }

              const isFocused = parentRow.classList.contains('ag-rich-select-row-selected') || 
                                parentRow.getAttribute('aria-selected') === 'true' ||
                                document.activeElement === parentRow;

              if (isFocused) {
                // 키보드로 선택되었을 때: 배경은 선명하게, 글자는 무조건 흰색으로!
                parentRow.style.backgroundColor = '#2196f3'; // 원하시는 RGB가 있다면 여기 배치하세요!
                container.style.color = '#ffffff'; 
                container.style.fontWeight = 'bold';
              } else {
                // 선택 해제된 평소 상태: 배경 투명, 글자 검은색계열
                parentRow.style.backgroundColor = '';
                container.style.color = '#333333';
                container.style.fontWeight = 'normal';
              }
            }, 50); // 50ms마다 상태를 체크하여 딜레이 없이 색상 변경
          }
        }, 0);

        return container;
      }
    }
  },
  cellStyle: params => {
    if (typeof params.data._id === 'string') {
      if (params.data._id.indexOf('get_') > -1) {
        return { backgroundColor: 'rgb(221 229 181 / 50%)' }
      }
    }
    return null
  },
  suppressKeyboardEvent: params => {
    const { event, editing } = params;
    if (editing) {
      const key = event.key;
      if (key === 'ArrowUp' || key === 'ArrowDown' || key === 'Enter') {
        event.stopPropagation();
        return true; 
      }
    }
    return false;
  }
},
