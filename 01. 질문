<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="dropdown custom-single-select" style="min-width: 220px">
            <InputBox
              id="input-proj"
              label="프로젝트"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택/입력"
              data-bs-toggle="dropdown"
              @input="projSearchQuery = selectedProjNo"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-0 w-100" style="max-height: 300px; overflow-y: auto; z-index: 1060">
              <li v-for="proj in filteredProjectOptions" :key="proj.value">
                <a class="dropdown-item py-2 px-3 cursor-pointer" :class="{ 'active-proj': selectedProjNo === proj.value }" @click="selectProject(proj.value)">
                  {{ proj.text }}
                </a>
              </li>
            </ul>
          </div>

          <InputBox id="input-keyword" label="키워드" v-model:value="searchKeyword" placeholder="Tag No 입력" style="width: 220px" />

          <div class="header-divider"></div>
          <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--primary" @click="confirmSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>
          <div class="header-divider"></div>

          <InputBox id="input-filter" label="결과 검색" v-model:value="localFilterQuery" icon="fa-filter" placeholder="결과 내 찾기" style="width: 220px" @input="onFilterInput" />
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue class="ag-theme-custom w-100 h-100" v-bind="gridOptions" @grid-ready="onGridReady" @cell-clicked="onCellClicked" />
      </div>
    </DefaultCard>

    <div v-if="showClassModal" class="custom-modal-overlay" @click.self="closeClassModal">
      <div class="custom-modal-window shadow-lg" style="width: 850px; height: 60%">
        <div class="modal-header-dark" style="background: #334155">
          <div class="d-flex align-items-center gap-2">
            <i class="fa fa-info-circle text-info"></i>
            <span class="fw-bold text-white">Class Info: {{ clickedClassId }}</span>
          </div>
          <button @click="closeClassModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-3 h-100 d-flex flex-column">
          <div class="ag-theme-custom flex-grow-1">
            <ag-grid-vue 
              style="width: 100%; height: 100%" 
              :columnDefs="classModalColDefs" 
              :rowData="classModalData" 
              :defaultColDef="{ resizable: true, sortable: true, filter: true }" 
              @cell-clicked="onClassGridCellClicked"
            />
          </div>
        </div>
      </div>
    </div>

    <div v-if="showDetailModal" class="custom-modal-overlay" @click.self="closeDetailModal">
      <div class="custom-modal-window shadow-lg" style="width: 900px; height: 80%">
        <div class="modal-header-dark">
          <span class="fw-bold text-white">Detail View: {{ selectedRow?.TAG_NO }}</span>
          <button @click="closeDetailModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-2 h-100">
          <div class="ag-theme-custom h-100">
            <ag-grid-vue style="width: 100%; height: 100%" :columnDefs="detailModalColDefs" :rowData="detailModalRowData" :defaultColDef="{ resizable: true }" />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, computed, shallowRef, onMounted } from 'vue'
  import { useRoute, useRouter } from 'vue-router'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import { useToast } from '@/composables/useToast'
  import { sAlert } from '@/utils/messages/alert-common'
  import { sortBy } from 'lodash-es'

  import DefaultCard from '@/components/default/DefaultCard.vue'
  import InputBox from '@/components/default/editors/InputBox.vue'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

  const route = useRoute()
  const router = useRouter()
  const toast = useToast()
  const cardTitle = { icon: 'fa-list', title: 'Tag 통합 분석', subtitle: '속성 필터링 분석' }

  const gridApi = shallowRef()
  const projectOptions = ref([])
  const selectedProjNo = ref('')
  const projSearchQuery = ref('')
  const searchKeyword = ref('')
  const localFilterQuery = ref('')
  const rawDataList = ref([])
  const dynamicAttCols = ref([])

  // 모달 상태 전용
  const showDetailModal = ref(false)
  const showClassModal = ref(false)
  const selectedRow = ref(null)
  const classModalData = ref([])
  const clickedClassId = ref('')

  const fetchProjectList = async () => {
    try {
      const res = await axiosWrapper.get('/api/Project/Get')
      projectOptions.value = (res || []).map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
    } catch (e) { console.error(e) }
  }

  const filteredProjectOptions = computed(() => {
    const query = projSearchQuery.value.toLowerCase()
    return projectOptions.value.filter(p => p.text.toLowerCase().includes(query))
  })

  const selectProject = val => { selectedProjNo.value = val; projSearchQuery.value = val; }

  const confirmSearch = () => {
    if (!selectedProjNo.value) return sAlert.Warning('프로젝트를 선택하세요.')
    fetchData()
  }

  const fetchData = async () => {
    if (gridApi.value) gridApi.value.setGridOption('loading', true)
    try {
      const payload = { ProjectNo: selectedProjNo.value, Keyword: searchKeyword.value }
      const [pRes, wRes] = await Promise.allSettled([
        axiosWrapper.post('/api/Data/SearchPublishData', payload),
        axiosWrapper.post('/api/Data/SearchWorkingData', payload),
      ])

      let combined = []
      if (pRes.status === 'fulfilled' && pRes.value) {
        combined.push(...(Array.isArray(pRes.value) ? pRes.value : [pRes.value]).map(i => ({ ...i, Source: 'Published' })))
      }
      if (wRes.status === 'fulfilled' && wRes.value) {
        combined.push(...(Array.isArray(wRes.value) ? wRes.value : [wRes.value]).map(i => ({ ...i, Source: 'Working' })))
      }

      const allAttIds = new Set()
      combined.forEach(item => {
        (item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
      })

      const processedData = combined.map(item => {
        const flatItem = { ...item }
        allAttIds.forEach(id => {
          const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
          flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
        })
        return flatItem
      })

      dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
        headerName: id, field: `ATT_${id}`, minWidth: 140, headerClass: 'att-column-header', cellRenderer: highlightRenderer,
      }))

      rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
    } catch (err) { sAlert.Error('조회 실패') } 
    finally { if (gridApi.value) gridApi.value.setGridOption('loading', false) }
  }

  const highlightRenderer = params => {
    const val = params.value === null || params.value === undefined ? '' : String(params.value)
    const searchTerm = localFilterQuery.value.trim()
    if (!searchTerm || val === 'null' || val === '') return val
    const re = new RegExp(`(${searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi')
    return val.replace(re, `<mark class="filter-highlight">$1</mark>`)
  }

  const onFilterInput = () => { if (gridApi.value) gridApi.value.refreshCells({ force: true }) }

  // [기능 추가] 셀 클릭 핸들러
  const onCellClicked = async p => {
    const colId = p.column.getColId()
    if (colId === 'Source') {
      selectedRow.value = p.data
      showDetailModal.value = true
    } else if (colId === 'CLS_ID' && p.value) {
      clickedClassId.value = p.value
      try {
        if (gridApi.value) gridApi.value.setGridOption('loading', true)
        const res = await axiosWrapper.post('/api/Register/GetByClassIDs', { ProjectNo: selectedProjNo.value, ClassIDs: [p.value] })
        classModalData.value = Array.isArray(res) ? res : [res]
        showClassModal.value = true
      } catch (e) { sAlert.Error('Class 정보 로드 실패') } 
      finally { if (gridApi.value) gridApi.value.setGridOption('loading', false) }
    }
  }

  const onClassGridCellClicked = p => {
    if (p.column.getColId() === 'TYPE_ID' && p.value) {
      const routeData = router.resolve({ path: '/register-mapping-setup', query: { reg_type_id: p.data.TYPE_ID, proj_no: selectedProjNo.value, ep_id: p.data.EP_ID } })
      window.open(routeData.href, '_blank')
    }
  }

  const gridOptions = computed(() => ({
    columnDefs: [
      { headerName: 'Source', field: 'Source', width: 110, pinned: 'left', cellStyle: { cursor: 'pointer' },
        cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'}; color:white;">${p.value}</span>` },
      { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      { field: 'CLS_ID', headerName: 'Class', width: 120, pinned: 'left', cellRenderer: highlightRenderer,
        cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd', fontWeight: 'bold' } },
      ...dynamicAttCols.value,
      { field: 'TAG_DESC', headerName: 'Description', width: 200, cellRenderer: highlightRenderer },
    ],
    rowData: filteredData.value,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: { sortable: true, filter: 'agTextColumnFilter', floatingFilter: true, resizable: true },
  }))

  const filteredData = computed(() => {
    const query = localFilterQuery.value.trim().toLowerCase()
    if (!query) return rawDataList.value
    return rawDataList.value.filter(i => Object.values(i).some(val => String(val).toLowerCase().includes(query)))
  })

  // 모달용 컬럼 정의
  const classModalColDefs = [
    { headerName: 'Register No', field: 'TYPE_ID', flex: 1, cellStyle: { fontWeight: 'bold', color: '#0d6efd', textDecoration: 'underline', cursor: 'pointer' } },
    { headerName: 'Description', field: 'DESC', flex: 1.5 },
    { headerName: 'EP ID', field: 'EP_ID', width: 120 },
  ]
  const detailModalColDefs = [
    { headerName: 'Property', field: 'key', width: 220, pinned: 'left', cellStyle: { background: '#f8f9fa', fontWeight: 'bold' } },
    { headerName: 'Value', field: 'value', flex: 1 },
  ]
  const detailModalRowData = computed(() => {
    if (!selectedRow.value) return []
    return Object.entries(selectedRow.value)
      .filter(([k]) => k !== 'ATTRIBUTES')
      .map(([k, v]) => ({ key: k, value: v ?? '-' }))
  })

  const onGridReady = params => { gridApi.value = params.api }
  const closeClassModal = () => { showClassModal.value = false; classModalData.value = []; }
  const closeDetailModal = () => { showDetailModal.value = false; selectedRow.value = null; }

  onMounted(async () => {
    await fetchProjectList()
    const urlProjNo = route.query?.proj_no || new URLSearchParams(window.location.search).get('proj_no')
    if (urlProjNo) { selectedProjNo.value = urlProjNo; fetchData(); }
  })
</script>

