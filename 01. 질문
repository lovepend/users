<script setup>
  import { shallowRef } from 'vue'
  import { saveAs } from 'file-saver'
  import GC from '@mescius/spread-sheets-designer'

  import GCLangResKO from '@/lang/spread/spread_language_KO'
  import GCLangResEN from '@/lang/spread/spread_language_EN'
  import GCLangResJA from '@/lang/spread/spread_language_JA'
  import GCLangResCN from '@/lang/spread/spread_language_CN'
  window.GC = GC

  /* !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! */
  import SpreadComboEditor from '@/components/editors/spreadJsEditor/SpreadComboEditor'
  import SpreadComboTestEditor from '@/components/editors/spreadJsEditor/SpreadComboTestEditor'

  import Switch from '@/components/default/editors/Switch.vue'
  /* !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! */

  const exportFileEncryptRef = shallowRef(true)
  const DesignerRef = shallowRef(null)
  const SpreadRef = shallowRef(null)
  const initDesigner = function (designer) {
    DesignerRef.value = designer
    SpreadRef.value = designer.getWorkbook()
  }

  const _SpreadVersion = '18.0.7'
  const DownloadTypeRef = shallowRef('KO')
  const LanguageTypeRef = shallowRef('KO')
  const _LangType = {
    KO: 'KO',
    EN: 'EN',
    JA: 'JA',
    CN: 'CN',
  }

  /**
   * @description
   * main.ts에 resource를 다운받고자 하는 언어로 import
   * languageType을 동일 언어로 설정후 다운로드 실행
   *
   * 파일 가장위 버전으로 변경 여부 확인
   */
  const onDownloadLocaleResource = function () {
    const languageType = DownloadTypeRef.value
    if (!languageType || !_LangType[languageType]) {
      return
    }
    try {
      let version = _SpreadVersion
      const spread = SpreadRef.value
      if (spread) {
        const spreadInfo = spread.toJSON()
        const spreadVersion = spreadInfo?.version
        if (spreadVersion) {
          version = spreadVersion
        }
      }
      const resource = GC.Spread.Sheets.Designer.getResources()
      const resourceJson = JSON.stringify(resource)
      let sourceJson = `const version = "${version}";`
      sourceJson += `const locale = "${languageType}";`
      sourceJson += 'export default ' + '`' + resourceJson + '`;'
      switch (languageType) {
        case _LangType.KO:
          sourceJson = sourceJson.replaceAll('\\', '\\\\')
          sourceJson = sourceJson.replaceAll('${', '&#36;{')
          break
        case _LangType.EN:
          sourceJson = sourceJson.replaceAll('\\', '\\\\')
          sourceJson = sourceJson.replaceAll('${', '&#36;{')
          break
        case _LangType.JA:
          sourceJson = sourceJson.replaceAll('\\', '\\\\')
          sourceJson = sourceJson.replaceAll('${', '&#36;{')
          break
        case _LangType.CN:
          sourceJson = sourceJson.replaceAll('\\', '\\\\')
          sourceJson = sourceJson.replaceAll('${', '&#36;{')
          break
        default:
          return
      }
      saveAs(new Blob([sourceJson], { type: 'text/javascript;charset=utf-8' }), `spread_language_${languageType}.js`)
    } catch (error) {
      console.error(error)
      alert(error.message)
    }
  }
  const spreadLocalization = function (LOCALE) {
    const _Locale = LOCALE
    switch (_Locale) {
      case 'KO':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResKO))
        GC.Spread.Common.CultureManager.culture('ko-kr')
        break
      case 'JA':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResJA))
        GC.Spread.Common.CultureManager.culture('ja-jp')
        break
      case 'CN':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResCN))
        GC.Spread.Common.CultureManager.culture('zh-cn')
        break
      case 'EN':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResEN))
        GC.Spread.Common.CultureManager.culture('en-us')
        break
      default:
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResEN))
        GC.Spread.Common.CultureManager.culture('en-us')
        break
    }
    return GC.Spread.Sheets.Designer.DefaultConfig
  }
  const onChangeLocale = function () {
    const languageType = LanguageTypeRef.value
    if (!languageType || !_LangType[languageType]) {
      return
    }

    const config = spreadLocalization(languageType)
    if (config) {
      const designer = DesignerRef.value
      designer.setConfig(config)
    }
  }

  /////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////
  const highlightFormulaRef = shallowRef()
  const highlightRangesRef = shallowRef()
  const keyRef = shallowRef(0)
  const onReset = () => (keyRef.value += 1)
  // prettier-ignore
  const onDefault = function () {
    const spread = SpreadRef.value
    const sheet = spread?.getActiveSheet()
    if (!sheet) { return; }
    sheet.bind(GC.Spread.Sheets.Events.LeaveCell, function (e, args) {
      const cell = args.sheet.getCell(args.row, args.col)
      const cellType = cell.cellType()
      if (cellType?.focusOut) {
        cellType?.focusOut(args)
      }
    })
    const cellType1 = new SpreadComboTestEditor({ showAllOptionButton: true, isPaintLabel: false, closeOnSelect: false, code: 'value', label: 'text', })
    const cellType2 = new SpreadComboEditor({ showAllOptionButton: true, applySelected: false, placeholer: 'PLACE_HOLDER', code: 'code', label: 'label', })
    const cellType3 = new SpreadComboEditor({ showAllOptionButton: true, deselectFromDropdown: true, multipleCheck: true, closeOnSelect: false, code: 'value', label: 'text', })
    const cellType4 = new SpreadComboEditor({ showAllOptionButton: true, multiple: true, code: 'value', label: 'text', })
    const cellType5 = new SpreadComboEditor({ showAllOptionButton: true, multiple: true, multipleCheck: true, closeOnSelect: false, code: 'value', label: 'text', })
    const cellType6 = new SpreadComboEditor({ showAllOptionButton: true, treeSelect: true, code: 'value', label: 'text', })
    const cellType7 = new SpreadComboEditor({ showAllOptionButton: true, treeSelect: true, multiple: true, code: 'value', label: 'text', })
    const cellType8 = new SpreadComboEditor({ showAllOptionButton: true, treeSelect: true, multiple: true, multipleCheck: true, code: 'value', label: 'text', })
    // cellType1.editorValueType(GC.Spread.Sheets.CellTypes.EditorValueType.value)
    const items = [
      { value: 'a_val', text: 'A_TEXT', code: 'a_code', label: 'A_LABEL', seq: 1, children:
        [
          { value: 'a_child_1_val', text: 'A_CHILD_1_TEXT', code: 'a_child_1_code', label: 'A_CHILD_1_LABEL', SEQ: 1 },
          { value: 'a_child_2_val', text: 'A_CHILD_2_TEXT', code: 'a_child_2_code', label: 'A_CHILD_2_LABEL', SEQ: 2 },
          { value: 'a_child_3_val', text: 'A_CHILD_3_TEXT', code: 'a_child_3_code', label: 'A_CHILD_3_LABEL', SEQ: 3 },
        ],
      },
      { value: 'b_val', text: 'B_TEXT', code: 'b_code', label: 'B_LABEL', seq: 2, selectable: false, },
      { value: 'c_val', text: 'C_TEXT', code: 'c_code', label: 'C_LABEL', seq: 3, selectable: false, children:
        [
          { value: 'c_child_1_val', text: 'C_CHILD_1_TEXT', code: 'c_child_1_code', label: 'C_CHILD_1_LABEL', SEQ: 1 },
          { value: 'c_child_2_val', text: 'C_CHILD_2_TEXT', code: 'c_child_2_code', label: 'C_CHILD_2_LABEL', SEQ: 2 },
          { value: 'c_child_3_val', text: 'C_CHILD_3_TEXT', code: 'c_child_3_code', label: 'C_CHILD_3_LABEL', SEQ: 3 },
        ],
      },
      { value: 'd_val', text: 'D_TEXT', code: 'd_code', label: 'D_LABEL', seq: 4 },
      { value: 'e_val', text: 'E_TEXT', code: 'e_code', label: 'E_LABEL', seq: 5, children:
        [
          { value: 'e_child_1_val', text: 'E_CHILD_1_TEXT', code: 'e_child_1_code', label: 'E_CHILD_1_LABEL', SEQ: 1 },
          { value: 'e_child_2_val', text: 'E_CHILD_2_TEXT', code: 'e_child_2_code', label: 'E_CHILD_2_LABEL', SEQ: 2 },
          { value: 'e_child_3_val', text: 'E_CHILD_3_TEXT', code: 'e_child_3_code', label: 'E_CHILD_3_LABEL', SEQ: 3 },
        ],
      },
    ]
    cellType1.items(items)
    cellType2.items(items)
    cellType3.items(items)
    cellType4.items(items)
    cellType5.items(items)
    cellType6.items(items)
    cellType7.items(items)
    cellType8.items(items)
    sheet.setColumnWidth(1, 140)
    sheet.setColumnWidth(2, 140)
    sheet.setColumnWidth(3, 140)
    sheet.setColumnWidth(4, 140)
    sheet.setColumnWidth(5, 140)
    sheet.setColumnWidth(6, 140)
    sheet.setColumnWidth(7, 140)
    sheet.setColumnWidth(8, 140)
    sheet.getCell(1, 1).hAlign(1)
    sheet.getCell(1, 2).hAlign(1)
    sheet.getCell(1, 3).hAlign(1)
    sheet.getCell(1, 4).hAlign(1)
    sheet.getCell(1, 5).hAlign(1)
    sheet.getCell(1, 6).hAlign(1)
    sheet.getCell(1, 7).hAlign(1)
    sheet.getCell(1, 8).hAlign(1)
    sheet.setValue(1, 1, 'BASE')
    sheet.setValue(1, 2, 'CODE_LABEL')
    sheet.setValue(1, 3, 'DESELECT')
    sheet.setValue(1, 4, 'MULTIPLE')
    sheet.setValue(1, 5, 'MULTI_CHECK')
    sheet.setValue(1, 6, 'TREE')
    sheet.setValue(1, 7, 'TREE_MULTIPLE')
    sheet.setValue(1, 8, 'TREE_MULTI_CHECK')
    sheet.getRange(2, 1, 10, 1).cellType(cellType1)
    sheet.getRange(2, 2, 10, 1).cellType(cellType2)
    sheet.getRange(2, 3, 10, 1).cellType(cellType3)
    sheet.getRange(2, 4, 10, 1).cellType(cellType4)
    sheet.getRange(2, 5, 10, 1).cellType(cellType5)
    sheet.getRange(2, 6, 10, 1).cellType(cellType6)
    sheet.getRange(2, 7, 10, 1).cellType(cellType7)
    sheet.getRange(2, 8, 10, 1).cellType(cellType8)
    // sheet.getCell(0, 0).cellType(cellType)
    // sheet.getCell(0, 1).cellType(cellType)
    // sheet.getCell(1, 0).cellType(cellType)
    // sheet.getCell(1, 1).cellType(cellType)
  }
  const onWhite = function () {
    const spread = SpreadRef.value
    const sheet = spread?.getActiveSheet()
    const ranges = sheet?.getSelections()
    // prettier-ignore
    const text = !ranges?.length ? '' : (
      GC.Spread.Sheets.CalcEngine.rangesToFormula(
        ranges,
        0,
        0,
        GC.Spread.Sheets.CalcEngine.RangeReferenceRelative.allRelative,
      )
    )
    sheet.setValue(0, 0, text)
    sheet.setSelection(0, 0, 1, 1)
  }
  const onGray = function () {
    const spread = SpreadRef.value
    const sheet = spread?.getActiveSheet()
    const row = sheet?.getActiveRowIndex()
    const col = sheet?.getActiveColumnIndex()
    const text = sheet?.getText(row, col)
    // highlightFormulaRef.value = text
    if (text) {
      const allRange = GC.Spread.Sheets.CalcEngine.formulaToRanges(sheet, text, 0, 0)
      highlightRangesRef.value = allRange?.[0]?.ranges
    } else {
      highlightRangesRef.value = null
    }
  }
  const onPurple = function () {}
  const onIndigo = function () {}
  const onYellow = function () {}
  const onPink = function () {}
  const onGreen = function () {}
  const onLime = function () {}
  const onDark = function () {}
  const onInfo = function () {}
  const onWarning = function () {}
  const onDanger = function () {}
  const onSuccess = function () {}
</script>

<template>
  <div class="w-100 h-100" style="display: flex; flex-direction: column">
    <div class="d-flex justify-content-between">
      <label class="d-inline-block p-2 bg-indigo-200 me-2 h-35px">
        <span class="me-2">Language </span>
        <select v-model="LanguageTypeRef" @change="onChangeLocale">
          <option :value="_LangType.KO">한국어</option>
          <option :value="_LangType.EN">English</option>
          <option :value="_LangType.JA">日本語</option>
          <option :value="_LangType.CN">中文</option>
        </select>
      </label>
      <label style="align-self: center; user-select: none">
        <Switch label="Export With Encrypt" v-model:value="exportFileEncryptRef" />
      </label>
      <button class="btn btn-default" @click="onDefault">Default</button>
      <button class="btn btn-white" @click="onWhite">White</button>
      <button class="btn btn-gray" @click="onGray">Gray</button>
      <button class="btn btn-purple" @click="onPurple">Purple</button>
      <button class="btn btn-indigo" @click="onIndigo">Indigo</button>
      <button class="btn btn-yellow" @click="onYellow">Yellow</button>
      <button class="btn btn-pink" @click="onPink">Pink</button>
      <button class="btn btn-green" @click="onGreen">Green</button>
      <button class="btn btn-lime" @click="onLime">Lime</button>
      <button class="btn btn-dark" @click="onDark">Dark</button>
      <button class="btn btn-info" @click="onInfo">Info</button>
      <button class="btn btn-warning" @click="onWarning">Warning</button>
      <button class="btn btn-danger" @click="onDanger">Danger</button>
      <button class="btn btn-success" @click="onSuccess">Success</button>
      <button class="btn btn-primary" @click="onReset">Reset</button>
      <div class="d-inline-block p-2 bg-indigo-200 h-35px">
        <select v-model="DownloadTypeRef" class="me-2">
          <option :value="_LangType.KO">한국어</option>
          <option :value="_LangType.EN">English</option>
          <option :value="_LangType.JA">日本語</option>
          <option :value="_LangType.CN">中文</option>
        </select>
        <button class="p-0 px-2" style="font-size: 12px" @click="onDownloadLocaleResource">언어 리소스 다운로드</button>
      </div>
    </div>
    <!-- highlightFormula: 사용 X -->
    <gc-spread-designer
      class="h-100"
      @designer-initialized="initDesigner"
      :key="keyRef"
      :EXPORT_FILE_ENCRYPT="exportFileEncryptRef"
      :highlightFormula="highlightFormulaRef"
      :highlightRanges="highlightRangesRef"
    />
  </div>
</template>

