<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="dropdown custom-single-select" style="min-width: 200px">
            <InputBox
              id="input-proj"
              label="Project"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택"
              readonly
              data-bs-toggle="dropdown"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto; z-index: 1060">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="Search..." @click.stop />
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item py-1 cursor-pointer" @click="selectProject(proj.PROJ_NO)">
                <div class="d-flex align-items-center justify-content-between">
                  <span :class="{ 'fw-bold text-primary': selectedProjNo === proj.PROJ_NO }">{{ proj.PROJ_NO }}</span>
                  <small class="text-muted ms-1 text-truncate" style="max-width: 100px;">{{ proj.DESC }}</small>
                </div>
              </li>
            </ul>
          </div>

          <div class="dropdown custom-single-select" style="min-width: 180px">
            <InputBox
              id="input-type"
              label="Type"
              v-model:value="selectedTypeId"
              placeholder="타입 선택"
              readonly
              :disabled="!tagTypes.length"
              data-bs-toggle="dropdown"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto; z-index: 1060">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="typeSearchKeyword" placeholder="Search..." @click.stop />
              </li>
              <li v-for="type in filteredTagTypes" :key="type.TYPE_ID" class="dropdown-item py-1 cursor-pointer" @click="selectType(type.TYPE_ID)">
                <span :class="{ 'fw-bold text-primary': selectedTypeId === type.TYPE_ID }">{{ type.TYPE_ID }}</span>
              </li>
            </ul>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center">
            <InputBox
              id="input-tagno"
              label="Tag No"
              v-model:value="tagNoForValidator"
              placeholder="검증할 Tag No 입력"
              style="width: 250px"
            />
          </div>

          <div class="header-divider"></div>

          <button type="button" class="tpl-btn tpl-btn--sm btn-outline-secondary bg-white border" @click="resetFilters" title="초기화">
            <i class="fa fa-sync text-muted"></i>
          </button>
        </div>
      </template>

      <div class="row m-0 h-100 w-100 overflow-hidden">
        <div class="col-md-6 p-0 h-100 border-end d-flex flex-column">
          <div class="grid-header-title d-flex justify-content-between align-items-center px-3 py-2">
            <span class="fw-bold small"><i class="fa fa-edit me-2 text-primary"></i>TAG_TYPE 정의</span>
            <span v-if="selectedTypeId" class="badge bg-primary-subtle text-primary border border-primary-subtle">{{ selectedTypeId }}</span>
          </div>
          <div class="flex-grow-1 overflow-hidden border-top">
            <ag-grid-vue
              v-bind="leftGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onLeftGridReady"
              @cell-value-changed="onRuleChanged"
            />
          </div>
        </div>

        <div class="col-md-6 p-0 h-100 d-flex flex-column">
          <div class="grid-header-title d-flex justify-content-between align-items-center px-3 py-2">
            <span class="fw-bold small"><i class="fa fa-vials me-2 text-success"></i>실시간 분석 리포트</span>
            <span :class="['badge shadow-sm px-3', isTagNoValid ? 'bg-success' : 'bg-danger']">
              {{ isTagNoValid ? 'VALID' : 'INVALID' }}
            </span>
          </div>
          <div class="flex-grow-1 overflow-hidden border-top">
            <ag-grid-vue
              v-bind="rightGridOptions"
              class="ag-theme-custom w-100 h-100"
              @grid-ready="onRightGridReady"
            />
          </div>
        </div>
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { useRoute } from 'vue-router' // URL 파라미터 읽기용
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'

const route = useRoute()
// 아이콘을 TagTab과 동일한 fa-list로 변경
const cardTitle = { icon: 'fa-list', title: 'Tag Type 검증', subtitle: 'Naming Rule 실시간 시뮬레이션' }

const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjNo = ref('')
const tagTypes = ref([])
const typeSearchKeyword = ref('')
const selectedTypeId = ref('')
const tagRules = ref([])
const tagNoForValidator = ref('')

const leftGridApi = shallowRef()
const rightGridApi = shallowRef()

// --- Filtering & Logic (기존 로직 유지) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})
const filteredTagTypes = computed(() => {
  const kw = typeSearchKeyword.value.trim().toLowerCase()
  return tagTypes.value.filter(t => t.TYPE_ID.toLowerCase().includes(kw))
})

const selectProject = async projNo => {
  selectedProjNo.value = projNo
  await onProjectChange()
}
const selectType = typeId => {
  selectedTypeId.value = typeId
  applyTagTypeRules()
}
const resetFilters = () => {
  selectedProjNo.value = ''; selectedTypeId.value = ''; tagNoForValidator.value = '';
  tagRules.value = []; tagTypes.value = [];
}

const fetchProjects = async () => {
  const res = await axiosWrapper.get('/api/Project/Get')
  projectList.value = Array.isArray(res) ? res : []
}

const onProjectChange = async () => {
  selectedTypeId.value = ''; tagRules.value = []
  const res = await axiosWrapper.post('/api/TagType/Get', { ProjectNo: selectedProjNo.value, ContainDeleted: false })
  tagTypes.value = Array.isArray(res) ? res : []
}

const applyTagTypeRules = () => {
  const target = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (target && target.LNK_CODE) {
    tagRules.value = target.LNK_CODE.map(item => ({
      attId: item.ATT_ID, delimiter: item.DL_VAL || '', regex: item.REG_EXPS || '^.*$'
    }))
  }
}

const onRuleChanged = () => {
  const updatedData = []
  leftGridApi.value.forEachNode(node => updatedData.push(node.data))
  tagRules.value = [...updatedData]
}

// --- Analysis Engine & Grid Options (기존과 동일) ---
const tagParts = computed(() => {
  const results = []; let currentStr = tagNoForValidator.value || ''; let cursor = 0
  for (let rule of tagRules.value) {
    const delim = rule.delimiter; const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null
    if (delim && delim !== '') {
      if (currentStr.substring(cursor).startsWith(delim)) { cursor += delim.length; dOk = true }
      else { dOk = new RegExp(`^(${pureRegex})$`).test('') }
    }
    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) { matchedVal = matcher[1]; cursor += matchedVal.length; cOk = true }
      else if (new RegExp(`^(${pureRegex})$`).test('')) { matchedVal = ''; cOk = true }
    } catch { cOk = false }
    results.push({ attId: rule.attId, matchedValue: matchedVal || '', delimiter: delim || '', isValid: dOk && cOk })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPass) return false
  let totalLen = 0
  tagParts.value.forEach(p => {
    if (p.delimiter && tagNoForValidator.value.substring(totalLen).startsWith(p.delimiter)) totalLen += p.delimiter.length
    if (p.matchedValue) totalLen += p.matchedValue.length
  })
  return totalLen === tagNoForValidator.value.length
})

const leftGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 140, pinned: 'left' },
    { headerName: 'Delim', field: 'delimiter', width: 90, editable: true, cellStyle: { textAlign: 'center', fontWeight: 'bold' } },
    { headerName: 'RegEx (Pattern)', field: 'regex', flex: 1, editable: true, cellClass: 'font-monospace' },
  ],
  rowData: tagRules.value,
  defaultColDef: { resizable: true, sortable: true },
}))

const rightGridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Attribute', field: 'attId', width: 140 },
    { headerName: 'Extracted Value', field: 'matchedValue', flex: 1, cellClass: 'fw-bold font-monospace text-primary' },
    { headerName: 'Result', field: 'isValid', width: 100,
      cellRenderer: p => p.value ? '<b class="text-success text-center d-block">OK</b>' : '<b class="text-danger text-center d-block">ERR</b>',
    },
  ],
  rowData: tagParts.value,
  defaultColDef: { resizable: true },
}))

const onLeftGridReady = p => { leftGridApi.value = p.api }
const onRightGridReady = p => { rightGridApi.value = p.api }

// URL에서 프로젝트 번호를 읽어오는 로직 추가
onMounted(async () => {
  await fetchProjects()
  
  // URL 쿼리 스트링 또는 라우트 파라미터 확인
  const urlProjNo = route.query?.proj_no || new URLSearchParams(window.location.search).get('proj_no')
  if (urlProjNo) {
    selectedProjNo.value = urlProjNo
    await onProjectChange() // 프로젝트 변경에 따른 Tag Type 로드
  }
})
</script>

