<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="dropdown custom-multi-select" style="min-width: 280px">
            <div 
              class="form-control form-control-sm cursor-pointer d-flex justify-content-between align-items-center bg-white"
              data-bs-toggle="dropdown" 
              data-bs-auto-close="outside"
            >
              <span class="text-truncate" style="max-width: 220px;">
                {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
              </span>
              <i class="fa fa-chevron-down ms-2 text-muted" style="font-size: 10px;"></i>
            </div>
            
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 400px; overflow-y: auto; z-index: 1060">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input
                  type="text"
                  class="form-control form-control-sm"
                  v-model="projectSearchKeyword"
                  placeholder="프로젝트 검색..."
                  @click.stop
                />
              </li>
              <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                <label class="form-check-label d-flex align-items-center w-100 fw-bold cursor-pointer">
                  <input
                    class="form-check-input me-2 mt-0"
                    type="checkbox"
                    :checked="isAllSelected"
                    :indeterminate="isIndeterminate"
                    @change="toggleAllSelection"
                  />
                  <span>전체 선택 / 해제</span>
                </label>
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                <label class="form-check-label d-flex align-items-center w-100 cursor-pointer">
                  <input
                    class="form-check-input me-2 mt-0"
                    type="checkbox"
                    :value="proj.PROJ_NO"
                    v-model="selectedProjects"
                  />
                  <span class="text-truncate">
                    <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                    <small class="text-muted ms-1">({{ proj.DESC }})</small>
                  </span>
                </label>
              </li>
            </ul>
          </div>

          <div class="view-mode-toggle-container mx-2">
            <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
              <input type="radio" class="btn-check" name="viewMode" id="modeSimple" value="simple" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeSimple">간편</label>

              <input type="radio" class="btn-check" name="viewMode" id="modeDetail" value="detail" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeDetail">상세</label>
            </div>
          </div>

          <div class="header-divider"></div>

          <button 
            type="button" 
            class="tpl-btn tpl-btn--sm tpl-btn--primary" 
            @click="onSearch"
            :disabled="selectedProjects.length === 0"
          >
            <i class="fa fa-copy me-1"></i>비교 조회
          </button>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2 bg-light px-2 py-1 rounded border">
            <span class="fw-bold text-success small text-nowrap"><i class="fa fa-filter me-1"></i>필터</span>
            <textarea
              class="form-control form-control-sm border-0 bg-transparent custom-textarea-filter"
              v-model="attributeFilter"
              rows="1"
              placeholder="ID 입력 (엔터/쉼표)"
              style="width: 180px; height: 24px; font-size: 11px; outline: none; box-shadow: none;"
            ></textarea>
          </div>
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue 
          class="ag-theme-custom w-100 h-100"
          v-bind="gridOptions" 
          @grid-ready="onGridReady" 
        />
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import DefaultCard from '@/components/default/DefaultCard.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()
const cardTitle = { icon: 'fa-columns', title: 'Attribute 비교 분석', subtitle: '프로젝트 간 속성 정합성 체크' }

// --- State (기존 로직 유지) ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')
const urlProjNo = computed(() => route.query.project_no || '')
const COMPARE_FIELDS = ['DESC', 'VAL_TYPE', 'CL_ID']

// --- 프로젝트 필터링/선택 로직 (기존 유지) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  if (!kw) return projectList.value
  return projectList.value.filter(
    p => (p.PROJ_NO && p.PROJ_NO.toLowerCase().includes(kw)) || (p.DESC && p.DESC.toLowerCase().includes(kw))
  )
})

const isAllSelected = computed(() =>
  filteredProjectList.value.length > 0 &&
  filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO))
)

const isIndeterminate = computed(() => {
  const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
})

const toggleAllSelection = e => {
  const checked = e.target.checked
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = checked
    ? [...new Set([...selectedProjects.value, ...filteredIds])]
    : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', {
      headers: { Projectno: urlProjNo.value, Ep_id: urlEpId.value },
    })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (error) { console.error(error) }
})

// --- 데이터 조회 로직 (기존 유지) ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const fetchPromises = selectedProjects.value.map(projNo =>
      axiosWrapper.post('/api/Attributes/Get', 
        { ContainDeleted: false, ProjectNo: projNo },
        { headers: { Projectno: projNo, Ep_id: urlEpId.value } }
      ).catch(() => [])
    )

    const results = await Promise.all(fetchPromises)
    const attrMap = new Map()

    results.forEach((projectData, index) => {
      const currentProjNo = selectedProjects.value[index]
      if (!Array.isArray(projectData)) return
      projectData.forEach(item => {
        if (!attrMap.has(item.ATT_ID)) {
          attrMap.set(item.ATT_ID, { ATT_ID: item.ATT_ID, projects: {} })
        }
        attrMap.get(item.ATT_ID).projects[currentProjNo] = {
          EXIST: true, DESC: item.DESC || '', VAL_TYPE: item.VAL_TYPE || '', CL_ID: item.CL_ID || '',
        }
      })
    })

    const processedData = Array.from(attrMap.values()).map(row => {
      let isDiff = false
      let diffDetails = []
      if (Object.keys(row.projects).length !== selectedProjects.value.length) {
        isDiff = true; diffDetails.push('Exist')
      }
      COMPARE_FIELDS.forEach(field => {
        const values = selectedProjects.value.filter(p => row.projects[p]).map(p => row.projects[p][field])
        if (new Set(values).size > 1) { isDiff = true; diffDetails.push(field) }
      })
      const resultRow = { ATT_ID: row.ATT_ID, CONDITION: isDiff ? 'Diff' : 'Pass', DIFF_INFO: diffDetails.join(', ') }
      selectedProjects.value.forEach(p => {
        resultRow[p] = row.projects[p] || { EXIST: false, DESC: '', VAL_TYPE: '', CL_ID: '' }
      })
      return resultRow
    })

    dynamicCols.value = [...selectedProjects.value]
    gridRowData.value = processedData
  } catch (e) { sAlert.Error('조회 실패') }
  finally { if (gridApi.value) gridApi.value.setGridOption('loading', false) }
}

// --- 그리드 설정 ---
const columnDefs = computed(() => {
  const multiFilterParams = { filters: [{ filter: 'agTextColumnFilter' }, { filter: 'agSetColumnFilter' }] }
  const cols = [
    {
      headerName: 'Condition', field: 'CONDITION', width: 100, pinned: 'left',
      cellStyle: p => ({
        color: p.value === 'Diff' ? '#dc3545' : '#198754',
        fontWeight: 'bold', textAlign: 'center',
        backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8',
      }),
    },
    { headerName: 'Diff Info', field: 'DIFF_INFO', width: 120, pinned: 'left', cellStyle: { fontSize: '11px', color: '#dc3545' } },
    { headerName: 'Attribute ID', field: 'ATT_ID', width: 160, pinned: 'left' },
  ]

  dynamicCols.value.forEach(proj => {
    const children = [{
      headerName: 'Exist', valueGetter: p => (p.data[proj]?.EXIST ? 'Alive' : '-'), width: 70,
      cellRenderer: p => p.value === 'Alive' ? `<i class="fa fa-check-circle" style="color: #198754;"></i>` : `<span class="text-muted">-</span>`,
      cellStyle: { textAlign: 'center' },
      cellClassRules: { 'bg-danger-light': p => !p.data[proj]?.EXIST },
    }]
    if (viewMode.value === 'detail') {
      children.push(
        { headerName: 'Desc', valueGetter: p => p.data[proj]?.DESC, width: 150 },
        { headerName: 'Type', valueGetter: p => p.data[proj]?.VAL_TYPE, width: 90 },
        { headerName: 'Len', valueGetter: p => p.data[proj]?.CL_ID, width: 70, cellStyle: { textAlign: 'right' } }
      )
    }
    cols.push({ headerName: proj, marryChildren: true, children })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  statusBar: {
    statusPanels: [
      { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'left' },
      { statusPanel: 'agSelectedRowCountComponent', align: 'right' },
    ],
  },
  defaultColDef: { sortable: true, resizable: true, filter: true, floatingFilter: true },
  enableRangeSelection: true,
  cellSelection: true,
  suppressRowClickSelection: true,
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const inputIds = attributeFilter.value.split(/[\s,\n]+/).filter(id => id.trim() !== '').map(id => id.toLowerCase())
    if (inputIds.length === 0) return true
    const targetId = String(node.data.ATT_ID || '').toLowerCase()
    return inputIds.some(id => targetId.includes(id))
  },
}))

const onGridReady = p => { gridApi.value = p.api }
watch([attributeFilter, viewMode], () => { if (gridApi.value) gridApi.value.onFilterChanged() })
</script>

