<template>
  <div class="h-100 d-flex flex-column bg-white">
    <!-- DefaultCard를 사용하되, index.vue에서 이미 감싸고 있다면 
         여기서는 디자인 가이드에 맞춘 컨테이너만 구성합니다. -->
    <div class="template__card d-flex flex-column h-100">
      
      <!-- 1. 컨트롤 영역 (템플릿의 #actions 영역 스타일 적용) -->
      <div class="tpl-check-demo tpl-field-demo border-0 border-bottom">
        <div class="d-flex align-items-center justify-content-between w-100 px-1">
          
          <!-- 왼쪽: 프로젝트 선택 영역 (SelectBox + InputBox 조합) -->
          <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2">
              <i class="fa fa-layer-group text-primary"></i>
              <span class="fw-bold">데이터 통합 집계</span>
            </div>

            <div class="d-flex align-items-center gap-2 border-start ps-3">
              <!-- 프로젝트 선택 셀렉트박스 -->
              <SelectBox
                label="대상 프로젝트"
                :list="projectSelectList"
                v-model:value="selectedProject"
                placeholder="프로젝트 선택"
                style="width: 180px"
              />
              <!-- 상세 검색/입력용 인풋박스 -->
              <InputBox
                id="proj-detail"
                v-model:value="projectSearchKeyword"
                placeholder="코드 직접 입력..."
                style="width: 150px"
              />
            </div>
          </div>

          <!-- 오른쪽: 검색 및 필터 영역 (돋보기 아이콘 적용) -->
          <div class="d-flex align-items-center gap-2">
            <!-- [요청사항] 돋보기 아이콘이 포함된 검색창 -->
            <InputBox
              id="tpl-in-keywords"
              v-model:value="attributeFilter"
              placeholder="결과 내 필터링..."
              icon="fa-search" 
              style="width: 220px"
              @clear="attributeFilter = ''"
            />
            <button 
              class="tpl-btn tpl-btn--sm tpl-btn--primary" 
              @click="onSearch"
              :disabled="!selectedProject"
            >
              조회
            </button>
          </div>
        </div>
      </div>

      <!-- 2. 그리드 영역 -->
      <div class="flex-grow-1 min-h-0">
        <ag-grid-vue
          class="ag-theme-custom h-100"
          v-bind="gridOptions"
          @grid-ready="onGridReady"
        />
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

// 공통 컴포넌트 임포트 (템플릿 기준 경로)
import SelectBox from '@/components/default/editors/SelectBox.vue'
import InputBox from '@/components/default/editors/InputBox.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

// --- State ---
const projectList = ref([])
const selectedProject = ref('') // SelectBox용
const projectSearchKeyword = ref('') // InputBox용
const attributeFilter = ref('')
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicColumnDefs = ref([])

// --- 프로젝트 리스트 변환 (SelectBox용) ---
const projectSelectList = computed(() => {
  return projectList.value.map(p => ({
    id: p.PROJ_NO,
    label: `${p.PROJ_NO} (${p.DESC || 'No Desc'})`
  }))
})

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) {
    console.error('프로젝트 로드 실패', e)
  }
})

// --- 데이터 조회 ---
const onSearch = async () => {
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  
  // SelectBox에서 선택된 값 또는 InputBox 입력값 우선순위 결정
  const targetProj = selectedProject.value || projectSearchKeyword.value
  
  try {
    const res = await axiosWrapper.post('/api/Attributes/Get', { ProjectNo: targetProj })
    gridRowData.value = Array.isArray(res) ? res : []
    
    if (gridRowData.value.length > 0) {
      dynamicColumnDefs.value = Object.keys(gridRowData.value[0]).map(k => ({
        headerName: k,
        field: k,
        filter: true,
        width: 130
      }))
    }
  } catch (e) {
    gridRowData.value = []
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// --- 그리드 설정 ---
const gridOptions = computed(() => ({
  columnDefs: dynamicColumnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, filter: true, resizable: true },
  isExternalFilterPresent: () => attributeFilter.value !== '',
  doesExternalFilterPass: node => {
    const val = attributeFilter.value.toLowerCase()
    return Object.values(node.data).some(v => String(v).toLowerCase().includes(val))
  }
}))

const onGridReady = p => { gridApi.value = p.api }
watch(() => attributeFilter.value, () => gridApi.value?.onFilterChanged())
</script>

