    const firstRowNode = params.api.getDisplayedRowAtIndex(0)
    if (firstRowNode) {
      firstRowNode.setSelected(true)
    }
  }

  const onGridReady_Att = params => {
    // console.log("AttGR");
    gridApi_Att.value = params.api
  }

  // refresh Cell Options
  const refreshParams = {
    force: true,
    suppressFlash: true,
  }

  const createGridRow = (grid, params) => {
    grid.stopEditing()
    //  grid.deselectAll();
    let randomKey = Math.random().toString(36).substring(2, 12)
    let newID = 'new_' + randomKey
    if (params.createID) {
      if (params.rowID) {
        Object.assign(params.newRow, { [params.rowID]: newID })
      } else {
        Object.assign(params.newRow, { _id: newID })
      }
    }
    let lastIdx = grid.getDisplayedRowCount()
    grid.applyTransaction({
      add: [params.newRow],
      addIndex: lastIdx,
    })
    grid.refreshCells(refreshParams)
    grid.ensureIndexVisible(lastIdx, 'bottom')
    grid.forEachNode((rowNode, index) => {
      if (index == lastIdx) {
        rowNode.setSelected(true)
      }
    })

    // if (params.createID) {
    //   let newRowNode = grid.getRowNode(newID);
    //   if (newRowNode) {
    //     newRowNode.setSelected(true);
    //   }
    //   else {
    //     grid.forEachNode((rowNode, index) => {
    //       if (index == lastIdx) {
    //         rowNode.setSelected(true);
    //       }
    //     });
    //   }
    // } else {
    //   grid.forEachNode((rowNode, index) => {
    //     if (index == lastIdx) {
    //       rowNode.setSelected(true);
    //     }
    //   });
    // }
  }
  /***************		CRUD 			**************/
  const checkValidation_Custom = selectedData => {
    /*******
     * NULL CHECK
     * 1. CUSTOM ID
     * 2. TYPE
     */
    let failCount = 0
    let failMsg = []
    selectedData.forEach(elem => {
      if (_.isNil(elem.CUS_ID) || _.isEmpty(elem.CUS_ID)) {
        failMsg.push("'CUSTOM ID' is Required.")
        failCount++
      }
      if (_.isNil(elem.TYPE) || _.isEmpty(elem.TYPE)) {
        failMsg.push("'Type' is Required.")
        failCount++
      }
    })

    if (failCount > 0) {
      sAlert.Error(failMsg ? _.uniq(failMsg).join('<br/>') : 'fail')
      return false
    } else return true
  }

  const checkValidation_Source = selectedData => {
    /*******
     * NULL CHECK
     * 1. Name
     */
    let failCount = 0
    let failMsg = []
    selectedData.forEach(elem => {
      if (_.isNil(elem.SRC_NM) || _.isEmpty(elem.SRC_NM)) {
        failMsg.push("'Name' is Required.")
        failCount++
      }
    })

    if (failCount > 0) {
      sAlert.Error(failMsg ? _.uniq(failMsg).join('<br/>') : 'fail')
      return false
    } else return true
  }

  const checkValidation_Att = selectedData => {
    /*******
     * NULL CHECK
     * 1. Name
     */
    let failCount = 0
    let failMsg = []
    selectedData.forEach(elem => {
      if (_.isNil(elem.ATT_NM) || _.isEmpty(elem.ATT_NM)) {
        failMsg.push("'Name' is Required.")
        failCount++
      }
    })

    if (failCount > 0) {
      sAlert.Error(failMsg ? _.uniq(failMsg).join('<br/>') : 'fail')
      return false
    } else return true
  }

  function invertNumber(num) {
    const invertedString = num.toString().split('').reverse().join('')
    return parseInt(invertedString, 10)
  }

  const createData_Custom = () => {
    let params = {}
    params.newRow = {
      CUS_ID: null,
      TYPE: 'Inhouse',
      STATUS: 'A',
      MGR: userInfo.value?.UserID,
      CRTER_NO: userInfo.value?.UserID,
      URL: '/grid-template',
      SOURCES: [],
    }
    params.createID = true

    createGridRow(gridApi_Custom.value, params)
  }

  const createData_Source = () => {
    let counter = 0
    let target = '0'
    gridApi_Source.value.forEachNode(elem => {
      if (elem.data.SRC_NM.includes('SOURCE_NAME_')) {
        target = elem.data.SRC_NM.replace('SOURCE_NAME_', '')
        // counter++;
      }
    })
    counter = invertNumber(target)
    counter++

    let params = {}
    params.newRow = { SRC_NM: `SOURCE_NAME_${counter}`, ATTS: [] }
    params.createID = true

    createGridRow(gridApi_Source.value, params)

    selectedCustom.value.SOURCES.push({ SRC_NM: `SOURCE_NAME_${counter}`, ATTS: [] })
  }

  const createData_Att = () => {
    let counter = 0
    let target = '0'
    gridApi_Att.value.forEachNode(elem => {
      if (elem.data.ATT_NM.includes('ATT_NAME_')) {
        target = elem.data.ATT_NM.replace('ATT_NAME_', '')
        // counter++;
      }
    })
    counter = invertNumber(target)
    counter++

    let params = {}
    params.newRow = { ATT_NM: `ATT_NAME_${counter}`, ATT_DESC: null }
    params.createID = true

    createGridRow(gridApi_Att.value, params)

    selectedSource.value.ATTS.push({ ATT_NM: `ATT_NAME_${counter}`, ATT_DESC: null })
  }

  const deleteSelected_Custom = async () => {
    let successCount = 0
    let failCount = 0
    let failTagCode = []
    let selectedRows = gridApi_Custom.value.getSelectedRows()
    if (_.isEmpty(selectedRows)) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }
    let confirmResult = await sAlert.Confirm('It will be deleted immediately. Are you sure you want to delete?')
    if (!confirmResult.isConfirmed) {
      return
    }

    for (let i = 0; i < selectedRows.length; i++) {
      let url = `/api/AdapterCustom/Delete`
      let bodyData = {
        id: selectedRows[i]._id,
      }

      try {
        await axiosWrapper.post(url, bodyData)
        successCount++
      } catch (error) {
        failCount++
        failTagCode.push(selectedRows[i].CUS_ID)
      }
    }
    let failinfo = failCount > 0 ? `failed to delete ${failCount} item.( TYPE ID : ${failTagCode.join(',')})` : ''

    if (successCount > 0) {
      sAlert.Success(`Successfully deleted ${successCount} Custom.<br> ${failinfo}`)
    } else {
      sAlert.Error(`Error occurred during delete Custom.<br> ${failinfo}`)
    }

    getCustomList()
  }

  const deleteSelected_Source = () => {
    let selectedData = gridApi_Source.value.getSelectedRows()
    if (_.isEmpty(selectedData)) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }
    const filteredSourceList = sourceListRef.value.filter(
      item => !selectedData.some(selected => selected.SRC_NM === item.SRC_NM)
    )
    sourceListRef.value = filteredSourceList
    gridApi_Source.value.applyTransaction({ remove: selectedData })
    gridApi_Source.value.refreshCells()
    selectedCustom.value.SOURCES = sourceListRef.value

    attListRef.value = []
    attListOrigin.value = null
    showCreateAtt = false
    showDeleteAtt = false
  }

  const deleteSelected_Att = () => {
    let selectedData = gridApi_Att.value.getSelectedRows()
    if (_.isEmpty(selectedData)) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }

    const filteredSourceList = attListRef.value.filter(
      item => !selectedData.some(selected => selected.ATT_NM === item.ATT_NM)
    )
    attListRef.value = filteredSourceList
    gridApi_Att.value.applyTransaction({ remove: selectedData })
    gridApi_Att.value.refreshCells()
    selectedSource.value.ATTS = attListRef.value
    selectedCustom.value.SOURCES = sourceListRef.value
  }

  const preSave_Custom = () => {
    gridApi_Att.value.stopEditing()
    gridApi_Source.value.stopEditing()
    gridApi_Custom.value.stopEditing()
    _.delay(saveData_Custom, 50)
  }

  const saveData_Custom = async () => {
    await gridApi_Att.value.refreshCells(refreshParams)
    await gridApi_Source.value.refreshCells(refreshParams)
    await gridApi_Custom.value.refreshCells(refreshParams)

    let selectedAttRows = gridApi_Att.value.getSelectedRows()
    let selectedSourceRows = gridApi_Source.value.getSelectedRows()
    let selectedRows = gridApi_Custom.value.getSelectedRows()

    if (selectedRows && selectedRows.length > 0) {
      let url = `/api/AdapterCustom`
      let createData = []
      let updateData = []
      let createCount = 0
      let updateCount = 0
      let updateIdData = []

      const data = selectedRows
      const data2 = selectedSourceRows
      const data3 = selectedAttRows

      selectedRows.forEach(elem => {
        //1
        if (elem.STATUS == 'A') {
          createCount++

          let { CRTE_DTM, _id, ...rest } = elem

          createData.push({ _id: null, ...rest })
        } else {
          updateCount++

          let { CHGER_NO, CHGE_DTM, ...rest } = elem
          updateData.push({ CHGER_NO: userInfo.value?.UserID, ...rest })
        }
      })

      if (!checkValidation_Custom(selectedRows)) return

      try {
        let successMessage = 'CustomList is  Saved. '
        if (createCount > 0) {
          await axiosWrapper.post(url + '/Create', createData)
          successMessage = successMessage + `Created :${createCount} `
        }
        if (updateCount > 0) {
          await axiosWrapper.put(url + '/Update', updateData)
          successMessage = successMessage + `Updated :${updateCount} `
        }

        sAlert.Success(successMessage)
        gridApi_Att.value.deselectAll()
        gridApi_Source.value.deselectAll()
        gridApi_Custom.value.deselectAll()

        await getCustomList()

        setTimeout(() => {
          gridApi_Custom.value.forEachNode(function (rowNode, index) {
            if (rowNode.data.CUS_ID === data[0].CUS_ID) {
              rowNode.setSelected(true)
            }
          })
        }, 0)
      } catch (error) {
        console.error('saveData', error)
        getCustomList()

        if (!(error instanceof axios.AxiosError)) {
          sAlert.Error('Error occurred during Custom save : ' + error.message)
        }
      }
    } else {
      sAlert.Warning('Select a row from the Custom list')
    }
  }

  // Keydown 단축키 Ctrl + S 저장 단축키
  const onKeyDown_Custom = event => {
    if (event.ctrlKey && event.key === 's') {
      event.preventDefault() //브라우저 기본 저장 동작 방지
      preSave_Custom()
    }
  }

  const agGridRefresh = async function (gridApi) {
    await gridApi.redrawRows()
    await gridApi.refreshCells()
  }

  const rowDragEventSource = event => {
    // console.log('Row drag ended', event);
    const updatedRowData = []
    event.api.forEachNodeAfterFilterAndSort(node => {
      updatedRowData.push(node.data)
    })

    sourceListRef.value = updatedRowData
    selectedCustom.value.SOURCES = sourceListRef.value
  }

  const gridBindCommonProps = ref({
    style: 'width: 100%; height: 100%',
    class: themeClass,
    suppressLastEmptyLineOnPaste: true,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
    enableFillHandle: true,
    pagination: false,
    suppressRowClickSelection: false,
    columnHoverHighlight: true,
    loadingOverlayComponent: AggridLoadingOverlay,
    loadingOverlayComponentParams: loadingOverlayComponentParams,
  })

  const gridBindCustomProps = ref({
    statusBar: statusBar,
    getRowId: getRowId,
    rowSelection: 'single',
    rowMultiSelectWithClick: false,
    defaultColDef: defaultColDef,
    columnDefs: colDefs_Custom,
    rowData: customListRef,
    ...gridBindCommonProps.value,
  })
  const gridBindSourceProps = ref({
    rowDragManaged: true,
    suppressMoveWhenRowDragging: true,
    onRowDragEnd: rowDragEventSource,
    statusBar: statusBar_Detail,
    rowSelection: 'single',
    rowMultiSelectWithClick: true,
    defaultColDef: defaultColDef2,
    columnDefs: colDefs_Source,
    rowData: sourceListRef,
    ...gridBindCommonProps.value,
  })
  const gridBindAttProps = ref({
    statusBar: statusBar,
    rowSelection: 'multiple',
    rowMultiSelectWithClick: true,
    defaultColDef: defaultColDef3,
    columnDefs: colDefs_Att,
    rowData: attListRef,
    ...gridBindCommonProps.value,
  })

  const gridOnCommonProps = index => {
    switch (index) {
      case 'custom':
        return {
          firstDataRendered: onFirstDataRendered_Custom,
          rowSelected: onRowSelected_Custom,
          cellValueChanged: onCellValueChanged_Custom,
          gridReady: onGridReady_Custom,
          keydown: onKeyDown_Custom,
        }
      case 'source':
        return {
          firstDataRendered: onFirstDataRendered_Source,
          rowSelected: onRowSelected_Source,
          cellValueChanged: onCellValueChanged_Source,
          gridReady: onGridReady_Source, // 행 드래그 종료 이벤트 핸들러
        }
      case 'att':
        return {
          firstDataRendered: onFirstDataRendered_Att,
          rowSelected: onRowSelected_Att,
          cellValueChanged: onCellValueChanged_Att,
          gridReady: onGridReady_Att,
        }
      default:
        return {
          firstDataRendered: onFirstDataRendered_Custom,
          rowSelected: onRowSelected_Custom,
          cellValueChanged: onCellValueChanged_Custom,
          gridReady: onGridReady_Custom,
          keydown: onKeyDown_Custom,
        }
    }
  }
  defineOptions({
    name: `AdapterCustomSetup`,
    components: { agDropBoxEditor, AgDetailStatusBar },
  })
</script>

