<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="dropdown custom-single-select" style="min-width: 200px">
            <InputBox
              id="input-proj-merge"
              label="Project"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택"
              readonly
              data-bs-toggle="dropdown"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto; z-index: 1060">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="Search..." @click.stop />
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item py-1 cursor-pointer" @click="selectProject(proj.PROJ_NO)">
                <div class="d-flex align-items-center justify-content-between">
                  <span :class="{ 'fw-bold text-primary': selectedProjNo === proj.PROJ_NO }">{{ proj.PROJ_NO }}</span>
                  <small class="text-muted ms-1 text-truncate" style="max-width: 100px;">{{ proj.DESC }}</small>
                </div>
              </li>
            </ul>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <button class="tpl-btn tpl-btn--sm btn-primary" @click="onMerge" :disabled="!isMergeable">
              <i class="fa fa-object-group me-1"></i> Merge
            </button>
            <button class="tpl-btn tpl-btn--sm btn-outline-secondary bg-white border" @click="resetFilters" title="초기화">
              <i class="fa fa-sync text-muted"></i>
            </button>
          </div>
        </div>
      </template>

      <div class="flex-grow-1 w-100 h-100 overflow-hidden d-flex flex-column">
        <div class="grid-header-title d-flex justify-content-between align-items-center px-3 py-2">
          <span class="fw-bold small"><i class="fa fa-table me-2 text-primary"></i>Data Merging List</span>
          <div class="d-flex gap-3">
             <small class="text-muted">Total: <strong>{{ rowData.length }}</strong></small>
          </div>
        </div>
        
        <div class="flex-grow-1 border-top">
          <ag-grid-vue
            v-bind="gridOptions"
            class="ag-theme-custom w-100 h-100"
            :row-data="rowData"
            @grid-ready="onGridReady"
          />
        </div>
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'

const route = useRoute()
const cardTitle = { icon: 'fa-list', title: 'Data Merge 관리', subtitle: '데이터 통합 및 매핑 설정' }

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjNo = ref('')
const rowData = ref([])
const gridApi = shallowRef()

// --- Filtering ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})

const isMergeable = computed(() => selectedProjNo.value && rowData.value.length > 0)

// --- Events ---
const selectProject = async projNo => {
  selectedProjNo.value = projNo
  await fetchData()
}

const resetFilters = () => {
  selectedProjNo.value = ''
  rowData.value = []
}

// --- API Calls ---
const fetchProjects = async () => {
  const res = await axiosWrapper.get('/api/Project/Get')
  projectList.value = Array.isArray(res) ? res : []
}

const fetchData = async () => {
  if (!selectedProjNo.value) return
  // 기존 머지 대상 조회 API 호출 로직 (예시)
  const res = await axiosWrapper.post('/api/Merge/GetList', { ProjectNo: selectedProjNo.value })
  rowData.value = Array.isArray(res) ? res : []
}

const onMerge = async () => {
  // 머지 실행 로직
  console.log('Merging process start...')
}

// --- AG Grid Config ---
const gridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'ID', field: 'ID', width: 100, checkboxSelection: true, headerCheckboxSelection: true },
    { headerName: 'Source Type', field: 'SOURCE_TYPE', width: 150 },
    { headerName: 'Target Type', field: 'TARGET_TYPE', width: 150 },
    { headerName: 'Status', field: 'STATUS', width: 120, 
      cellRenderer: p => `<span class="badge ${p.value === 'Done' ? 'bg-success' : 'bg-warning text-dark'}">${p.value}</span>`
    },
    { headerName: 'Description', field: 'DESC', flex: 1 },
  ],
  defaultColDef: {
    resizable: true,
    sortable: true,
    filter: true,
  },
  rowSelection: 'multiple',
}))

const onGridReady = p => { gridApi.value = p.api }

// 초기 진입 시 로직
onMounted(async () => {
  await fetchProjects()
  const urlProjNo = route.query?.proj_no
  if (urlProjNo) {
    selectedProjNo.value = urlProjNo
    await fetchData()
  }
})
</script>

