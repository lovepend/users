/**
 * Ag-Grid가 만든 엑셀 바이너리를 가로채서 백엔드로 전송 후 처리된 파일을 다운받는 함수
 */
const handleAgGridExcelIntercept = async () => {
  if (!gridApi.value) {
    console.error('[Excel Intercept] gridApi가 초기화되지 않았습니다.');
    return;
  }

  try {
    console.log('[Excel Intercept] 1단계: Ag-Grid 내부 엑셀 데이터 추출 추출 시작');
    
    // 💡 Tip: 버전에 따라 파일이 즉시 반환되지 않는 경우를 대비해 인자값으로 빈 객체({})를 명시합니다.
    const agExcelBlob = gridApi.value.getDataAsExcel({});
    
    console.log('[Excel Intercept] 추출된 Blob 객체:', agExcelBlob);

    if (!agExcelBlob) {
      throw new Error('Ag-Grid가 엑셀 바이너리(Blob)를 생성하지 못했습니다. 데이터나 패키지 설정을 확인하세요.');
    }

    console.log('[Excel Intercept] 2단계: Multipart FormData 구성 시작');
    const formData = new FormData();
    
    // 💡 백엔드 컨트럴러의 수신 변수명 확인 필요 (현재 'file'로 세팅)
    formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`);

    console.log('[Excel Intercept] 3단계: 백엔드 API 요청 전송 (/api/File/File)');
    
    // 전역 인터셉터가 걸린 Axios 인스턴스로 요청 전송
    const response = await api.post('/api/File/File', formData, {
      headers: {
        'Content-Type': 'multipart/form-data'
      },
      responseType: 'blob' // 💡 바이너리 파일 스트림을 깨뜨리지 않고 받기 위해 필수
    });

    console.log('[Excel Intercept] 4단계: 서버 응답 수신 완료 및 다운로드 처리 시작', response);

    // 5. 서버로부터 리턴받은 바이너리 데이터를 브라우저 파일로 변환
    const returnBlob = new Blob([response.data], { 
      type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' 
    });
    
    const downloadUrl = window.URL.createObjectURL(returnBlob);
    const linkElement = document.createElement('a');
    
    linkElement.href = downloadUrl
    linkElement.download = `Excel_Report_${Date.now()}.xlsx`;
    
    document.body.appendChild(linkElement);
    linkElement.click();
    
    // 메모리 및 엘리먼트 환원
    document.body.removeChild(linkElement);
    window.URL.revokeObjectURL(downloadUrl);
    
    console.log('[Excel Intercept] 5단계: 최종 파일 다운로드 트리거 완료');

  } catch (error) {
    // 🚨 예외 발생 시 상세 원인 파악을 위한 디버깅 로그 구조화
    console.error('====================================================');
    console.error('🚨 [Excel Intercept Error] Ag-Grid 가로채기 후 전송 실패');
    console.error('에러 원인 메시지:', error.message);
    console.error('에러 오브젝트 전체:', error);

    // 만약 HTTP 통신 에러(AxiosError)인 경우 서버 응답 상세 내용 출력
    if (error.response) {
      console.error('❌ 서버 응답 에러 상태코드 (HTTP Status):', error.response.status);
      console.error('❌ 서버 응답 에러 데이터 (Response Data):', error.response.data);
    }
    console.error('====================================================');
    
    alert('엑셀 다운로드 중 에러가 발생했습니다. 개발자 도구(F12) 콘솔 로그를 확인해 주세요.');
  }
}
