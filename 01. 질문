<template>
  <div class="panel mb-0" style="width: 100%">
    <div class="panel-heading border-bottom h-50px" style="background-color: var(--bg07)">
      <span class="fs-2 fw-bold" style="color: var(--basic02)">{{ $t('ReleasedNote_vue.title') }}</span>
    </div>

    <div v-if="isDeveloper" class="h-35px p-0 m-0" style="background-color: var(--bg11); padding: 8px 8px 6px">
      <button
        class="btn btn-xs btn-green float-start align-items-center shadow-none ms-2 me-2 mt-1"
        @click="updateVersion"
      >
        {{ $t('ReleasedNote_vue.vUpdate') }}
      </button>
      <button class="btn btn-xs btn-red float-start align-items-center shadow-none me-2 mt-1" @click="saveVersion">
        {{ $t('ReleasedNote_vue.vSave') }}
      </button>
      <button class="btn btn-xs btn-blue float-end align-items-center shadow-none me-2 mt-1" @click="exportExcel">
        {{ $t('ReleasedNote_vue.export') }}
      </button>
      <input
        id="selectedFile"
        ref="fileInput"
        class="d-none"
        type="file"
        accept=".xlsx, .xls"
        @change="handleFileUpload"
      />
      <button class="btn btn-xs btn-orange float-end align-items-center shadow-none me-2 mt-1" @click="importExcel">
        {{ $t('ReleasedNote_vue.import') }}
      </button>
    </div>

    <div class="panel-body py-2 overflow-auto" style="height: calc(100vh - 150px); background-color: var(--bg14)">
      <Splitter class="h-100" layout="vertical">
        <SplitterPanel id="editorVersion" class="d-none" :size="200">
          <div class="h-100 w-100">
            <!-- id="gc-spread"
            hostClass="spreadHost" -->
            <gc-spread-designer
              class="h-100 w-100 text-black"
              :config="designConfig"
              @designer-initialized="initWorkbook"
            />
          </div>
        </SplitterPanel>
        <SplitterPanel class="flex overflow-scroll">
          <div class="pt-2 ps-3">
            <template v-if="releaseNotesGrouped && releaseNotesGrouped.length > 0">
              <div v-for="(versionGroup, groupIndex) in releaseNotesGrouped" :key="groupIndex">
                <span class="fs-3" style="color: var(--txt04)"
                  >{{ $t('ReleasedNote_vue.version') }} {{ versionGroup.version }}</span
                >
                <span class="fs-5 ps-2" style="color: var(--txt02)">({{ $t('ReleasedNote_vue.update') }})</span>

                <ul class="pt-2">
                  <li v-for="(item, itemIndex) in versionGroup.items" :key="itemIndex">
                    <div class="fs-13px">
                      <div class="h-auto mb-1 pt-1 text-white" :class="getBadgeClass(item.category)">
                        {{ item.category }}
                      </div>

                      <div
                        class="border rounded-3 mb-1 description-text me-2"
                        :class="getBadgeTextColorClass(item.category)"
                        style="background-color: var(--basic02)"
                      >
                        <div class="p-1 pb-0">[{{ item.AutoNo }}] : [{{ item.status }}]</div>
                        <div class="p-2 pb-1 fw-normal" style="color: var(--txt03)">{{ item.description }}</div>
                      </div>

                      <div class="border rounded-3 text-cyan-700 mb-1 me-2" style="background-color: var(--basic02)">
                        <div class="p-1 pb-0">{{ $t('ReleasedNote_vue.act_desc') }}</div>
                        <div class="p-2 pb-1 fw-normal" style="color: var(--txt03)">: {{ item.actionDesc }}</div>
                      </div>

                      <div class="border rounded-3 text-green-600 mb-1 me-2" style="background-color: var(--basic02)">
                        <div class="p-1 pb-0">{{ $t('ReleasedNote_vue.dev_desc') }}</div>
                        <div class="p-2 pb-1 fw-normal" style="color: var(--txt03)">: {{ item.remarkDev }}</div>
                      </div>
                    </div>
                  </li>
                </ul>
                <hr v-if="isNotLastItem(groupIndex)" />
              </div>
            </template>

            <template v-else>
              <p v-if="isLoading">{{ $t('ReleasedNote_vue.load_desc') }}</p>
              <p v-else>{{ $t('ReleasedNote_vue.empt_desc') }}</p>
            </template>
          </div>
        </SplitterPanel>
      </Splitter>
    </div>
  </div>
</template>

<script setup lang="ts">
  import { ref, onMounted, computed, toRaw } from 'vue'
  import { useAppAuthenticationStore } from '@/stores/app-authentication'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import * as XLSX from 'xlsx'
  import { ApiCommon } from '@/utils/axios/api-common'
  import Splitter from 'primevue/splitter' /** 영역 분할 기능 */
  import SplitterPanel from 'primevue/splitterpanel' /** 영역 분할 기능 */
  // @ts-ignore
  import * as SEF from '@/utils/spread/spread-excel-funtions.js'
  /** Spread List */
  import GC from '@mescius/spread-sheets-designer'
  import * as _ from 'lodash-es'
  /** Helper List */
  import * as SIC from '@/utils/spread/spread-io-common'
  import { sAlert } from '@/utils/messages/alert-common'

  /** 변수 정의 */
  const releaseNotesGrouped = ref<any[]>([])
  const isLoading = ref(true)
  const authStore = useAppAuthenticationStore()
  const fileInput = ref<HTMLInputElement | null>(null)
  const fileId = ref<string | null>(null)
  const updateOnOff = ref(false)
  const spreadRef: any = ref() // Spread Template Designer
  const filename = 'temp.xlsx'
  const urlList = { gfi: '/api/File/Get', gfr: '/api/File/Replace' }
  const sitefileIds = {
    dev: '69aa1e6f9535f36ce196e4fd', //운영 DB가 개발로 복사되면 무조건 변경해줘야함
    devop: '698963e8ed2aff6e2771b20d',
    oper: '6982ac8ea605319e04771832',
  }

  // 템플릿 에러 방지를 위해 computed로 권한 체크 로직 분리
  const isDeveloper = computed(() => {
    return authStore.userInfo && (authStore.userInfo as any).IsDeveloper
  })

  onMounted(() => {
    const baseSiteName = (import.meta as any).env.VITE_BASE_SITENAME

    // 사이트 별 File Id 체크
    if (baseSiteName === 'dev') fileId.value = sitefileIds.dev
    else if (baseSiteName === 'devop') fileId.value = sitefileIds.devop
    else fileId.value = sitefileIds.oper
    fetchAndParseExcel()
  })

  /**
   * 마지막 아이템 체크
   * @param index
   */
  const isNotLastItem = (index: number): boolean => {
    return index < releaseNotesGrouped.value.length - 1
  }

  /**
   * 운영 환경용 날짜 계산 로직
   * @param version
   */
  const getUpdatedVersionForProd = (version: string): string => {
    const parts = version.split('.')
    if (parts.length < 2) return version

    const lastPart = parts[parts.length - 1]
    const monthPart = parts[parts.length - 2]

    const dayNum = parseInt(lastPart)
    const monthNum = parseInt(monthPart)

    if (isNaN(dayNum) || isNaN(monthNum)) return version

    const currentYear = new Date().getFullYear()
    const date = new Date(currentYear, monthNum - 1, dayNum)
    date.setDate(date.getDate()) //date.setDate(date.getDate() + 1) [26.03.36: 안홍서 프로님 요청]

    const newMonth = String(date.getMonth() + 1).padStart(2, '0')
    const newDay = String(date.getDate()).padStart(2, '0')

    const prefix = parts.slice(0, parts.length - 2).join('.')
    return prefix ? `${prefix}.${newMonth}.${newDay}` : `${newMonth}.${newDay}`
  }

  /** 시트 파싱 */
  const parseSheetWithHeaders = (sheet: any, skipRows: number): any[] => {
    if (!sheet) return []
    const rows: any[] = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '' })
    if (rows.length <= skipRows) return []

    const headers = rows[skipRows].map((h: any) => String(h || '').replace(/\s/g, ''))
    const dataRows = rows.slice(skipRows + 1)
    const getIdx = (name: string) => headers.indexOf(name.replace(/\s/g, ''))

    const idx = {
      autoNo: getIdx('AutoNo'),
      category: getIdx('구분'),
      desc: getIdx('기능요청상세내용'),
      action: getIdx('ACTION부서회신내용'),
      remark: getIdx('Remark(개발)'),
      status: getIdx('STATUS'),
      version: getIdx('완료버젼'),
    }

    return dataRows
      .map(row => ({
        AutoNo: idx.autoNo !== -1 ? row[idx.autoNo] : '',
        category: idx.category !== -1 ? row[idx.category] : '',
        description: idx.desc !== -1 ? row[idx.desc] : '',
        actionDesc: idx.action !== -1 ? row[idx.action] : '',
        remarkDev: idx.remark !== -1 ? row[idx.remark] : '',
        status: idx.status !== -1 ? row[idx.status] : '',
        completionVersion: idx.version !== -1 ? row[idx.version] : '',
      }))
      .filter(item => item.status || item.completionVersion)
  }

  /** [수정됨] 메인 페치 함수: 로컬 우선 -> 서버 차선 -> 로컬 시 복호화 생략 */
  const fetchAndParseExcel = async () => {
    try {
      isLoading.value = true
      const baseSiteName = (import.meta as any).env.VITE_BASE_SITENAME
      const isProd = !(baseSiteName === 'dev' || baseSiteName === 'devop')
      let allowedStatus = ['FINISH', 'CHECKED']
      if (!isProd) allowedStatus.push('READY')

      let fileBlob: Blob | null = null
      let isLocalFile = false

      // 1. 로컬 파일 시도 (public/temp.xlsx)
      try {
        const localRes = await fetch(`/${filename}`, { cache: 'no-store' })
        if (localRes.ok) {
          fileBlob = await localRes.blob()
          isLocalFile = true
          console.log('로컬 파일을 성공적으로 읽어왔습니다.')
        } else {
          throw new Error('Local file not found')
        }
      } catch (e) {
        // 2. 로컬 실패 시 서버 API 시도
        console.warn('로컬 파일이 없거나 읽기 실패하여 서버 API를 호출합니다.')
        try {
          const response: any = await axiosWrapper.postAll(
            urlList.gfi,
            { id: fileId.value },
            { responseType: 'blob', headers: { FileToken: 'frontserver@sh' } }
          )
          fileBlob = response.data
          isLocalFile = false
        } catch (serverErr) {
          console.error('서버 파일 호출 실패:', serverErr)
        }
      }

      if (!fileBlob) {
        isLoading.value = false
        return
      }

      // 3. 복호화 선택적 적용
      let arrayBuffer: ArrayBuffer
      if (isLocalFile) {
        // 로컬 파일은 바로 변환
        arrayBuffer = await fileBlob.arrayBuffer()
      } else {
        // 서버 파일은 복호화 후 변환
        const decrypted: any = await ApiCommon.postFileDecryptFile({
          FILE: new File([fileBlob], filename),
        })
        arrayBuffer = await decrypted.arrayBuffer()
      }

      const workbook = XLSX.read(arrayBuffer, { type: 'array' })
      let combined: any[] = []

      workbook.SheetNames.forEach((name, index) => {
        // 로컬 파일의 양식이 서버와 다를 경우(예: 헤더가 1행부터라면) 이 부분을 조정해야 함
        const skip = index === 0 ? 2 : 0
        combined = [...combined, ...parseSheetWithHeaders(workbook.Sheets[name], skip)]
      })

      const grouped: Record<string, any> = {}
      combined.forEach((row: any) => {
        const status = String(row.status || '')
          .trim()
          .toUpperCase()
        let version = String(row.completionVersion || '').trim()

        if (allowedStatus.includes(status) && version) {
          if (isProd) version = getUpdatedVersionForProd(version)
          if (!grouped[version]) grouped[version] = { version: version, items: [] }
          grouped[version].items.push({
            ...row,
            category: String(row.category || '').toLowerCase(),
            status: status,
          })
        }
      })

      releaseNotesGrouped.value = Object.values(grouped).sort((a: any, b: any) =>
        b.version.localeCompare(a.version, undefined, { numeric: true })
      )
    } catch (error) {
      console.error('fetchAndParseExcel Error:', error)
    } finally {
      isLoading.value = false
      if (SEF && (SEF as any).onHideOverlay) (SEF as any).onHideOverlay()
    }
  }

  /** 배지 클래스 */
  const getBadgeClass = (category: any) => {
    const c = String(category).toLowerCase()
    if (['오류', 'fixed'].includes(c)) return 'badge bg-gradient-orange-red'
    if (['기능개선', 'changed'].includes(c)) return 'badge bg-gradient-yellow-orange'
    if (['신규기능', 'added'].includes(c)) return 'badge bg-gradient-teal-green'
    return 'badge'
  }

  const getBadgeTextColorClass = (category: any) => {
    const c = String(category).toLowerCase()
    if (['오류', 'fixed'].includes(c)) return 'text-danger'
    if (['기능개선', 'changed'].includes(c)) return 'text-warning'
    if (['신규기능', 'added'].includes(c)) return 'text-success'
    return 'text-gray'
  }

  /**
   * 업로드할 파일 선택 창 나타내기
   */
  const importExcel = () => fileInput.value?.click()

  /**
   * Content를 읽어, Spread에 load하는 기능
   */
  const loadSpreadJS = async function () {
    try {
      let spread = toRaw(spreadRef.value)
      spread.suspendPaint()

      const response: any = await ApiCommon.postFileGet({ id: fileId.value as string }, { blockToast: true })
      const decryptedBlob: any = await ApiCommon.postFileDecryptFile({ FILE: new File([response], response.filename) })
      const extensions = 'XLSX'
      const importFile = new File([decryptedBlob], response.filename, { type: extensions })
      const importOptions = SIC.getOpenOptions(extensions) ?? {}

      await new Promise((resolve, reject) => {
        spread.import(importFile, resolve, reject, importOptions)
      })
      spread.resumePaint()
    } catch (err) {
      SEF.logMng("'loadSpread' 함수 오류: ", err, 'err')
    }
  }

  /**
   * 등록되어 있는 엑셀 파일에 정보를 등록하기 위해 화면 표현
   * @param event
   */
  const updateVersion = async function (event: any) {
    try {
      let splitSpr: any = document.getElementById('editorVersion')

      if (!updateOnOff.value) {
        updateOnOff.value = true
        Object.assign(splitSpr, { className: 'd-flex align-items-center justify-content-center' })
      } else {
        updateOnOff.value = false
        Object.assign(splitSpr, { className: 'd-none' })
      }

      loadSpreadJS()
    } catch (err) {
      SEF.setToast(`'updateVersion' 함수 오류: ${err}`)
    }
  }

  const saveVersion = function (event: any) {
    try {
      let splitSpr: any = document.getElementById('editorVersion')

      if (updateOnOff.value) {
        let uploadFile: any = { target: { files: [] } }

        let spread = toRaw(spreadRef.value)
        spread.export((blob: any) => {
          const file: any = new File([blob], filename)

          uploadFile.target.files.push(file)

          handleFileUpload(uploadFile)
        })
        // 닫기
        updateOnOff.value = false
        Object.assign(splitSpr, { className: 'd-none' })
      } else {
        sAlert.Warning('수정 버튼을 눌러주세요.')
      }
    } catch (err) {
      SEF.setToast(`'updateVersion' 함수 오류: ${err}`)
    }
  }

  /**
   * 엑셀 업로드 처리
   * @param event
   */
  const handleFileUpload = async (event: any) => {
    const file = event.target.files[0]
    console.log('do??', file, event.target.files)
    if (!file) return
    try {
      await axiosWrapper.post(
        urlList.gfr,
        { id: fileId.value, File: file },
        { headers: { 'Content-Type': 'multipart/form-data', FileToken: 'frontserver@sh' } }
      )

      fetchAndParseExcel()
    } catch (err) {
      console.error('Upload Error:', err)
    }
  }

  /**
   * 파일 내려받기
   */
  const exportExcel = async () => {
    const response: any = await axiosWrapper.postAll(
      urlList.gfi,
      { id: fileId.value },
      { responseType: 'blob', headers: { FileToken: 'frontserver@sh' } }
    )
    const decryptedBlob: any = await ApiCommon.postFileDecryptFile({ FILE: new File([response.data], filename) })
    const workbook = XLSX.read(await decryptedBlob.arrayBuffer(), { type: 'array' })

    // 엑셀 파일로 다운로드 (파일명 지정)
    XLSX.writeFile(workbook, filename)
  }

  const defConfMenu = {
    home: { id: 'home', text: '홈' },
    insert: { id: 'insert', text: '삽입' },
    pageLayout: { id: 'pageLayout', text: '페이지 레이아웃' },
    formulas: { id: 'formulas', text: '수식' },
    data: { id: 'data', text: '데이터' },
    view: { id: 'view', text: '보기' },
    settings: { id: 'settings', text: '설정' },
    tableDesign: { id: 'tableDesign', text: '테이블 디자인' },
    pictDesign: { id: 'pictureDesign', text: '그림 서식' },
    shapeDesign: { id: 'shapeDesign', text: '도형 서식' },
    pictShapDesign: { id: 'pictureShapeDesign', text: '그림 서식' },
    slicerDesign: { id: 'slicerDesign', text: '슬라이서' },
    timelineDesign: { id: 'timelineDesign', text: '타임라인' },
    chartDesign: { id: 'chartDesign', text: '차트 디자인' },
    formSpaLDesign: { id: 'formulaSparkLineDesign', text: '스파크라인' },
    sparkLineDesign: { id: 'sparkLineDesign', text: '스파크라인' },
    barcodeDesignId: { id: 'barcodeDesignId', text: '바코드 디자인' },
    pivTableAnalyze: { id: 'pivotTableAnalyze', text: '피벗 테이블 분석' },
    pivTableDesign: { id: 'pivotTableDesign', text: '디자인' },
  }

  const initConfig = () => {
    const gcSprDesigner = (GC.Spread.Sheets as any).Designer
    const commandNames = gcSprDesigner.CommandNames
    const templateNames = gcSprDesigner.TemplateNames
    const config = _.cloneDeep(gcSprDesigner.DefaultConfig)
    const ribbon = config.ribbon
    const insertTab = ribbon.find(({ id }: any) => id === defConfMenu.insert.id)
    const dataTab = ribbon.find(({ id }: any) => id === defConfMenu.data.id)
    const viewTab = ribbon.find(({ id }: any) => id === defConfMenu.view.id)
    const setTab = ribbon.find(({ id }: any) => id === defConfMenu.settings.id)
    const sidePanels = config.sidePanels
    const fileMenuPanel = sidePanels.find(({ command }: any) => command === commandNames.FileMenuPanel)

    //////////////////////////////////////////////
    // Ribbon - 삽입 - 버튼 삭제 ( 시트 )
    insertTab.buttonGroups = insertTab.buttonGroups.filter(
      ({ thumbnailClass }: any) => thumbnailClass !== 'ribbon-thumbnail-sheets'
    )

    //////////////////////////////////////////////
    // Ribbon - 데이터 - 버튼 삭제 ( 데이터 바인딩, 쿼리 및 연결, 정렬 및 필터 )
    dataTab.buttonGroups = dataTab.buttonGroups.filter(
      ({ thumbnailClass }: any) =>
        thumbnailClass !== 'ribbon-thumbnail-data-sources' &&
        thumbnailClass !== 'ribbon-thumbnail-queriedAndConnections' &&
        thumbnailClass !== 'ribbon-thumbnail-sortAndFilter'
    )

    //////////////////////////////////////////////
    // Ribbon - 보기 - 버튼 삭제 ( 명령 팔레트 )
    viewTab.buttonGroups = viewTab.buttonGroups.filter(({ thumbnailClass }: any) => thumbnailClass)

    //////////////////////////////////////////////
    // Ribbon - 설정 - 버튼 삭제 ( Spread 설정 )
    // setTab.buttonGroups = setTab.buttonGroups.filter(({thumbnailClass}: any)=>
    //   thumbnailClass !== "ribbon-thumbnail-spreadsettings"
    // );

    ////////////////////////////////
    // Ribbon - 파일 - 템플릿 변경
    const fileMenuTemplate = gcSprDesigner.getTemplate(templateNames.FileMenuPanelTemplate)
    const fileMenuChilds = fileMenuTemplate['content'][0]['children'][0]['children']
    const fileMenuList = fileMenuChilds[0]['children'][0]['children'] //파일 템플릿 내 좌측 메뉴 목록
    const fileMenuRightPanel = fileMenuChilds[1] //파일 템플릿 내 우측 패널
    for (let i = fileMenuList.length; i--; ) {
      const fileMenu = fileMenuList[i]
      const menuItems = fileMenu.items
      if (!menuItems) {
        continue
      }
      for (let j = menuItems.length; j--; ) {
        const menuItem = menuItems[j]
        const menuName = menuItem.value
        if (
          menuName === 'New' || // 새로 만들기
          menuName === 'OpenSJS' || // 열기
          menuName === 'SaveSJS' || // 저장
          menuName === 'Import' || // 가져오기
          menuName === 'Info' // 정보
        ) {
          menuItems.splice(j, 1)
        }
      }
      if (menuItems.length === 0) {
        const prevIndex = i - 1
        const prevFileMenu = fileMenuList[prevIndex]
        const prevMenuType = prevFileMenu?.type
        if (prevMenuType === 'LabelLine') {
          fileMenuList.splice(prevIndex, 1)
          i -= 1
        }
      }
    }
    const newFileMenuPanelName = `NEW_${templateNames.FileMenuPanelTemplate}`
    gcSprDesigner.registerTemplate(newFileMenuPanelName, fileMenuTemplate)
    if (fileMenuPanel) {
      fileMenuPanel.uiTemplate = newFileMenuPanelName
    }

    //////////////////////////////////////////
    // Ribbon - 파일 - 초기 상태 변경 ( 새로 만들기 -> 내보내기 )
    const fileMenuPanelCommand = gcSprDesigner.getCommand(commandNames.FileMenuPanel)
    const orgGetStateCommand = fileMenuPanelCommand.getState
    fileMenuPanelCommand.getState = function (...args: any) {
      const options = orgGetStateCommand(...args)
      if (options['activeCategory_main'] === 'New') {
        options['activeCategory_main'] = 'Export'
      }
      return options
    }

    return config
  }

  const designConfig = ref(initConfig())

  /**
   * SpreadJS 초기 Loading 및 Setting
   * @param spread : SpreadJS
   */
  const initWorkbook = function (designer: any) {
    try {
      spreadRef.value = designer.getWorkbook()

      // 첫화면 상위 메뉴 최소화
      designer.setData('isRibbonCollapse', true)

      // spreadWorkbookInstance = spreadRef.value.getWorkbook();

      if (spreadRef.value) {
        spreadRef.value.refresh()
      } // 초기 로드 시 SpreadJS 크기 조절
    } catch (err) {
      SEF.logMng("SPREADJS-'initWorkbook'함수 오류: ", err, 'err')
    }
  }
