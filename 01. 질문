/**
 * Ag-Grid 엑셀 가로채기 및 백엔드 전송 (Vue 3 전용 완벽 방어형 코드)
 */
const handleAgGridExcelIntercept = async () => {
  // 1. Grid API 인스턴스 체크
  if (!gridApi.value) {
    console.error('❌ [Vue3 Excel] gridApi가 반응형 변수에 담기지 않았습니다. @grid-ready가 실행되었는지 확인하세요.');
    alert('그리드가 아직 준비되지 않았습니다.');
    return;
  }

  try {
    console.log('🔄 [Vue3 Excel] 1단계: Ag-Grid 내장 엑셀 함수 존재 여부 체크');
    console.log('- getDataAsExcel 존재 여부:', typeof gridApi.value.getDataAsExcel);
    console.log('- getExcelExportParams 존재 여부:', typeof gridApi.value.getExcelExportParams);

    let agExcelBlob = null;

    // 💡 Ag-Grid 최신 버전(v31+) 대응
    if (typeof gridApi.value.getDataAsExcel === 'function') {
      console.log('👉 [Vue3 Excel] v31+ 스타일인 getDataAsExcel()을 실행합니다.');
      agExcelBlob = gridApi.value.getDataAsExcel({});
    } 
    // 💡 Ag-Grid 구버전 대응
    else if (typeof gridApi.value.exportDataAsExcel === 'function') {
      console.warn('👉 [Vue3 Excel] 이 버전은 다이렉트 Blob 추출 함수가 없습니다. 차선책인 CSV 가공을 시작합니다.');
      if (typeof gridApi.value.getDataAsCsv === 'function') {
        const csvContent = gridApi.value.getDataAsCsv({});
        if (csvContent) {
          // 한글 깨짐 방지용 BOM(0xEF, 0xBB, 0xBF) 추가하여 Blob 생성
          agExcelBlob = new Blob([new Uint8Array([0xEF, 0xBB, 0xBF]), csvContent], { type: 'text/csv;charset=utf-8;' });
        }
      }
    }

    // 2. 가로챈 결과값 검증
    if (!agExcelBlob) {
      console.error('❌ [Vue3 Excel] Ag-Grid 엔터프라이즈 기능(ExcelExportModule)이 등록되지 않았거나 데이터 추출에 실패했습니다.');
      alert('엑셀 추출 모듈이 활성화되어 있지 않습니다. 엔터프라이즈 라이선스 및 모듈 임포트를 확인해 주세요.');
      return;
    }

    console.log('✅ [Vue3 Excel] 2단계: 파일화 성공. 크기:', agExcelBlob.size, 'bytes');

    // 3. FormData 변환
    const formData = new FormData();
    // 💡 백엔드가 수신하는 Key 명칭이 'file'이 맞는지 대소문자 확인 필요!
    formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`);

    console.log('🚀 [Vue3 Excel] 3단계: 네트워크 통신 시작 -> URL: /api/File/File');

    // 💡 네트워크 탭에 아예 안 떴던 문제를 유발한 주원인 통제: 
    // 기존 프로젝트 커스텀 api가 꼬였을 수 있으니 기본 axios로 베이스 URL을 직접 쳐서 테스트해 봅니다.
    const response = await axios.post('/api/File/File', formData, {
      headers: {
        'Content-Type': 'multipart/form-data'
      },
      responseType: 'blob' // 서버 응답 바이너리를 깨뜨리지 않기 위해 필수
    });

    console.log('🎉 [Vue3 Excel] 4단계: 백엔드 응답 성공! 다운로드 처리 진행', response);

    // 4. 리턴받은 파일 브라우저 다운로드 처리
    const returnBlob = new Blob([response.data], { 
      type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' 
    });
    
    const downloadUrl = window.URL.createObjectURL(returnBlob);
    const linkElement = document.createElement('a');
    
    linkElement.href = downloadUrl;
    linkElement.download = `Excel_DRM_Report_${Date.now()}.xlsx`;
    
    document.body.appendChild(linkElement);
    linkElement.click();
    
    // 트리거 후 가비지 컬렉션 처리
    document.body.removeChild(linkElement);
    window.URL.revokeObjectURL(downloadUrl);
    console.log('🏁 [Vue3 Excel] 5단계: 최종 파일 교체 및 다운로드 완료');

  } catch (error) {
    console.error('====================================================');
    console.error('🚨 [Vue3 Excel Catch] 예외 발생 구역 진입');
    console.error('에러 코드/메시지:', error.message);
    console.error('에러 객체 상세:', error);
    
    if (error.response) {
      console.error('❌ 백엔드 서버 에러 코드:', error.response.status);
      console.error('❌ 백엔드 서버 에러 데이터:', error.response.data);
    }
    console.error('====================================================');
    alert('엑셀 가로채기 도중 오류가 발생했습니다. 콘솔 창을 열어 [Vue3 Excel] 로그를 순서대로 파악해 보세요.');
  }
}
