<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="dropdown custom-single-select" style="min-width: 220px">
            <InputBox
              id="input-proj"
              label="프로젝트"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택/입력"
              data-bs-toggle="dropdown"
              @input="projSearchQuery = selectedProjNo"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-0 w-100" style="max-height: 300px; overflow-y: auto; z-index: 1060">
              <li v-for="proj in filteredProjectOptions" :key="proj.value">
                <a
                  class="dropdown-item py-2 px-3 cursor-pointer"
                  :class="{ 'active-proj': selectedProjNo === proj.value }"
                  @click="selectProject(proj.value)"
                >
                  {{ proj.text }}
                </a>
              </li>
            </ul>
          </div>

          <InputBox
            id="input-keyword"
            label="키워드"
            v-model:value="searchKeyword"
            placeholder="Tag No 입력"
            style="width: 220px"
          />
          <div class="header-divider"></div>
          <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--primary" @click="confirmSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>
          <div class="header-divider"></div>
          <InputBox
            id="input-filter"
            label="결과 검색"
            v-model:value="localFilterQuery"
            icon="fa-filter"
            placeholder="결과 내 찾기"
            style="width: 220px"
            @input="onFilterInput"
          />
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue
          class="ag-theme-custom w-100 h-100"
          v-bind="gridOptions"
          :getContextMenuItems="getContextMenuItems"
          @grid-ready="onGridReady"
          @cell-clicked="onCellClicked"
        />
      </div>
    </DefaultCard>

    <div v-if="showClassModal" class="custom-modal-overlay" @click.self="closeClassModal">
      <div class="custom-modal-window shadow-lg draggable-modal" :style="modalPos.class">
        <div class="modal-header-dark cursor-move" @mousedown="startDrag($event, 'class')">
          <div class="d-flex align-items-center gap-2">
            <i class="fa fa-info-circle text-info"></i>
            <span class="fw-bold text-white">Class Info: {{ clickedClassId }} (이동 가능)</span>
          </div>
          <button @click="closeClassModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-3 h-100 d-flex flex-column">
          <div class="ag-theme-custom flex-grow-1">
            <ag-grid-vue
              style="width: 100%; height: 100%"
              :columnDefs="classModalColDefs"
              :rowData="classModalData"
              :defaultColDef="{ resizable: true, sortable: true, filter: true }"
              @cell-clicked="onClassGridCellClicked"
            />
          </div>
        </div>
      </div>
    </div>

    <div v-if="showDetailModal" class="custom-modal-overlay" @click.self="closeDetailModal">
      <div class="custom-modal-window shadow-lg draggable-modal" :style="modalPos.detail">
        <div class="modal-header-dark cursor-move" @mousedown="startDrag($event, 'detail')">
          <span class="fw-bold text-white">Detail View: {{ selectedRow?.TAG_NO }} (이동 가능)</span>
          <button @click="closeDetailModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content p-2 h-100">
          <div class="ag-theme-custom h-100">
            <ag-grid-vue
              style="width: 100%; height: 100%"
              :columnDefs="detailModalColDefs"
              :rowData="detailModalRowData"
              :defaultColDef="{ resizable: true }"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, computed, shallowRef, onMounted, reactive } from 'vue'
  import { useRoute, useRouter } from 'vue-router'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import { sAlert } from '@/utils/messages/alert-common'
  import { sortBy } from 'lodash-es'
  import DefaultCard from '@/components/default/DefaultCard.vue'
  import InputBox from '@/components/default/editors/InputBox.vue'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

  const route = useRoute()
  const router = useRouter()
  const cardTitle = { icon: 'fa-list', title: 'Tag 통합 분석', subtitle: '속성 필터링 분석' }

  // --- 모달 드래그 및 위치 상태 ---
  const modalPos = reactive({
    class: {
      top: '200px',
      left: '50%',
      transform: 'translateX(-50%)',
      width: '850px',
      height: '60%',
      position: 'absolute',
    },
    detail: {
      top: '200px',
      left: '50%',
      transform: 'translateX(-50%)',
      width: '900px',
      height: '80%',
      position: 'absolute',
    },
  })

  // --- 상태 관리 ---
  const gridApi = shallowRef()
  const projectOptions = ref([])
  const selectedProjNo = ref('')
  const projSearchQuery = ref('')
  const searchKeyword = ref('')
  const localFilterQuery = ref('')
  const rawDataList = ref([])
  const dynamicAttCols = ref([])
  const showDetailModal = ref(false)
  const showClassModal = ref(false)
  const selectedRow = ref(null)
  const classModalData = ref([])
  const clickedClassId = ref('')

  // --- [추가] 드래그 로직 ---
  const startDrag = (event, type) => {
    const modal = event.currentTarget.parentElement
    let shiftX = event.clientX - modal.getBoundingClientRect().left
    let shiftY = event.clientY - modal.getBoundingClientRect().top

    const moveAt = (pageX, pageY) => {
      modalPos[type].left = pageX - shiftX + 'px'
      modalPos[type].top = pageY - shiftY + 'px'
      modalPos[type].transform = 'none' // 드래그 시작 시 중앙정렬 해제
    }

    const onMouseMove = e => moveAt(e.pageX, e.pageY)
    document.addEventListener('mousemove', onMouseMove)
    document.onmouseup = () => {
      document.removeEventListener('mousemove', onMouseMove)
      document.onmouseup = null
    }
  }

  // --- 기존 로직 (100% 복구) ---
  const fetchProjectList = async () => {
    try {
      const res = await axiosWrapper.get('/api/Project/Get')
      projectOptions.value = (res || []).map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
    } catch (e) {
      console.error(e)
    }
  }

  const filteredProjectOptions = computed(() => {
    const query = projSearchQuery.value.toLowerCase()
    return projectOptions.value.filter(p => p.text.toLowerCase().includes(query))
  })

  const selectProject = val => {
    selectedProjNo.value = val
    projSearchQuery.value = val
  }

  const confirmSearch = () => {
    if (!selectedProjNo.value) return sAlert.Warning('프로젝트를 선택하세요.')
    fetchData()
  }

  const fetchData = async () => {
    if (gridApi.value) gridApi.value.setGridOption('loading', true)
    try {
      const payload = { ProjectNo: selectedProjNo.value, Keyword: searchKeyword.value }
      const [pRes, wRes] = await Promise.allSettled([
        axiosWrapper.post('/api/Data/SearchPublishData', payload),
        axiosWrapper.post('/api/Data/SearchWorkingData', payload),
      ])

      let combined = []
      if (pRes.status === 'fulfilled' && pRes.value) {
        combined.push(
          ...(Array.isArray(pRes.value) ? pRes.value : [pRes.value]).map(i => ({ ...i, Source: 'Published' }))
        )
      }
      if (wRes.status === 'fulfilled' && wRes.value) {
        combined.push(
          ...(Array.isArray(wRes.value) ? wRes.value : [wRes.value]).map(i => ({ ...i, Source: 'Working' }))
        )
      }

      const allAttIds = new Set()
      combined.forEach(item => {
        ;(item.ATTRIBUTES || []).forEach(a => {
          if (a?.ATT_ID) allAttIds.add(a.ATT_ID)
        })
      })

      const processedData = combined.map(item => {
        const flatItem = { ...item }
        allAttIds.forEach(id => {
          const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
          flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
        })
        return flatItem
      })

      dynamicAttCols.value = Array.from(allAttIds)
        .sort()
        .map(id => ({
          headerName: id,
          field: `ATT_${id}`,
          minWidth: 140,
          headerClass: 'att-column-header',
          cellRenderer: highlightRenderer,
        }))

      rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
    } catch (err) {
      sAlert.Error('조회 실패')
    } finally {
      if (gridApi.value) gridApi.value.setGridOption('loading', false)
    }
  }

  const highlightRenderer = params => {
    const val = params.value === null || params.value === undefined ? '' : String(params.value)
    const searchTerm = localFilterQuery.value.trim()
    if (!searchTerm || val === 'null' || val === '') return val
    const re = new RegExp(`(${searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi')
    return val.replace(re, `<mark class="filter-highlight">$1</mark>`)
  }

  const onFilterInput = () => {
    if (gridApi.value) gridApi.value.refreshCells({ force: true })
  }

  const onCellClicked = async p => {
    const colId = p.column.getColId()
    if (colId === 'Source') {
      selectedRow.value = p.data
      showDetailModal.value = true
    } else if (colId === 'CLS_ID' && p.value) {
      clickedClassId.value = p.value
      try {
        if (gridApi.value) gridApi.value.setGridOption('loading', true)
        const res = await axiosWrapper.post('/api/Register/GetByClassIDs', {
          ProjectNo: selectedProjNo.value,
          ClassIDs: [p.value],
        })
        classModalData.value = Array.isArray(res) ? res : [res]
        showClassModal.value = true
      } catch (e) {
        sAlert.Error('Class 정보 로드 실패')
      } finally {
        if (gridApi.value) gridApi.value.setGridOption('loading', false)
      }
    }
  }

  const onClassGridCellClicked = p => {
    if (p.column.getColId() === 'TYPE_ID' && p.value) {
      const routeData = router.resolve({
        path: '/register-mapping-setup',
        query: { reg_type_id: p.data.TYPE_ID, proj_no: selectedProjNo.value, ep_id: p.data.EP_ID },
      })
      window.open(routeData.href, '_blank')
    }
  }

  /**
   * 2. 마우스 우클릭 메뉴 커스터마이징 함수
   * (템플릿의 :getContextMenuItems="getContextMenuItems" 와 연결되어야 함)
   */
  const getContextMenuItems = params => {
    // 기본 제공 메뉴 배열 (없으면 빈 배열로 방어)
    const defaultItems = params.defaultItems || []

    // 🚫 원래 Ag-Grid가 제공하는 기본 다운로드 메뉴 숨기기 ('excelExport', 'export')
    const filteredItems = defaultItems.filter(item => item !== 'excelExport' && item !== 'export')

    // ✨ 우리가 만든 백엔드 토스용 커스텀 메뉴 정의
    const myCustomExcelMenu = {
      name: 'Excel 다운로드',
      action: () => {
        // 메뉴 클릭 시 파일 가로채기 실행
        handleAgGridExcelIntercept()
      },
      // Ag-Grid 순정 스타일의 녹색 엑셀 아이콘 주입
      icon: '<span class="ag-icon ag-icon-excel" style="color: #1f7246;"></span>',
    }

    // 🤝 새 메뉴를 맨 위에 올리고 구분선(separator)과 함께 나머지 메뉴 병합
    return [myCustomExcelMenu, 'separator', ...filteredItems]
  }

  /**
   * 3. Ag-Grid 엑셀 바이너리를 가로채서 백엔드로 토스하고 결과 파일을 다운받는 핵심 함수
   */
  const handleAgGridExcelIntercept = async () => {
    if (!gridApi.value) {
      console.error('❌ [Excel Intercept] gridApi가 존재하지 않아 중단합니다.')
      return
    }

    try {
      console.log('🔄 [Excel Intercept] 1단계: Ag-Grid 내장 데이터 추출 시도')
      let agExcelBlob = null

      // [1단계 차선책] Ag-Grid 최신 버전 기능 체크
      if (typeof gridApi.value.getDataAsExcel === 'function') {
        try {
          agExcelBlob = gridApi.value.getDataAsExcel({})
        } catch (e) {
          console.warn('⚠️ [Excel Intercept] getDataAsExcel 실패 (모듈 등록 누락 의심):', e.message)
        }
      }

      // [2단계 차선책] 모듈 문제로 Blob 추출 안 될 시 내장 CSV 함수로 가공해서 우회
      if (!agExcelBlob && typeof gridApi.value.getDataAsCsv === 'function') {
        console.log('🔄 [Excel Intercept] 2단계: CSV 가공 우회 진행')
        try {
          const csvContent = gridApi.value.getDataAsCsv({})
          if (csvContent) {
            // 한글 깨짐 방지용 UTF-8 BOM 주입
            agExcelBlob = new Blob([new Uint8Array([0xef, 0xbb, 0xbf]), csvContent], {
              type: 'text/csv;charset=utf-8;',
            })
          }
        } catch (e) {
          console.warn('⚠️ [Excel Intercept] getDataAsCsv 실패:', e.message)
        }
      }

      // [3단계 차선책] 최후의 보루: 화면 JSON 데이터를 강제로 Blob 파일화
      if (!agExcelBlob) {
        console.log('🔄 [Excel Intercept] 3단계: 화면 JSON 덤프 데이터 구축')
        const fallbackData = []
        gridApi.value.forEachNodeAfterFilterAndSort(node => {
          if (node.data) fallbackData.push(node.data)
        })
        const jsonStr = JSON.stringify(fallbackData, null, 2)
        agExcelBlob = new Blob([jsonStr], { type: 'application/json' })
      }

      // 최종 데이터 추출 검증
      if (!agExcelBlob || agExcelBlob.size === 0) {
        alert('그리드에서 데이터를 추출할 수 없습니다.')
        return
      }

      console.log('✅ [Excel Intercept] 파일 데이터화 완료. 크기:', agExcelBlob.size, 'bytes')

      // Multipart FormData 객체 생성 및 파일 바인딩
      const formData = new FormData()
      // 💡 백엔드 파일 수신 Controller 변수명이 'file'인지 확인 필요!
      formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`)

      console.log('🚀 [Excel Intercept] 백엔드 API 요청 전송 -> URL: /api/File/File')

      // 💡 네트워크 탭 추적용 실제 API 호출부
      const response = await axios.post('/api/File/File', formData, {
        headers: {
          'Content-Type': 'multipart/form-data',
        },
        responseType: 'blob', // 바이너리 파일 스트림 보존을 위해 절대 필수!
      })

      console.log('🎉 [Excel Intercept] 백엔드 응답 성공. 최종 다운로드 처리 시작')

      // 서버가 돌려준 가공 완료 파일(DRM 등 적용됨)을 브라우저에 다운로드 다운로드 처리
      const returnBlob = new Blob([response.data], {
        type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
      })

      const downloadUrl = window.URL.createObjectURL(returnBlob)
      const linkElement = document.createElement('a')
      linkElement.href = downloadUrl
      linkElement.download = `Excel_Report_${Date.now()}.xlsx` // 최종 파일명

      document.body.appendChild(linkElement)
      linkElement.click()

      // 사용 완료된 가비지 메모리 회수
      document.body.removeChild(linkElement)
      window.URL.revokeObjectURL(downloadUrl)
      console.log('🏁 [Excel Intercept] 전체 다운로드 프로세스 정상 종료')
    } catch (error) {
      console.error('====================================================')
      console.error('🚨 [Excel Intercept Catch Error] 예외 발생')
      console.error('❌ 메시지:', error.message)
      console.error('❌ 상세 객체:', error)
      if (error.response) {
        console.error('❌ HTTP 에러 코드:', error.response.status)
        console.error('❌ 서버 리턴 에러 본문:', error.response.data)
      }
      console.error('====================================================')
      alert(`엑셀 처리 중 오류가 발생했습니다.\n원인: ${error.message}`)
    }
  }

  const gridOptions = computed(() => ({
    columnDefs: [
      {
        headerName: 'Source',
        field: 'Source',
        width: 110,
        pinned: 'left',
        cellStyle: { cursor: 'pointer' },
        cellRenderer: p =>
          `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'}; color:white;">${p.value}</span>`,
      },
      { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      { field: 'TAG_IDX', headerName: 'Tag Idx', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      { field: 'TAG_DESC', headerName: 'Tag Desc', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      { field: 'EP_IC', headerName: 'EP IC', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      { field: 'EP_ID', headerName: 'EP ID', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
      {
        field: 'CLS_ID',
        headerName: 'Class',
        width: 120,
        pinned: 'left',
        cellRenderer: highlightRenderer,
        cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd', fontWeight: 'bold' },
      },
      ...dynamicAttCols.value,
    ],
    rowData: filteredData.value,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: { sortable: true, filter: 'agTextColumnFilter', floatingFilter: true, resizable: true },
    cellSelection: true,
    enableRangeSelection: true,
    suppressRowClickSelection: true,
    statusBar: {
      statusPanels: [
        { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'right' },
        { statusPanel: 'agSelectedRowCountComponent', align: 'right' },
        { statusPanel: 'agAggregationComponent', align: 'right' },
      ],
    },
  }))

  const filteredData = computed(() => {
    const query = localFilterQuery.value.trim().toLowerCase()
    if (!query) return rawDataList.value
    return rawDataList.value.filter(i => Object.values(i).some(val => String(val).toLowerCase().includes(query)))
  })

  const classModalColDefs = [
    {
      headerName: 'Register No',
      field: 'TYPE_ID',
      flex: 1,
      cellStyle: { fontWeight: 'bold', color: '#0d6efd', textDecoration: 'underline', cursor: 'pointer' },
    },
    { headerName: 'Description', field: 'DESC', flex: 1.5 },
    { headerName: 'EP ID', field: 'EP_ID', width: 120 },
  ]

  const detailModalColDefs = [
    {
      headerName: 'Property',
      field: 'key',
      width: 220,
      pinned: 'left',
      cellStyle: { background: '#f8f9fa', fontWeight: 'bold' },
    },
    { headerName: 'Value', field: 'value', flex: 1 },
  ]

  const detailModalRowData = computed(() => {
    if (!selectedRow.value) return []
    return Object.entries(selectedRow.value)
      .filter(([k]) => k !== 'ATTRIBUTES')
      .map(([k, v]) => ({ key: k, value: v ?? '-' }))
  })

  const onGridReady = params => {
    gridApi.value = params.api
  }
  const closeClassModal = () => {
    showClassModal.value = false
    classModalData.value = []
    resetPos('class')
  }
  const closeDetailModal = () => {
    showDetailModal.value = false
    selectedRow.value = null
    resetPos('detail')
  }

  const resetPos = type => {
    modalPos[type].top = '200px'
    modalPos[type].left = '50%'
    modalPos[type].transform = 'translateX(-50%)'
  }

  onMounted(async () => {
    await fetchProjectList()
    const urlProjNo = route.query?.proj_no || new URLSearchParams(window.location.search).get('proj_no')
    if (urlProjNo) {
      selectedProjNo.value = urlProjNo
      projSearchQuery.value = urlProjNo
    }
  })
</script>

