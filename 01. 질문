<template>
  <!-- h-100과 w-100으로 부모 너비/높이에 맞춤 -->
  <DefaultCard
    :title="cardTitle"
    icon="fa-boxes-stacked"
    class="w-100 h-100"
  >
    <!-- [header-right] 상단 검색 조건 영역 -->
    <template #header-right>
      <div class="d-flex align-items-center gap-2">
        <!-- 1. 프로젝트 (메모 스타일) -->
        <InputBox
          id="input-proj"
          label="프로젝트"
          v-model:value="projectCode"
          placeholder="코드 입력"
          style="width: 140px"
        />
        <!-- 2. 키워드 (메모 스타일) -->
        <InputBox
          id="input-keyword"
          label="키워드"
          v-model:value="keyword"
          placeholder="키워드 입력"
          style="width: 140px"
        />
        <!-- 3. 검색 (돋보기 아이콘) -->
        <InputBox
          id="input-search"
          label="검색"
          v-model:value="attributeFilter"
          icon="fa-search"
          placeholder="검색어 입력"
          style="width: 180px"
          @clear="attributeFilter = ''"
        />

        <div class="header-divider"></div>

        <!-- Toast 연동 조회 버튼 -->
        <button 
          type="button" 
          class="tpl-btn tpl-btn--sm tpl-btn--primary" 
          @click="confirmSearch"
        >
          조회
        </button>
      </div>
    </template>

    <!-- [contents] 그리드 영역: 카드 너비에 100% 맞춤 -->
    <div class="grid-wrapper w-100 h-100">
      <ag-grid-vue
        class="ag-theme-custom w-100 h-100"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </DefaultCard>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { useToast } from '@/composables/useToast'

// 템플릿 공통 컴포넌트
import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const toast = useToast()

// 상태 데이터
const cardTitle = {
  title: '재고 현황',
  subtitle: '창고별 집계 · 실시간 반영'
}

const projectCode = ref('')
const keyword = ref('')
const attributeFilter = ref('')

const gridApi = shallowRef()
const gridRowData = ref([])
const columnDefs = ref([])

/**
 * Toast "확인/취소"를 이용한 조회 컨펌
 */
const confirmSearch = () => {
  toast.show({
    title: '조회 확인',
    content: '입력하신 조건으로 데이터를 집계하시겠습니까?',
    okText: '확인',
    cancelText: '취소',
    onOk: () => {
      fetchData()
    }
  })
}

/**
 * API 데이터 호출
 */
const fetchData = async () => {
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  
  try {
    const res = await axiosWrapper.post('/api/Inventory/GetStatus', { 
      ProjectNo: projectCode.value,
      Keyword: keyword.value 
    })
    
    gridRowData.value = Array.isArray(res) ? res : []
    
    // 첫 번째 데이터를 기준으로 컬럼 자동 생성
    if (gridRowData.value.length > 0) {
      columnDefs.value = Object.keys(gridRowData.value[0]).map(key => ({
        headerName: key,
        field: key,
        sortable: true,
        filter: true,
        resizable: true,
        flex: 1 // 모든 컬럼이 너비에 맞춰 균등 배분되도록 설정
      }))
    }
  } catch (error) {
    toast.fail({ title: '오류 발생', content: '데이터 조회 중 에러가 발생했습니다.' })
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

/**
 * Ag-Grid 설정
 */
const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  headerHeight: 40,
  rowHeight: 35,
  // 텍스트 필터 연동을 위한 가이드
  quickFilterText: attributeFilter.value
}))

const onGridReady = (params) => {
  gridApi.value = params.api
  // 그리드 너비를 카드에 맞게 강제 조정
  params.api.sizeColumnsToFit()
}
</script>

<style scoped>
/* 카드와 그리드 너비 일치를 위한 스타일 */
.w-100 { width: 100%; }
.h-100 { height: 100%; }

.grid-wrapper {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  padding: 0; /* 카드 패딩과 충돌을 피하기 위해 0으로 설정 가능 */
}

.header-divider {
  width: 1px;
  height: 14px;
  background-color: #dee2e6;
  margin: 0 10px;
}

/* InputBox 간격 미세 조정 */
:deep(.input-box-container) {
  margin-bottom: 0;
}

/* Ag-Grid 테마가 카드 너비를 벗어나지 않도록 설정 */
.ag-theme-custom {
  border: 1px solid var(--tpl-border-color, #e0e0e0);
  border-radius: 4px;
  overflow: hidden;
}
</style>
