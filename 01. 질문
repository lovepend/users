<template>
  <div class="w-100 h-100" style="display: flex; flex-direction: column">
    <div class="d-flex justify-content-between p-2 alignment-bar bg-light border-bottom">
      <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2 bg-white px-3 py-1 border rounded" style="height: 35px;">
          <label class="d-flex align-items-center gap-1 m-0 cursor-pointer" style="font-size: 13px; font-weight: bold;">
            <input type="radio" v-model="viewModeRef" value="DEFAULT" @change="onViewModeChange" />
            기본 화면
          </label>
          <div class="border-left h-100 mx-2" style="border-right: 1px solid #dee2e6;"></div>
          <label class="d-flex align-items-center gap-1 m-0 cursor-pointer" style="font-size: 13px; font-weight: bold; color: #6366f1;">
            <input type="radio" v-model="viewModeRef" value="COMPARE" @change="onViewModeChange" />
            리비전 비교
          </label>
        </div>

        <label class="d-inline-block p-2 bg-indigo-200 h-35px m-0 d-flex align-items-center">
          <span class="me-2">Language </span>
          <select v-model="LanguageTypeRef" @change="onChangeLocale">
            <option :value="_LangType.KO">한국어</option>
            <option :value="_LangType.EN">English</option>
            <option :value="_LangType.JA">日本語</option>
            <option :value="_LangType.CN">中文</option>
          </select>
        </label>
        <label class="m-0 d-flex align-items-center" style="user-select: none">
          <Switch label="Export With Encrypt" v-model:value="exportFileEncryptRef" />
        </label>
      </div>

      <div class="d-flex gap-1 align-items-center">
        <button class="btn btn-default" @click="onDefault">Default</button>
        <button class="btn btn-white" @click="onWhite">White</button>
        <button class="btn btn-gray" @click="onGray">Gray</button>
        <button class="btn btn-purple" @click="onPurple">Purple</button>
        <button class="btn btn-indigo" @click="onIndigo">Indigo</button>
        <button class="btn btn-yellow" @click="onYellow">Yellow</button>
        <button class="btn btn-pink" @click="onPink">Pink</button>
        <button class="btn btn-green" @click="onGreen">Green</button>
        <button class="btn btn-lime" @click="onLime">Lime</button>
        <button class="btn btn-dark" @click="onDark">Dark</button>
        <button class="btn btn-info" @click="onInfo">Info</button>
        <button class="btn btn-warning" @click="onWarning">Warning</button>
        <button class="btn btn-danger" @click="onDanger">Danger</button>
        <button class="btn btn-success" @click="onSuccess">Success</button>
        <button class="btn btn-primary" @click="onReset">Reset</button>
      </div>

      <div class="d-inline-block p-2 bg-indigo-200 h-35px d-flex align-items-center">
        <select v-model="DownloadTypeRef" class="me-2">
          <option :value="_LangType.KO">한국어</option>
          <option :value="_LangType.EN">English</option>
          <option :value="_LangType.JA">日本語</option>
          <option :value="_LangType.CN">中文</option>
        </select>
        <button class="p-0 px-2" style="font-size: 12px" @click="onDownloadLocaleResource">언어 리소스 다운로드</button>
      </div>
    </div>

    <div class="main-content-container flex-grow-1 w-100" style="overflow: hidden; position: relative;">
      
      <div v-if="viewModeRef === 'DEFAULT'" class="w-100 h-100">
        <gc-spread-designer
          class="w-100 h-100"
          @designer-initialized="initSingleDesigner"
          :key="`single-${keyRef}`"
          :EXPORT_FILE_ENCRYPT="exportFileEncryptRef"
          :highlightFormula="highlightFormulaRef"
          :highlightRanges="highlightRangesRef"
        />
      </div>

      <div v-else-if="viewModeRef === 'COMPARE'" class="d-flex flex-row w-100 h-100" style="background-color: #f5f5f5;">
        <div class="split-pane position-relative h-100" style="width: 50%; border-right: 2px solid #ccc;">
          <div class="pane-badge">이전 Revision (좌)</div>
          <gc-spread-designer
            class="w-100 h-100"
            @designer-initialized="initLeftDesigner"
            :key="`left-${keyRef}`"
            :EXPORT_FILE_ENCRYPT="exportFileEncryptRef"
            :highlightFormula="highlightFormulaRef"
            :highlightRanges="highlightRangesRef"
          />
        </div>

        <div class="split-pane position-relative h-100" style="width: 50%;">
          <div class="pane-badge">신규 Revision (우)</div>
          <gc-spread-designer
            class="w-100 h-100"
            @designer-initialized="initRightDesigner"
            :key="`right-${keyRef}`"
            :EXPORT_FILE_ENCRYPT="exportFileEncryptRef"
            :highlightFormula="highlightFormulaRef"
            :highlightRanges="highlightRangesRef"
          />
        </div>
      </div>

    </div>
  </div>
</template>

<script setup>
  import { shallowRef, ref } from 'vue'
  import { saveAs } from 'file-saver'
  import GC from '@mescius/spread-sheets-designer'

  import GCLangResKO from '@/lang/spread/spread_language_KO'
  import GCLangResEN from '@/lang/spread/spread_language_EN'
  import GCLangResJA from '@/lang/spread/spread_language_JA'
  import GCLangResCN from '@/lang/spread/spread_language_CN'
  window.GC = GC

  import SpreadComboEditor from '@/components/editors/spreadJsEditor/SpreadComboEditor'
  import SpreadComboTestEditor from '@/components/editors/spreadJsEditor/SpreadComboTestEditor'
  import Switch from '@/components/default/editors/Switch.vue'

  const exportFileEncryptRef = shallowRef(true)
  const keyRef = shallowRef(0)

  // --- [추가] 화면 뷰 상태 제어 레퍼런스 ('DEFAULT' 또는 'COMPARE') ---
  const viewModeRef = ref('DEFAULT')

  // --- 디자이너 및 워크북 레퍼런스 분리 정의 ---
  const singleDesignerRef = shallowRef(null)
  const singleSpreadRef = shallowRef(null)
  
  const leftDesignerRef = shallowRef(null)
  const leftSpreadRef = shallowRef(null)
  
  const rightDesignerRef = shallowRef(null)
  const rightSpreadRef = shallowRef(null)

  // 1. 단일(기본) 화면 디자이너 초기화
  const initSingleDesigner = function (designer) {
    singleDesignerRef.value = designer
    singleSpreadRef.value = designer.getWorkbook()
  }

  // 2. 비교 화면(좌) 디자이너 초기화
  const initLeftDesigner = function (designer) {
    leftDesignerRef.value = designer
    leftSpreadRef.value = designer.getWorkbook()
  }

  // 3. 비교 화면(우) 디자이너 초기화
  const initRightDesigner = function (designer) {
    rightDesignerRef.value = designer
    rightSpreadRef.value = designer.getWorkbook()
  }

  // 라디오 버튼 모드 체인지 시 작동할 핸들러 공란 배치 (필요 시 강제 리프레시나 스냅샷 데이터 동화 가능)
  const onViewModeChange = function () {
    // console.log("현재 보기 모드 변경됨: ", viewModeRef.value)
  }

  const _SpreadVersion = '18.0.7'
  const DownloadTypeRef = shallowRef('KO')
  const LanguageTypeRef = shallowRef('KO')
  const _LangType = { KO: 'KO', EN: 'EN', JA: 'JA', CN: 'CN' }

  // 로컬 리소스 다운로드 스크립트 수정 (활성화된 워크북 인스턴스 유동 검사)
  const onDownloadLocaleResource = function () {
    const languageType = DownloadTypeRef.value
    if (!languageType || !_LangType[languageType]) return
    try {
      let version = _SpreadVersion
      const spread = singleSpreadRef.value || leftSpreadRef.value || rightSpreadRef.value
      if (spread) {
        const spreadInfo = spread.toJSON()
        const spreadVersion = spreadInfo?.version
        if (spreadVersion) version = spreadVersion
      }
      const resource = GC.Spread.Sheets.Designer.getResources()
      const resourceJson = JSON.stringify(resource)
      let sourceJson = `const version = "${version}"; const locale = "${languageType}"; export default \`${resourceJson}\`;`
      
      sourceJson = sourceJson.replaceAll('\\', '\\\\').replaceAll('${', '&#36;{')
      saveAs(new Blob([sourceJson], { type: 'text/javascript;charset=utf-8' }), `spread_language_${languageType}.js`)
    } catch (error) {
      console.error(error)
      alert(error.message)
    }
  }

  const spreadLocalization = function (LOCALE) {
    const _Locale = LOCALE
    switch (_Locale) {
      case 'KO':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResKO))
        GC.Spread.Common.CultureManager.culture('ko-kr')
        break
      case 'JA':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResJA))
        GC.Spread.Common.CultureManager.culture('ja-jp')
        break
      case 'CN':
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResCN))
        GC.Spread.Common.CultureManager.culture('zh-cn')
        break
      default:
        GC.Spread.Sheets.Designer.setResources(JSON.parse(GCLangResEN))
        GC.Spread.Common.CultureManager.culture('en-us')
        break
    }
    return GC.Spread.Sheets.Designer.DefaultConfig
  }

  // 언어셋 변경 시 로드된 모든 가용 디자이너 컴포넌트에 환경 세팅 일괄 지정
  const onChangeLocale = function () {
    const languageType = LanguageTypeRef.value
    if (!languageType || !_LangType[languageType]) return

    const config = spreadLocalization(languageType)
    if (config) {
      if (singleDesignerRef.value) singleDesignerRef.value.setConfig(config)
      if (leftDesignerRef.value) leftDesignerRef.value.setConfig(config)
      if (rightDesignerRef.value) rightDesignerRef.value.setConfig(config)
    }
  }

  const highlightFormulaRef = shallowRef()
  const highlightRangesRef = shallowRef()
  const onReset = () => (keyRef.value += 1)

  // 샘플 데이터 적용 로직 (가용 활성화 맵 전체 순회)
  const onDefault = function () {
    const applyDemoToSheet = (spread) => {
      const sheet = spread?.getActiveSheet()
      if (!sheet) return
      sheet.bind(GC.Spread.Sheets.Events.LeaveCell, function (e, args) {
        const cell = args.sheet.getCell(args.row, args.col)
        const cellType = cell.cellType()
        if (cellType?.focusOut) cellType.focusOut(args)
      })
      
      const cellType1 = new SpreadComboTestEditor({ showAllOptionButton: true, isPaintLabel: false, closeOnSelect: false, code: 'value', label: 'text' })
      const cellType2 = new SpreadComboEditor({ showAllOptionButton: true, applySelected: false, placeholer: 'PLACE_HOLDER', code: 'code', label: 'label' })

      const items = [
        { value: 'a_val', text: 'A_TEXT', code: 'a_code', label: 'A_LABEL', seq: 1 }
      ]
      
      cellType1.items(items); cellType2.items(items)
      sheet.setColumnWidth(1, 140); sheet.setColumnWidth(2, 140);
      sheet.setValue(1, 1, 'BASE'); sheet.setValue(1, 2, 'CODE_LABEL');
      sheet.getRange(2, 1, 10, 1).cellType(cellType1);
      sheet.getRange(2, 2, 10, 1).cellType(cellType2);
    }

    if (viewModeRef.value === 'DEFAULT' && singleSpreadRef.value) {
      applyDemoToSheet(singleSpreadRef.value)
    } else {
      if (leftSpreadRef.value) applyDemoToSheet(leftSpreadRef.value)
      if (rightSpreadRef.value) applyDemoToSheet(rightSpreadRef.value)
    }
  }

  const onWhite = function () {
    const activeSpread = singleSpreadRef.value || leftSpreadRef.value
    const sheet = activeSpread?.getActiveSheet()
    if (!sheet) return
    const ranges = sheet.getSelections()
    const text = !ranges?.length ? '' : GC.Spread.Sheets.CalcEngine.rangesToFormula(ranges, 0, 0, GC.Spread.Sheets.CalcEngine.RangeReferenceRelative.allRelative)
    sheet.setValue(0, 0, text)
    sheet.setSelection(0, 0, 1, 1)
  }

  const onGray = function () {
    const activeSpread = singleSpreadRef.value || leftSpreadRef.value
    const sheet = activeSpread?.getActiveSheet()
    const row = sheet?.getActiveRowIndex()
    const col = sheet?.getActiveColumnIndex()
    const text = sheet?.getText(row, col)
    if (text) {
      const allRange = GC.Spread.Sheets.CalcEngine.formulaToRanges(sheet, text, 0, 0)
      highlightRangesRef.value = allRange?.[0]?.ranges
    } else {
      highlightRangesRef.value = null
    }
  }

  const onPurple = function () {}
  const onIndigo = function () {}
  const onYellow = function () {}
  const onPink = function () {}
  const onGreen = function () {}
  const onLime = function () {}
  const onDark = function () {}
  const onInfo = function () {}
  const onWarning = function () {}
  const onDanger = function () {}
  const onSuccess = function () {}
</script>

<style scoped>
