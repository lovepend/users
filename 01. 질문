<template>
  <div class="d-flex flex-column h-100 bg-white">
    <!-- 상단 컨트롤 영역 -->
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        
        <!-- 왼쪽: 프로젝트 선택 & 조회 버튼 -->
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2" style="max-width: 200px;">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트 선택' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <!-- 프로젝트 검색/전체선택/리스트 (기존 유지) -->
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="프로젝트 검색..." @click.stop />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <span><b class="text-primary">{{ proj.PROJ_NO }}</b> ({{ proj.DESC }})</span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <!-- 메인 조회 버튼 -->
          <button
            class="btn btn-sm btn-primary px-4 shadow-sm fw-bold"
            @click="onSearchCombined"
            :disabled="selectedProjects.length === 0"
          >
            <i class="fa fa-exchange me-1"></i> 통합 비교 조회
          </button>
        </div>

        <!-- 오른쪽: 키워드 입력창 (여기에 필터를 넘어선 "조회 조건" 역할 부여) -->
        <div class="d-flex align-items-start gap-2 flex-grow-1" style="max-width: 600px;">
          <span class="fw-bold text-success text-nowrap mt-1"><i class="fa fa-tags me-1"></i>Tag Keywords</span>
          <textarea
            class="form-control form-control-sm border-success custom-textarea-filter"
            v-model="searchKeywords"
            rows="2"
            placeholder="조회할 Tag 번호를 입력하세요 (엔터로 여러 개 입력 가능)"
          ></textarea>
        </div>
      </div>
    </div>

    <!-- 그리드 영역 -->
    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue v-bind="gridOptions" @grid-ready="onGridReady" />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()
const gridApi = shallowRef()

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([]) // 현재 선택된 프로젝트들
const searchKeywords = ref('')   // 입력한 Tag 키워드들
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')

// --- 1. 프로젝트 목록 로드 (초기화) ---
onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', {
      headers: { Ep_id: urlEpId.value },
    })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (error) { console.error(error) }
})

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw) || p.DESC.toLowerCase().includes(kw))
})

// --- 2. 핵심: 통합 데이터 조회 로직 ---
const onSearchCombined = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const keywordList = searchKeywords.value.split(/[\s,\n]+/).filter(k => k.trim() !== '')
    const allData = []

    // 각 프로젝트별로 Publish와 Working 데이터를 모두 호출
    const promises = selectedProjects.value.flatMap(projNo => [
      axiosWrapper.post('/api/Data/SearchPublishData', { ProjectNo: projNo, Keywords: keywordList }).then(res => ({ projNo, type: 'Publish', data: res })),
      axiosWrapper.post('/api/Data/SearchWorkingData', { ProjectNo: projNo, Keywords: keywordList }).then(res => ({ projNo, type: 'Working', data: res }))
    ])

    const results = await Promise.allSettled(promises)
    
    // 데이터를 TAG_NO 기준으로 맵핑 (비교를 위해)
    const tagMap = new Map()

    results.forEach(result => {
      if (result.status === 'fulfilled' && Array.isArray(result.value.data)) {
        const { projNo, type, data } = result.value
        
        data.forEach(item => {
          const key = item.TAG_NO
          if (!tagMap.has(key)) {
            tagMap.set(key, { TAG_NO: key, TAG_DESC: item.TAG_DESC, CLS_ID: item.CLS_ID, values: {} })
          }
          // 프로젝트별/출처별로 데이터 저장 (예: 'PRJ001_Publish')
          tagMap.get(key).values[`${projNo}_${type}`] = item
        })
      }
    })

    // 그리드에 뿌릴 형태로 가공
    gridRowData.value = Array.from(tagMap.values()).map(row => {
      const flatRow = { ...row }
      // 각 셀에 데이터 매칭
      selectedProjects.value.forEach(p => {
        flatRow[`${p}_Publish`] = row.values[`${p}_Publish`] || null
        flatRow[`${p}_Working`] = row.values[`${p}_Working`] || null
      })
      return flatRow
    })

    // 동적 컬럼 생성 (프로젝트별 그룹 컬럼)
    dynamicCols.value = selectedProjects.value
    
  } catch (e) {
    sAlert.Error('데이터 조회 중 오류가 발생했습니다.')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// --- 3. 그리드 컬럼 정의 ---
const columnDefs = computed(() => {
  const baseCols = [
    { headerName: 'Tag Number', field: 'TAG_NO', width: 180, pinned: 'left', filter: 'agTextColumnFilter' },
    { headerName: 'Description', field: 'TAG_DESC', width: 200 },
    { headerName: 'Class', field: 'CLS_ID', width: 100 },
  ]

  const projectCols = dynamicCols.value.map(proj => ({
    headerName: `Project: ${proj}`,
    children: [
      {
        headerName: 'Publish',
        valueGetter: p => p.data[`${proj}_Publish`] ? 'O' : '-',
        width: 100,
        cellStyle: p => ({ textAlign: 'center', color: p.value === 'O' ? '#27ae60' : '#ccc' })
      },
      {
        headerName: 'Working',
        valueGetter: p => p.data[`${proj}_Working`] ? 'O' : '-',
        width: 100,
        cellStyle: p => ({ textAlign: 'center', color: p.value === 'O' ? '#e67e22' : '#ccc', fontWeight: 'bold' })
      }
    ]
  }))

  return [...baseCols, ...projectCols]
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true },
  loadingOverlayComponent: AggridLoadingOverlay,
}))

const onGridReady = p => { gridApi.value = p.api }
</script>

<style scoped>
.custom-project-dropdown { width: 300px; }
.custom-textarea-filter { width: 100%; min-height: 60px; font-size: 0.85rem; }
:deep(.ag-header-group-cell) { background-color: #f1f3f5 !important; font-weight: bold; }
</style>
