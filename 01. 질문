<template>
  <div class="d-flex flex-column h-100 bg-white shadow-sm rounded">
    <!-- 상단 컨트롤 바 -->
    <div class="p-3 border-bottom bg-light">
      <div class="row g-2 align-items-center">
        <!-- 프로젝트 선택 -->
        <div class="col-auto d-flex align-items-center gap-2">
          <span class="fw-bold text-secondary">Projects</span>
          <div class="dropdown">
            <button
              class="btn btn-sm btn-white border dropdown-toggle custom-project-dropdown text-start shadow-sm"
              type="button"
              data-bs-toggle="dropdown"
              data-bs-auto-close="outside"
            >
              <span class="text-truncate">
                {{ selectedProjects.length > 0 ? `${selectedProjects[0]} 외 ${selectedProjects.length - 1}건` : '선택하세요' }}
              </span>
            </button>
            <ul class="dropdown-menu p-2 shadow" style="min-width: 350px; max-height: 500px; overflow-y: auto;">
              <li class="px-2 pb-2">
                <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="Project ID/Name..." @click.stop />
              </li>
              <li class="dropdown-item py-1 bg-light border-bottom">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" :checked="isAllSelected" :indeterminate="isIndeterminate" @change="toggleAllSelection" />
                  <label class="form-check-label fw-bold">전체 선택</label>
                </div>
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item py-1">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                  <label class="form-check-label">
                    <span class="badge bg-primary me-1">{{ proj.PROJ_NO }}</span> {{ proj.DESC }}
                  </label>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- 키워드 검색 (통합 조회) -->
        <div class="col-auto d-flex align-items-center gap-2 border-start ps-3">
          <span class="fw-bold text-secondary">Keyword</span>
          <div class="input-group input-group-sm" style="width: 250px;">
            <input 
              type="text" 
              class="form-control" 
              v-model="searchKeyword" 
              placeholder="Tag No (쉼표 구분 가능)"
              @keyup.enter="onSearch"
            />
            <button class="btn btn-primary" @click="onSearch" :disabled="isLoading">
              <i v-if="isLoading" class="fa fa-spinner fa-spin"></i>
              <i v-else class="fa fa-search"></i>
            </button>
          </div>
        </div>

        <!-- 상세/간편 모드 (기존 토글) -->
        <div class="col-auto ms-auto">
          <div class="btn-group border rounded-pill p-1 bg-white shadow-sm">
            <input type="radio" class="btn-check" id="vSimple" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill border-0 px-3" for="vSimple">간편</label>
            <input type="radio" class="btn-check" id="vDetail" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill border-0 px-3" for="vDetail">상세</label>
          </div>
        </div>

        <!-- 멀티 필터 (그리드 내부 검색) -->
        <div class="col-auto d-flex align-items-center gap-2 border-start ps-3">
          <span class="fw-bold text-success"><i class="fa fa-filter"></i></span>
          <textarea
            class="form-control form-control-sm custom-filter-area"
            v-model="attributeFilter"
            rows="1"
            placeholder="결과 내 필터..."
          ></textarea>
        </div>
      </div>
    </div>

    <!-- 메인 그리드 영역 -->
    <div class="flex-grow-1 position-relative">
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import { AgGridVue } from 'ag-grid-vue3'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()
const gridApi = shallowRef(null)
const isLoading = ref(false)

// --- State 설정 ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const searchKeyword = ref('')
const attributeFilter = ref('')
const viewMode = ref('simple')

const gridRowData = ref([])
const activeProjectColumns = ref([])

const urlEpId = computed(() => route.query.ep_id || '')

// --- 프로젝트 선택 핸들링 (전체 선택/검색 등 유지) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw) || p.DESC.toLowerCase().includes(kw))
})

const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selCount = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selCount > 0 && selCount < filteredProjectList.value.length
})

const toggleAllSelection = (e) => {
  const checked = e.target.checked
  const currentFiltered = filteredProjectList.value.map(p => p.PROJ_NO)
  if (checked) {
    selectedProjects.value = [...new Set([...selectedProjects.value, ...currentFiltered])]
  } else {
    selectedProjects.value = selectedProjects.value.filter(id => !currentFiltered.includes(id))
  }
}

// --- API 데이터 조회 및 고도화된 매핑 ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('대상 프로젝트를 먼저 선택해 주세요.')
  
  isLoading.value = true
  gridApi.value?.showLoadingOverlay()

  try {
    const keywords = searchKeyword.value.split(/[\s,]+/).filter(k => k.trim())
    const tagMap = new Map()

    // 병렬 데이터 호출 (Publish & Working)
    const apiCalls = selectedProjects.value.flatMap(projNo => [
      axiosWrapper.post('/api/Data/SearchPublishData', { ProjectNo: projNo, Keywords: keywords }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } }),
      axiosWrapper.post('/api/Data/SearchWorkingData', { ProjectNo: projNo, Keywords: keywords }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } })
    ])

    const results = await Promise.all(apiCalls)

    selectedProjects.value.forEach((projNo, idx) => {
      const pubData = results[idx * 2] || []
      const workData = results[idx * 2 + 1] || []

      const process = (data, type) => {
        data.forEach(item => {
          const key = item.TAG_NO
          if (!tagMap.has(key)) {
            tagMap.set(key, { ...item, _projects: {} })
          }
          const row = tagMap.get(key)
          if (!row._projects[projNo]) row._projects[projNo] = { Publish: null, Working: null }
          row._projects[projNo][type] = item
        })
      }

      process(pubData, 'Publish')
      process(workData, 'Working')
    })

    gridRowData.value = Array.from(tagMap.values())
    activeProjectColumns.value = [...selectedProjects.value]
    
  } catch (err) {
    console.error(err)
    sAlert.Error('데이터를 불러오는 중 오류가 발생했습니다.')
  } finally {
    isLoading.value = false
    gridApi.value?.hideOverlay()
    if (gridRowData.value.length === 0) gridApi.value?.showNoRowsOverlay()
  }
}

// --- 그리드 정의 (컬럼 및 옵션) ---
const columnDefs = computed(() => {
  const base = [
    { headerName: 'Tag Number', field: 'TAG_NO', width: 160, pinned: 'left', checkboxSelection: true, headerCheckboxSelection: true },
    { headerName: 'Description', field: 'TAG_DESC', width: 250 },
    { headerName: 'Class', field: 'CLS_ID', width: 100 },
  ]

  const dynamic = activeProjectColumns.value.map(proj => ({
    headerName: `PJ: ${proj}`,
    children: [
      { 
        headerName: 'PUB', 
        width: 80, 
        valueGetter: p => p.data._projects[proj]?.Publish ? 'ON' : '-',
        cellClassRules: { 'text-success fw-bold': "x === 'ON'" }
      },
      { 
        headerName: 'WORK', 
        width: 80, 
        valueGetter: p => p.data._projects[proj]?.Working ? 'ON' : '-',
        cellClassRules: { 'text-warning fw-bold': "x === 'ON'" }
      }
    ]
  }))

  return [...base, ...dynamic]
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true },
  rowSelection: 'multiple',
  loadingOverlayComponent: AggridLoadingOverlay,
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: (node) => {
    const searchTerms = attributeFilter.value.split(/[\s,\n]+/).filter(t => t.trim()).map(t => t.toLowerCase())
    const target = String(node.data.TAG_NO || '').toLowerCase()
    return searchTerms.some(term => target.includes(term))
  }
}))

const onGridReady = (params) => {
  gridApi.value = params.api
}

// 필터 변경 시 그리드 갱신
watch(attributeFilter, () => gridApi.value?.onFilterChanged())

onMounted(async () => {
  const res = await axiosWrapper.get('/api/Project/Get', { headers: { Ep_id: urlEpId.value } })
  projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
})
</script>

<style scoped>
.custom-project-dropdown { width: 220px; background-color: white; }
.custom-filter-area { width: 250px; transition: all 0.3s; }
.custom-filter-area:focus { width: 400px; height: 80px !important; position: absolute; right: 20px; z-index: 100; }
.btn-check:checked + .btn { background-color: #0d6efd; color: white; }
</style>
