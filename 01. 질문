// fetchAndParseExcel 함수 내부
const workbook = XLSX.read(arrayBuffer, { type: 'array' })
let combined: any[] = []

workbook.SheetNames.forEach((name, index) => {
  // 사용자가 "3번째부터 데이터가 있다"고 했으므로 
  // index 0(첫시트)뿐만 아니라 로컬 파일 전체가 그렇다면 skip을 2로 고정해야 할 수도 있습니다.
  const skip = index === 0 ? 2 : 0 
  
  const parsedData = parseSheetWithHeaders(workbook.Sheets[name], skip);
  console.log(`${name} 시트에서 ${parsedData.length}건 파싱됨`); // 시트별 데이터 개수 확인
  
  combined = combined.concat(parsedData);
})
