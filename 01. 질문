    columnHoverHighlight: true,
    suppressRowClickSelection: true,
    suppressLastEmptyLineOnPaste: true,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
  })
  const gridOnPropsProcess = {
    gridReady: params => {
      gridRef_Process.value = params.api
    },
  }

  const getAdapterBrokerProcessList = async selectNode => {
    try {
      // showOverlay();

      const tool_id = selectNode.GROUP
      const tool_type = selectNode.NAME

      if (!tool_id) {
        sAlert.Warning(`The specified '${toolType}' does not exist.`)
        return
      }

      if (tool_id && tool_type) {
        getBrokerProcessData(tool_id, tool_type)
      }
    } catch (error) {
      sAlert.Error(`Failed to getAdapterBrokerProcessList : ${error.message}`)
    } finally {
      // hideOverlay();
    }
  }

  const getBrokerProcessData = async function (tool_id, tool_type) {
    gridRef_Process.value.setGridOption('loading', true)

    const currentFilters = gridRef_Process.value.getFilterModel()

    console.log(currentFilters)

    // currentFilters 객체의 키(컬럼 이름) 배열을 가져와서 map 메서드 적용
    const attributes = Object.keys(currentFilters)
      .map(columnName => {
        const columnFilter = currentFilters[columnName]

        // filterModels 배열이 있고, 첫 번째 요소에 실제 필터 정보가 있는지 안전하게 확인
        // 옵셔널 체이닝 (?.)과 널 병합 연산자 (??)를 사용해서 안전하게 값 추출
        const filterValue = columnFilter?.filterModels?.[0]?.filter ?? null

        // filterValue가 유효하면 원하는 객체 형태로 반환
        if (filterValue !== null && filterValue !== undefined) {
          return {
            NAME: columnName,
            VALUE: filterValue,
          }
        }

        // filterValue가 유효하지 않으면 null 또는 undefined 반환 (나중에 filter로 걸러낼 것임)
        return null
      })
      .filter(item => item !== null && item !== undefined)

    dataListRef_Process.value = []

    let urlProcess = `/api/AdapterBroker/Process`

    try {
      // API 미확정으로 임시 하드 코딩
      const bodyDataProcess = {
        Group: tool_id,
        Name: tool_type,
        ProjectNo: 'string',
        EP_ID: 'string',
        REG_TYPE_ID: 'string',
        UserID: searchUserId.value,
        MappedAtts: [
          {
            ATTRIBUTES: attributes,
          },
        ],
      }

      // proj_no 값이 null도 아니고 빈 문자열도 아닐 때만 ProjectNo 속성 추가
      if (searchProjectNo.value !== null && searchProjectNo.value !== undefined && searchProjectNo.value !== '') {
        bodyDataProcess.ProjectNo = searchProjectNo.value
      } else {
        delete bodyDataProcess.ProjectNo
      }

      if (searchEPId.value !== null && searchEPId.value !== undefined && searchEPId.value !== '') {
        bodyDataProcess.EP_ID = searchEPId.value
      } else {
        delete bodyDataProcess.EP_ID
      }

      if (searchRegisterId.value !== null && searchRegisterId.value !== undefined && searchRegisterId.value !== '') {
        bodyDataProcess.REG_TYPE_ID = searchRegisterId.value
      } else {
        delete bodyDataProcess.REG_TYPE_ID
      }

      if (isSearchButtonClicked.value) {
        let confirmResult = await sAlert.Confirm(
          `아래의 파라메터로 테스트를 진행하시겠습니까?` +
            `<br>` +
            `<small class="text-primary">` +
            JSON.stringify(bodyDataProcess) +
            `</small>`
        )

        if (!confirmResult.isConfirmed) return

        let jsonDataProcess = await axiosWrapper.post(urlProcess, bodyDataProcess)
        let dtProcess = jsonDataProcess

        if (dtProcess.length > 0) {
          const transformedData = dtProcess.map(item => {
            const newItem = {}
            // 각 ATTRIBUTES 배열을 순회하며 새 객체에 속성을 추가합니다.
            item.ATTRIBUTES.forEach(attr => {
              newItem[attr.NAME] = attr.VALUE
            })
            return newItem
          })

          dataListRef_Process.value = transformedData
        }
      }
    } catch (error) {
      dataListRef_Process.value = []

      if (!(error instanceof axios.AxiosError)) {
        sAlert.Error('Failed to getBrokerProcessData : ' + error.message)
      }
    }

    gridRef_Process.value.setGridOption('loading', false)
  }
  //#endregion Functions

  const isSearchButtonClicked = ref(false)

  //#region Event
  const searchBrokerData = async event => {
    isSearchButtonClicked.value = true

    const tool_id = searchToolId.value
    const tool_type = searchToolType.value

    if (tool_id && tool_type) {
      getBrokerProcessData(tool_id, tool_type)
    }

    isSearchButtonClicked.value = false
  }
  defineOptions({
    name: `AdapterBrokerSetup`,
    components: { agDropBoxEditor, AgDetailStatusBar },
  })
</script>

