/**
 * @module stores/app-version-check
 * @desc 배포 버전 확인용 Store ( Store기능 X - 버전 반복 확인용 )
 */

import { defineStore } from 'pinia'
import { ref, readonly } from 'vue'

export const useVersionCheck = defineStore('appVersionCheck', () => {
  const isLocal = import.meta.env.MODE === 'development'
  const version = ref(null)
  const delayMin = 1000 * 60
  const delayMax = 1000 * 60 * 5
  let delayMS = delayMin
  let interID = undefined as undefined | number
  let isPend = false as boolean
  let isStop = false as boolean
  let isNews = true as boolean
  const checkVersion = async function () {
    if (isLocal) {
      return
    }
    isPend = true
    window.clearInterval(interID)
    try {
      if (isNews) {
        const res = await fetch('./build-meta.json')
        const data = await res.json()
        const newVersion = data.buildTime
        const oldVersion = version.value
        if (!oldVersion) {
          isNews = true
          version.value = newVersion
        } else if (oldVersion !== newVersion) {
          version.value = newVersion
          const isRefresh = confirm('The new Version has been deployed. The page will now refresh.')
          if (isRefresh) {
            isNews = true
            ;(location.reload as any)(true)
          } else {
            isNews = false
          }
        } else {
          isNews = true
          // console.log('Matching versions!', newVersion)
        }
        delayMS = isNews ? delayMin : delayMax
      } else {
        const isRefresh = confirm('The new Version has been deployed. The page will now refresh.')
        if (isRefresh) {
          isNews = true
          ;(location.reload as any)(true)
        }
      }
    } catch (error) {
      // console.warn('Failed to check versions!')
      delayMS = delayMax
    } finally {
      if (!isStop) {
        interID = window.setInterval(checkVersion, delayMS)
      }
      isPend = false
    }
  }
  const stop = function () {
    isStop = true
    window.clearInterval(interID)
  }
  const start = function () {
    if (!isPend) {
      isStop = false
      checkVersion()
    }
  }
  return {
    stop,
    start,
    version: readonly(version),
  }
})
