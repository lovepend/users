import { ref } from 'vue'
import api from '@/api' // 기존 세팅된 Axios 인스턴스

const gridApi = ref(null)

const onGridReady = (params) => {
  gridApi.value = params.api
}

/**
 * 마우스 우클릭 메뉴 커스터마이징
 */
const getContextMenuItems = (params) => {
  const defaultItems = params.defaultItems || []
  
  // 1. Ag-Grid가 로컬에 바로 다운로드 시켜버리는 기본 엑셀 메뉴들은 제외합니다.
  const filteredItems = defaultItems.filter(item => item !== 'excelExport' && item !== 'export')

  // 2. 가로채기용 커스텀 엑셀 메뉴 정의
  const customExcelMenu = {
    name: 'Excel 다운로드',
    action: () => {
      handleAgGridExcelIntercept()
    },
    icon: '<span class="ag-icon ag-icon-excel" style="color: #1f7246;"></span>'
  }

  // 3. 원래 메뉴 위치에 우리가 가로챈 메뉴 배치
  return [customExcelMenu, 'separator', ...filteredItems]
}

/**
 * Ag-Grid가 만든 엑셀 바이너리를 백엔드로 보내서 처리된 파일을 다운받는 함수
 */
const handleAgGridExcelIntercept = async () => {
  if (!gridApi.value) return

  try {
    // 1. Ag-Grid 내장 기능을 통해 화면 스타일 그대로 엑셀 파일(Blob)을 메모리에 만듭니다.
    // (이 시점에는 로컬 컴퓨터에 저장이 되지 않고 변수에만 담깁니다)
    const agExcelBlob = gridApi.value.getDataAsExcel({
      // 필요한 경우 Ag-Grid 공식 엑셀 옵션을 여기에 그대로 넣을 수 있습니다.
      // 예: exportMode: 'xlsx'
    })

    if (!agExcelBlob) {
      alert('엑셀 파일을 생성하지 못했습니다.')
      return
    }

    // 2. 파일 전송을 위해 Multipart FormData 객체 생성
    const formData = new FormData()
    // Ag-Grid가 뽑아준 blob 데이터와 파일명을 묶어서 append (파일명은 원하는 대로 변경 가능)
    formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`)

    // 3. 지정하신 백엔드 API 주소로 Ag-Grid가 만든 엑셀 파일 전송
    // 파일 스트림 응답을 깨지지 않고 그대로 받기 위해 responseType: 'blob' 설정
    const response = await api.post('/api/File/File', formData, {
      headers: {
        'Content-Type': 'multipart/form-data' // 파일 전송용 헤더 지정
      },
      responseType: 'blob' 
    })

    // 4. 백엔드가 DRM 처리 등을 마친 후 최종 리턴해 준 파일(Blob)을 유저에게 내려줌
    const returnBlob = new Blob([response.data], { 
      type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' 
    })
    
    const downloadUrl = window.URL.createObjectURL(returnBlob)
    const linkElement = document.createElement('a')
    
    linkElement.href = downloadUrl
    linkElement.download = `Excel_Report_${Date.now()}.xlsx` // 유저가 최종 다운로드 받을 파일명
    
    document.body.appendChild(linkElement)
    linkElement.click()
    
    // 메모리 정리
    document.body.removeChild(linkElement)
    window.URL.revokeObjectURL(downloadUrl)

  } catch (error) {
    console.error('Ag-Grid 엑셀 가로채기 후 백엔드 전송 실패:', error)
    alert('엑셀 다운로드 처리 중 오류가 발생했습니다.')
  }
}
