<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard 
      :title="{ icon: 'fa-list', title: 'Attribute 비교 분석', subtitle: '프로젝트 간 속성 정합성 체크' }" 
      class="w-100 h-100"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">프로젝트</span>
            <div class="dropdown">
              <div 
                class="form-control form-control-sm cursor-pointer d-flex justify-content-between align-items-center bg-white border-secondary-subtle"
                data-bs-toggle="dropdown" 
                data-bs-auto-close="outside"
                style="min-width: 200px; height: 32px;"
              >
                <span class="text-truncate small">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '선택하세요' }}
                </span>
                <i class="fa fa-caret-down ms-2 text-muted"></i>
              </div>
              <ul class="dropdown-menu p-2 shadow-lg" style="max-height: 400px; overflow-y: auto; width: 350px; z-index: 1060">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="검색..." @click.stop />
                </li>
                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold cursor-pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :checked="isAllSelected" :indeterminate="isIndeterminate" @change="toggleAllSelection" />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 cursor-pointer small">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <span class="text-truncate text-primary fw-bold">{{ proj.PROJ_NO }} <small class="text-muted">({{ proj.DESC }})</small></span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button class="tpl-btn tpl-btn--sm tpl-btn--primary" @click="onSearch" :disabled="selectedProjects.length === 0">
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">결과 검색</span>
            <div class="position-relative">
              <i class="fa fa-filter position-absolute text-muted" style="left: 10px; top: 50%; transform: translateY(-50%); z-index: 5;"></i>
              <textarea
                class="form-control form-control-sm custom-textarea-filter"
                v-model="attributeFilter"
                rows="1"
                placeholder="ID 입력 (엔터/쉼표 구분)"
              ></textarea>
            </div>
          </div>

          <div class="header-divider"></div>

          <div class="btn-group p-1 bg-light rounded-pill border" role="group">
            <input type="radio" class="btn-check" name="viewMode" id="modeSimple" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeSimple">간편</label>
            <input type="radio" class="btn-check" name="viewMode" id="modeDetail" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeDetail">상세</label>
          </div>
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue class="ag-theme-custom w-100 h-100" v-bind="gridOptions" @grid-ready="onGridReady" />
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import DefaultCard from '@/components/default/DefaultCard.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')
const urlProjNo = computed(() => route.query.project_no || '')

// --- 프로젝트 선택 로직 ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO?.toLowerCase().includes(kw) || p.DESC?.toLowerCase().includes(kw))
})

const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selInFil = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selInFil > 0 && selInFil < filteredProjectList.value.length
})

const toggleAllSelection = e => {
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = e.target.checked ? [...new Set([...selectedProjects.value, ...filteredIds])] : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Projectno: urlProjNo.value, Ep_id: urlEpId.value } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

// --- 데이터 조회 ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)
  try {
    const fetchPromises = selectedProjects.value.map(projNo =>
      axiosWrapper.post('/api/Attributes/Get', { ContainDeleted: false, ProjectNo: projNo }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } }).catch(() => [])
    )
    const results = await Promise.all(fetchPromises)
    const attrMap = new Map()
    results.forEach((data, idx) => {
      const pNo = selectedProjects.value[idx]
      if (Array.isArray(data)) {
        data.forEach(item => {
          if (!attrMap.has(item.ATT_ID)) attrMap.set(item.ATT_ID, { ATT_ID: item.ATT_ID, projects: {} })
          attrMap.get(item.ATT_ID).projects[pNo] = { EXIST: true, DESC: item.DESC || '', VAL_TYPE: item.VAL_TYPE || '', CL_ID: item.CL_ID || '' }
        })
      }
    })
    const processed = Array.from(attrMap.values()).map(row => {
      let isDiff = Object.keys(row.projects).length !== selectedProjects.value.length
      const fields = ['DESC', 'VAL_TYPE', 'CL_ID']
      if (!isDiff) {
        fields.forEach(f => {
          const vals = selectedProjects.value.map(p => row.projects[p][f])
          if (new Set(vals).size > 1) isDiff = true
        })
      }
      const resRow = { ATT_ID: row.ATT_ID, CONDITION: isDiff ? 'Diff' : 'Pass' }
      selectedProjects.value.forEach(p => { resRow[p] = row.projects[p] || { EXIST: false } })
      return resRow
    })
    dynamicCols.value = [...selectedProjects.value]
    gridRowData.value = processed
  } catch (e) { sAlert.Error('조회 실패') }
  finally { gridApi.value?.setGridOption('loading', false) }
}

// --- 그리드 옵션 (Floating Filter 제거) ---
const columnDefs = computed(() => {
  const cols = [
    { headerName: 'Condition', field: 'CONDITION', width: 100, pinned: 'left', cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) },
    { headerName: 'Attribute ID', field: 'ATT_ID', width: 180, pinned: 'left' },
  ]
  dynamicCols.value.forEach(proj => {
    const children = [{ headerName: 'Exist', valueGetter: p => (p.data[proj]?.EXIST ? 'OK' : '-'), width: 70, cellStyle: { textAlign: 'center' }, cellClassRules: { 'text-success fw-bold': p => p.data[proj]?.EXIST, 'bg-danger-light': p => !p.data[proj]?.EXIST } }]
    if (viewMode.value === 'detail') {
      children.push({ headerName: 'Desc', valueGetter: p => p.data[proj]?.DESC, width: 150 }, { headerName: 'Type', valueGetter: p => p.data[proj]?.VAL_TYPE, width: 90 })
    }
    cols.push({ headerName: proj, children })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  // 💡 중요: floatingFilter: false로 설정하여 헤더 밑 회색바 제거
  defaultColDef: { sortable: true, resizable: true, filter: true, floatingFilter: false },
  enableRangeSelection: true,
  cellSelection: true,
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const keywords = attributeFilter.value.split(/[\s,\n]+/).filter(k => k.trim() !== '').map(k => k.toLowerCase())
    return keywords.length === 0 || keywords.some(k => String(node.data.ATT_ID).toLowerCase().includes(k))
  },
}))

const onGridReady = p => { gridApi.value = p.api }
watch([attributeFilter, viewMode], () => { gridApi.value?.onFilterChanged() })
</script>

