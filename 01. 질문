<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="dropdown custom-single-select" style="min-width: 200px">
            <InputBox
              id="input-proj-merge"
              label="Project"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택"
              readonly
              data-bs-toggle="dropdown"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto;">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="Search..." @click.stop />
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item py-1 cursor-pointer" @click="selectProject(proj.PROJ_NO)">
                <div class="d-flex align-items-center justify-content-between">
                  <span :class="{ 'fw-bold text-primary': selectedProjNo === proj.PROJ_NO }">{{ proj.PROJ_NO }}</span>
                  <small class="text-muted text-truncate" style="max-width: 100px;">{{ proj.DESC }}</small>
                </div>
              </li>
            </ul>
          </div>

          <div class="dropdown custom-single-select" style="min-width: 200px">
            <InputBox
              id="input-reg-merge"
              label="Register No"
              v-model:value="selectedRegNo"
              placeholder="Register 선택"
              readonly
              :disabled="!registerList.length"
              data-bs-toggle="dropdown"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto;">
              <li class="px-2 pb-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="regSearchKeyword" placeholder="Search..." @click.stop />
              </li>
              <li v-for="reg in filteredRegisterList" :key="reg.REG_TYPE_ID" class="dropdown-item py-1 cursor-pointer" @click="selectRegister(reg.REG_TYPE_ID)">
                <span :class="{ 'fw-bold text-primary': selectedRegNo === reg.REG_TYPE_ID }">{{ reg.REG_TYPE_ID }}</span>
              </li>
              <li v-if="!registerList.length" class="dropdown-item text-muted small text-center">프로젝트를 먼저 선택하세요</li>
            </ul>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <button class="tpl-btn tpl-btn--sm btn-primary" @click="onMergeExecute" :disabled="!isMergeable">
              <i class="fa fa-object-group me-1"></i> Merge
            </button>
            <button class="tpl-btn tpl-btn--sm btn-outline-secondary bg-white border" @click="resetFilters" title="초기화">
              <i class="fa fa-sync text-muted"></i>
            </button>
          </div>
        </div>
      </template>

      <div class="flex-grow-1 w-100 h-100 overflow-hidden d-flex flex-column">
        <div class="grid-header-title d-flex justify-content-between align-items-center px-3 py-2">
          <span class="fw-bold small"><i class="fa fa-table me-2 text-primary"></i>Merged Data List</span>
          <div class="d-flex gap-3 align-items-center">
             <small class="text-muted">Total: <strong>{{ rowData.length }}</strong></small>
          </div>
        </div>
        
        <div class="flex-grow-1 border-top">
          <ag-grid-vue
            v-bind="gridOptions"
            class="ag-theme-custom w-100 h-100"
            :row-data="rowData"
            @grid-ready="onGridReady"
          />
        </div>
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, shallowRef } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'

const route = useRoute()
const cardTitle = { icon: 'fa-list', title: 'Data Merge 관리', subtitle: 'Working / Published 통합 데이터 조회' }

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjNo = ref('')

const registerList = ref([]) // Register No 리스트 전용
const regSearchKeyword = ref('')
const selectedRegNo = ref('')

const rowData = ref([])
const gridApi = shallowRef()

// --- Filtering ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC?.toLowerCase().includes(kw)))
})

const filteredRegisterList = computed(() => {
  const kw = regSearchKeyword.value.trim().toLowerCase()
  return registerList.value.filter(r => r.REG_TYPE_ID.toLowerCase().includes(kw))
})

const isMergeable = computed(() => selectedProjNo.value && selectedRegNo.value && rowData.value.length > 0)

// --- Events ---
const selectProject = async projNo => {
  selectedProjNo.value = projNo
  selectedRegNo.value = '' // 프로젝트 바뀌면 Register 초기화
  rowData.value = []
  await fetchRegisters() // Register 리스트 새로 가져오기
}

const selectRegister = async regNo => {
  selectedRegNo.value = regNo
  await fetchData() // Register 선택되면 실제 데이터 로드
}

const resetFilters = () => {
  selectedProjNo.value = ''; selectedRegNo.value = '';
  registerList.value = []; rowData.value = [];
}

// --- API Calls ---
const fetchProjects = async () => {
  const res = await axiosWrapper.get('/api/Project/Get')
  projectList.value = Array.isArray(res) ? res : []
}

// 💡 프로젝트에 딸린 Register(101TEST 등) 목록을 가져오는 API
const fetchRegisters = async () => {
  if (!selectedProjNo.value) return
  try {
    // API 주소는 프로젝트 규칙에 맞게 /api/TagType/Get 또는 /api/Register/Get 등으로 조정
    const res = await axiosWrapper.post('/api/TagType/Get', { 
      ProjectNo: selectedProjNo.value,
      ContainDeleted: false 
    })
    registerList.value = Array.isArray(res) ? res : []
  } catch (error) {
    console.error("Register Load Error:", error)
  }
}

// 💡 최종 병합 데이터 호출
const fetchData = async () => {
  if (!selectedProjNo.value || !selectedRegNo.value) return
  
  try {
    const payload = {
      ProjectNo: selectedProjNo.value,
      REG_TYPE_ID: selectedRegNo.value,
      Type: 'Merged'
    }
    const res = await axiosWrapper.post('/api/Data/GetMergedData', payload) 
    rowData.value = Array.isArray(res) ? res : []
  } catch (error) {
    console.error("Merge Data Load Error:", error)
    rowData.value = []
  }
}

const onMergeExecute = () => { console.log('Merge 실행') }

// --- AG Grid Config ---
const gridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Tag No', field: 'TAG_NO', width: 180, checkboxSelection: true, headerCheckboxSelection: true, pinned: 'left' },
    { headerName: 'Status', field: 'STATUS', width: 100 },
    { headerName: 'Description', field: 'DESC', flex: 1 },
    { headerName: 'Update Date', field: 'UPDATE_DT', width: 150 },
  ],
  defaultColDef: { resizable: true, sortable: true, filter: true },
  rowSelection: 'multiple',
}))

const onGridReady = p => { gridApi.value = p.api }

onMounted(async () => {
  await fetchProjects()
  const urlProjNo = route.query?.proj_no
  if (urlProjNo) {
    selectedProjNo.value = urlProjNo
    await fetchRegisters()
    // URL에 reg_no까지 있다면 자동 로드 로직 추가 가능
  }
})
</script>

