<template>
  <DefaultCard
    :title="cardTitle"
    icon="fa-th-list"
    class="h-100"
  >
    <!-- [header-right] InputBox 세트 + Toast 버튼 -->
    <template #header-right>
      <div class="d-flex align-items-center gap-2">
        <!-- 1. 프로젝트 (메모 스타일: 아이콘 없음) -->
        <InputBox
          id="input-proj"
          label="프로젝트"
          v-model:value="projectCode"
          placeholder="코드 입력"
          style="width: 150px"
        />
        <!-- 2. 키워드 (메모 스타일: 아이콘 없음) -->
        <InputBox
          id="input-keyword"
          label="키워드"
          v-model:value="keyword"
          placeholder="키워드 입력"
          style="width: 150px"
        />
        <!-- 3. 검색 (돋보기 아이콘 적용) -->
        <InputBox
          id="input-search"
          label="검색"
          v-model:value="attributeFilter"
          icon="fa-search"
          placeholder="검색어 입력"
          style="width: 180px"
          @clear="attributeFilter = ''"
        />

        <div class="header-divider"></div>

        <!-- Toast "확인/취소" 스타일의 조회 버튼 -->
        <button 
          type="button" 
          class="tpl-btn tpl-btn--sm tpl-btn--primary" 
          @click="confirmSearch"
        >
          조회
        </button>
      </div>
    </template>

    <!-- [contents] Ag-Grid Custom 테마 영역 -->
    <div class="grid-container">
      <ag-grid-vue
        class="ag-theme-custom h-100"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </DefaultCard>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { useToast } from '@/composables/useToast'

// 컴포넌트 임포트
import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const toast = useToast()

// 상태 관리
const cardTitle = {
  title: '재고 현황',
  subtitle: '창고별 집계 · 실시간 반영'
}

const projectCode = ref('')
const keyword = ref('')
const attributeFilter = ref('')

const gridApi = shallowRef()
const gridRowData = ref([])
const columnDefs = ref([])

// 1. Toast를 이용한 조회 확인 로직
const confirmSearch = () => {
  toast.show({
    title: '데이터 조회',
    content: '입력한 조건으로 조회를 시작하시겠습니까?',
    okText: '확인',
    cancelText: '취소',
    onOk: () => {
      fetchData()
    }
  })
}

// 2. 실제 데이터 조회 함수
const fetchData = async () => {
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  
  try {
    const res = await axiosWrapper.post('/api/Attributes/Get', { 
      ProjectNo: projectCode.value,
      Keyword: keyword.value 
    })
    
    gridRowData.value = Array.isArray(res) ? res : []
    
    // 컬럼 자동 생성
    if (gridRowData.value.length > 0) {
      columnDefs.value = Object.keys(gridRowData.value[0]).map(key => ({
        headerName: key,
        field: key,
        sortable: true,
        filter: true,
        resizable: true
      }))
    }
  } catch (error) {
    toast.fail({ title: '조회 실패', content: '데이터를 불러오지 못했습니다.' })
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// Ag-Grid 설정
const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  // 템플릿의 Ag-Grid 스타일 가이드 준수
}))

const onGridReady = (params) => {
  gridApi.value = params.api
}
</script>

<style scoped>
.grid-container {
  flex: 1;
  min-height: 0;
  height: 100%;
}

.header-divider {
  width: 1px;
  height: 16px;
  background-color: var(--tpl-divider);
  margin: 0 8px;
}

/* 템플릿 InputBox 레이아웃 조정 */
:deep(.input-box-container) {
  margin-bottom: 0;
}
</style>
