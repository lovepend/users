<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard
      :title="cardTitle"
      class="w-100 h-100"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="dropdown custom-single-select" style="min-width: 220px">
            <InputBox
              id="input-proj"
              label="프로젝트"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택/입력"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              @input="projSearchQuery = selectedProjNo"
              style="width: 100%"
            />
            <ul class="dropdown-menu shadow-lg p-0 w-100" style="max-height: 300px; overflow-y: auto;">
              <li v-for="proj in filteredProjectOptions" :key="proj.value">
                <a class="dropdown-item py-2 px-3 cursor-pointer" 
                   :class="{ 'active-proj': selectedProjNo === proj.value }"
                   @click="selectProject(proj.value)">
                  {{ proj.text }}
                </a>
              </li>
              <li v-if="filteredProjectOptions.length === 0" class="p-3 text-muted small text-center">
                검색 결과가 없습니다.
              </li>
            </ul>
          </div>

          <InputBox
            id="input-keyword"
            label="키워드"
            v-model:value="searchKeyword"
            placeholder="Tag No 입력"
            style="width: 160px"
          />

          <div class="header-divider"></div>

          <button 
            type="button" 
            class="tpl-btn tpl-btn--sm tpl-btn--primary me-2" 
            @click="confirmSearch"
          >
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="header-divider"></div>

          <InputBox
            id="input-filter"
            label="결과 검색"
            v-model:value="localFilterQuery"
            icon="fa-filter"
            placeholder="결과 내 실시간 찾기"
            style="width: 200px"
            class="border-success"
          />
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue
          class="ag-theme-custom w-100 h-100 custom-tag-analysis-grid"
          v-bind="gridOptions"
          @grid-ready="onGridReady"
        />
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { useToast } from '@/composables/useToast'
import { sAlert } from '@/utils/messages/alert-common'
import { sortBy } from 'lodash-es'

// 표준 컴포넌트
import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const toast = useToast()

// 상태 관리
const cardTitle = {
  icon: 'fa-search-plus',
  title: 'Tag 통합 분석',
  subtitle: 'Publish/Working 데이터 교차 비교'
}

const projectOptions = ref([])
const selectedProjNo = ref('')
const projSearchQuery = ref('')
const searchKeyword = ref('')
const localFilterQuery = ref('')

const gridApi = shallowRef()
const rawDataList = ref([])
const dynamicAttCols = ref([])

// 1. 프로젝트 리스트 조회 및 필터링 로직
const fetchProjectList = async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectOptions.value = (res || []).map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
  } catch (e) { console.error(e) }
}

const filteredProjectOptions = computed(() => {
  const query = projSearchQuery.value.toLowerCase()
  if (!query) return projectOptions.value
  return projectOptions.value.filter(p => p.text.toLowerCase().includes(query))
})

const selectProject = (val) => {
  selectedProjNo.value = val
  projSearchQuery.value = val
}

// 2 & 4. API 통합 조회 (Pub + Wrk)
const confirmSearch = () => {
  if (!selectedProjNo.value) return sAlert.Warning('프로젝트를 먼저 선택하세요.')
  
  toast.show({
    title: '통합 조회 시작',
    content: `[${selectedProjNo.value}] 프로젝트의 데이터를 분석하시겠습니까?`,
    okText: '조회',
    cancelText: '취소',
    onOk: () => fetchData()
  })
}

const fetchData = async () => {
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const payload = { ProjectNo: selectedProjNo.value, Keyword: searchKeyword.value }
    
    // 4. 공용(Publish) 및 작업(Working) 데이터 동시 호출
    const [pubRes, wrkRes] = await Promise.allSettled([
      axiosWrapper.post('/api/Data/SearchPublishData', payload),
      axiosWrapper.post('/api/Data/SearchWorkingData', payload)
    ])

    let combined = []
    if (pubRes.status === 'fulfilled' && pubRes.value) {
      const data = Array.isArray(pubRes.value) ? pubRes.value : [pubRes.value]
      combined.push(...data.map(i => ({ ...i, Source: 'Published' })))
    }
    if (wrkRes.status === 'fulfilled' && wrkRes.value) {
      const data = Array.isArray(wrkRes.value) ? wrkRes.value : [wrkRes.value]
      combined.push(...data.map(i => ({ ...i, Source: 'Working' })))
    }

    // 데이터 가공 (Attributes 평탄화)
    const allAttIds = new Set()
    combined.forEach(item => {
      (item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
    })

    const processedData = combined.map(item => {
      const flatItem = { ...item }
      allAttIds.forEach(id => {
        const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
        flatItem[`ATT_${id}`] = target ? target.VALUE : 'null'
      })
      return flatItem
    })

    // 동적 컬럼 생성
    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id,
      field: `ATT_${id}`,
      minWidth: 120,
      headerClass: 'att-column-header',
      cellRenderer: highlightRenderer, // 3. 하이라이트 적용
      cellStyle: p => ({ background: '#fff9db', color: p.value === 'null' ? '#adb5bd' : '#000' })
    }))

    rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
  } catch (err) {
    sAlert.Error('데이터 통합 중 오류 발생')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// 3. 결과 내 하이라이트 렌더러
const highlightRenderer = (p) => {
  const val = p.value === null || p.value === undefined ? '' : String(p.value)
  if (!val || !localFilterQuery.value.trim()) return val
  
  const kw = localFilterQuery.value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  return val.replace(new RegExp(`(${kw})`, 'gi'), `<mark class="filter-highlight">$1</mark>`)
}

// 그리드 설정
const gridOptions = computed(() => ({
  columnDefs: [
    { 
      headerName: 'Source', 
      field: 'Source', 
      width: 110, 
      pinned: 'left',
      cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'}; color:white;">${p.value}</span>`
    },
    { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'CLS_ID', headerName: 'Class', width: 120, pinned: 'left' },
    ...dynamicAttCols.value
  ],
  rowData: filteredData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  quickFilterText: localFilterQuery.value, // 그리드 자체 필터 기능 활용
  defaultColDef: { sortable: true, filter: true, resizable: true }
}))

const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const query = localFilterQuery.value.toLowerCase()
  return rawDataList.value.filter(i => 
    `${i.TAG_NO} ${i.TAG_IDX} ${i.CLS_ID} ${i.Source}`.toLowerCase().includes(query)
  )
})

const onGridReady = (params) => { gridApi.value = params.api }

onMounted(fetchProjectList)
</script>

