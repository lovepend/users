onMounted(() => {
  const baseSiteName = import.meta.env.VITE_BASE_SITENAME

  // 사이트 별 File Id 체크
  switch (baseSiteName) {
    case 'dev':
    case 'portal-dev':
      fileId.value = sitefileIds.dev
      break
    case 'devop':
    case 'portal-devop':
      fileId.value = sitefileIds.devop
      break
    default:
      fileId.value = sitefileIds.oper
      break
  }

  fetchAndParseExcel()
})
