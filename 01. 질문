<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard :title="cardTitle" class="w-100 h-100">
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="dropdown custom-single-select" style="min-width: 180px">
            <InputBox
              id="input-proj-merge"
              label="Project"
              v-model:value="selectedProjNo"
              placeholder="프로젝트 선택"
              readonly
              data-bs-toggle="dropdown"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto;">
              <li class="p-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="projSearchQuery" placeholder="Search..." @click.stop />
              </li>
              <li v-for="p in filteredProjectOptions" :key="p.value" class="dropdown-item py-1 cursor-pointer" @click="selectedProjNo = p.value">
                <span :class="{ 'fw-bold text-primary': selectedProjNo === p.value }">{{ p.text }}</span>
              </li>
            </ul>
          </div>

          <div class="dropdown custom-single-select" style="min-width: 180px">
            <InputBox
              id="input-reg-merge"
              label="Register"
              v-model:value="selectedRegTypeId"
              placeholder="ID 선택"
              readonly
              :disabled="!regOptions.length"
              data-bs-toggle="dropdown"
            />
            <ul class="dropdown-menu shadow-lg p-2 w-100" style="max-height: 300px; overflow-y: auto;">
              <li class="p-2 border-bottom mb-1">
                <input type="text" class="form-control form-control-sm" v-model="regSearchQuery" placeholder="Search..." @click.stop />
              </li>
              <li v-for="r in filteredRegOptions" :key="r.TYPE_ID" class="dropdown-item py-1 cursor-pointer" @click="selectedRegTypeId = r.TYPE_ID">
                <span :class="{ 'fw-bold text-primary': selectedRegTypeId === r.TYPE_ID }">{{ r.TYPE_ID }}</span>
              </li>
            </ul>
          </div>

          <div class="btn-group btn-group-sm ms-1" style="height: 32px;">
            <input type="radio" class="btn-check" id="type_working" value="Working" v-model="selectedType" />
            <label class="btn btn-outline-secondary d-flex align-items-center" for="type_working">Working</label>
            <input type="radio" class="btn-check" id="type_publish" value="Publish" v-model="selectedType" />
            <label class="btn btn-outline-secondary d-flex align-items-center" for="type_publish">Publish</label>
            <input type="radio" class="btn-check" id="type_merged" value="Merged" v-model="selectedType" />
            <label class="btn btn-outline-secondary d-flex align-items-center" for="type_merged">Merged</label>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <button class="tpl-btn tpl-btn--sm btn-primary" @click="onSearch" :disabled="!selectedRegTypeId">
              <i class="fa fa-search me-1"></i> 조회
            </button>
            <button class="tpl-btn tpl-btn--sm btn-outline-secondary bg-white border" @click="resetFilters">
              <i class="fa fa-sync text-muted"></i>
            </button>
          </div>
        </div>
      </template>

      <div class="flex-grow-1 w-100 h-100 overflow-hidden d-flex flex-column">
        <div class="grid-header-title d-flex justify-content-between align-items-center px-3 py-2">
          <span class="fw-bold small">
            <i class="fa fa-table me-2 text-primary"></i>
            {{ selectedType }} Data List <small v-if="selectedRegTypeId" class="text-muted ms-2">({{ selectedRegTypeId }})</small>
          </span>
          <small class="text-muted">Total: <strong>{{ rowData.length }}</strong></small>
        </div>
        
        <div class="flex-grow-1 border-top">
          <ag-grid-vue
            style="width: 100%; height: 100%;"
            class="ag-theme-custom"
            :column-defs="columnDefs"
            :row-data="rowData"
            @grid-ready="onGridReady"
            v-bind="gridOptions"
          />
        </div>
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, watch, onMounted, shallowRef } from 'vue'
import { useRoute } from 'vue-router' // URL 인식용 추가
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'

import DefaultCard from '@/components/default/DefaultCard.vue'
import InputBox from '@/components/default/editors/InputBox.vue'

const route = useRoute()
const cardTitle = { icon: 'fa-list', title: 'Data Merge 관리', subtitle: '속성 합집합 및 Diff 상태 조회' }

// --- 상태 관리 ---
const projectOptions = ref([])
const regOptions = ref([])
const selectedProjNo = ref('')
const selectedRegTypeId = ref('')
const selectedType = ref('Working')
const projSearchQuery = ref('')
const regSearchQuery = ref('')

const rowData = ref([])
const columnDefs = ref([]) 
const gridApi = shallowRef()

// --- 필터링 ---
const filteredProjectOptions = computed(() => {
  const q = projSearchQuery.value.toLowerCase()
  return projectOptions.value.filter(p => p.text.toLowerCase().includes(q))
})
const filteredRegOptions = computed(() => {
  const q = regSearchQuery.value.toLowerCase()
  return regOptions.value.filter(r => r.TYPE_ID.toLowerCase().includes(q))
})

// --- API 로직 ---
const fetchProjectList = async () => {
  const res = await axiosWrapper.get('/api/Project/Get')
  projectOptions.value = res.map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
}

// 💡 프로젝트 변경 감지하여 Register 목록 로드
const fetchRegisters = async (projNo) => {
  if (!projNo) return
  const res = await axiosWrapper.post('/api/Register/Get', { ProjectNo: projNo })
  if (res) regOptions.value = res
}

watch(selectedProjNo, async (newVal) => {
  selectedRegTypeId.value = ''; regOptions.value = []
  if (newVal) await fetchRegisters(newVal)
})

const onSearch = async () => {
  if (!selectedProjNo.value || !selectedRegTypeId.value) {
    return sAlert.Warning('Project No와 Register ID를 선택하세요.')
  }

  try {
    const payload = {
      ProjectNo: selectedProjNo.value,
      REG_TYPE_ID: selectedRegTypeId.value,
      Type: selectedType.value,
      ContainDeleted: false,
    }

    const response = await axiosWrapper.post('/api/Data/GetMergedData', payload)
    const resData = response.data || response
    const resultObj = resData[selectedRegTypeId.value]

    if (!resultObj) {
      rowData.value = []; columnDefs.value = [];
      return sAlert.Info('조회된 데이터가 없습니다.')
    }

    const diffMap = new Map()
    if (Array.isArray(resultObj.DiffData)) {
      resultObj.DiffData.forEach(d => { if (d.TAG_IDX) diffMap.set(d.TAG_IDX.toString(), d) })
    }

    let rawList = []
    if (selectedType.value === 'Working') rawList = resultObj.WrkData || []
    else if (selectedType.value === 'Publish') rawList = resultObj.PubData || []
    else if (selectedType.value === 'Merged') rawList = resultObj.MergeData || []

    const allKeys = new Set()
    const processedData = rawList.map(item => {
      const diffInfo = diffMap.get(item.TAG_IDX?.toString()) || {}
      let flat = { 선택: false }

      if (Array.isArray(item.ATTRIBUTES)) {
        item.ATTRIBUTES.forEach(attr => { if (attr.ATT_ID) flat[attr.ATT_ID] = attr.VALUE ?? '' })
      }

      Object.assign(flat, { ...item, Edit: diffInfo.EditType || '', Status: diffInfo.Status || '' })

      Object.keys(flat).forEach(key => {
        if (!['ATTRIBUTES', '__diffProps', '_id', '선택', 'Edit', 'Status'].includes(key) && typeof flat[key] !== 'object') {
          allKeys.add(key)
        }
      })
      return flat
    })

    const dynamicCols = [
      { headerName: 'Edit', field: 'Edit', width: 90, pinned: 'left', cellStyle: { textAlign: 'center', fontWeight: 'bold' } },
      { headerName: 'Status', field: 'Status', width: 100, pinned: 'left', cellStyle: { textAlign: 'center', fontWeight: 'bold' } },
      { headerName: 'Tag No', field: 'TAG_NO', width: 180, pinned: 'left', checkboxSelection: true, headerCheckboxSelection: true },
      ...Array.from(allKeys).filter(k => k !== 'TAG_NO').sort().map(key => ({
        headerName: key, field: key, minWidth: 130
      }))
    ]

    columnDefs.value = dynamicCols
    rowData.value = processedData
    sAlert.Success(`조회 완료: ${processedData.length}건`)
  } catch (err) {
    console.error(err); sAlert.Error('데이터 로드 실패')
  }
}

const resetFilters = () => {
  selectedProjNo.value = ''; selectedRegTypeId.value = ''; rowData.value = [];
}

const gridOptions = {
  defaultColDef: { resizable: true, sortable: true, filter: true, floatingFilter: true },
  rowSelection: 'multiple',
  suppressFieldDotNotation: true
}

const onGridReady = p => { gridApi.value = p.api }

// 💡 https://m.kpedia.jp/w/19171 최초 마운트 시 실행
onMounted(async () => {
  await fetchProjectList()
  
  // URL 쿼리 파라미터 확인 (?proj_no=TE1002 형태)
  const urlProjNo = route.query?.proj_no
  if (urlProjNo) {
    const exists = projectOptions.value.find(p => p.value === urlProjNo)
    if (exists) {
      selectedProjNo.value = urlProjNo
      // watch(selectedProjNo)에 의해 fetchRegisters가 자동 호출됩니다.
    }
  }
})
</script>

<style scoped lang="scss">
.header-divider { width: 1px; height: 14px; background-color: var(--tpl-divider); margin: 0 8px; }
.grid-header-title { background-color: var(--tpl-table-thead-bg, #f8f9fa); color: var(--tpl-body-color); }
