.header-divider { width: 1px; height: 14px; background-color: var(--tpl-divider); margin: 0 8px; }
.grid-header-title { background-color: var(--tpl-table-thead-bg, #f8f9fa); color: var(--tpl-body-color); }
:deep(.ag-theme-custom) {
  --ag-background-color: var(--card-bg, #ffffff);
  --ag-foreground-color: var(--tpl-body-color, #212529);
  --ag-header-background-color: var(--tpl-table-thead-bg, #f8f9fa);
  --ag-border-color: var(--tpl-divider, #dee2e6);
