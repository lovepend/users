<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard
      :title="{ icon: 'fa-sitemap', title: 'Object Class 비교 분석', subtitle: '프로젝트 간 클래스 구조 및 속성 정합성 체크' }"
      class="w-100 h-100"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">프로젝트</span>
            <div class="dropdown">
              <div class="ui-tag-tab-box" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <span class="text-truncate">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
                </span>
                <i class="fa fa-caret-down text-muted small"></i>
              </div>
              <ul class="dropdown-menu p-3 shadow-lg" style="max-height: 500px; overflow-y: auto; width: 400px; z-index: 1060">
                <li class="px-1 pb-2 border-bottom mb-2" @click.stop>
                  <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="fa fa-search text-muted"></i></span>
                    <input type="text" class="form-control" v-model="projectSearchKeyword" placeholder="번호/명 검색..." />
                  </div>
                </li>
                <li class="dropdown-item px-2 py-2 border-bottom mb-1 bg-light rounded" @click.stop>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="allCheckClass" :checked="isAllSelected" :indeterminate="isIndeterminate" @change="toggleAllSelection" />
                    <label class="form-check-label fw-bold w-100 ms-1 cursor-pointer small" for="allCheckClass">전체 선택 / 해제</label>
                  </div>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1 rounded" @click.stop>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" :id="'cls_proj_' + proj.PROJ_NO" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <label class="form-check-label w-100 ms-1 cursor-pointer small fw-normal" :for="'cls_proj_' + proj.PROJ_NO">
                      <span class="text-primary fw-bold">{{ proj.PROJ_NO }}</span>
                      <span class="text-muted ms-2 small">{{ proj.DESC }}</span>
                    </label>
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <button class="ui-tag-tab-search-btn" @click="onSearch" :disabled="selectedProjects.length === 0">
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="header-divider"></div>

          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
            <input type="radio" class="btn-check" name="clsViewMode" id="clsModeSimple" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="clsModeSimple">간편 조회</label>
            <input type="radio" class="btn-check" name="clsViewMode" id="clsModeDetail" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="clsModeDetail">상세 조회</label>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">ID 검색</span>
            <textarea class="ui-tag-tab-textarea shadow-sm" v-model="attributeFilter" rows="1" placeholder="Class ID 입력 (엔터/쉼표)"></textarea>
          </div>
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue class="ag-theme-custom w-100 h-100" v-bind="gridOptions" @grid-ready="onGridReady" />
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import DefaultCard from '@/components/default/DefaultCard.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')
const urlProjNo = computed(() => route.query.project_no || '')

// Object Class 전용 비교 필드
const COMPARE_FIELDS = ['DESC', 'PRT_CLS_ID', 'TAG_TYPE_ID']

// --- 프로젝트 선택 로직 ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO?.toLowerCase().includes(kw) || p.DESC?.toLowerCase().includes(kw))
})

const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
})

const toggleAllSelection = e => {
  const checked = e.target.checked
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = checked ? [...new Set([...selectedProjects.value, ...filteredIds])] : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Projectno: urlProjNo.value, Ep_id: urlEpId.value } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

// --- 데이터 조회 및 가공 (ObjectClass) ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)
  
  try {
    const fetchPromises = selectedProjects.value.map(projNo =>
      axiosWrapper.post('/api/ObjectClass/Get', { ContainDeleted: false, ProjectNo: projNo }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } }).catch(() => [])
    )

    const results = await Promise.all(fetchPromises)
    const classMap = new Map()

    results.forEach((data, index) => {
      const currentProjNo = selectedProjects.value[index]
      if (Array.isArray(data)) data.forEach(item => {
        if (!classMap.has(item.CLS_ID)) classMap.set(item.CLS_ID, { CLS_ID: item.CLS_ID, projects: {} })
        classMap.get(item.CLS_ID).projects[currentProjNo] = { 
          EXIST: true, 
          DESC: item.DESC || '', 
          PRT_CLS_ID: item.PRT_CLS_ID || '', 
          TAG_TYPE_ID: item.TAG_TYPE_ID || '' 
        }
      })
    })

    const processedData = Array.from(classMap.values()).map(row => {
      let isDiff = Object.keys(row.projects).length !== selectedProjects.value.length
      let diffDetails = []
      if (isDiff) diffDetails.push('Exist')

      COMPARE_FIELDS.forEach(field => {
        const values = selectedProjects.value.filter(p => row.projects[p]).map(p => row.projects[p][field])
        if (new Set(values).size > 1) { isDiff = true; diffDetails.push(field) }
      })

      const resultRow = { CLS_ID: row.CLS_ID, CONDITION: isDiff ? 'Diff' : 'Pass', DIFF_INFO: diffDetails.join(', ') }
      selectedProjects.value.forEach(p => { resultRow[p] = row.projects[p] || { EXIST: false } })
      return resultRow
    })

    dynamicCols.value = [...selectedProjects.value]
    gridRowData.value = processedData
  } catch (e) { sAlert.Error('조회 실패') }
  finally { gridApi.value?.setGridOption('loading', false) }
}

// --- 그리드 설정 ---
const multiFilterParams = {
  filters: [{ filter: 'agTextColumnFilter', filterParams: { debounceMs: 0 } }, { filter: 'agSetColumnFilter' }]
}

const columnDefs = computed(() => {
  const cols = [
    { 
      headerName: 'Condition', field: 'CONDITION', width: 110, pinned: 'left',
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams,
      cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) 
    },
    { 
      headerName: 'Diff Info', field: 'DIFF_INFO', width: 140, pinned: 'left',
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams,
      cellStyle: { fontSize: '11px', color: '#dc3545', fontWeight: 'bold' }
    },
    { 
      headerName: 'Class ID', field: 'CLS_ID', width: 180, pinned: 'left',
      filter: 'agMultiColumnFilter', filterParams: multiFilterParams
    },
  ]

  dynamicCols.value.forEach(proj => {
    const children = [
      { 
        headerName: 'Exist', valueGetter: p => (p.data[proj]?.EXIST ? 'Y' : '-'), width: 80, 
        filter: 'agMultiColumnFilter', filterParams: multiFilterParams,
        cellStyle: { textAlign: 'center' },
        cellRenderer: p => p.value === 'Y' ? `<i class="fa fa-check-circle text-success" style="font-size: 1rem;"></i>` : `<span class="text-muted">-</span>`
      }
    ]

    if (viewMode.value === 'detail') {
      children.push(
        { headerName: 'Description', valueGetter: p => p.data[proj]?.DESC, width: 200, filter: 'agMultiColumnFilter', filterParams: multiFilterParams },
        { headerName: 'Parent ID', valueGetter: p => p.data[proj]?.PRT_CLS_ID, width: 150, filter: 'agMultiColumnFilter', filterParams: multiFilterParams },
        { headerName: 'Tag Type', valueGetter: p => p.data[proj]?.TAG_TYPE_ID, width: 120, filter: 'agMultiColumnFilter', filterParams: multiFilterParams }
      )
    }
    cols.push({ headerName: proj, children })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, resizable: true, filter: true, floatingFilter: true },
  enableRangeSelection: true,
  rowSelection: 'multiple',
  statusBar: {
    statusPanels: [
      { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'left' },
      { statusPanel: 'agSelectedRowCountComponent', align: 'right' },
    ]
  },
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const inputIds = attributeFilter.value.split(/[\s,\n]+/).filter(id => id.trim() !== '').map(id => id.toLowerCase())
    return inputIds.length === 0 || inputIds.some(id => String(node.data.CLS_ID || '').toLowerCase().includes(id))
  },
}))

const onGridReady = p => { gridApi.value = p.api }
watch([attributeFilter, viewMode], () => { gridApi.value?.onFilterChanged() })
</script>

