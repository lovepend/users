<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <DefaultCard
      :title="{ icon: 'fa-tags', title: 'Tag No 비교 분석', subtitle: '프로젝트 간 클래스 트리 기준 정합성 체크' }"
      class="w-100 h-100"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">프로젝트</span>
            <div class="dropdown">
              <div class="ui-tag-tab-box" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <span class="text-truncate">{{
                  selectedProjects.length > 0 ? selectedProjects.join(', ') : '선택하세요'
                }}</span>
                <i class="fa fa-caret-down text-muted small"></i>
              </div>
              <ul
                class="dropdown-menu p-2 shadow-lg"
                style="max-height: 400px; overflow-y: auto; width: 350px; z-index: 1060"
              >
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="검색..."
                    @click.stop
                  />
                </li>
                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold cursor-pointer small">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :checked="isAllSelected"
                      :indeterminate="isIndeterminate"
                      @change="toggleAllSelection"
                    />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 cursor-pointer small fw-normal">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :value="proj.PROJ_NO"
                      v-model="selectedProjects"
                    />
                    <span class="text-primary">{{ proj.PROJ_NO }}</span>
                    <small class="text-muted ms-1">({{ proj.DESC }})</small>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">Object Class 트리</span>
            <div class="dropdown">
              <div class="ui-tag-tab-box" data-bs-toggle="dropdown" data-bs-auto-close="outside" style="width: 260px;">
                <span class="text-truncate text-primary fw-bold">
                  {{ selectedClassId ? selectedClassId : '클래스를 선택하세요' }}
                </span>
                <i class="fa fa-sitemap text-muted small"></i>
              </div>
              <div
                class="dropdown-menu p-3 shadow-lg"
                style="max-height: 450px; overflow-y: auto; width: 380px; z-index: 1060;"
              >
                <div class="px-1 pb-2 border-bottom mb-2" @click.stop>
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="classSearchKeyword"
                    placeholder="클래스 ID 검색..."
                  />
                </div>

                <div v-if="filteredTreeData.length === 0" class="text-muted small text-center py-2">
                  <i class="fa fa-exclamation-circle me-1"></i> 검색 결과가 없거나 프로젝트를 선택해 주세요.
                </div>
                
                <div class="class-tree-root" v-else>
                  <TreeItem 
                    v-for="node in filteredTreeData" 
                    :key="node.CLS_ID" 
                    :node="node" 
                    :selected-id="selectedClassId"
                    @select="handleClassSelect"
                  />
                </div>
              </div>
            </div>
          </div>

          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
            <input type="radio" class="btn-check" name="dataMode" id="modePub" value="PUB" v-model="dataMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modePub">PUB</label>
            <input type="radio" class="btn-check" name="dataMode" id="modeWork" value="WORK" v-model="dataMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeWork">WORK</label>
          </div>

          <button class="ui-tag-tab-search-btn" @click="onSearch" :disabled="selectedProjects.length === 0 || !selectedClassId">
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="header-divider"></div>

          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
            <input type="radio" class="btn-check" name="viewMode" id="modeSimple" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeSimple">간편 조회</label>
            <input type="radio" class="btn-check" name="viewMode" id="modeDetail" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeDetail">상세 조회</label>
          </div>

          <div class="header-divider"></div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">결과 검색</span>
            <textarea
              class="ui-tag-tab-textarea shadow-sm"
              v-model="attributeFilter"
              rows="1"
              placeholder="Tag No 입력 (엔터/쉼표)"
            ></textarea>
          </div>
        </div>
      </template>

      <div class="grid-wrapper w-100 h-100">
        <ag-grid-vue class="ag-theme-custom w-100 h-100" v-bind="gridOptions" @grid-ready="onGridReady" />
      </div>
    </DefaultCard>
  </div>
</template>

<script setup>
  import { ref, computed, shallowRef, onMounted, watch, defineComponent, h } from 'vue'
  import { useRoute } from 'vue-router'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import { sAlert } from '@/utils/messages/alert-common'
  import DefaultCard from '@/components/default/DefaultCard.vue'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

  const route = useRoute()

  // --- State ---
  const projectList = ref([])
  const projectSearchKeyword = ref('')
  const selectedProjects = ref([])
  
  const rawClassList = ref([])      
  const classSearchKeyword = ref('') 
  const selectedClassId = ref('')   
  
  const dataMode = ref('PUB')        // PUB 또는 WORK 상태 관리용 밸류 변수 추가
  const attributeFilter = ref('')
  const viewMode = ref('simple')
  const gridApi = shallowRef()
  const gridRowData = ref([])
  const dynamicCols = ref([])

  const urlEpId = computed(() => route.query.ep_id || '')
  const urlProjNo = computed(() => route.query.project_no || '')

  const COMPARE_FIELDS = computed(() => {
    return viewMode.value === 'simple' 
      ? ['CLS_ID'] 
      : ['CLS_ID', 'TAG_IDX', 'TAG_DESC', 'EP_IC', 'EP_ID', 'DELETED']
  })

  // 데이터 모드 상태에 따른 동적 타겟 엔드포인트 URL 분기 처리식
  const targetApiUrl = computed(() => {
    return dataMode.value === 'PUB' 
      ? '/api/Data/SearchPublishData' 
      : '/api/Data/SearchWorkingData'
  })

  // --- [1] 순수 텍스트 트리 자식 노드 컴포넌트 구성 ---
  const TreeItem = defineComponent({
    name: 'TreeItem',
    props: {
      node: { type: Object, required: true },
      selectedId: { type: String, default: '' }
    },
    emits: ['select'],
    setup(props, { emit }) {
      const isOpen = ref(true)
      
      const toggleOpen = (e) => {
        e.stopPropagation()
        isOpen.value = !isOpen.value
      }

      const selectNode = (e) => {
        e.stopPropagation()
        emit('select', props.node.CLS_ID)
      }

      return () => {
        const hasChildren = props.node.children && props.node.children.length > 0
        const isCurrentSelected = props.node.CLS_ID === props.selectedId

        return h('div', { class: 'tree-item-node', style: { paddingLeft: '16px' } }, [
          h('div', { 
            class: `tree-node-label d-flex align-items-center gap-1 py-1 my-1 rounded cursor-pointer transition-all ${
              isCurrentSelected ? 'bg-primary text-white px-2 fw-bold shadow-sm' : 'text-dark px-1'
            }`,
            onClick: selectNode
          }, [
            hasChildren 
              ? h('i', { 
                  class: `fa ${isOpen.value ? 'fa-caret-down' : 'fa-caret-right'} me-1 p-1 text-muted`, 
                  style: { color: isCurrentSelected ? '#ffffff !important' : '' },
                  onClick: toggleOpen 
                })
              : h('span', { style: { display: 'inline-block', width: '16px' } }),
            
            h('i', { 
              class: `fa ${hasChildren ? 'fa-folder-open' : 'fa-file-code'} small`,
              style: { color: isCurrentSelected ? '#ffffff' : (hasChildren ? '#ffc107' : '#17a2b8') }
            }),
            h('span', { class: 'small ms-1' }, props.node.CLS_ID)
          ]),
          
          (hasChildren && isOpen.value)
            ? h('div', { class: 'tree-node-children' }, 
                props.node.children.map(child => h(TreeItem, { 
                  node: child, 
                  selectedId: props.selectedId,
                  onSelect: (id) => emit('select', id)
                }))
              )
            : null
        ])
      }
    }
  })

  // --- [2] 기준 프로젝트 변경에 따른 클래스 트리 갱신 ---
  const baseProjectNo = computed(() => selectedProjects.value[0] || '')

  const fetchObjectClassTree = async (projNo) => {
    if (!projNo) {
      rawClassList.value = []
      selectedClassId.value = ''
      return
    }
    try {
      const res = await axiosWrapper.post('/api/ObjectClass/Get', { ProjectNo: projNo }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } })
      rawClassList.value = Array.isArray(res) ? res : []
    } catch (e) {
      console.error(e)
      rawClassList.value = []
    }
  }

  watch(baseProjectNo, (newProjNo) => {
    fetchObjectClassTree(newProjNo)
  })

  // --- [3] 검색 키워드 필터 트리기반 데이터 셋 변환 ---
  const filteredTreeData = computed(() => {
    const searchKw = classSearchKeyword.value.trim().toLowerCase()
    
    const map = {}
    rawClassList.value.forEach(item => {
      map[item.CLS_ID] = { ...item, children: [] }
    })

    const roots = []
    rawClassList.value.forEach(item => {
      const parentId = item.PRT_CLS_ID
      if (parentId && map[parentId]) {
        map[parentId].children.push(map[item.CLS_ID])
      } else {
        roots.push(map[item.CLS_ID])
      }
    })

    if (!searchKw) return roots

    const filterTree = (nodes) => {
      return nodes
        .map(node => {
          const matchedChildren = node.children ? filterTree(node.children) : []
          const isMatch = node.CLS_ID.toLowerCase().includes(searchKw)
          
          if (isMatch || matchedChildren.length > 0) {
            return { ...node, children: matchedChildren }
          }
          return null
        })
        .filter(Boolean)
    }

    return filterTree(roots)
  })

  const handleClassSelect = (clsId) => {
    selectedClassId.value = clsId
  }

  // --- [4] 클래스 자식 포함 다단계 하위 추출 재귀함수 ---
  const getAllChildClassIds = (targetId) => {
    const targetNode = rawClassList.value.find(c => c.CLS_ID === targetId)
    if (!targetNode) return [targetId]

    const collected = [targetId]
    const traverse = (id) => {
      rawClassList.value.forEach(item => {
        if (item.PRT_CLS_ID === id) {
          collected.push(item.CLS_ID)
          traverse(item.CLS_ID)
        }
      })
    }
    traverse(targetId)
    return [...new Set(collected)]
  }

  // --- 프로젝트 셀렉트 핸들링 구역 ---
  const filteredProjectList = computed(() => {
    const kw = projectSearchKeyword.value.trim().toLowerCase()
    return projectList.value.filter(
      p => !kw || p.PROJ_NO?.toLowerCase().includes(kw) || p.DESC?.toLowerCase().includes(kw)
    )
  })

  const isAllSelected = computed(
    () => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO))
  )
  const isIndeterminate = computed(() => {
    const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
    return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
  })

  const toggleAllSelection = e => {
    const checked = e.target.checked
    const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
    selectedProjects.value = checked
      ? [...new Set([...selectedProjects.value, ...filteredIds])]
      : selectedProjects.value.filter(id => !filteredIds.includes(id))
  }

  onMounted(async () => {
    try {
      const res = await axiosWrapper.get('/api/Project/Get', {
        headers: { Projectno: urlProjNo.value, Ep_id: urlEpId.value },
      })
      projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
    } catch (e) {
      console.error(e)
    }
  })

  // --- [5] 태그 데이터 통합 비동기 조회 코어 엔진 ---
  const onSearch = async () => {
    if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
    if (!selectedClassId.value) return sAlert.Warning('대조할 Object Class를 선택하세요.')
    
    gridApi.value?.setGridOption('loading', true)
    const allTargetClassIds = getAllChildClassIds(selectedClassId.value)

    try {
      const fetchPromises = []

      selectedProjects.value.forEach(projNo => {
        allTargetClassIds.forEach(clsId => {
          const promise = axiosWrapper
            .post(
              targetApiUrl.value, // 동적 타겟 API 라우터 반영 적용
              { Keyword: clsId, ProjectNo: projNo },
              { headers: { Projectno: projNo, Ep_id: urlEpId.value } }
            )
            .then(res => ({ projNo, data: Array.isArray(res) ? res : [] }))
            .catch(() => ({ projNo, data: [] }))
          
          fetchPromises.push(promise)
        })
      })

      const rawResults = await Promise.all(fetchPromises)
      const tagMap = new Map()

      rawResults.forEach(({ projNo, data }) => {
        data.forEach(item => {
          if (!item.TAG_NO) return 
          
          if (!tagMap.has(item.TAG_NO)) {
            tagMap.set(item.TAG_NO, { TAG_NO: item.TAG_NO, projects: {} })
          }
          
          tagMap.get(item.TAG_NO).projects[projNo] = {
            EXIST: true,
            CLS_ID: item.CLS_ID || '',
            TAG_IDX: item.TAG_IDX ?? '',
            TAG_DESC: item.TAG_DESC || '',
            EP_IC: item.EP_IC || '',
            EP_ID: item.EP_ID || '',
            DELETED: item.DELETED ?? '',
          }
        })
      })

      const processedData = Array.from(tagMap.values()).map(row => {
        let isDiff = Object.keys(row.projects).length !== selectedProjects.value.length
        let diffDetails = []
        if (isDiff) diffDetails.push('Exist')

        COMPARE_FIELDS.value.forEach(field => {
          const values = selectedProjects.value
            .filter(p => row.projects[p])
            .map(p => row.projects[p][field])
          
          if (new Set(values).size > 1) {
            isDiff = true
            if (!diffDetails.includes(field)) diffDetails.push(field)
          }
        })

        const resultRow = { 
          TAG_NO: row.TAG_NO, 
          CONDITION: isDiff ? 'Diff' : 'Pass', 
          DIFF_INFO: diffDetails.join(', ') 
        }

        selectedProjects.value.forEach(p => {
          resultRow[p] = row.projects[p] || { EXIST: false }
        })
        return resultRow
      })

      dynamicCols.value = [...selectedProjects.value]
      gridRowData.value = processedData
    } catch (e) {
      sAlert.Error('조회 처리 중 에러가 발생했습니다.')
    } finally {
      gridApi.value?.setGridOption('loading', false)
    }
  }

  // --- Ag Grid 설정 정의 ---
  const setFilterParams = {
    filters: [{ filter: 'agTextColumnFilter', filterParams: { debounceMs: 0 } }, { filter: 'agSetColumnFilter' }],
  }

  const columnDefs = computed(() => {
    const cols = [
      {
        headerName: 'Condition',
        field: 'CONDITION',
        width: 110,
        pinned: 'left',
        filter: 'agMultiColumnFilter',
        filterParams: setFilterParams,
        cellStyle: p => ({
          color: p.value === 'Diff' ? '#dc3545' : '#198754',
          fontWeight: 'bold',
          textAlign: 'center',
          backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8',
        }),
      },
      {
        headerName: 'Diff Info',
        field: 'DIFF_INFO',
        width: 140,
        pinned: 'left',
        filter: 'agMultiColumnFilter',
        filterParams: setFilterParams,
        cellStyle: { fontSize: '11px', color: '#dc3545', fontWeight: 'bold' },
      },
      {
        headerName: 'Tag No',
        field: 'TAG_NO',
        width: 220,
        pinned: 'left',
        filter: 'agMultiColumnFilter',
        filterParams: setFilterParams,
      },
    ]

    dynamicCols.value.forEach(proj => {
      const children = [
        {
          headerName: 'Exist',
          valueGetter: p => (p.data[proj]?.EXIST ? 'Alive' : '-'),
          width: 85,
          filter: 'agMultiColumnFilter',
          filterParams: setFilterParams,
          cellStyle: { textAlign: 'center' },
          cellRenderer: p =>
            p.value === 'Alive'
              ? `<i class="fa fa-check-circle text-success"></i>`
              : `<span class="text-muted">-</span>`,
        },
        {
          headerName: 'Class ID',
          valueGetter: p => p.data[proj]?.CLS_ID,
          width: 120,
          filter: 'agMultiColumnFilter',
          filterParams: setFilterParams,
        }
      ]

      if (viewMode.value === 'detail') {
        children.push(
          { headerName: 'Tag Idx', valueGetter: p => p.data[proj]?.TAG_IDX, width: 90, filter: 'agMultiColumnFilter', filterParams: setFilterParams },
          { headerName: 'Tag Desc', valueGetter: p => p.data[proj]?.TAG_DESC, width: 150, filter: 'agMultiColumnFilter', filterParams: setFilterParams },
          { headerName: 'EP IC', valueGetter: p => p.data[proj]?.EP_IC, width: 90, filter: 'agMultiColumnFilter', filterParams: setFilterParams },
          { headerName: 'EP ID', valueGetter: p => p.data[proj]?.EP_ID, width: 90, filter: 'agMultiColumnFilter', filterParams: setFilterParams },
          { headerName: 'Deleted', valueGetter: p => p.data[proj]?.DELETED, width: 90, filter: 'agMultiColumnFilter', filterParams: setFilterParams }
        )
      }
      cols.push({ headerName: proj, children })
    })
    return cols
  })

  const gridOptions = computed(() => ({
    columnDefs: columnDefs.value,
    rowData: gridRowData.value,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: { sortable: true, resizable: true, filter: true, floatingFilter: true, flex: 0 },
    enableRangeSelection: true,
    copyHeadersToClipboard: false,
    rowSelection: 'multiple',
    statusBar: {
      statusPanels: [
        { statusPanel: 'agTotalAndFilteredRowCountComponent', align: 'left' },
        { statusPanel: 'agSelectedRowCountComponent', align: 'right' },
      ],
    },
    isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
    doesExternalFilterPass: node => {
      const inputIds = attributeFilter.value.split(/[\s,\n]+/).filter(id => id.trim() !== '').map(id => id.toLowerCase())
      return inputIds.length === 0 || inputIds.some(id => String(node.data.TAG_NO || '').toLowerCase().includes(id))
    },
  }))

  const onGridReady = p => {
    gridApi.value = p.api
  }

  watch(viewMode, () => {
    gridApi.value?.setGridOption('columnDefs', columnDefs.value)
  })
  watch(attributeFilter, () => {
    gridApi.value?.onFilterChanged()
  })
</script>

