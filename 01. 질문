<template>
  <div class="adapter-compare-page h-100 w-100 d-flex flex-column bg-white">
    <DefaultCard
      :title="{
        icon: 'fa-project-diagram',
        title: 'Adapter Mapping 비교 분석',
        subtitle: '프로젝트 간 매핑 차이를 분석하고 상세 내역을 대조합니다.',
      }"
      class="flex-grow-1"
      body-class="p-0 d-flex flex-column"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">대상 프로젝트</span>
            <div class="dropdown">
              <div class="ui-tag-tab-box dropdown-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <span class="text-truncate">{{
                  selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트 선택'
                }}</span>
              </div>
              <ul
                class="dropdown-menu p-2 shadow-lg border-0"
                style="width: 300px; max-height: 400px; overflow-y: auto; z-index: 1060"
              >
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="검색..."
                    @click.stop
                  />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 cursor-pointer small">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :value="proj.PROJ_NO"
                      v-model="selectedProjects"
                    />
                    <span>{{ proj.PROJ_NO }}</span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button class="ui-tag-tab-search-btn" @click="onSearch" :disabled="selectedProjects.length === 0">
            조회
          </button>

          <div class="header-divider mx-2"></div>

          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border">
            <input type="radio" class="btn-check" id="modeS" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeS">간편</label>
            <input type="radio" class="btn-check" id="modeD" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeD">상세</label>
          </div>

          <div class="header-divider mx-2"></div>

          <textarea class="ui-tag-tab-textarea" v-model="attributeFilter" placeholder="MAP_ID 필터..."></textarea>
        </div>
      </template>

      <div class="grid-wrapper flex-grow-1 border-top bg-white">
        <ag-grid-vue
          style="width: 100%; height: 100%; position: absolute"
          class="ag-theme-custom"
          :columnDefs="mainColumnDefs"
          :rowData="gridRowData"
          :defaultColDef="defaultColDef"
          :loadingOverlayComponent="AggridLoadingOverlay"
          :isExternalFilterPresent="isExternalFilterPresent"
          :doesExternalFilterPass="doesExternalFilterPass"
          @grid-ready="onGridReady"
          @cell-clicked="onCellClicked"
        />
      </div>
    </DefaultCard>

    <div v-if="showDiffModal" class="custom-modal-overlay" @click.self="closeDiffModal">
      <div 
        class="custom-modal-window shadow-lg draggable-modal" 
        :style="modalPos"
      >
        <div class="modal-header-dark cursor-move" @mousedown="startDrag">
          <h6 class="modal-title small mb-0">
            <i class="fa fa-copy me-2"></i>상세 비교 분석 [<span class="text-warning">{{ selectedMapId }}</span>] (이동 가능)
          </h6>
          <button @click="closeDiffModal" class="btn btn-xs btn-danger shadow-none">✕</button>
        </div>
        
        <div class="modal-body p-0 d-flex flex-column" style="height: 60vh; background: #fff">
          <div class="bg-light p-2 border-bottom d-flex gap-1">
            <button
              v-for="t in ['MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']"
              :key="t"
              class="btn btn-xs px-3"
              :class="activeTab === t ? 'btn-primary fw-bold' : 'btn-white border'"
              @click="activeTab = t"
            >
              {{ t }}
            </button>
          </div>
          <div class="flex-grow-1 position-relative">
            <ag-grid-vue
              style="width: 100%; height: 100%; position: absolute"
              class="ag-theme-custom"
              :columnDefs="modalColumnDefs"
              :rowData="modalRowData"
              :defaultColDef="defaultColDef"
            />
          </div>
        </div>
        
        <div class="modal-footer py-1 bg-light border-top text-end">
          <button type="button" class="btn btn-secondary btn-xs px-3" @click="closeDiffModal">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch, nextTick, reactive } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import DefaultCard from '@/components/default/DefaultCard.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

// --- 모달 위치 및 드래그 상태 ---
const showDiffModal = ref(false)
const modalPos = reactive({
  top: '200px',
  left: '50%',
  transform: 'translateX(-50%)',
  width: '1200px',
  position: 'absolute'
})

const startDrag = (event) => {
  const modal = event.currentTarget.parentElement
  let shiftX = event.clientX - modal.getBoundingClientRect().left
  let shiftY = event.clientY - modal.getBoundingClientRect().top

  const moveAt = (pageX, pageY) => {
    modalPos.left = (pageX - shiftX) + 'px'
    modalPos.top = (pageY - shiftY) + 'px'
    modalPos.transform = 'none'
  }

  const onMouseMove = (e) => moveAt(e.pageX, e.pageY)
  document.addEventListener('mousemove', onMouseMove)
  document.onmouseup = () => {
    document.removeEventListener('mousemove', onMouseMove)
    document.onmouseup = null
  }
}

const closeDiffModal = () => {
  showDiffModal.value = false
  modalPos.top = '200px'
  modalPos.left = '50%'
  modalPos.transform = 'translateX(-50%)'
}

// --- 기존 로직 상태 관리 ---
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])
const selectedProjects = ref([])
const projectList = ref([])
const projectSearchKeyword = ref('')
const attributeFilter = ref('')
const viewMode = ref('simple')
const selectedMapId = ref('')
const activeTab = ref('MAP_ATT')
const modalRowData = ref([])
const clickedRow = ref(null)

const COMPARE_FIELDS = ['DESC', 'REG_TYPE_ID', 'CATEGORY', 'TOOL_ID', 'TOOL_TYPE', 'MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']
const TAB_KEY_MAP = { MAP_ATT: 'SEDP_ATT_ID', MAP_CLS: 'SEDP_OBJ_CLS_ID', MAP_TMPLS: 'TMP_ID', MAP_RELS: 'REL_ID' }

const defaultColDef = { sortable: true, resizable: true, filter: 'agTextColumnFilter', floatingFilter: true, minWidth: 100 }

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw))
})

const onGridReady = params => {
  gridApi.value = params.api
  setTimeout(() => { params.api.sizeColumnsToFit() }, 200)
}

const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)
  try {
    const results = await Promise.all(
      selectedProjects.value.map(p => axiosWrapper.post('/api/AdapterDataMapping/Get', { ProjectNo: p }, { headers: { Projectno: p } }).catch(() => []))
    )
    const dataMap = new Map()
    results.forEach((data, idx) => {
      const pNo = selectedProjects.value[idx]
      data.forEach(item => {
        if (!dataMap.has(item.MAP_ID)) dataMap.set(item.MAP_ID, { MAP_ID: item.MAP_ID, projects: {} })
        dataMap.get(item.MAP_ID).projects[pNo] = { EXIST: true, ...item }
      })
    })
    gridRowData.value = Array.from(dataMap.values()).map(row => {
      let diffFields = []
      const activePs = selectedProjects.value.filter(p => row.projects[p])
      if (activePs.length > 1) {
        COMPARE_FIELDS.forEach(f => {
          const firstVal = JSON.stringify(row.projects[activePs[0]][f] || '')
          if (activePs.some(p => JSON.stringify(row.projects[p][f] || '') !== firstVal)) diffFields.push(f)
        })
      }
      const res = { MAP_ID: row.MAP_ID, CONDITION: diffFields.length > 0 ? 'Diff' : 'Pass', DIFF_INFO: diffFields.join(', ') }
      selectedProjects.value.forEach(p => (res[p] = row.projects[p] || { EXIST: false }))
      return res
    })
    dynamicCols.value = [...selectedProjects.value]
    nextTick(() => { gridApi.value?.sizeColumnsToFit() })
  } finally { gridApi.value?.setGridOption('loading', false) }
}

const mainColumnDefs = computed(() => {
  const cols = [
    { headerName: 'Condition', field: 'CONDITION', width: 90, pinned: 'left', cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center' }) },
    { headerName: 'Diff Info', field: 'DIFF_INFO', width: 130, pinned: 'left', cellStyle: { color: '#0d6efd', textDecoration: 'underline', cursor: 'pointer', fontWeight: 'bold' } },
    { headerName: 'Mapping ID', field: 'MAP_ID', width: 220, pinned: 'left' },
  ]
  dynamicCols.value.forEach(p => {
    cols.push({
      headerName: p,
      children: [
        { headerName: 'Exist', valueGetter: params => (params.data[p]?.EXIST ? 'Y' : 'N'), width: 70, cellStyle: { textAlign: 'center' } },
        ...(viewMode.value === 'detail' ? COMPARE_FIELDS.filter(f => !f.includes('MAP_')).map(f => ({ headerName: f, valueGetter: params => params.data[p]?.[f] || '', width: 120 })) : []),
      ],
    })
  })
  return cols
})

const onCellClicked = p => {
  if (p.column.getColId() === 'DIFF_INFO' && p.value) {
    clickedRow.value = p.data
    selectedMapId.value = p.data.MAP_ID
    showDiffModal.value = true // 부트스트랩 대신 커스텀 모달 노출
  }
}

watch([activeTab, clickedRow], () => {
  if (!clickedRow.value) return
  const keyField = TAB_KEY_MAP[activeTab.value]
  const mergeMap = new Map()
  dynamicCols.value.forEach(pNo => {
    const pRow = clickedRow.value[pNo]
    if (!pRow || !pRow[activeTab.value]) return
    let items = pRow[activeTab.value]
    if (activeTab.value === 'MAP_CLS' && items.ITEMS) items = items.ITEMS
    if (Array.isArray(items)) {
      items.forEach(item => {
        const id = item[keyField]
        if (id) {
          if (!mergeMap.has(id)) mergeMap.set(id, { [keyField]: id })
          mergeMap.get(id)[pNo] = item
        }
      })
    }
  })
  modalRowData.value = Array.from(mergeMap.values()).map(row => {
    const activePs = dynamicCols.value.filter(p => row[p])
    const isRowDiff = activePs.length !== dynamicCols.value.length || activePs.some(p => JSON.stringify(row[p]) !== JSON.stringify(row[activePs[0]]))
    return { ...row, CONDITION: isRowDiff ? 'Diff' : 'Pass' }
  })
})

const modalColumnDefs = computed(() => {
  const keyField = TAB_KEY_MAP[activeTab.value]
  if (!keyField) return []
  const cols = [
    { headerName: keyField, field: keyField, pinned: 'left', width: 180, cellClass: 'bg-light fw-bold' },
    { headerName: 'Condition', field: 'CONDITION', pinned: 'left', width: 90, cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center' }) },
  ]
  const allKeys = new Set()
  modalRowData.value.forEach(row => {
    dynamicCols.value.forEach(pNo => {
      if (row[pNo]) Object.keys(row[pNo]).forEach(k => { if (k !== keyField) allKeys.add(k) })
    })
  })
  dynamicCols.value.forEach(pNo => {
    const children = Array.from(allKeys).map(attrKey => ({
      headerName: attrKey, valueGetter: p => p.data[pNo]?.[attrKey] ?? '-', width: 130,
      cellStyle: p => {
        const val = p.data[pNo]?.[attrKey]
        const isDiff = dynamicCols.value.some(other => JSON.stringify(val) !== JSON.stringify(p.data[other]?.[attrKey]))
        return isDiff ? { color: '#dc3545', fontWeight: 'bold' } : null
      },
    }))
    cols.push({ headerName: pNo, children })
  })
  return cols
})

const isExternalFilterPresent = () => attributeFilter.value !== ''
const doesExternalFilterPass = n => String(n.data.MAP_ID).toLowerCase().includes(attributeFilter.value.toLowerCase())
watch(attributeFilter, () => gridApi.value?.onFilterChanged())
</script>

