return { setValue };
}

// ✨ 추가되는 부분 (사용자가 알림창 '확인'을 누를 때 실행되는 함수)
const onClickDialogConfirm = function () {
  // 1. 우선 '메일을 발신하였습니다' 알림 팝업창을 닫습니다.
  _IsShowDialogRef.value = false;
  
  // 2. 띄워져 있던 메시지가 메일 발송 완료 문구인 경우에만 전체 메일창(또는 팝업)을 종료합니다.
  if (_DialogMessageRef.value === '메일을 발신하였습니다.') {
    onActionClose(); 
  }
}

