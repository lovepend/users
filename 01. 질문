// 1. 상단 ref 선언부에 추가
const toolSourceList = ref([]); // 리스트 데이터를 담을 변수

// 2. colDefs 설정 수정 (기존 colDefs 변수 내 TOOL_SOURCE 부분 찾기)
const colDefs = ref([
  // ... 다른 컬럼들
  {
    field: 'TOOL_SOURCE',
    headerName: 'Tool Source',
    minWidth: 100,
    initialWidth: 200,
    flex: 2,
    editable: true,
    cellEditor: 'agSelectCellEditor',
    cellEditorParams: {
      // 💡 toolSourceList 변수를 직접 할당 (computed나 watch로 갱신됨)
      values: toolSourceList.value, 
    },
  },
  // ... 나머지 컬럼들
]);

// 3. API 로직 수정 (getDictionaryList 함수 내부)
const getDictionaryList = async function () {
  try {
    const key = 'ADAPTER_TOOLS';
    const projectNo = currProjNoRef.value;
    const epId = userInfo.value?.UserID;

    const res = await ApiCommon.postDictionaryGetByKey(
      { Key: key, ProjectNo: projectNo },
      { headers: { Projectno: projectNo, Ep_id: epId } }
    );

    const dictionaryData = res.data || res;
    
    if (dictionaryData && Array.isArray(dictionaryData)) {
      // 💡 받아온 데이터를 toolSourceList에 저장
      toolSourceList.value = dictionaryData; 
      console.log('toolSourceList 로드 성공:', toolSourceList.value);
    }
  } catch (error) {
    console.error('Dictionary 로드 실패:', error);
  }
};

// 4. ✨ 핵심: 데이터 로드 시 그리드 컬럼 정보를 최신화하는 Watch 추가
watch(toolSourceList, (newList) => {
  if (newList && newList.length > 0 && gridApi.value) {
    // 컬럼 정의를 다시 찾아서 values를 교체해줍니다.
    const newColDefs = gridApi.value.getColumnDefs();
    const toolSourceCol = newColDefs.find(col => col.field === 'TOOL_SOURCE');
    
    if (toolSourceCol) {
      toolSourceCol.cellEditorParams = { values: newList };
      gridApi.value.setGridOption('columnDefs', newColDefs);
      console.log('그리드 에디터 리스트 갱신 완료');
    }
  }
}, { deep: true });
