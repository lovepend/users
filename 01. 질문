<template>
  <div class="tag-analysis-container">
    <div class="search-section">
      <!-- 왼쪽: 프로젝트 선택 및 조회 버튼 -->
      <div class="left-controls">
        <div class="control-item">
          <label>Project</label>
          <select v-model="selectedProject" class="project-select">
            <option value="TE1002">TE1002 (Current)</option>
            <option value="TE1003">TE1003 (Next)</option>
          </select>
        </div>
        <button @click="fetchMergedData" class="btn-search">
          <i class="icon-search"></i> 조회 (Search)
        </button>
      </div>

      <!-- 오른쪽: 키워드 입력 창 -->
      <div class="right-keywords">
        <label>Keywords (Tag No / Name)</label>
        <textarea 
          v-model="searchKeywords" 
          placeholder="여러 개 입력 시 엔터(Enter)로 구분"
          @input="handleSearch"
        ></textarea>
      </div>
    </div>

    <!-- 하단 그리드 영역 -->
    <div class="grid-container">
      <ag-grid-vue
        style="width: 100%; height: 650px;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import 'ag-grid-community/styles/ag-grid.css';
import 'ag-grid-community/styles/ag-theme-alpine.css';

export default {
  name: 'TagIntegratedAnalysis',
  components: { AgGridVue },
  setup() {
    const gridApi = ref(null);
    const selectedProject = ref('TE1002'); // 기본값 프로젝트 번호
    const searchKeywords = ref('');
    const rowData = ref([]);
    const dynamicAttCols = ref([]);

    // 컬럼 정의 (베이스 + 동적 속성)
    const columnDefs = computed(() => [
      { headerName: 'Source', field: 'Source', width: 100, pinned: 'left' },
      { headerName: 'Tag No', field: 'TAG_NO', width: 160, pinned: 'left' },
      { headerName: 'Description', field: 'TAG_DESC', width: 200 },
      { headerName: 'Class ID', field: 'CLS_ID', width: 120 },
      ...dynamicAttCols.value
    ]);

    const defaultColDef = {
      sortable: true, filter: true, resizable: true, floatingFilter: true
    };

    const fetchMergedData = async () => {
      console.log(`Searching for Project: ${selectedProject.value}`);
      // 실제 구현 시 여기서 axios.get(..., { params: { project: selectedProject.value } })
      
      // 테스트용 가상 데이터
      const mockData = [
        { TAG_NO: 'TAG-001', TAG_DESC: 'Sample Pump', CLS_ID: 'C01', Source: 'Publish', ATTRIBUTES: [{ ATTR_NAME: 'RPM', VALUE: '1500' }] },
        { TAG_NO: 'TAG-001', TAG_DESC: 'Sample Pump(Mod)', CLS_ID: 'C01', Source: 'Working', ATTRIBUTES: [{ ATTR_NAME: 'RPM', VALUE: '1800' }, { ATTR_NAME: 'Material', VALUE: 'Iron' }] }
      ];

      // 데이터 평면화 로직
      const attrSet = new Set();
      const rows = mockData.map(d => {
        const row = { ...d };
        d.ATTRIBUTES?.forEach(a => {
          attrSet.add(a.ATTR_NAME);
          row[`ATTR_${a.ATTR_NAME}`] = a.VALUE;
        });
        return row;
      });

      // 동적 컬럼 생성
      dynamicAttCols.value = Array.from(attrSet).map(name => ({
        headerName: name,
        field: `ATTR_${name}`,
        width: 120
      }));

      rowData.value = rows;
    };

    const handleSearch = () => {
      if (gridApi.value) {
        gridApi.value.setQuickFilter(searchKeywords.value.replace(/\n/g, ' '));
      }
    };

    const onGridReady = (params) => {
      gridApi.value = params.api;
      fetchMergedData();
    };

    return {
      selectedProject, searchKeywords, rowData, columnDefs, defaultColDef,
      onGridReady, fetchMergedData, handleSearch
    };
  }
};
</script>

