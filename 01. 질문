    let failinfo = failCount > 0 ? `failed to delete ${failCount} item.( TYPE ID : ${failTagCode.join(',')})` : ''

    if (successCount > 0) {
      sAlert.Success(`Successfully deleted ${successCount} AdapterBroker.<br> ${failinfo}`)
    } else {
      sAlert.Error(`Error occurred during delete AdapterBroker.<br> ${failinfo}`)
    }

    getAdapterBrokerList()
  }

  const preSave = () => {
    gridApi.value.stopEditing()
    _.delay(saveData, 50)
  }

  const saveData = async () => {
    let selectedRows = gridApi.value.getSelectedRows()
    if (selectedRows && selectedRows.length > 0) {
      let url = `/api/AdapterBroker`
      let createData = []
      let updateData = []
      let createCount = 0
      let updateCount = 0
      let updateIdData = []

      const data = selectedRows
      selectedRows.forEach(elem => {
        //1
        if (elem.STATUS == 'A') {
          createCount++

          let { CRTE_DTM, _id, ...rest } = elem

          createData.push({ _id: null, ...rest })
        } else {
          updateCount++

          let { CHGER_NO, CHGE_DTM, ...rest } = elem
          updateData.push({ CHGER_NO: userInfo.value?.UserID, ...rest })
        }
      })

      if (!checkValidation(selectedRows)) return

      try {
        let successMessage = 'AdapterBroker is  Saved. '
        if (createCount > 0) {
          await axiosWrapper.post(url + '/Create', createData)
          successMessage = successMessage + `Created :${createCount} `
        }
        if (updateCount > 0) {
          await axiosWrapper.put(url + '/Update', updateData)
          // for (let item in updateData) {

          // }
          // await axiosWrapper.put(url + '/Update', updateData)
          successMessage = successMessage + `Updated :${updateCount} `
        }

        sAlert.Success(successMessage)
        gridApi.value.deselectAll()

        getAdapterBrokerList()
      } catch (error) {
        console.error('saveData', error)
        getAdapterBrokerList()

        if (!(error instanceof axios.AxiosError)) {
          sAlert.Error('Error occurred during AdapterBroker save : ' + error.message)
        }
      }
    } else {
      sAlert.Warning(`Select a row from the AdapterBroker list`)
    }
  }

  // Keydown 단축키 Ctrl + S 저장 단축키
  const onKeyDown = event => {
    if (event.ctrlKey && event.key === 's') {
      event.preventDefault() //브라우저 기본 저장 동작 방지
      preSave()
    }
  }

  const checkDuplicate = (data = null, fieldName1 = null, fieldName2 = null, event = null) => {
    if (!data || !fieldName1 || !fieldName2 || !event) {
      sAlert.Warning("'checkDuplicate' Data Not Found.")
      return false
    }
    // index != event.rowIndex
    let tic = data.find(
      (elem, index) =>
        compareTwoCase(elem[fieldName1] + elem[fieldName2], event.data[fieldName1] + event.data[fieldName2]) &&
        elem['_id'] !== event.data._id
    )
    if (tic) {
      event.data[event.colDef.field] = event.oldValue
      event.api.stopEditing()
      event.api.redrawRows()
      sAlert.Warning('This is the use of duplicate names.')
      return false
    }

    return true
  }

  const upCase = str => {
    return str.toUpperCase()
  }

  const compareTwoCase = (str1, str2) => {
    let word1 = upCase(str1.trim())
    let word2 = upCase(str2.trim())
    if (word1 == word2) {
      return true
    } else {
      return false
    }
  }

  const agGridRefresh = async function (gridApi) {
    await gridApi.redrawRows()
    await gridApi.refreshCells()
  }

  const getDictionaryList = async function () {
    try {
      const key = 'ADAPTER_TOOLS'
      const projectNo = currProjNoRef.value
      const epId = userInfo.value?.UserID

      const res = await ApiCommon.postDictionaryGetByKey(
        {
          Key: key,
          ProjectNo: projectNo,
        },
        {
          headers: {
            Projectno: projectNo,
            Ep_id: epId,
          },
        }
      )
      // 만약 ApiCommon이 axios를 래핑한 형태라면 res.data에 데이터가 있습니다.
      const dictionaryData = res.data || res
      console.log('Received Data List:', dictionaryData)

      if (dictionaryData && Array.isArray(dictionaryData)) {
        toolSourceList.value = dictionaryData
        console.log('toolSourceList updated successfully. Count:', toolSourceList.value.length)
      } else {
        console.warn('Data received but it is not an array or is empty:', dictionaryData)
      }
    } catch (error) {
      // 3. 에러 발생 로그
      console.error('--- [Dictionary API Response Error] ---')
    } finally {
      console.log('--- [Dictionary API Request Finished] ---')
    }
  }

  const gridBindProps = ref({
    style: 'width: 100%; height: 100%;',
    class: themeClass,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
    enableFillHandle: true,
    defaultColDef: defaultColDef,
    suppressLastEmptyLineOnPaste: true,
    pagination: false,
    statusBar: statusBar,
    rowSelection: 'single',
    rowMultiSelectWithClick: false,
    suppressRowClickSelection: false,
    columnHoverHighlight: true,
    getRowId: getRowId,
    loadingOverlayComponent: AggridLoadingOverlay,
    loadingOverlayComponentParams: loadingOverlayComponentParams,
  })
  const gridOnProps = {
    firstDataRendered: onFirstDataRendered,
    rowSelected: onRowSelected,
    cellValueChanged: onCellValueChanged,
    gridReady: onGridReady,
    keydown: onKeyDown,
    cellClicked: onCellClicked,
    selectionChanged: onSelectionChanged,
  }

  const gridBindPropsSchema = ref({
    style: 'width: 100%; height: 100%;',
    class: themeClass,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
    enableFillHandle: true,
