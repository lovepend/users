/**
 * Ag-Grid 엑셀 가로채기 및 백엔드 전송 (초강력 완벽 방어 버전)
 */
const handleAgGridExcelIntercept = async () => {
  if (!gridApi.value) {
    console.error('❌ [Excel Error] gridApi가 준비되지 않았습니다.');
    return;
  }

  try {
    let agExcelBlob = null;

    // --- [1단계: Ag-Grid 내장 엑셀 함수 시도] ---
    if (typeof gridApi.value.getDataAsExcel === 'function') {
      console.log('🔄 [Excel] 1단계: getDataAsExcel 실행 시도');
      try {
        agExcelBlob = gridApi.value.getDataAsExcel({});
      } catch (e) {
        console.warn('⚠️ getDataAsExcel 실행 도중 예외 발생 (모듈 누락 가능성):', e.message);
      }
    } 

    // --- [2단계: 차선책 - 내장 CSV 함수 시도] ---
    if (!agExcelBlob && typeof gridApi.value.getDataAsCsv === 'function') {
      console.log('🔄 [Excel] 2단계: CSV 스트림으로 우회 추출 시도');
      try {
        const csvContent = gridApi.value.getDataAsCsv({});
        if (csvContent) {
          agExcelBlob = new Blob([new Uint8Array([0xEF, 0xBB, 0xBF]), csvContent], { type: 'text/csv;charset=utf-8;' });
        }
      } catch (e) {
        console.warn('⚠️ getDataAsCsv 실행 실패:', e.message);
      }
    }

    // --- [3단계: 최후의 보루 - 화면 JSON 데이터를 엑셀 호환 파일로 강제 조립] ---
    if (!agExcelBlob) {
      console.log('🔄 [Excel] 3단계: 최후의 보루 (그리드 JSON 데이터를 직접 파일 객체화)');
      const fallbackData = [];
      gridApi.value.forEachNodeAfterFilterAndSort((node) => {
        if (node.data) fallbackData.push(node.data);
      });
      
      // JSON 데이터를 문자열화하여 Blob 파일 형태로 강제 가공
      const jsonStr = JSON.stringify(fallbackData, null, 2);
      agExcelBlob = new Blob([jsonStr], { type: 'application/json' });
    }

    // 최종 검증
    if (!agExcelBlob || agExcelBlob.size === 0) {
      alert('그리드에서 데이터를 추출하는 데 모두 실패했습니다.');
      return;
    }

    console.log('✅ [Excel] 데이터 파일화 성공! 크기:', agExcelBlob.size, 'bytes');

    // --- [4단계: FormData 조립] ---
    const formData = new FormData();
    // 💡 백엔드가 엑셀 형식을 무조건 요구하면 .xlsx, 3단계 우회 시 .json 등 상황에 맞게 확장자 전달
    // 💡 'file'이라는 명칭이 백엔드 Multipart 받는 변수명과 일치하는지 꼭 확인하세요!
    formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`);

    console.log('🚀 [Excel] 5단계: 백엔드 API 전송 시작 -> URL: /api/File/File');
    
    // --- [5단계: API 요청 수행] ---
    const response = await axios.post('/api/File/File', formData, {
      headers: {
        'Content-Type': 'multipart/form-data'
      },
      responseType: 'blob' // 바이너리 다운로드 필수 설정
    });

    console.log('🎉 [Excel] 6단계: 백엔드 응답 수신 성공!', response);

    // --- [6단계: 브라우저 다운로드 실행] ---
    const returnBlob = new Blob([response.data], { 
      type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' 
    });
    
    const downloadUrl = window.URL.createObjectURL(returnBlob);
    const linkElement = document.createElement('a');
    linkElement.href = downloadUrl;
    linkElement.download = `Excel_Report_${Date.now()}.xlsx`;
    
    document.body.appendChild(linkElement);
    linkElement.click();
    
    document.body.removeChild(linkElement);
    window.URL.revokeObjectURL(downloadUrl);
    console.log('🏁 [Excel] 7단계: 프로세스 정상 종료');

  } catch (error) {
    console.error('====================================================');
    console.error('🚨 [Excel 가로채기 최종 catch 에러 발생]');
    console.error('❌ 에러 메시지:', error.message);
    console.error('❌ 에러 오브젝트 상세:', error);
    
    if (error.response) {
      console.error('❌ HTTP 상태 코드:', error.response.status);
      console.error('❌ 서버 리턴 에러 내용:', error.response.data);
    }
    console.error('====================================================');
    alert(`엑셀 처리 중 오류가 발생했습니다.\n원인: ${error.message}`);
  }
}
