<template>
  <!-- 💡 중요: :getContextMenuItems 속성이 반드시 바인딩되어 있어야 합니다! -->
  <ag-grid-vue
    class="ag-theme-alpine"
    style="width: 100%; height: 500px;"
    :columnDefs="columnDefs"
    :rowData="rowData"
    :getContextMenuItems="getContextMenuItems"
    @grid-ready="onGridReady"
  />
</template>

<script setup>
import { ref } from 'vue'
import { AgGridVue } from 'ag-grid-vue3'
import axios from 'axios' // 통신 모듈

const gridApi = ref(null)
const columnDefs = ref([/* 컬럼 정의 */])
const rowData = ref([/* 데이터 정의 */])

const onGridReady = (params) => {
  gridApi.value = params.api
}

/**
 * 1. 마우스 우클릭 메뉴 제어 (기존 엑셀 숨기고 커스텀 심기)
 */
const getContextMenuItems = (params) => {
  console.log('🖱️ 우클릭 감지됨! 기본 제공 메뉴 목록:', params.defaultItems)

  // 기본 메뉴가 없다면 빈 배열로 초기화
  const defaultItems = params.defaultItems || []
  
  // 🚫 원래 Ag-Grid가 기본으로 제공하는 로컬 엑셀 내보내기 메뉴 제거 ('excelExport', 'export')
  const filteredItems = defaultItems.filter(item => item !== 'excelExport' && item !== 'export')

  // ✨ 우리가 만든 백엔드 가로채기용 커스텀 메뉴 정의
  const myCustomExcelMenu = {
    name: 'Excel 다운로드 (보안 적용)',
    action: () => {
      // 메뉴 클릭 시 실행될 가로채기 함수 호출
      handleAgGridExcelIntercept()
    },
    // Ag-Grid 내장 엑셀 아이콘 스타일 적용 (녹색 엑셀 아이콘)
    icon: '<span class="ag-icon ag-icon-excel" style="color: #1f7246;"></span>'
  }

  // 🤝 기존 메뉴 맨 위에 커스텀 메뉴를 올리고 구분선(separator)을 넣어서 반환합니다.
  return [myCustomExcelMenu, 'separator', ...filteredItems]
}

/**
 * 2. Ag-Grid 엑셀 바이너리를 가로채서 백엔드로 토스하는 함수
 */
const handleAgGridExcelIntercept = async () => {
  if (!gridApi.value) {
    console.error('❌ gridApi가 존재하지 않습니다.');
    return;
  }

  try {
    console.log('🔄 [Excel 가로채기] 1단계: Ag-Grid 내장 데이터 추출');
    
    let agExcelBlob = null;

    // Ag-Grid 최신 버전 기능 체크
    if (typeof gridApi.value.getDataAsExcel === 'function') {
      agExcelBlob = gridApi.value.getDataAsExcel({});
    } 
    // 라이선스나 모듈 문제로 Blob 추출 안 될 시 CSV로 가공해서 우회
    else if (typeof gridApi.value.getDataAsCsv === 'function') {
      console.warn('⚠️ getDataAsExcel 사용 불가로 CSV 데이터 가공 우회 진행');
      const csvContent = gridApi.value.getDataAsCsv({});
      if (csvContent) {
        agExcelBlob = new Blob([new Uint8Array([0xEF, 0xBB, 0xBF]), csvContent], { type: 'text/csv;charset=utf-8;' });
      }
    }

    if (!agExcelBlob) {
      alert('그리드에서 데이터를 추출할 수 없습니다. Ag-Grid Enterprise 모듈 등록을 확인해 주세요.');
      return;
    }

    console.log('✅ [Excel 가로채기] 2단계: 파일화 성공. FormData 조립 시작');
    
    const formData = new FormData();
    formData.append('file', agExcelBlob, `Grid_Export_${Date.now()}.xlsx`);

    console.log('🚀 [Excel 가로채기] 3단계: 백엔드 API 요청 (/api/File/File)');
    
    // 백엔드로 전송
    const response = await axios.post('/api/File/File', formData, {
      headers: {
        'Content-Type': 'multipart/form-data'
      },
      responseType: 'blob' // 바이너리 스트림 보존용
    });

    console.log('🎉 [Excel 가로채기] 4단계: 백엔드 DRM 처리 파일 수신 완료. 다운로드 진행');

    // 서버가 돌려준 가공된 파일(Blob)을 브라우저에 다운로드 다운로드 처리
    const returnBlob = new Blob([response.data], { 
      type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' 
    });
    
    const downloadUrl = window.URL.createObjectURL(returnBlob);
    const linkElement = document.createElement('a');
    linkElement.href = downloadUrl;
    linkElement.download = `Excel_Report_${Date.now()}.xlsx`;
    
    document.body.appendChild(linkElement);
    linkElement.click();
    
    document.body.removeChild(linkElement);
    window.URL.revokeObjectURL(downloadUrl);
    console.log('🏁 [Excel 가로채기] 5단계: 완료');

  } catch (error) {
    console.error('🚨 [Excel 가로채기 에러]:', error);
    if (error.response) {
      console.error('❌ 서버 응답 에러 코드:', error.response.status);
    }
    alert('엑셀 다운로드 중 오류가 발생했습니다.');
  }
}
</script>
