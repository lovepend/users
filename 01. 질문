.search-header { display: flex; gap: 20px; margin-bottom: 15px; align-items: flex-end; }
.input-group { display: flex; flex-direction: column; flex: 1; }
textarea { height: 60px; padding: 8px; border: 1px solid #ddd; border-radius: 4px; resize: none; }
