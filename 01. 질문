<template>
  <div class="tag-analysis-container">
    <!-- 상단 검색 영역 -->
    <div class="search-header">
      <div class="input-group">
        <label>검색어(TAG NO/Name)</label>
        <textarea 
          v-model="searchKeywords" 
          placeholder="여러 개 입력 시 줄바꿈이나 공백으로 구분"
          @input="handleSearch"
        ></textarea>
      </div>
      <div class="action-buttons">
        <button @click="fetchMergedData" class="btn-primary">통합 조회</button>
        <button @click="exportToExcel" class="btn-success">엑셀 저장</button>
      </div>
    </div>

    <!-- 메인 그리드 영역 -->
    <div class="grid-wrapper">
      <ag-grid-vue
        style="width: 100%; height: 600px;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
        :getRowStyle="getRowStyle"
      />
    </div>

    <!-- 속성 비교 상세 모달 -->
    <div v-if="showDetail" class="detail-modal">
      <div class="modal-content">
        <h3>Tag 속성 상세 비교 ({{ selectedTag?.TAG_NO }})</h3>
        <div class="tab-menu">
          <button :class="{ active: viewMode === 'table' }" @click="viewMode = 'table'">Table View</button>
          <button :class="{ active: viewMode === 'json' }" @click="viewMode = 'json'">JSON View</button>
        </div>
        
        <div class="scroll-area">
          <table v-if="viewMode === 'table'" class="detail-table">
            <thead>
              <tr>
                <th>속성명</th>
                <th>값</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="(val, key) in flattenedAttributes" :key="key">
                <td>{{ key }}</td>
                <td :class="{ 'no-value': val === 'null' }">{{ val }}</td>
              </tr>
            </tbody>
          </table>
          <pre v-else class="json-viewer">{{ JSON.stringify(selectedTag, null, 2) }}</pre>
        </div>
        <button @click="showDetail = false" class="btn-close">닫기</button>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed, reactive } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import 'ag-grid-community/styles/ag-grid.css';
import 'ag-grid-community/styles/ag-theme-alpine.css';

export default {
  name: 'TagIntegratedAnalysis',
  components: { AgGridVue },
  setup() {
    const gridApi = ref(null);
    const searchKeywords = ref('');
    const rowData = ref([]);
    const dynamicAttCols = ref([]);
    const showDetail = ref(false);
    const selectedTag = ref(null);
    const viewMode = ref('table');

    // 1. 기본 컬럼 정의
    const columnDefs = computed(() => [
      { headerName: 'Source', field: 'Source', width: 100, pinned: 'left', 
        cellStyle: params => params.value === 'Working' ? { color: '#e67e22', fontWeight: 'bold' } : { color: '#27ae60' } 
      },
      { headerName: 'Tag No', field: 'TAG_NO', width: 150, pinned: 'left', cellRenderer: 'HighlightRenderer' },
      { headerName: 'Description', field: 'TAG_DESC', width: 200 },
      { headerName: 'Class ID', field: 'CLS_ID', width: 120, cellClass: 'link-cell', onCellClicked: (p) => openClassSpec(p.data.CLS_ID) },
      // 동적 속성 컬럼들이 여기에 병합됨
      ...dynamicAttCols.value
    ]);

    const defaultColDef = {
      sortable: true,
      filter: true,
      resizable: true,
      floatingFilter: true
    };

    // 2. 데이터 통합 및 속성 피벗 로직 (핵심 기능)
    const fetchMergedData = async () => {
      // Mock API 호출 (SearchPublishData + SearchWorkingData 병합 시뮬레이션)
      const publishData = [
        { TAG_NO: 'TAG-001', TAG_DESC: 'Main Pump', CLS_ID: 'C01', ATTRIBUTES: [{ ATTR_NAME: 'Pressure', VALUE: '10bar' }, { ATTR_NAME: 'Temp', VALUE: '50C' }] },
        { TAG_NO: 'TAG-002', TAG_DESC: 'Side Valve', CLS_ID: 'C02', ATTRIBUTES: [{ ATTR_NAME: 'Material', VALUE: 'SUS304' }] }
      ];
      const workingData = [
        { TAG_NO: 'TAG-001', TAG_DESC: 'Main Pump(Rev)', CLS_ID: 'C01', ATTRIBUTES: [{ ATTR_NAME: 'Pressure', VALUE: '12bar' }, { ATTR_NAME: 'Vibration', VALUE: 'Normal' }] }
      ];

      // 데이터 병합 (Source 구분)
      const merged = [
        ...publishData.map(d => ({ ...d, Source: 'Publish' })),
        ...workingData.map(d => ({ ...d, Source: 'Working' }))
      ];

      // 동적 속성 컬럼 추출 로직
      const attrSet = new Set();
      merged.forEach(row => {
        row.ATTRIBUTES?.forEach(attr => attrSet.add(attr.ATTR_NAME));
        // 그리드에서 접근하기 쉽게 속성을 최상위 필드로 평면화
        row.ATTRIBUTES?.forEach(attr => {
          row[`ATTR_${attr.ATTR_NAME}`] = attr.VALUE;
        });
      });

      dynamicAttCols.value = Array.from(attrSet).map(attrName => ({
        headerName: `Attr: ${attrName}`,
        field: `ATTR_${attrName}`,
        width: 130,
        valueFormatter: p => p.value || 'null',
        cellStyle: p => !p.value ? { color: '#ccc', fontStyle: 'italic' } : null
      }));

      rowData.value = merged;
    };

    // 3. 하이라이트 및 검색 필터 로직
    const handleSearch = () => {
      if (!gridApi.value) return;
      const keywords = searchKeywords.value.split(/[\s\n]+/).filter(k => k.length > 0);
      
      // AG-Grid 외부 필터링 혹은 QuickFilter 적용
      gridApi.value.setQuickFilter(keywords.join(' '));
    };

    // 4. 상세 모달 데이터 가공
    const flattenedAttributes = computed(() => {
      if (!selectedTag.value) return {};
      const attrs = {};
      selectedTag.value.ATTRIBUTES?.forEach(a => {
        attrs[a.ATTR_NAME] = a.VALUE;
      });
      return attrs;
    });

    const openClassSpec = (clsId) => {
      console.log(`Navigating to Class Spec: ${clsId}`);
      // 신규 탭 이동 로직 예시: window.open(`/spec/${clsId}`);
    };

    const onGridReady = (params) => {
      gridApi.value = params.api;
      fetchMergedData();
    };

    const getRowStyle = (params) => {
      if (params.data.Source === 'Working') return { backgroundColor: '#fffaf0' };
    };

    return {
      searchKeywords, rowData, columnDefs, defaultColDef,
      dynamicAttCols, showDetail, selectedTag, viewMode,
      flattenedAttributes, onGridReady, handleSearch, fetchMergedData,
      getRowStyle
    };
  }
};
</script>

