<template>
  <div class="uom-compare-page h-100 w-100 d-flex flex-column bg-white">
    <DefaultCard
      :title="{
        icon: 'fa-balance-scale',
        title: 'UOM 비교 분석',
        subtitle: '프로젝트 간 단위(UOM) 설정 차이 및 누락 항목을 대조합니다.',
      }"
      class="flex-grow-1"
      body-class="p-0 d-flex flex-column"
    >
      <template #header-right>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap small">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
                style="min-width: 200px"
              >
                <span class="text-truncate me-2 small">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-lg border-0" style="max-height: 400px; overflow-y: auto; width: 350px; z-index: 1060">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 번호/명 검색..."
                    @click.stop
                  />
                </li>
                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold small" style="cursor: pointer">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :checked="isAllSelected"
                      :indeterminate="isIndeterminate"
                      @change="toggleAllSelection"
                    />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 small" style="cursor: pointer">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :value="proj.PROJ_NO"
                      v-model="selectedProjects"
                    />
                    <span class="text-truncate">
                      <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                      <small class="text-muted ms-1">({{ proj.DESC }})</small>
                    </span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button
            class="ui-tag-tab-search-btn"
            @click="onSearch"
            :disabled="selectedProjects.length === 0"
          >
            조회
          </button>

          <div class="header-divider mx-2"></div>

          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border">
            <input type="radio" class="btn-check" id="uomModeSimple" value="simple" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="uomModeSimple">간편</label>
            <input type="radio" class="btn-check" id="uomModeDetail" value="detail" v-model="viewMode" />
            <label class="btn btn-sm rounded-pill px-3 toggle-label" for="uomModeDetail">상세</label>
          </div>

          <div class="header-divider mx-2"></div>

          <textarea
            class="ui-tag-tab-textarea"
            v-model="attributeFilter"
            placeholder="TYPE_ID 필터 (엔터/쉼표 구분)"
          ></textarea>
        </div>
      </template>

      <div class="grid-wrapper flex-grow-1 border-top bg-white">
        <ag-grid-vue 
          v-bind="gridOptions" 
          @grid-ready="onGridReady" 
          style="width: 100%; height: 100%; position: absolute"
        />
      </div>
    </DefaultCard>

    <div v-if="showDetailModal" class="custom-modal-overlay" @click.self="closeModal">
      <div 
        class="custom-modal-window shadow-lg" 
        :style="modalPos"
      >
        <div class="modal-header-dark cursor-move" @mousedown="startDrag">
          <h6 class="modal-title small mb-0">
            <i class="fa fa-info-circle me-2"></i>UOM 상세 정보 (이동 가능)
          </h6>
          <button @click="closeModal" class="btn btn-xs btn-danger shadow-none">✕</button>
        </div>
        <div class="modal-body p-3" style="background: #fff; min-height: 200px;">
           <p class="small text-muted">선택된 TYPE_ID: <strong>{{ selectedTypeId }}</strong></p>
        </div>
        <div class="modal-footer py-1 bg-light border-top text-end">
          <button type="button" class="btn btn-secondary btn-xs px-3" @click="closeModal">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch, reactive } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import DefaultCard from '@/components/default/DefaultCard.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()

// --- 모달 드래그 및 위치 상태 ---
const showDetailModal = ref(false)
const selectedTypeId = ref('')
const modalPos = reactive({
  top: '200px',
  left: '50%',
  transform: 'translateX(-50%)',
  width: '600px',
  position: 'absolute'
})

const startDrag = (event) => {
  const modal = event.currentTarget.parentElement
  let shiftX = event.clientX - modal.getBoundingClientRect().left
  let shiftY = event.clientY - modal.getBoundingClientRect().top
  const moveAt = (pageX, pageY) => {
    modalPos.left = (pageX - shiftX) + 'px'
    modalPos.top = (pageY - shiftY) + 'px'
    modalPos.transform = 'none'
  }
  const onMouseMove = (e) => moveAt(e.pageX, e.pageY)
  document.addEventListener('mousemove', onMouseMove)
  document.onmouseup = () => {
    document.removeEventListener('mousemove', onMouseMove)
    document.onmouseup = null
  }
}

const closeModal = () => {
  showDetailModal.value = false
  modalPos.top = '200px'
  modalPos.left = '50%'
  modalPos.transform = 'translateX(-50%)'
}

// --- 기존 State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const urlEpId = computed(() => route.query.ep_id || '')
const urlProjNo = computed(() => route.query.project_no || '')

// --- 기존 로직 (수정 없음) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})

const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
})

const toggleAllSelection = e => {
  const checked = e.target.checked
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = checked ? [...new Set([...selectedProjects.value, ...filteredIds])] : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Projectno: urlProjNo.value, Ep_id: urlEpId.value } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  try {
    const fetchPromises = selectedProjects.value.map(async projNo => {
      const config = { headers: { Projectno: projNo, Ep_id: urlEpId.value } }
      const [regRes, attrRes] = await Promise.all([
        axiosWrapper.post('/api/Register/Get', { ProjectNo: projNo }, config).catch(() => []),
        axiosWrapper.post('/api/Attributes/Get', { ProjectNo: projNo }, config).catch(() => []),
      ])
      return { projNo, regData: regRes || [], attrData: attrRes || [] }
    })
    const allProjectResults = await Promise.all(fetchPromises)
    const typeMap = new Map()
    allProjectResults.forEach(({ projNo, regData, attrData }) => {
      const masterMap = new Map(attrData.map(a => [a.ATT_ID, a]))
      regData.forEach(reg => {
        if (!typeMap.has(reg.TYPE_ID)) typeMap.set(reg.TYPE_ID, { TYPE_ID: reg.TYPE_ID, projects: {} })
        let diffDetails = []
        reg.LNK_ATT?.forEach(lnk => {
          const mst = masterMap.get(lnk.ATT_ID)
          if (mst?.VAL_TYPE === 'NUMBER' && mst.UOM_ID?.trim() && !lnk.UOM_ID?.trim()) {
            diffDetails.push(`${lnk.ATT_ID}(${mst.UOM_ID})`)
          }
        })
        typeMap.get(reg.TYPE_ID).projects[projNo] = { EXIST: true, IS_DIFF: diffDetails.length > 0, MISSING_INFO: diffDetails.join(', ') }
      })
    })
    const processedData = Array.from(typeMap.values()).map(row => {
      let isAnyDiff = false
      selectedProjects.value.forEach(p => { if (row.projects[p]?.IS_DIFF) isAnyDiff = true })
      const resultRow = { TYPE_ID: row.TYPE_ID, CONDITION: isAnyDiff ? 'Diff' : 'Pass' }
      selectedProjects.value.forEach(p => { resultRow[p] = row.projects[p] || { EXIST: false, IS_DIFF: false, MISSING_INFO: '' } })
      return resultRow
    })
    dynamicCols.value = [...selectedProjects.value]
    gridRowData.value = processedData
  } catch (e) { sAlert.Error('조회 실패') } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

const columnDefs = computed(() => {
  const cols = [
    { headerName: 'Condition', field: 'CONDITION', width: 110, pinned: 'left', cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) },
    { headerName: 'Register TYPE_ID', field: 'TYPE_ID', width: 200, pinned: 'left' },
  ]
  dynamicCols.value.forEach(proj => {
    const children = [{ headerName: 'UOM Status', valueGetter: p => { const target = p.data[proj]; if (!target?.EXIST) return '-'; return target.IS_DIFF ? 'Missing' : 'OK' }, width: 110, cellStyle: p => ({ textAlign: 'center', fontWeight: 'bold', color: p.value === 'Missing' ? '#dc3545' : p.value === 'OK' ? '#198754' : '#ccc' }) }]
    if (viewMode.value === 'detail') { children.push({ headerName: 'Missing Details', valueGetter: p => p.data[proj]?.MISSING_INFO || '', width: 250, cellStyle: { fontSize: '11px', color: '#dc3545' } }) }
    cols.push({ headerName: `${proj}`, marryChildren: true, children: children })
  })
  return cols
})

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  class: 'ag-theme-custom',
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, resizable: true, filter: true, floatingFilter: true },
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const kws = attributeFilter.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
    const target = String(node.data.TYPE_ID || '').toLowerCase()
    return kws.length === 0 || kws.some(kw => target.includes(kw))
  },
}))

const onGridReady = p => { gridApi.value = p.api }
watch([attributeFilter, viewMode], () => { if (gridApi.value) gridApi.value.onFilterChanged() })
</script>

