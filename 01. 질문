<script setup>
  import { shallowRef, ref, computed, unref } from 'vue'
  import { useContentLoading } from '@/composables/useContentLoading'
  import global from '@/constants/enums/global'

  const _Field = global.Field

  // #region Received - Props
  const _Props = defineProps({
    proj_no: { type: [String, Object], required: false, default: null },
    ep_id: { type: [String, Object], required: false, default: null },
    reg_type_id: { type: [String, Object], required: false, default: null },

    tag_idx: { type: [String, Object], required: false, default: null },
    compare_data: { type: [Object], required: false, default: null },
    fn_focusColumn: { type: [Function], required: false, default: null },

    // Auto Created by Modal Wrapper
    var_isModal: { type: [Boolean], required: false, default: null },
    fn_onActionApply: { type: [Function], required: false, default: null },
    fn_onActionClose: { type: [Function], required: false, default: null },
    fn_onShowOverlay: { type: [Function], required: false, default: null },
    fn_onHideOverlay: { type: [Function], required: false, default: null },
    fn_onSetAutoHeight: { type: [Function], required: false, default: null },
  })

  const projNoRef = computed(() => unref(_Props.proj_no))
  const regEpIdRef = computed(() => unref(_Props.ep_id))
  const regIdRef = computed(() => unref(_Props.reg_type_id))
  const tagIdxRef = computed(() => unref(_Props.tag_idx))
  const compareDataRef = computed(() => unref(_Props.compare_data))
  //#endregion Received - Props

  //#region import Component, Modal 사용시 필수 설정
  const onSetAutoHeight = function () {
    const { fn_onSetAutoHeight: fn } = _Props
    if (fn && typeof fn?.call === 'function') return fn.call(this)
  }
  const onActionClose = function () {
    const { fn_onActionClose: fn } = _Props
    if (fn && typeof fn?.call === 'function') return fn.call(this)
  }
  const onActionApply = function (data) {
    const { fn_onActionApply: fn } = _Props
    if (fn && typeof fn?.call === 'function') return fn.call(this, data)
  }
  const onClickClose = () => onActionClose()
  const onClickApply = () => onActionClose()
  //#endregion

  //#region WRAPPER
  const _PageWrapperRef = shallowRef(null)
  const onShowOverlay = function (config) {
    const pageWrapper = _PageWrapperRef.value
    const loadConfig = pageWrapper ? { target: pageWrapper } : {}
    useContentLoading?.startLoading({ ...loadConfig, ...config })
  }
  const onHideOverlay = function () {
    useContentLoading?.stopLoading()
  }
  //#endregion WRAPPER

  // -------------------------------------------------------------
  // [추가] 라디오 버튼 상태 관리 (default: 'display', original: 'original')
  // -------------------------------------------------------------
  const valueMode = ref('original')

  // 라디오 버튼 변경 시 AG-Grid 셀 재렌더링
  const onChangeValueMode = () => {
    if (gridRef.value) {
      gridRef.value.refreshCells({ force: true })
    }
  }

  const EXCLUDE_FIELDS = ['EP_ID', '_id']
  const gridRef = shallowRef(null)
  const gridDataRef = computed(() => {
    const list = compareDataRef.value ?? []
    return list.filter(v => !EXCLUDE_FIELDS.includes(v.ATT_ID))
  })

  // 헬퍼 함수: 라디오 버튼 옵션에 따라 DB Value를 보여줄지 기본 데이터를 보여줄지 판단
  const getFormattedValue = (params, defaultField, rawValField) => {
    const data = params.data || {}
    if (valueMode.value === 'original') {
      // DB 전달 원본 값 (WRK_VAL_RAW 또는 WRK_VAL 등 DB 필드명에 맞게 참조)
      return data[rawValField] ?? data[defaultField] ?? ''
    }
    return data[defaultField] ?? ''
  }

  const gridColDefs = [
    {
      field: _Field.ATT_ID,
      headerName: 'Attribute',
      cellClass: 'bg-col-odd',
      width: 120,
      cellRenderer: params => {
        const isUseFocus = params.data?.USE_FOCUS
        const fn_focus = _Props.fn_focusColumn
        if (isUseFocus && fn_focus) {
          const link = document.createElement('a')
          link.href = 'javascript:void(0);'
          link.innerText = params.value
          link.onclick = () => fn_focus(params.value)
          return link
        }
        return params.value
      },
    },
    { field: _Field.DESC, headerName: 'Description', cellClass: 'bg-col-even', width: 120 },
    {
      field: 'WRK_VAL',
      headerName: 'Working Value',
      cellClass: 'bg-col-odd',
      width: 180,
      valueGetter: params => getFormattedValue(params, 'WRK_VAL', 'WRK_VAL_RAW'),
    },
    {
      field: 'PUB_VAL',
      width: 180,
      headerName: 'Publish Value',
      cellClass: params => {
        const classList = ['bg-col-even']
        if (params?.data?.PUB_DELETED) {
          classList.push('text-red', 'text-decoration-line-through')
        }
        return classList
      },
      valueGetter: params => getFormattedValue(params, 'PUB_VAL', 'PUB_VAL_RAW'),
    },
    {
      field: 'JOIN_VAL',
      headerName: 'Join Value',
      cellClass: 'bg-col-odd',
      width: 180,
      valueGetter: params => getFormattedValue(params, 'JOIN_VAL', 'JOIN_VAL_RAW'),
    },
    {
      field: _Field.EDIT_YN,
      headerName: 'Edit',
      cellClass: 'bg-col-even checkbox-center-cell',
      maxWidth: 70,
      hide: false,
    },
    {
      field: _Field.PUB_YN,
      headerName: 'Publish',
      cellClass: 'bg-col-odd checkbox-center-cell',
      maxWidth: 70,
      hide: false,
    },
    {
      field: 'DIFF',
      headerName: 'Diff',
      cellClass: 'bg-col-even checkbox-center-cell',
      maxWidth: 70,
      hide: true,
      cellDataType: 'boolean',
      valueGetter: params => {
        const dataItem = params.data
        const attId = dataItem.ATT_ID
        const attrs = [
          _Field._ID, _Field.TAG_IDX, _Field.PROJ_NO, _Field.PRNT_TAG_IDX,
          _Field.REG_TMPL_PAIRS, _Field.CRTER_NO, _Field.CRTE_DTM,
          _Field.CHGER_NO, _Field.CHGE_DTM, _Field.PIC_NO,
        ]
        if (!attrs.includes(attId)) {
          const wVal = String(dataItem.WRK_VAL ?? '').toLowerCase()
          const pVal = String(dataItem.PUB_VAL ?? '').toLowerCase()
          return wVal !== pVal
        }
        return false
      },
    },
    {
      field: 'DIFF_JOIN',
      headerName: 'Diff Join',
      cellClass: 'bg-col-odd checkbox-center-cell',
      maxWidth: 70,
      hide: true,
      cellDataType: 'boolean',
      valueGetter: params => {
        const dataItem = params.data
        const attId = dataItem.ATT_ID
        const isJoinVal = dataItem.isJoinVal
        const attrs = [
          _Field._ID, _Field.TAG_IDX, _Field.PROJ_NO, _Field.PRNT_TAG_IDX,
          _Field.REG_TMPL_PAIRS, _Field.CRTER_NO, _Field.CRTE_DTM,
          _Field.CHGER_NO, _Field.CHGE_DTM, _Field.PIC_NO,
        ]
        if (!attrs.includes(attId) && isJoinVal) {
          const wVal = String(dataItem.WRK_VAL ?? '').toLowerCase()
          const jVal = String(dataItem.JOIN_VAL ?? '').toLowerCase()
          return wVal !== jVal
        }
        return false
      },
    },
  ]

  const _GridBindProps = ref({
    columnDefs: gridColDefs,
    rowData: gridDataRef,
    class: 'ag-theme-custom',
    rowSelection: 'single',
    defaultColDef: {
      editable: false,
      minWidth: 80,
      floatingFilter: true,
      filter: 'agMultiColumnFilter',
      filterParams: {
        maxNumConditions: 2,
        numAlwaysVisibleConditions: 2,
        defaultJoinOperator: 'OR',
      },
    },
    rowClassRules: {
      'bg-row-diff': params => {
        const dataItem = params.data
        const attId = dataItem.ATT_ID
        const attrs = [
          _Field._ID, _Field.TAG_IDX, _Field.PROJ_NO, _Field.PRNT_TAG_IDX,
          _Field.REG_TMPL_PAIRS, _Field.CRTER_NO, _Field.CRTE_DTM,
          _Field.CHGER_NO, _Field.CHGE_DTM, _Field.PIC_NO,
        ]
        if (!attrs.includes(attId)) {
          const wVal = String(dataItem.WRK_VAL ?? '').trim().toLowerCase()
          const pVal = String(dataItem.PUB_VAL ?? '').trim().toLowerCase()
          return wVal !== pVal
        }
        return false
      },
      'bg-row-diff-join': params => {
        const dataItem = params.data
        const attId = dataItem.ATT_ID
        const isJoinVal = dataItem.isJoinVal
        const attrs = [
          _Field._ID, _Field.TAG_IDX, _Field.PROJ_NO, _Field.PRNT_TAG_IDX,
          _Field.REG_TMPL_PAIRS, _Field.CRTER_NO, _Field.CRTE_DTM,
          _Field.CHGER_NO, _Field.CHGE_DTM, _Field.PIC_NO,
        ]
        if (!attrs.includes(attId) && isJoinVal) {
          const wVal = String(dataItem.WRK_VAL ?? '').trim().toLowerCase()
          const jVal = String(dataItem.JOIN_VAL ?? '').trim().toLowerCase()
          return wVal !== jVal
        }
        return false
      },
    },
    statusBar: {
      statusPanels: [
        { statusPanel: 'agTotalRowCountComponent' },
        { statusPanel: 'agFilteredRowCountComponent' },
        { statusPanel: 'agSelectedRowCountComponent' },
      ],
    },
    suppressRowTransform: true,
    pagination: false,
    rowDragManaged: true,
    rowMultiSelectWithClick: false,
    columnHoverHighlight: true,
    suppressRowClickSelection: true,
    suppressLastEmptyLineOnPaste: true,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
  })

  const _GridOnProps = {
    gridReady: params => {
      gridRef.value = params.api
    },
  }

  defineOptions({ name: 'CommonProperties', inheritAttrs: false })
  defineExpose({
    onClickApply,
    onClickClose,
  })
</script>

<template>
  <div class="w-100 h-100 d-flex flex-column" ref="_PageWrapperRef">
    <!-- 상단 라디오 버튼 옵션 영역 -->
    <div class="radio-option-bar p-2 d-flex align-items-center gap-3">
      <label class="radio-label">
        <input
          type="radio"
          value="original"
          v-model="valueMode"
          @change="onChangeValueMode"
        />
        <span>Original Value (DB Value)</span>
      </label>
      <label class="radio-label">
        <input
          type="radio"
          value="display"
          v-model="valueMode"
          @change="onChangeValueMode"
        />
        <span>Display Value</span>
      </label>
    </div>

    <!-- 그리드 영역 -->
    <div class="flex-grow-1 w-100 h-100">
      <ag-grid-vue class="w-100 h-100" v-bind="_GridBindProps" v-on="_GridOnProps" />
    </div>
  </div>
</template>

<style scoped lang="scss">
  .radio-option-bar {
    background-color: #f1f3f5;
    border-bottom: 1px solid #dee2e6;
    .radio-label {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
    }
  }

  :deep(.checkbox-center-cell) {
    place-items: center;
  }
  :deep(.bg-row-diff) {
    background-color: #ffff00;
    > .bg-col-odd,
    .bg-col-even {
      background-color: inherit;
    }
  }
  :deep(.bg-row-diff-join) {
    background-color: #ff8000;
    > .bg-col-odd,
    .bg-col-even {
      background-color: inherit;
    }
  }
  :deep(.bg-col-odd) {
    background-color: #f9f9f9;
  }
  :deep(.bg-col-even) {
    background-color: #f5f5f5;
  }
  :deep(.ag-checkbox-input-wrapper.ag-disabled, .ag-radio-button-input-wrapper.ag-disabled) {
    filter: unset;
    opacity: unset;
  }
</style>
