<template>
  <div class="d-flex flex-column h-100 bg-white">
    <!-- 상단 컨트롤바 (조회 조건 영역) -->
    <div class="search-header p-3 border-bottom bg-light">
      <div class="d-flex align-items-center justify-content-between w-100">
        <div class="d-flex align-items-center gap-3">
          <!-- 타이틀 영역 -->
          <div class="d-flex align-items-center gap-2 border-end pe-3">
            <i class="fa fa-layer-group text-primary"></i>
            <span class="fw-bold text-dark">데이터 통합 집계</span>
          </div>

          <!-- 프로젝트 선택 Dropdown -->
          <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">대상 프로젝트</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-white border d-flex justify-content-between align-items-center bg-white custom-dropdown"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate">{{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트 선택' }}</span>
                <i class="fa fa-chevron-down ms-2 text-muted tiny"></i>
              </button>
              <ul class="dropdown-menu p-2 shadow-lg border-0" style="min-width: 250px; max-height: 400px; overflow-y: auto">
                <li class="px-2 pb-2 border-bottom mb-2">
                  <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="프로젝트 검색..." @click.stop />
                </li>
                <li class="dropdown-item px-2 py-1 rounded">
                  <CheckBox id="all-check" label="전체 선택" :value="isAllSelected" @change="toggleAllSelection" />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <CheckBox
                    :id="'p-' + proj.PROJ_NO"
                    :label="proj.PROJ_NO"
                    :value="selectedProjects.includes(proj.PROJ_NO)"
                    @change="val => handleProjectChange(proj.PROJ_NO, val)"
                  />
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 필터 및 버튼 -->
        <div class="d-flex align-items-center gap-2">
          <InputBox
            v-model:value="attributeFilter"
            placeholder="결과 내 필터링..."
            icon="fa-filter"
            style="width: 200px"
            @clear="attributeFilter = ''"
          />
          <button class="btn btn-primary btn-sm px-3" @click="onSearch" :disabled="selectedProjects.length === 0">
            조회
          </button>
        </div>
      </div>
    </div>

    <!-- 그리드 영역 -->
    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue
        class="ag-theme-custom h-100"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

// 에디터 컴포넌트 임포트 (경로 확인 필수)
import CheckBox from '@/components/default/editors/CheckBox.vue'
import InputBox from '@/components/default/editors/InputBox.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicColumnDefs = ref([])

// 프로젝트 필터링
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.toLowerCase()
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw))
})

const isAllSelected = computed(() => 
  filteredProjectList.value.length > 0 && 
  filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO))
)

const toggleAllSelection = val => {
  const ids = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = val ? [...new Set([...selectedProjects.value, ...ids])] : []
}

const handleProjectChange = (id, val) => {
  if (val) selectedProjects.value.push(id)
  else selectedProjects.value = selectedProjects.value.filter(i => i !== id)
}

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

const onSearch = async () => {
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  try {
    const promises = selectedProjects.value.map(p =>
      axiosWrapper.post('/api/Attributes/Get', { ProjectNo: p })
        .then(res => res.map(row => ({ ...row, _P_NO: p })))
        .catch(() => [])
    )
    const results = await Promise.all(promises)
    gridRowData.value = results.flat()
    
    if (gridRowData.value.length > 0) {
      dynamicColumnDefs.value = Object.keys(gridRowData.value[0]).map(k => ({
        headerName: k === '_P_NO' ? '프로젝트' : k,
        field: k,
        pinned: k === '_P_NO' ? 'left' : null,
        width: 120
      }))
    }
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

const gridOptions = computed(() => ({
  columnDefs: dynamicColumnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, filter: true, resizable: true },
  isExternalFilterPresent: () => attributeFilter.value !== '',
  doesExternalFilterPass: node => {
    const val = attributeFilter.value.toLowerCase()
    return Object.values(node.data).some(v => String(v).toLowerCase().includes(val))
  }
}))

const onGridReady = p => { gridApi.value = p.api }
watch(() => attributeFilter.value, () => gridApi.value?.onFilterChanged())
</script>

<style scoped>
.custom-dropdown { height: 32px; min-width: 160px; font-size: 0.85rem; }
.tiny { font-size: 0.7rem; }
.search-header { z-index: 10; }
:deep(.ag-theme-custom) { height: 100% !important; }
</style>
