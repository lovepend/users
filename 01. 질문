{
  field: 'INOUT',
  headerName: 'In/Out',
  suppressHeaderMenuButton: true,
  editable: params => {
    return projectPermissions.value.some(
      el => isProjectAdmin.value || (el.EP_ID === selectedRegEp.value && el.Role === 'Manager')
    )
  },
  flex: 0.8,
  cellEditor: 'agRichSelectCellEditor',
  cellEditorParams: function (params) {
    return {
      values: ['BOTH', 'IN', 'OUT'],
      valueListGap: 5,
      allowTyping: true,
      filterList: true,
      highlightMatch: true,
      valueListMaxHeight: 220,
      focusOnOpen: true,

      // 👇 콤보 리스트 내부 아이템들의 스타일을 제어하는 렌더러를 꽂아줍니다.
      cellRenderer: params => {
        // params.value: 현재 리스트 아이템의 값 ('BOTH', 'IN' 등)
        const element = document.createElement('div');
        element.innerText = params.value;
        element.style.padding = '4px 8px';
        
        // 마우스를 올리거나 키보드로 선택 시 시각적 효과를 주기 위해 
        // 렌더러 엘리먼트 자체에 스타일 속성을 부여합니다.
        element.style.borderRadius = '4px';
        
        // ag-grid가 내부적으로 포커스된 아이템에 클래스를 주므로, 
        // CSS 대신 스타일 속성으로 hover 효과 등을 연동하고 싶을 때 유용합니다.
        return element;
      }
    }
  },
  cellStyle: params => {
    if (typeof params.data._id === 'string') {
      if (params.data._id.indexOf('get_') > -1) {
        return { backgroundColor: 'rgb(221 229 181 / 50%)' }
      }
    }
    return null
  },
  suppressKeyboardEvent: params => {
    const { event, editing } = params;
    if (editing) {
      const key = event.key;
      if (key === 'ArrowUp' || key === 'ArrowDown' || key === 'Enter') {
        event.stopPropagation();
        return true; 
      }
    }
    return false;
  }
}
