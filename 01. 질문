<template>
  <div class="d-flex flex-column h-100 bg-white">
    <!-- 상단 컨트롤 영역 -->
    <div class="p-3 border-bottom bg-light">
      <div class="d-flex align-items-center gap-3">
        
        <!-- 1. 프로젝트 선택 (기존 방식 원복: 키인 검색) -->
        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-dark text-nowrap">Project</span>
          <div class="dropdown">
            <button
              class="btn btn-sm btn-outline-secondary dropdown-toggle bg-white custom-dropdown"
              type="button"
              data-bs-toggle="dropdown"
            >
              {{ selectedProject ? selectedProject.PROJ_NO : '프로젝트를 선택하세요' }}
            </button>
            <ul class="dropdown-menu p-2 shadow" style="min-width: 300px; max-height: 400px; overflow-y: auto;">
              <li class="px-2 pb-2 border-bottom mb-2">
                <input 
                  type="text" 
                  class="form-control form-control-sm" 
                  v-model="projectSearchKeyword" 
                  @click.stop 
                  placeholder="프로젝트 번호/명 입력..." 
                />
              </li>
              <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO">
                <a class="dropdown-item" @click="selectProject(proj)" style="cursor: pointer;">
                  <b class="text-primary">{{ proj.PROJ_NO }}</b> <small class="text-muted ms-1">{{ proj.DESC }}</small>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- 2. 통합 조회 키워드 입력 -->
        <div class="d-flex align-items-center gap-2 border-start ps-3">
          <span class="fw-bold text-dark text-nowrap">Keyword</span>
          <input 
            type="text" 
            class="form-control form-control-sm" 
            style="width: 250px" 
            v-model="searchKeyword" 
            placeholder="Tag No 입력 (엔터 시 조회)"
            @keyup.enter="onSearch"
          />
        </div>

        <!-- 3. 조회 버튼 -->
        <button
          class="btn btn-sm btn-primary px-3"
          @click="onSearch"
          :disabled="!selectedProject || isLoading"
        >
          <i v-if="isLoading" class="fa fa-spinner fa-spin me-1"></i>
          <i v-else class="fa fa-search me-1"></i>조회
        </button>

        <!-- 4. 멀티 필터 (그리드 내부 검색용) -->
        <div class="d-flex align-items-center gap-2 border-start ps-3 ms-auto">
          <span class="fw-bold text-success text-nowrap"><i class="fa fa-filter me-1"></i>Filter</span>
          <textarea
            class="form-control form-control-sm border-success"
            v-model="attributeFilter"
            rows="1"
            style="width: 200px; font-size: 12px;"
            placeholder="결과 내 필터..."
          ></textarea>
        </div>
      </div>
    </div>

    <!-- 그리드 영역 -->
    <div class="flex-grow-1">
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import { AgGridVue } from 'ag-grid-vue3'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()
const gridApi = shallowRef(null)
const isLoading = ref(false)

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProject = ref(null) // 단일 선택으로 변경
const searchKeyword = ref('')
const attributeFilter = ref('')
const gridRowData = ref([])

const urlEpId = computed(() => route.query.ep_id || '')

// --- 프로젝트 선택 (기존 검색 기능 원복) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => 
    !kw || p.PROJ_NO.toLowerCase().includes(kw) || p.DESC.toLowerCase().includes(kw)
  )
})

const selectProject = (proj) => {
  selectedProject.value = proj
}

// --- 핵심: 조회 및 데이터 합치기 (Publish + Working) ---
const onSearch = async () => {
  if (!selectedProject.value) return sAlert.Warning('프로젝트를 선택해 주세요.')
  
  isLoading.value = true
  gridApi.value?.showLoadingOverlay()

  try {
    const projNo = selectedProject.value.PROJ_NO
    const keywords = searchKeyword.value.split(/[\s,]+/).filter(k => k.trim())

    // 1. Publish 데이터와 Working 데이터 병렬 호출
    const [pubRes, workRes] = await Promise.all([
      axiosWrapper.post('/api/Data/SearchPublishData', { ProjectNo: projNo, Keywords: keywords }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } }),
      axiosWrapper.post('/api/Data/SearchWorkingData', { ProjectNo: projNo, Keywords: keywords }, { headers: { Projectno: projNo, Ep_id: urlEpId.value } })
    ])

    // 2. 참조 코드 기반 데이터 매핑 (Type 구분자 추가하여 합치기)
    // 서버 응답이 배열인지 확인 후 가공
    const pubList = (Array.isArray(pubRes) ? pubRes : []).map(item => ({
      ...item,
      DATA_TYPE: 'Publish', // 구분값 추가
      REG_TYPE_ID: item.REG_TYPE_ID || 'PUB'
    }))

    const workList = (Array.isArray(workRes) ? workRes : []).map(item => ({
      ...item,
      DATA_TYPE: 'Working', // 구분값 추가
      REG_TYPE_ID: item.REG_TYPE_ID || 'WORK'
    }))

    // 3. 두 리스트를 하나로 합쳐서 그리드에 전달 (Total)
    gridRowData.value = [...pubList, ...workList]

    if (gridRowData.value.length === 0) {
      gridApi.value?.showNoRowsOverlay()
    }

  } catch (err) {
    console.error(err)
    sAlert.Error('데이터 조회 중 오류가 발생했습니다.')
  } finally {
    isLoading.value = false
    gridApi.value?.hideOverlay()
  }
}

// --- 그리드 정의 ---
const columnDefs = [
  { headerName: 'Source', field: 'DATA_TYPE', width: 100, cellStyle: p => ({ fontWeight: 'bold', color: p.value === 'Publish' ? '#0d6efd' : '#fd7e14' }) },
  { headerName: 'Tag Number', field: 'TAG_NO', width: 180, filter: 'agTextColumnFilter' },
  { headerName: 'Description', field: 'TAG_DESC', width: 250 },
  { headerName: 'Class', field: 'CLS_ID', width: 100 },
  { headerName: 'Status', field: 'STATUS_ID', width: 100 },
  { headerName: 'Reg Type', field: 'REG_TYPE_ID', width: 120 },
  { headerName: 'Project No', field: 'PROJECT_NO', width: 120 }
]

const gridOptions = computed(() => ({
  columnDefs: columnDefs,
  rowData: gridRowData.value,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true },
  loadingOverlayComponent: AggridLoadingOverlay,
  // 내부 멀티 필터 로직
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: (node) => {
    const terms = attributeFilter.value.split(/[\s,\n]+/).filter(t => t.trim()).map(t => t.toLowerCase())
    const target = String(node.data.TAG_NO || '').toLowerCase()
    return terms.some(term => target.includes(term))
  }
}))

const onGridReady = (params) => { gridApi.value = params.api }

watch(attributeFilter, () => gridApi.value?.onFilterChanged())

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Ep_id: urlEpId.value } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})
</script>

<style scoped>
.custom-dropdown { width: 250px; text-align: left; display: flex; justify-content: space-between; align-items: center; }
</style>
