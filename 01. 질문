<template>
  <div class="template__page d-flex flex-column h-100 bg-white">
    <!-- 상단 헤더 영역: 프로젝트 선택 및 조회 버튼 -->
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 번호/명 검색..."
                    @click.stop
                  />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer">
                    <input
                      class="form-check-input me-2 mt-0"
                      type="checkbox"
                      :value="proj.PROJ_NO"
                      v-model="selectedProjects"
                    />
                    <span class="text-truncate">
                      <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                      <small class="text-muted ms-1">({{ proj.DESC }})</small>
                    </span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button
            class="btn btn-sm btn-primary px-4 shadow-sm"
            @click="onSearch"
            :disabled="selectedProjects.length === 0"
          >
            <i class="fa fa-play me-1"></i>데이터 원본 조회
          </button>
          
          <span class="text-muted small">※ 서버에서 받은 JSON 데이터를 그대로 테이블로 변환합니다.</span>
        </div>

        <!-- 결과 내 필터 -->
        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-success text-nowrap small"><i class="fa fa-filter"></i> 결과 필터</span>
          <input
            type="text"
            class="form-control form-control-sm border-success"
            style="width: 200px"
            v-model="quickFilterText"
            placeholder="빠른 검색..."
          />
        </div>
      </div>
    </div>

    <!-- 그리드 영역 -->
    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue
        class="ag-theme-alpine w-100 h-100"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        :loadingOverlayComponent="loadingOverlayComponent"
        @grid-ready="onGridReady"
        :quickFilterText="quickFilterText"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

import 'ag-grid-community/styles/ag-grid.css'
import 'ag-grid-community/styles/ag-theme-alpine.css'

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const quickFilterText = ref('')

const gridApi = shallowRef()
const rowData = ref([])
const columnDefs = ref([])

const loadingOverlayComponent = AggridLoadingOverlay
const defaultColDef = {
  sortable: true,
  filter: true,
  resizable: true,
  floatingFilter: true,
  flex: 1,
  minWidth: 100
}

// --- 프로젝트 목록 로드 ---
onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (error) {
    console.error('Project Load Error:', error)
  }
})

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  if (!kw) return projectList.value
  return projectList.value.filter(p => 
    p.PROJ_NO?.toLowerCase().includes(kw) || p.DESC?.toLowerCase().includes(kw)
  )
})

// --- 데이터 조회 및 자동 컬럼 생성 ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  rowData.value = []
  columnDefs.value = []

  try {
    // 1. 선택된 프로젝트들의 데이터를 병렬로 가져옴
    const fetchPromises = selectedProjects.value.map(projNo =>
      axiosWrapper.post('/api/Attributes/Get', { ContainDeleted: false, ProjectNo: projNo })
        .then(res => {
          // 각 로우에 소속 프로젝트 정보를 추가
          return (Array.isArray(res) ? res : []).map(item => ({
            ...item,
            __ORIGIN_PROJ_NO: projNo // 출처 표시용 서비스 컬럼
          }))
        })
        .catch(() => [])
    )

    const results = await Promise.all(fetchPromises)
    const combinedData = results.flat()

    if (combinedData.length > 0) {
      // 2. JSON 데이터의 모든 Key를 추출하여 컬럼 정의 생성
      const allKeys = new Set()
      combinedData.forEach(obj => {
        Object.keys(obj).forEach(key => {
          // ATTRIBUTES 같은 객체/배열 타입은 제외하거나 문자열화 해서 보여줌
          if (typeof obj[key] !== 'object') {
            allKeys.add(key)
          }
        })
      })

      const generatedCols = Array.from(allKeys).map(key => ({
        headerName: key,
        field: key,
        // 출처 컬럼은 특별 관리
        pinned: key === '__ORIGIN_PROJ_NO' ? 'left' : null,
        cellClass: key === '__ORIGIN_PROJ_NO' ? 'bg-light fw-bold' : ''
      }))

      columnDefs.value = generatedCols
      rowData.value = combinedData
    } else {
      sAlert.Info('조회된 데이터가 없습니다.')
    }
  } catch (e) {
    console.error(e)
    sAlert.Error('데이터 로드 실패')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

const onGridReady = (params) => {
  gridApi.value = params.api
}
</script>

