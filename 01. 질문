  })

  const onSearch = () => {
    tagAttListRef.value = []

    if (gridApi_TagData.value) {
      getData()
    }
  }

  onBeforeMount(() => {
    if (sAlert?.isVisible()) {
      sAlert.close()
    }
    statusBar_Atts.value = {
      statusPanels: [
        { statusPanel: 'agTotalRowCountComponent' },
        { statusPanel: 'agFilteredRowCountComponent' },
        { statusPanel: 'agSelectedRowCountComponent' },
        {
          statusPanel: 'AgDetailStatusBar',
          statusPanelParams: { customStyle: { 'background-color': '#e4dbe9' } },
          align: 'left',
        },
      ],
    }
  })

  watch(currentProjNo, newProject => {
    getData()
    selectedTagData.value = null
    firstGridDataModel.value = null
    firstGridDataModel2.value = null

    context.value = { customKey: 'Tag Idx : ', customValue: '' }
  })

  /*			AG GRID 정의 				*/
  const gridApi_TagData = shallowRef()
  const gridApi_Atts = shallowRef()

  const themeClass = 'ag-theme-custom'
  const getRowId = params => {
    return params.data.Id
  }
  const refreshParams = {
    force: true,
    suppressFlash: true,
  }

  const context = ref()

  const agMultiColumnFilterParams = {
    filters: [
      {
        filter: 'agTextColumnFilter',
        filterParams: {
          buttons: ['reset'],
        },
      },
      {
        filter: 'agSetColumnFilter',
        filterParams: {
          comparator: (a, b) => {
            const valA = parseInt(a)
            const valB = parseInt(b)
            if (valA === valB) return 0
            return valA > valB ? 1 : -1
          },
          buttons: ['reset'],
        },
      },
      {
        filter: 'AgCustomFilter',
        filterParams: {
          buttons: ['reset'],
        },
      },
    ],
  }

  const checkClassType = (params, originData, standColumn) => {
    if (originData) {
      let v = originData.find(elem => elem[standColumn] == params.data[standColumn])
      if (v) {
        if (params.colDef.field) {
          if (Array.isArray(v[params.colDef.field])) {
            if (Array.isArray(params.value)) {
              if (v[params.colDef.field].join(',') === params.value.join(',')) {
                return null
              } else {
                return 'hasWork'
              }
            } else {
              if (params.value) {
                return 'hasWork'
              } else {
                return 'hasWorkEmpty'
              }
            }
          } else {
            if (params.value == v[params.colDef.field]) {
              return null
            } else {
              return 'hasWork'
            }
          }
        }
      } else {
        return 'hasWorkEmpty'
      }
    } else {
      return null
    }
  }

  const checkRefEmpty = obj => {
    if (typeof obj === 'number') {
      if (!obj) return false
      else return true
    } else {
      if (!obj) return false
      else if (_.isNil(obj)) return false
      else if (_.isEmpty(obj)) return false
      else if (obj.length == 1 && _.isEmpty(obj[0])) {
        return false
      } else return true
    }
  }

  var dateFilterParams = {
    minValidDate: '2008-01-08',
    maxValidDate: new Date(new Date().getTime() + 24 * 60 * 60 * 1000),
    comparator: (filterLocalDateAtMidnight, cellValue) => {
      var dateAsString = cellValue.substring(0, 10)
      if (dateAsString == null) return -1
      var dateParts = dateAsString.split('-')
      var cellDate = new Date(Number(dateParts[0]), Number(dateParts[1]) - 1, Number(dateParts[2]))

      if (filterLocalDateAtMidnight.getTime() === cellDate.getTime()) {
        return 0
      }

      if (cellDate < filterLocalDateAtMidnight) {
        return -1
      }

      if (cellDate > filterLocalDateAtMidnight) {
        return 1
      }
      return 0
    },
  }

  const dateFullFormatter = params => {
    let fmt = ''
    if (params.value) fmt = new Date(params.value).toLocaleString()
    else fmt = ''
    return fmt
  }

  const loadingOverlayComponentParams = {
    loadingMessage: 'Loading...',
  }

  const upCase = str => {
    return str.toUpperCase()
  }

  const compareTwoCase = (str1, str2) => {
    let word1 = upCase(str1.trim())
    let word2 = upCase(str2.trim())
    if (word1 == word2) {
      return true
    } else {
      return false
    }
  }

  const statusBar = {
    statusPanels: [
      { statusPanel: 'agTotalRowCountComponent' },
      { statusPanel: 'agFilteredRowCountComponent' },
      { statusPanel: 'agSelectedRowCountComponent' },
    ],
  }

  const defaultColDef = ref({
    editable: params => {
      const canEdit = params.data.PROJ_NO === currentProjNo.value
      return canEdit
    },
    filter: 'agMultiColumnFilter',
    filterParams: agMultiColumnFilterParams,
    floatingFilter: true,
  })
  const defaultColDef_Atts = ref({
    editable: true,
    filter: 'agMultiColumnFilter',
    filterParams: agMultiColumnFilterParams,
    floatingFilter: true,
  })

  const colDefs = ref([
    {
      suppressHeaderMenuButton: true,
      headerCheckboxSelection: true,
      headerCheckboxSelectionFilteredOnly: true,
      filter: false,
      flex: 1,
      minWidth: 30,
      maxWidth: 30,
      checkboxSelection: params => (params.data.PROJ_NO != currentProjNo.value ? false : true),
    },
    { field: 'TAG_NO', headerName: 'TagNo', minWidth: 50, flex: 1 },
    { field: 'TAG_IDX', headerName: 'TagIdx', minWidth: 180, flex: 1 },
    { field: 'ClS_ID', headerName: 'ClsId', editable: false, minWidth: 140, flex: 1 },
    { field: 'TAG_DESC', headerName: 'TagDesc', minWidth: 200, flex: 1 },
    { field: 'TAG_TYPE_ID', headerName: 'TagTypeId', minWidth: 100, flex: 1 },

    { field: 'EP_ID', headerName: 'EpId', minWidth: 50, flex: 1 },
    { field: 'EP_IC', headerName: 'EpIc', minWidth: 50, flex: 1 },
    {
      field: 'CRTE_DTM',
      headerName: 'CRTE DTM',
      cellDataType: 'date',
      valueFormatter: dateFullFormatter,
      filter: 'agDateColumnFilter',
      filterParams: dateFilterParams,
      editable: false,
      cellClass: 'agReadOnly',
      hide: true,
    },
    { field: 'CHGER_NO', headerName: 'CHGER NO', editable: false, cellClass: 'agReadOnly', hide: true },
    {
      field: 'CHGE_DTM',
      headerName: 'CHGE DTM',
      cellDataType: 'date',
      valueFormatter: dateFullFormatter,
      filter: 'agDateColumnFilter',
      filterParams: dateFilterParams,
      editable: false,
      cellClass: 'agReadOnly',
      hide: true,
    },
    { field: '_id', headerName: 'id', editable: false, hide: true },
    { field: 'STATUS', editable: false, hide: true },
  ])

  const colDefs_Atts = [
    { rowDrag: true, width: 30, suppressHeaderMenuButton: true, filter: false, sortable: false },
    {
      checkboxSelection: true,
      suppressHeaderMenuButton: true,
      headerCheckboxSelection: true,
      headerCheckboxSelectionFilteredOnly: true,
      minWidth: 30,
      maxWidth: 30,
      flex: 1,
      filter: false,
      editable: true,
    },
    { field: 'ATT_ID', headerName: 'ATT_ID', flex: 1 },
    { field: 'VALUE', headerName: 'VALUE', flex: 1 },
    { field: 'VALUE_DBL', headerName: 'VALUE_DBL', flex: 1 },
    { field: 'UOM_ID', headerName: 'UOM_ID', flex: 1 },
  ]

  /*****		API 통신 			******/

  const tagDataListRef = ref(null)

  const tagAttListRef = ref(null)

  const selectedTagData = ref(null)
  const firstGridDataModel = ref(null)
  const firstGridDataModel2 = ref(null)

  let changedCells = []

  // Register 연결 여부를 판단
  const isConnectedToRegister = computed(() => {
    return selectedTagData.value && selectedTagData.value.REG_TYPE_ID
  })

  /************************************
   * 	GET DATA
   * ***********************************/

  const getData = async () => {
    tagDataListRef.value = []
    changedCells = []
    tagAttListRef.value = []
    if (!currentProjNo.value) {
      sAlert.Warning(`Project를  선택해주세요`)
      return
    }

    gridApi_TagData.value.setGridOption('loading', true)

    let url = `/api/Data/SearchPublishData`

    if (isWorkingRef.value === true) {
      url = `/api/Data/SearchPublishData`
    }

    try {
      const jsonData = await axiosWrapper.post(url, {
        ProjectNo: currentProjNo.value,
        Keyword: searchKeywordRef.value.trim(),
      })
      if (_.isEmpty(jsonData)) {
        tagDataListRef.value = []
        changedCells = []
        tagAttListRef.value = []
        gridApi_TagData.value.setGridOption('loading', false)
        return
      }

      allTagDataList.value = jsonData
      const filteredData = jsonData.filter(item => !item.DELETED) // 삭제된 ID제외하고 저장
      tagDataListRef.value = filteredData
      firstGridDataModel.value = _.cloneDeep(tagDataListRef.value)
    } catch (error) {
      gridApi_TagData.value.setGridOption('loading', false)
      tagDataListRef.value = []
      changedCells = []

      if (!(error instanceof axios.AxiosError)) {
        sAlert.Warning('Failed to get Tag Data : ' + error.message)
      }
    }

    gridApi_TagData.value.setGridOption('loading', false)
  }

  //   CODE VALUE LIST (오른쪽 grid) 불러온다.
  const getTagDataAttList = async tagData => {
    if (_.isNil(tagData)) {
      tagAttListRef.value = []
      context.value = { customKey: 'Tag Idx : ', customValue: '' }
      return
    }

    isShowCreateBtn.value = true
    isShowDeleteBtn.value = true
    isShowSaveBtn.value = true
    isShowMultiCreateBtn.value = true
    showAddAttr.value = true

    if (!_.isNil(selectedTagData.value?.CL_ID)) {
      context.value = {
        customKey: 'Tag Idx : ',
        customValue: `${selectedTagData.value.CL_ID}     [ ${selectedTagData.value.DESC} ]`,
      }
    } else {
      context.value = { customKey: 'Tag Idx : ', customValue: '' }
      tagAttListRef.value = []
      gridApi_Atts.value.setGridOption('loading', false)

      return
    }

    try {
      let jsonData = selectedTagData.value.Attributes

      if (_.isEmpty(jsonData)) {
        tagAttListRef.value = []
      } else {
        let data = jsonData.VALUES
        let lnkAtt = jsonData.LNK_ATT
        if (checkRefEmpty(lnkAtt)) {
          // column 정의
          lnkAtt = _.sortBy(lnkAtt, ['ATT_ID']) // SEQ에 따른 컬럼 순서 적용
          lnkAtt.forEach(a => {
            cols.push({ field: a.ATT_ID, headerName: a.ATT_ID, minWidth: 110, flex: 1 })
          })
          // attributes 분해
          data = data.map(item => {
            // 각 item의 요소 중에 배열인 값이 있다면 객체로 convert!(ATTRIBUTES)
            let attrsObj = {}

            for (const property in item) {
              //ATTRIBUTES
              if (Array.isArray(item[property]) && property == 'ATTRIBUTES') {
                item[property].forEach(attr => {
                  attrsObj[attr.ATT_ID] = attr.VALUE
                })
              }
            }
            //배열 이나 객체 요소는 제거
            let newItem = _.omitBy(item, _.isObject)
            //Convert한 Attributes 합친다.
            newItem = Object.assign({}, attrsObj, item)
            return newItem
          })
        }
        tagAttListRef.value = data
        firstGridDataModel2.value = _.cloneDeep(tagAttListRef.value)
      }
      colDefs_Atts.value = cols
      gridApi_Atts.value.setGridOption('loading', false)
    } catch (error) {
      tagAttListRef.value = []

      if (!(error instanceof axios.AxiosError)) {
        sAlert.Warning('Failed to get Tag Data Value List : ' + error.message)
      }
    }
  }

  /************************************
   * 	GRID EVENT
   * ***********************************/
  const onFirstDataRendered = event => {
    gridApi_TagData.value.forEachNode(function (rowNode, index) {
      if (index == 0) {
        getTagDataAttList(rowNode.data)
      }
    })
  }

  const onRowClicked = event => {
    // event 객체에서 클릭된 로우의 node를 가져옴
    const clickedNode = event.node

    // 해당 node를 선택 상태로 만듦
    if (clickedNode) {
      gridApi_TagData.value.deselectAll()
      clickedNode.setSelected(true)
    }

    selectedTagData.value = event.data

    getTagDataAttList(event.data)

    isDisabledDeleteSubBtn.value = true
  }

  const onRowSelected = event => {
    selectedTagData.value = event.data

    tagAttListRef.value = event.data.Attributes
  }

  const onRowSelected_Atts = event => {}

  const onGridReady = params => {
    gridApi_TagData.value = params.api
    if (currentProjNo.value) getData()
  }
  const onGridReady_Atts = params => {
    gridApi_Atts.value = params.api
  }

  const modal = ref(null) // isModalType - 0: Del, 1: Add, 2: Edit]
  const isModalType = ref(1)
  const attrModalTitle = computed({
    get() {
      switch (isModalType.value) {
        case 0:
          return 'Del Attribute'
        case 1:
          return 'Add Attribute'
        case 2:
          return 'Edit Attribute'
        default:
          return 'Attribute Management'
      }
    },
  })
  const attrModalBtnName = computed({
    get() {
      switch (isModalType.value) {
        case 0:
          return 'DELETE'
        case 1:
          return 'CREATE'
        case 2:
          return 'SAVE'
        default:
          return 'Confirm'
      }
    },
  })

  const deleteSelectedData = async () => {
    let successCount = 0
    let failCount = 0

    let selectedRows = gridApi_TagData.value.getSelectedRows()
    if (_.isEmpty(selectedRows)) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }
    let confirmResult = await sAlert.Confirm('It will be deleted immediately. Are you sure you want to delete?')
    if (!confirmResult.isConfirmed) {
      return
    }

    // 필요 시 해당 코드 작성
  }

  const gridBindCommonProps = ref({
    style: 'width: 100%; height: 100%',
    class: themeClass,
    rowSelection: 'multiple',
    suppressLastEmptyLineOnPaste: true,
    enableRangeSelection: true,
    pagination: false,
    suppressRowClickSelection: true,
    columnHoverHighlight: true,
    undoRedoCellEditing: true,
    enableFillHandle: true,
    undoRedoCellEditingLimit: 20,
    loadingOverlayComponent: AggridLoadingOverlay,
    loadingOverlayComponentParams: loadingOverlayComponentParams,
  })

  const gridBindTagProps = ref({
    statusBar: statusBar,
    getRowId: getRowId,
    rowMultiSelectWithClick: false,
    defaultColDef: defaultColDef,
    columnDefs: colDefs,
    rowData: tagDataListRef,
    ...gridBindCommonProps.value,
  })

  const gridBindAttProps = ref({
    statusBar: statusBar_Atts,
    rowMultiSelectWithClick: true,
    defaultColDef: defaultColDef_Atts,
    columnDefs: colDefs_Atts,
    rowData: tagAttListRef,
    context: context,
    rowDragManaged: true,
    ...gridBindCommonProps.value,
  })

  const gridOnCommonProps = index => {
    switch (index) {
      case 'Tag':
        return {
          firstDataRendered: onFirstDataRendered,
          rowSelected: onRowSelected,
          cellClicked: onRowClicked,
          gridReady: onGridReady,
        }
      case 'Att':
        return {
          rowSelected: onRowSelected_Atts,
          gridReady: onGridReady_Atts,
        }
    }
  }

  defineOptions({
    name: `PubWrkData`,
    components: { AgDetailStatusBar, AgCustomFilter },
  })
</script>

