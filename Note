import GC from '@mescius/spread-sheets-designer'
import { ApiCommon } from '@/utils/axios/api-common'
import { useEmployees } from '@/stores/app-employees'
const { setEmployeeInfo } = useEmployees()

const _EditorType = 'UserEditor'

function UserSelectCellType(FIELD, NAME_FIELD, DEPT_FIELD) {
  this.field = FIELD
  this.nameField = NAME_FIELD
  this.deptField = DEPT_FIELD
  this.searchTimer = null
  this.listbox = null
  this.originalValue = null // ESC лҢҖл№„ кё°мЎҙ мӮ¬лІҲ м ҖмһҘ
}

UserSelectCellType.prototype = new GC.Spread.Sheets.CellTypes.Base()

// 1. нҷ”л©ҙ н‘ңмӢң: мқҙлҰ„(л¶Җм„ң)
UserSelectCellType.prototype.paint = function (ctx, value, x, y, w, h, style, options) {
  const data = options.sheet.getDataItem(options.row)
  const name = data?.[this.nameField] ?? ''
  const dept = data?.[this.deptField] ?? ''
  const text = name ? `${name}${dept ? `(${dept})` : ''}` : ''
  GC.Spread.Sheets.CellTypes.Base.prototype.paint.apply(this, [ctx, text, x, y, w, h, style, options])
}

// 2. м—җл””н„° мғқм„ұ
UserSelectCellType.prototype.createEditorElement = function (context) {
  // SpreadJS лӮҙмһҘ м—җл””н„°(input) мғқм„ұ
  const editor = GC.Spread.Sheets.CellTypes.Base.prototype.createEditorElement.apply(this, arguments);
  editor.setAttribute('EditorType', _EditorType);
  
  // кё°мЎҙ мҪ”л“ңмІҳлҹј мӮ¬лІҲмқ„ лӢҙмқ„ hidden input мғқм„ұ л°Ҹ л¶Җм°©
  const hiddenInput = document.createElement('input');
  hiddenInput.type = 'hidden';
  hiddenInput.setAttribute('EditorUses', 'value');
  editor.parentElement.appendChild(hiddenInput);
  editor.hiddenInput = hiddenInput;

  // лҰ¬мҠӨнҠёл°•мҠӨ мғқм„ұ (Bodyм—җ л”ұ н•ң лІҲл§Ң мғқм„ұн•ҳкұ°лӮҳ мһ¬мӮ¬мҡ©)
  if (!this.listbox) {
    this.listbox = document.createElement('ul');
    this.listbox.className = 'vs__dropdown-menu'; // кё°мЎҙ н…Ңл§Ҳ мҠӨнғҖмқј мң м§Җ
    this.listbox.style.cssText = 'position: fixed; z-index: 30000; background: white; border: 1px solid #ccc; display: none; list-style: none; padding: 0; margin: 0; overflow-y: auto; max-height: 200px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);';
    document.body.appendChild(this.listbox);
  }

  // лӮҙмһҘ м—җл””н„° мһ…л Ҙ мқҙлІӨнҠё
  editor.addEventListener('input', (e) => {
    const keyword = e.target.value.trim();
    if (this.searchTimer) clearTimeout(this.searchTimer);

    this.searchTimer = setTimeout(async () => {
      if (keyword.length < 1) { this.listbox.style.display = 'none'; return; }

      const response = await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: keyword }) ?? [];
      this.listbox.innerHTML = '';

      if (response.length > 0) {
        const rect = editor.getBoundingClientRect();
        this.listbox.style.width = `${rect.width}px`;
        this.listbox.style.left = `${rect.left}px`;
        this.listbox.style.top = `${rect.bottom}px`;
        this.listbox.style.display = 'block';

        response.forEach(item => {
          const li = document.createElement('li');
          li.className = 'vs__dropdown-option';
          li.style.cssText = 'padding: 6px 10px; cursor: pointer; list-style: none; font-size: 13px;';
          li.innerText = `${item.EMP_NM}(${item.DEPT_NAME || ''})`;
          
          li.onmouseover = () => { li.style.backgroundColor = '#0078d4'; li.style.color = 'white'; };
          li.onmouseout = () => { li.style.backgroundColor = 'white'; li.style.color = 'black'; };

          li.onmousedown = (ev) => {
            ev.preventDefault();
            // мӨ‘мҡ”: Hidden Inputм—җ мӮ¬лІҲ м ҖмһҘ (getEditorValueм—җм„ң м°ёмЎ°)
            hiddenInput.value = item.EMP_NO;
            editor.value = item.EMP_NM;

            setEmployeeInfo({ ...item, code: item.EMP_NO });
            this.listbox.style.display = 'none';
            
            // нҺём§‘ к°•м ң мў…лЈҢ -> getEditorValue нҳём¶ңлҗЁ
            context.sheet.endEdit();
          };
          this.listbox.appendChild(li);
        });
      } else {
        this.listbox.style.display = 'none';
      }
    }, 300);
  });

  return editor;
}

// 3. к°’ л°ҳнҷҳ: кё°мЎҙ мҪ”л“ңмқҳ лЎңм§Ғмқ„ к·ёлҢҖлЎң мӮҙлҰј
UserSelectCellType.prototype.getEditorValue = function (editorContext) {
  // editorContextлҠ” input м—ҳлҰ¬лЁјнҠёмһ„
  const hiddenInput = editorContext.parentElement.querySelector('[EditorUses="value"]');
  const val = hiddenInput ? hiddenInput.value : null;

  // м„ нғқлҗң мӮ¬лІҲмқҙ мһҲмңјл©ҙ л°ҳнҷҳ, м—Ҷмңјл©ҙ кё°мЎҙ мӮ¬лІҲ(originalValue) л°ҳнҷҳ
  return val || this.originalValue;
}

// 4. нҺём§‘ мӢңмһ‘ мӢң к°’ м„Өм •
UserSelectCellType.prototype.setEditorValue = function (editorContext, value) {
  this.originalValue = value; // кё°мЎҙ мӮ¬лІҲ ліҙкҙҖ
  const hiddenInput = editorContext.parentElement.querySelector('[EditorUses="value"]');
  if (hiddenInput) hiddenInput.value = ''; // мҙҲкё°нҷ”
  editorContext.value = ''; // мһ…л Ҙм°Ҫ л№„мӣҖ
}

UserSelectCellType.prototype.destroyEditorElement = function (editorContext) {
  if (this.listbox) {
    this.listbox.style.display = 'none';
  }
}

UserSelectCellType.prototype.updateEditor = function (editorContext, cellStyle, cellRect) {
  if (editorContext) {
    return { width: cellRect.width, height: cellRect.height };
  }
}

export default UserSelectCellType;
