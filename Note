<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="input-box">
            <label class="field-label">Project No</label>
            <input v-model="projectNo" type="text" class="design-input" placeholder="P0001" />
          </div>
          <div class="input-box flex-grow">
            <label class="field-label">API Keywords</label>
            <textarea v-model="keyword" class="design-textarea" placeholder="Keywords..."></textarea>
          </div>
          <div class="input-box">
            <label class="field-label">Result Filter</label>
            <input v-model="localSearchQuery" type="text" class="design-input filter-highlight" placeholder="Search Tag No..." />
          </div>
          <div class="btn-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="primary-gradient-btn">
              {{ isLoading ? 'Loading...' : '데이터 통합 조회' }}
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="result-count">Total: <strong>{{ filteredList.length }}</strong></div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn-action btn-danger-custom" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn-action btn-success-custom">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-outer-container">
        <table class="master-table">
          <thead>
            <tr class="header-row-top">
              <th rowspan="2" class="sticky-header sticky-col col-chk h-double">
                <div class="center-vh"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div>
              </th>
              <th rowspan="2" class="sticky-header sticky-col col-idx h-double">Idx</th>
              <th rowspan="2" class="sticky-header sticky-col col-tag h-double">Tag No</th>
              
              <th colspan="3" class="group-header pub-bg h-single">Published (Master)</th>
              <th colspan="3" class="group-header wrk-bg h-single">Working (Current)</th>
            </tr>
            <tr class="header-row-sub">
              <th class="sub-th pub-bg h-single">EP ID</th>
              <th class="sub-th pub-bg h-single">CLS</th>
              <th class="sub-th pub-bg h-single">Del</th>
              <th class="sub-th wrk-bg h-single">EP ID</th>
              <th class="sub-th wrk-bg h-single">CLS</th>
              <th class="sub-th wrk-bg h-single">Del</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="data-group">
            <tr v-for="rowNum in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum">
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-td">
                <div class="center-vh"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-td clickable" @click="openModal(group)">
                <div class="center-vh font-bold">{{ group.TagIdx }}</div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-td clickable" @click="openModal(group)">
                <div class="cell-padding"><span class="tag-highlight" v-html="highlightText(group.TagNo)"></span></div>
              </td>
              
              <td class="cell-pub data-td clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.EpId || 'null' }}</td>
              <td class="cell-pub data-td clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.ClsId || 'null' }}</td>
              <td class="cell-pub data-td clickable" @click="openModal(group)">
                <div class="center-vh">
                  <span v-if="group.pubList[rowNum-1]" :class="['status-badge', group.pubList[rowNum-1].Deleted ? 'is-del' : 'is-active']">
                    {{ group.pubList[rowNum-1].Deleted ? 'Y' : 'N' }}
                  </span>
                  <span v-else class="null-txt">null</span>
                </div>
              </td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.EpId || 'null' }}</td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.ClsId || 'null' }}</td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)">
                <div class="center-vh">
                  <span v-if="group.wrkList[rowNum-1]" :class="['status-badge', group.wrkList[rowNum-1].Deleted ? 'is-del' : 'is-active']">
                    {{ group.wrkList[rowNum-1].Deleted ? 'Y' : 'N' }}
                  </span>
                  <span v-else class="null-txt">null</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-window">
        <div class="modal-header">
          <div class="title-area">
            <h2>Data Analysis</h2>
            <div class="meta-info-row">
              <span class="info-item"><small>TAG NO:</small> <strong>{{ selectedItem?.TagNo }}</strong></span>
              <span class="info-item"><small>TAG IDX:</small> <strong>{{ selectedItem?.TagIdx }}</strong></span>
              <span class="info-item"><small>_ID:</small> <strong>{{ selectedItem?.pubList[0]?._id || selectedItem?.wrkList[0]?._id || 'N/A' }}</strong></span>
            </div>
          </div>
          <div class="modal-actions">
            <button @click="isJsonMode = !isJsonMode" class="btn-mode-toggle">
              {{ isJsonMode ? '📊 Table View' : '{} JSON View' }}
            </button>
            <button @click="closeModal" class="btn-modal-close">✕</button>
          </div>
        </div>
        <div class="modal-body">
          <div v-if="!isJsonMode" class="modal-table-container">
            <table class="analysis-table">
              <thead>
                <tr>
                  <th colspan="5" class="th-sys">System Info</th>
                  <th :colspan="allAttributeKeys.length" class="th-attr">Attributes</th>
                </tr>
                <tr>
                  <th>Source</th><th>Tag No</th><th>EP ID</th><th>Class</th><th>Status</th>
                  <th v-for="key in allAttributeKeys" :key="key">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(row, idx) in modalRows" :key="idx">
                  <td><span class="src-tag">{{ row.source }}</span></td>
                  <td><strong>{{ row.TagNo }}</strong></td>
                  <td>{{ row.EpId }}</td><td>{{ row.ClsId }}</td>
                  <td class="text-center"><span :class="['status-badge', row.Deleted ? 'is-del' : 'is-active']">{{ row.Deleted ? 'DEL' : 'ACT' }}</span></td>
                  <td v-for="key in allAttributeKeys" :key="key + idx">
                    <span v-if="row.attrMap[key] === undefined" class="empty-val">-</span>
                    <span v-else :class="{'null-val': row.attrMap[key] === 'null'}">{{ row.attrMap[key] }}</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div v-else class="json-viewer-container">
             <div class="json-pane"><h3>Published</h3><pre><code>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</code></pre></div>
             <div class="json-pane"><h3>Working</h3><pre><code>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</code></pre></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)
    const isJsonMode = ref(false)

    const filteredList = computed(() => {
      const q = localSearchQuery.value.trim().toLowerCase();
      return q ? mergedList.value.filter(g => String(g.TagNo).toLowerCase().includes(q)) : mergedList.value;
    });

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      const groupMap = new Map();
      try {
        const keys = keyword.value.split(/[\s,\n,]+/).map(k => k.trim()).filter(k => k);
        for (const k of keys) {
          const payload = { ProjectNo: projectNo.value, Keyword: k };
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload).catch(() => ({ data: [] })),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload).catch(() => ({ data: [] }))
          ]);
          const pData = Array.isArray(pubRes) ? pubRes : (pubRes?.data || []);
          const wData = Array.isArray(wrkRes) ? wrkRes : (wrkRes?.data || []);
          const merge = (list, type) => {
            list.forEach(item => {
              if (!item.TagIdx) return;
              if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] });
              groupMap.get(item.TagIdx)[type].push(item);
            });
          };
          merge(pData, 'pubList'); merge(wData, 'wrkList');
        }
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => String(a.TagNo).localeCompare(b.TagNo, undefined, { numeric: true }));
      } catch (e) { alert('조회 실패'); } finally { isLoading.value = false; }
    };

    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const extract = (list) => list.forEach(i => (i.Attributes || i.attributes || []).forEach(a => { if(a.ATT_ID) keys.add(a.ATT_ID) }));
      extract(selectedItem.value.pubList); extract(selectedItem.value.wrkList);
      return Array.from(keys).sort();
    });

    const modalRows = computed(() => {
      if (!selectedItem.value) return [];
      const parse = (item, src) => {
        const attrMap = {};
        (item.Attributes || item.attributes || []).forEach(a => {
          let val = 'null';
          if (a.VALUE !== null && a.VALUE !== undefined && String(a.VALUE).trim() !== '') val = String(a.VALUE);
          else if (a.VALUE_DBL !== null && a.VALUE_DBL !== 0) val = String(a.VALUE_DBL);
          attrMap[a.ATT_ID] = val;
        });
        return { source: src, TagNo: item.TagNo || selectedItem.value.TagNo, EpId: item.EpId || 'null', ClsId: item.ClsId || 'null', Deleted: !!item.Deleted, attrMap };
      };
      const res = [];
      selectedItem.value.pubList.forEach(i => res.push(parse(i, 'Published')));
      selectedItem.value.wrkList.forEach(i => res.push(parse(i, 'Working')));
      return res;
    });

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem, isJsonMode,
      allAttributeKeys, modalRows, fetchAndMergeData,
      highlightText: (t) => {
        const q = localSearchQuery.value.trim();
        return q ? String(t).replace(new RegExp(`(${q})`, 'gi'), '<mark class="hl">$1</mark>') : t;
      },
      openModal: (g) => { selectedItem.value = g; showModal.value = true; isJsonMode.value = false; },
      closeModal: () => { showModal.value = false; },
      toggleAllSelect: () => { selectedIds.value = (selectedIds.value.length === filteredList.value.length) ? [] : filteredList.value.map(g => g.TagIdx) },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('삭제하시겠습니까?'),
      downloadExcel: () => alert('CSV 다운로드')
    };
  }
}
</script>

