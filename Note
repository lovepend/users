.scroll-area { flex: 1; overflow-y: auto; border: 1px solid #e1e4e8; border-radius: 6px; background: #fcfcfc; }
.data-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
.data-table th { background: #f1f3f5; padding: 10px; font-size: 0.75rem; color: #444; position: sticky; top: 0; z-index: 5; border-bottom: 1px solid #ddd; }
.data-table td { padding: 8px; border-bottom: 1px solid #eee; vertical-align: middle; }
.cell-input { width: 100%; border: 1px solid #ccc; padding: 6px; border-radius: 4px; box-sizing: border-box; font-family: monospace; font-size: 0.9rem; }
.font-code { font-family: 'Consolas', monospace; color: #666; }
