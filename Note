<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-square-check"
      :title="'Tag 통합 분석 조회 (Published + Working)'"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-primary">Project No</span>
            <input
              type="text"
              placeholder="e.g. P0001"
              class="form-control form-control-sm"
              style="width: 100px;"
              v-model="manualProjNo"
            />
          </label>

          <label class="d-flex align-items-center gap-2">
            <span class="fw-500">Keyword</span>
            <input
              type="text"
              placeholder="Input Keyword"
              class="form-control form-control-sm"
              v-model="searchKeywordRef"
              @keyup.enter="onSearch"
            />
          </label>
          
          <button class="btn btn-xs btn-primary" @click="onSearch">Search</button>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-heading p-0 m-0">
          <div class="w-100 h-100">
            <BasicToolBar
              @delete-data="deleteSelectedData"
              :showCreate="false"
              :showMultiCreate="false"
              :showDelete="isSetupAdmin"
              :isDisabledDeleteBtn="isDisabledDeleteBtn"
              :showSave="false"
            />
          </div>
        </div>
        
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue 
            v-bind="gridBindProps" 
            @grid-ready="onGridReady"
            @selection-changed="onSelectionChanged"
          />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, computed, shallowRef } from 'vue'
  import { storeToRefs } from 'pinia'

  // Library & Store
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppMenuStore } from '@/stores/app-menu'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import * as _ from 'lodash-es'

  // Components
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import { sAlert } from '@/utils/messages/alert-common'
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'

  const appPermission = useAppPermissionStore()
  const { isSetupAdmin } = storeToRefs(appPermission)
  const appMenu = useAppMenuStore()

  // --- 상태 정의 ---
  const gridApi = shallowRef()
  const manualProjNo = ref(appMenu.currentProjNo || '') 
  const searchKeywordRef = ref('')
  const tagDataListRef = ref([]) 
  const isDisabledDeleteBtn = ref(true)

  const onSearch = () => getData()

  // --- 데이터 조회 로직 (동시 호출 및 통합) ---
  const getData = async () => {
    if (!manualProjNo.value) {
      sAlert.Warning(`Project No를 입력해주세요.`)
      return
    }

    gridApi.value.setGridOption('loading', true)
    tagDataListRef.value = [] // 조회 시작 시 초기화

    const payload = {
      ProjectNo: manualProjNo.value.trim(),
      Keyword: searchKeywordRef.value.trim(),
    }

    try {
      // Published와 Working 데이터를 동시에 호출
      const [pubRes, wrkRes] = await Promise.allSettled([
        axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
        axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
      ])

      let combinedData = []

      // Published 데이터 처리
      if (pubRes.status === 'fulfilled' && !_.isEmpty(pubRes.value)) {
        const pubList = pubRes.value
          .filter(item => !item.DELETED)
          .map(item => ({ ...item, Source: 'Published' }))
        combinedData = [...combinedData, ...pubList]
      }

      // Working 데이터 처리
      if (wrkRes.status === 'fulfilled' && !_.isEmpty(wrkRes.value)) {
        const wrkList = wrkRes.value
          .filter(item => !item.DELETED)
          .map(item => ({ ...item, Source: 'Working' }))
        combinedData = [...combinedData, ...wrkList]
      }

      if (combinedData.length === 0) {
        sAlert.Info('조회된 데이터가 없습니다.')
      } else {
        // TagNo 순으로 정렬하여 그리드에 삽입
        tagDataListRef.value = _.sortBy(combinedData, ['TagNo', 'Source'])
      }
    } catch (error) {
      sAlert.Error('데이터 로드 중 오류가 발생했습니다.')
    } finally {
      gridApi.value.setGridOption('loading', false)
    }
  }

  // --- AG Grid 설정 ---
  const colDefs = [
    {
      headerName: 'Source',
      field: 'Source',
      minWidth: 100,
      maxWidth: 100,
      pinned: 'left',
      cellRenderer: params => {
        const isWrk = params.value === 'Working'
        const color = isWrk ? '#ed6c02' : '#0288d1'
        return `<span class="badge" style="background-color: ${color}; color: white; border-radius: 4px; padding: 2px 6px; font-size: 11px;">${params.value}</span>`
      },
      // 소스별로 필터링 가능하도록 설정
      filter: 'agSetColumnFilter'
    },
    { field: 'TagIdx', headerName: 'TagIdx', minWidth: 120, pinned: 'left' },
    { field: 'TagNo', headerName: 'TagNo', minWidth: 160, pinned: 'left' },
    { field: 'EpId', headerName: 'EP ID', minWidth: 100 },
    { field: 'ClsId', headerName: 'Class', minWidth: 120 },
    { field: 'TagDesc', headerName: 'Description', minWidth: 300, flex: 1 },
    { 
      field: 'CHGE_DTM', 
      headerName: 'Last Updated', 
      minWidth: 180,
      valueFormatter: p => p.value ? new Date(p.value).toLocaleString() : '-' 
    }
  ]

  const gridBindProps = computed(() => ({
    columnDefs: colDefs,
    rowData: tagDataListRef.value,
    style: 'width: 100%; height: 100%',
    class: 'ag-theme-custom',
    rowSelection: 'multiple',
    pagination: true,
    paginationPageSize: 100,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: {
      sortable: true,
      filter: true,
      resizable: true,
      floatingFilter: true,
      cellStyle: { 'background-color': '#ffffff' }
    }
  }))

  const onGridReady = params => {
    gridApi.value = params.api
  }

  const onSelectionChanged = () => {
    const nodes = gridApi.value.getSelectedNodes()
    isDisabledDeleteBtn.value = nodes.length === 0
  }

  const deleteSelectedData = async () => {
    const rows = gridApi.value.getSelectedRows()
    if (_.isEmpty(rows)) return
    const confirm = await sAlert.Confirm(`선택한 ${rows.length}건을 삭제하시겠습니까?`)
    if (confirm.isConfirmed) {
      // 삭제 처리 후 재조회
      getData()
    }
  }

  defineOptions({ name: 'PubWrkAllInOneGrid' })
</script>

<style scoped lang="scss">
  /* 틀고정 경계선 및 스타일 */
  ::v-deep(.ag-pinned-left-cols-container) {
    border-right: 1.5px solid #bdc3c7 !important;
    background-color: #fff;
  }

  ::v-deep(.badge) {
    font-weight: bold;
  }
</style>
