<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-search-plus" :title="'Tag 통합 분석 및 속성 비교' + (manualProjNo ? ` [ ${manualProjNo} ]` : '')">
      <template #actions>
        <div class="d-flex align-items-center gap-3 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-primary">Project No</span>
            <input type="text" class="form-control form-control-sm" style="width: 80px;" v-model="manualProjNo" />
          </label>
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold">조회 키워드</span>
            <textarea class="form-control form-control-sm" style="width: 180px; height: 31px; resize: none;" v-model="searchKeywordRef" placeholder="공백/엔터 구분"></textarea>
          </label>
          <button class="btn btn-xs btn-primary" @click="onSearch">조회</button>
          
          <div class="ms-3 ps-3 border-start d-flex align-items-center gap-2">
            <span class="fw-bold text-success"><i class="fa-filter"></i> 결과 필터</span>
            <input type="text" class="form-control form-control-sm border-success" style="width: 180px;" v-model="localFilterQuery" placeholder="필터 키워드" />
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-heading p-0 m-0">
          <div class="w-100 h-100">
            <BasicToolBar :showCreate="false" :showMultiCreate="false" :showSave="false" :showDelete="isSetupAdmin" :isDisabledDeleteBtn="isDisabledDeleteBtn" />
          </div>
        </div>
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue 
            v-bind="gridBindProps" 
            @grid-ready="onGridReady" 
            @selection-changed="onSelectionChanged" 
            @cell-clicked="onCellClicked" 
          />
        </div>
      </div>
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">{{ selectedRow?.Source }}</span>
            <span class="fw-bold text-white">Detail View: {{ selectedRow?.TagNo }}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-xs" :class="isJsonMode ? 'btn-outline-info' : 'btn-info'" @click="isJsonMode = !isJsonMode">
              {{ isJsonMode ? 'Table View' : 'JSON View' }}
            </button>
            <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
          </div>
        </div>
        <div class="modal-body-content">
          <div v-if="isJsonMode" class="h-100 w-100 json-container">
            <pre class="json-content"><code>{{ JSON.stringify(selectedRow, null, 2) }}</code></pre>
          </div>
          <div v-else class="h-100 w-100">
            <ag-grid-vue v-bind="modalGridBindProps" class="ag-theme-alpine w-100 h-100" />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
import { storeToRefs } from 'pinia'
import { useAppPermissionStore } from '@/stores/app-permission'
import { useAppMenuStore } from '@/stores/app-menu'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import * as _ from 'lodash-es'

import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import { sAlert } from '@/utils/messages/alert-common'
import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

const { isSetupAdmin } = storeToRefs(useAppPermissionStore())
const appMenu = useAppMenuStore()

const gridApi = shallowRef()
const manualProjNo = ref(appMenu.currentProjNo || '')
const searchKeywordRef = ref('')
const localFilterQuery = ref('')
const rawDataList = ref([])
const dynamicAttCols = ref([]) 
const isDisabledDeleteBtn = ref(true)

const showModal = ref(false)
const isJsonMode = ref(true) 
const selectedRow = ref(null)

// --- 필터 및 하이라이트 (데이터가 매핑된 후에 작동해야 함) ---
const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
  return rawDataList.value.filter(i => {
    // 모든 컬럼 데이터를 검사하도록 확장 가능하나, 주요 키워드 위주로 필터링
    const target = `${i.TagNo} ${i.EpId} ${i.ClsId} ${i.TagDesc} ${i.Source}`.toLowerCase()
    return kws.some(kw => target.includes(kw))
  })
})

const highlightRenderer = (p) => {
  if (!p.value || !localFilterQuery.value.trim()) return p.value
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k)
  let text = String(p.value)
  kws.forEach(kw => { 
    const reg = new RegExp(`(${kw})`, 'gi')
    text = text.replace(reg, `<mark class="filter-highlight">$1</mark>`) 
  })
  return text
}

// --- 데이터 조회 및 가공 검증 로직 ---
const onSearch = () => getData()
const getData = async () => {
  if (!manualProjNo.value) return sAlert.Warning(`Project No를 입력하세요.`)
  
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  
  const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
  let combined = []

  try {
    // 1. API 호출 (Published / Working)
    for (const key of searchKeys) {
      const payload = { ProjectNo: manualProjNo.value.trim(), Keyword: key }
      const [p, w] = await Promise.allSettled([
        axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
        axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
      ])
      
      if (p.status === 'fulfilled' && Array.isArray(p.value)) {
        combined.push(...p.value.map(i => ({ ...i, Source: 'Published' })))
      }
      if (w.status === 'fulfilled' && Array.isArray(w.value)) {
        combined.push(...w.value.map(i => ({ ...i, Source: 'Working' })))
      }
    }

    // 데이터가 없는 경우 처리
    if (combined.length === 0) {
      rawDataList.value = []
      dynamicAttCols.value = []
      sAlert.Info('조회된 데이터가 없습니다.')
      return
    }

    // 2. 모든 Attribute ID 수집 (VALUE가 있는 것 기준)
    const allAttIds = new Set()
    combined.forEach(item => {
      const attrs = item.Attributes || item.attributes || []
      attrs.forEach(a => { if (a.ATT_ID) allAttIds.add(a.ATT_ID) })
    })

    // 3. 데이터 Flat화 및 null 처리
    const processedData = combined.filter(i => !i.DELETED).map(item => {
      const flatItem = { ...item }
      const attrs = item.Attributes || item.attributes || []
      
      // 먼저 모든 수집된 ID에 대해 'null'로 초기화
      allAttIds.forEach(id => { flatItem[`ATT_${id}`] = 'null' })

      // 실제 데이터 매핑 (VALUE만 사용)
      attrs.forEach(a => {
        if (a.VALUE !== undefined && a.VALUE !== null && a.VALUE !== '') {
          flatItem[`ATT_${a.ATT_ID}`] = a.VALUE
        }
      })
      return flatItem
    })

    // 4. 동적 컬럼 생성 (반응형 변수 업데이트)
    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id,
      field: `ATT_${id}`,
      minWidth: 130,
      headerClass: 'att-column-header',
      cellStyle: params => ({ 
        background: '#fff9db', 
        color: params.value === 'null' ? '#adb5bd' : '#000',
        fontStyle: params.value === 'null' ? 'italic' : 'normal',
        borderRight: '1px solid #e2e8f0'
      })
    }))

    // 5. 최종 데이터 할당 (이 시점에 그리드가 갱신됨)
    rawDataList.value = _.sortBy(processedData, ['TagNo', 'Source'])

  } catch (error) {
    console.error('Data Fetch Error:', error)
    sAlert.Error('데이터를 가져오는 중 오류가 발생했습니다.')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// --- 메인 컬럼 정의 (computed) ---
const mainColDefs = computed(() => {
  const fixedCols = [
    { headerName: 'Source', field: 'Source', width: 95, pinned: 'left', cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'};color:white;cursor:pointer;">${p.value}</span>` },
    { field: 'TagIdx', headerName: 'TagIdx', width: 100, pinned: 'left' },
    { field: 'TagNo', headerName: 'TagNo', width: 150, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'EpId', headerName: 'EP ID', width: 100, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'ClsId', headerName: 'Class', width: 100, pinned: 'left', cellRenderer: highlightRenderer },
  ]
  const otherCols = [
    { field: 'TagDesc', headerName: 'Description', minWidth: 250, cellRenderer: highlightRenderer },
    { field: 'CHGE_DTM', headerName: 'Updated', width: 170, valueFormatter: p => p.value ? new Date(p.value).toLocaleString() : '-' }
  ]
  // 순서 보장: 고정 -> 동적 속성 -> 나머지
  return [...fixedCols, ...dynamicAttCols.value, ...otherCols]
})

const gridBindProps = computed(() => ({
  columnDefs: mainColDefs.value,
  rowData: filteredData.value,
  style: 'width: 100%; height: 100%',
  class: 'ag-theme-custom',
  pagination: true,
  paginationPageSize: 100,
  loadingOverlayComponent: AggridLoadingOverlay,
  // 컬럼 정의가 동적으로 바뀔 때 그리드를 리프레시하도록 설정
  reactiveCustomComponents: true,
  defaultColDef: { 
    sortable: true, 
    filter: true, 
    resizable: true, 
    floatingFilter: true, 
    cellStyle: { background: '#fff' } 
  }
}))

// --- 모달 설정 및 핸들러 ---
const modalGridBindProps = computed(() => {
  if (!selectedRow.value) return {}
  const rows = []
  const ignore = ['Attributes', 'attributes', 'Source']
  Object.entries(selectedRow.value).forEach(([k, v]) => {
    if (!ignore.includes(k) && !k.startsWith('ATT_')) {
      rows.push({ category: 'System', key: k, value: typeof v === 'object' ? JSON.stringify(v) : v })
    }
  })
  const attrs = selectedRow.value.Attributes || selectedRow.value.attributes || []
  attrs.forEach(a => { rows.push({ category: 'Attribute', key: a.ATT_ID, value: a.VALUE ?? 'null' }) })

  return {
    columnDefs: [
      { headerName: 'Category', field: 'category', width: 110, pinned: 'left', cellStyle: { background: '#f1f5f9', fontWeight: '600' } },
      { headerName: 'ID / Key', field: 'key', width: 200, pinned: 'left' },
      { headerName: 'Value', field: 'value', flex: 1, cellStyle: p => ({ color: p.value === 'null' ? '#adb5bd' : '#334155' }) }
    ],
    rowData: rows,
    defaultColDef: { sortable: true, filter: true, resizable: true },
    headerHeight: 32, rowHeight: 30
  }
})

const onCellClicked = (p) => { 
  if (p.column.getColId() === 'Source') { 
    selectedRow.value = p.data; 
    showModal.value = true; 
    isJsonMode.value = true; 
  } 
}
const closeModal = () => { showModal.value = false; selectedRow.value = null; }
const onGridReady = p => { gridApi.value = p.api }
const onSelectionChanged = () => { 
  if (gridApi.value) {
    isDisabledDeleteBtn.value = gridApi.value.getSelectedNodes().length === 0 
  }
}

defineOptions({ name: 'PubWrkFinalManager' })
</script>

<style scoped lang="scss">
.custom-modal-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center;
}
.custom-modal-window {
  background: #fff; width: 950px; height: 85%; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.3);
}
.modal-header-dark {
  background: #0f172a; color: #fff; padding: 10px 16px; display: flex; justify-content: space-between; align-items: center;
}
.modal-body-content { flex: 1; overflow: hidden; background: #fff; }
.json-container { padding: 15px; background: #1e293b; overflow: auto; }
.json-content { margin: 0; color: #f1f5f9; font-family: 'Consolas', monospace; font-size: 13px; line-height: 1.4; }

::v-deep(.filter-highlight) { background-color: #ffeb3b !important; color: #000 !important; padding: 0 2px; border-radius: 2px; font-weight: bold; }
::v-deep(.ag-pinned-left-cols-container) { border-right: 2px solid #cbd5e1 !important; background: #fff; }
::v-deep(.badge) { font-size: 11px; font-weight: bold; padding: 3px 8px; border-radius: 4px; display: inline-block; }
::v-deep(.att-column-header) { background-color: #fff9db !important; color: #856404 !important; font-weight: bold !important; border-right: 1px solid #dee2e6 !important; }
</style>
