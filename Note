<template>
  <div id="app">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 조회 시스템</h2>
        <p class="subtitle">Pub(Master)와 Wrk(Current) 데이터를 통합하여 비교 분석합니다.</p>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field flex-grow">
            <label>Keywords <span class="label-hint">(공백/줄바꿈으로 구분)</span></label>
            <textarea
              v-model="keyword"
              placeholder="조회할 태그 번호들을 입력하세요..."
              class="base-input multi-input"
              @keyup.ctrl.enter="fetchAndMergeData"
            ></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">
              <span v-if="!isLoading">통합 검색</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="filter-wrapper">
          <i class="icon-filter"></i>
          <select v-model="filterStatus" class="base-select">
            <option value="all">모든 데이터 보기</option>
            <option value="deleted">삭제된 항목만 (Deleted)</option>
            <option value="active">사용 중인 항목만</option>
          </select>
          <span class="count-badge">총 <b>{{ filteredList.length }}</b>건</span>
        </div>
        <button @click="downloadExcel" class="btn btn-success">📥 엑셀 저장 (CSV)</button>
      </div>

      <main class="content-panel">
        <div v-if="errorMessage" class="alert alert-error">{{ errorMessage }}</div>

        <div class="table-wrapper" v-if="filteredList.length > 0">
          <table class="modern-table">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="w-idx">Index</th>
                <th rowspan="2" class="w-tag">Tag No</th>
                <th colspan="4" class="col-group pub">Published (Master)</th>
                <th colspan="4" class="col-group wrk">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th>EP ID</th><th>CLS</th><th>Type</th><th>Status</th>
                <th>EP ID</th><th>CLS</th><th>Del</th><th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="item in filteredList" :key="item.TagIdx" @click="openModal(item)" class="data-row">
                <td class="cell-idx">{{ item.TagIdx }}</td>
                <td class="cell-tag">{{ item.TagNo }}</td>
                
                <td>{{ item.pub?.EpId || '-' }}</td>
                <td>{{ item.pub?.ClsId || '-' }}</td>
                <td>{{ item.pub?.TagTypeId || '-' }}</td>
                <td>
                  <span v-if="item.pub" :class="['badge', item.pub.Deleted ? 'bg-red' : 'bg-green']">
                    {{ item.pub.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>

                <td>{{ item.wrk?.EpId || '-' }}</td>
                <td>{{ item.wrk?.ClsId || '-' }}</td>
                <td>
                  <span v-if="item.wrk" :class="item.wrk.DelYn ? 'text-red' : ''">{{ item.wrk.DelYn ? 'Y' : 'N' }}</span>
                </td>
                <td>
                  <span v-if="item.wrk" :class="['badge', item.wrk.Deleted ? 'bg-red' : 'bg-green']">
                    {{ item.wrk.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div v-else-if="searched && !isLoading" class="empty-state">
          <p>검색 결과가 없습니다. 키워드를 확인해 주세요.</p>
        </div>
      </main>
    </div>

    <Transition name="fade">
      <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
        <div class="modal-card">
          <header class="modal-header">
            <h3>Tag Detail <small>#{{ selectedItem?.TagIdx }}</small></h3>
            <button @click="closeModal" class="btn-close">&times;</button>
          </header>
          <div class="modal-body">
            <div class="json-grid">
              <div class="json-box">
                <label>Published (Master)</label>
                <pre>{{ selectedItem.pub || 'No Data' }}</pre>
              </div>
              <div class="json-box">
                <label>Working (Current)</label>
                <pre>{{ selectedItem.wrk || 'No Data' }}</pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Transition>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  name: 'TagIntegratedManager',
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const errorMessage = ref('')
    const searched = ref(false)
    const filterStatus = ref('all')
    const showModal = ref(false)
    const selectedItem = ref(null)

    const filteredList = computed(() => {
      if (filterStatus.value === 'deleted') {
        return mergedList.value.filter(item => item.pub?.Deleted || item.wrk?.Deleted || item.wrk?.DelYn)
      } else if (filterStatus.value === 'active') {
        return mergedList.value.filter(item => !item.pub?.Deleted && !item.wrk?.Deleted)
      }
      return mergedList.value
    })

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      errorMessage.value = ''
      searched.value = true
      
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k.length > 0)
      const dataMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload),
          ])
          const pubData = pubRes?.data || pubRes
          const wrkData = wrkRes?.data || wrkRes

          if (Array.isArray(pubData)) {
            pubData.forEach(item => dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: item, wrk: dataMap.get(item.TagIdx)?.wrk || null }))
          }
          if (Array.isArray(wrkData)) {
            wrkData.forEach(item => {
              const existing = dataMap.get(item.TagIdx)
              if (existing) existing.wrk = item
              else dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: null, wrk: item })
            })
          }
        }))
        mergedList.value = Array.from(dataMap.values())
      } catch (err) {
        errorMessage.value = '데이터를 불러오는 중 오류가 발생했습니다.'
      } finally {
        isLoading.value = false
      }
    }

    const downloadExcel = () => {
      let csv = '\uFEFFTagIdx,TagNo,Pub_Ep,Pub_Cls,Wrk_Ep,Wrk_Cls\n'
      filteredList.value.forEach(i => {
        csv += `${i.TagIdx},"${i.TagNo}",${i.pub?.EpId || ''},${i.pub?.ClsId || ''},${i.wrk?.EpId || ''},${i.wrk?.ClsId || ''}\n`
      })
      const link = document.createElement('a')
      link.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }))
      link.setAttribute('download', `Tag_Export_${Date.now()}.csv`)
      link.click()
    }

    const openModal = (item) => { selectedItem.value = item; showModal.value = true; }
    const closeModal = () => { showModal.value = false; selectedItem.value = null; }

    return {
      projectNo, keyword, mergedList, filteredList, isLoading, errorMessage, searched,
      filterStatus, showModal, selectedItem,
      fetchAndMergeData, downloadExcel, openModal, closeModal
    }
  }
}
</script>

