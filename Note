<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="input-box proj-box">
            <label class="field-label">Project No</label>
            <input v-model="projectNo" type="text" class="design-input" placeholder="P0001" />
          </div>
          <div class="input-box kw-box">
            <label class="field-label">API Keywords</label>
            <textarea v-model="keyword" class="design-textarea" placeholder="Enter keywords..."></textarea>
          </div>
          <div class="input-box filter-box">
            <label class="field-label">Result Filter</label>
            <input v-model="localSearchQuery" type="text" class="design-input filter-highlight" placeholder="Filter Tag No..." />
          </div>
          <div class="btn-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="primary-gradient-btn">
              {{ isLoading ? '조회 중...' : '데이터 통합 조회' }}
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="result-count">Total Found: <strong>{{ filteredList.length }}</strong></div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn-action btn-danger-custom" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn-action btn-success-custom">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-outer-container">
        <table class="master-table">
          <thead>
            <tr>
              <th class="m-sticky-th col-chk">Chk</th>
              <th class="m-sticky-th col-idx">Idx</th>
              <th class="m-sticky-th col-tag">Tag No</th>
              <th>Src</th>
              <th>EP ID</th>
              <th>Class ID</th>
              <th>Status</th>
              <th>Deleted</th>
            </tr>
          </thead>
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="data-group">
            <tr v-for="(item, pIdx) in group.pubList" :key="'p-'+group.TagIdx+'-'+pIdx" class="row-pub">
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-chk group-td">
                <input type="checkbox" :value="group.TagIdx" v-model="selectedIds" />
              </td>
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-idx group-td clickable" @click="openModal(group)">
                {{ group.TagIdx }}
              </td>
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-tag group-td clickable" @click="openModal(group)">
                <strong>{{ group.TagNo }}</strong>
              </td>
              <td class="src-cell"><span class="badge pub">P</span></td>
              <td class="clickable" @click="openModal(group)">{{ item.EpId || '-' }}</td>
              <td class="clickable" @click="openModal(group)">{{ item.ClsId || '-' }}</td>
              <td><span :class="['st-badge', item.Deleted ? 'is-del' : 'is-active']">{{ item.Deleted ? 'Inactive' : 'Active' }}</span></td>
              <td class="center-txt">{{ item.Deleted ? 'Y' : 'N' }}</td>
            </tr>
            <tr v-for="(item, wIdx) in group.wrkList" :key="'w-'+group.TagIdx+'-'+wIdx" class="row-wrk">
              <td class="src-cell"><span class="badge wrk">W</span></td>
              <td class="clickable" @click="openModal(group)">{{ item.EpId || '-' }}</td>
              <td class="clickable" @click="openModal(group)">{{ item.ClsId || '-' }}</td>
              <td><span :class="['st-badge', item.Deleted ? 'is-del' : 'is-active']">{{ item.Deleted ? 'Inactive' : 'Active' }}</span></td>
              <td class="center-txt">{{ item.Deleted ? 'Y' : 'N' }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-window">
        <div class="modal-header">
          <div class="title-area">
            <div class="main-title">🔍 Full Data Comparison Analysis</div>
            <div class="meta-info-row">
              <span class="info-chip tag-main"><strong>TAG:</strong> {{ selectedItem?.TagNo }}</span>
              <span class="info-chip"><strong>IDX:</strong> {{ selectedItem?.TagIdx }}</span>
            </div>
          </div>
          <div class="modal-actions">
            <button @click="isJsonMode = !isJsonMode" class="btn-mode-toggle">{{ isJsonMode ? '📋 Table' : '📄 JSON' }}</button>
            <button @click="closeModal" class="btn-modal-close">✕</button>
          </div>
        </div>
        <div class="modal-body">
          <div v-if="!isJsonMode" class="modal-table-container">
            <table class="analysis-table auto-layout">
              <thead>
                <tr>
                  <th class="f-sticky-th f-col-src">Source</th>
                  <th class="f-sticky-th f-col-tag">Tag No</th>
                  <th class="f-sticky-th f-col-epid">EP ID</th>
                  <th class="f-sticky-th f-col-cls">Class</th>
                  <th v-for="key in allSystemKeys" :key="'sh-'+key" class="f-sticky-th sys-h">{{ key }}</th>
                  <th v-for="key in allAttributeKeys" :key="'ah-'+key" class="f-sticky-th attr-h">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(item, idx) in selectedItem?.pubList" :key="'md-p-'+idx" class="row-pub">
                  <td class="f-sticky-td f-col-src"><span class="badge pub">PUBLISHED</span></td>
                  <td class="f-sticky-td f-col-tag">{{ item.TagNo }}</td>
                  <td class="f-sticky-td f-col-epid">{{ item.EpId }}</td>
                  <td class="f-sticky-td f-col-cls">{{ item.ClsId }}</td>
                  <td v-for="key in allSystemKeys" :key="'ps-'+key">{{ item[key] ?? '-' }}</td>
                  <td v-for="key in allAttributeKeys" :key="'pa-'+key">{{ getAttrValue(item, key) }}</td>
                </tr>
                <tr v-for="(item, idx) in selectedItem?.wrkList" :key="'md-w-'+idx" class="row-wrk">
                  <td class="f-sticky-td f-col-src"><span class="badge wrk">WORKING</span></td>
                  <td class="f-sticky-td f-col-tag">{{ item.TagNo }}</td>
                  <td class="f-sticky-td f-col-epid">{{ item.EpId }}</td>
                  <td class="f-sticky-td f-col-cls">{{ item.ClsId }}</td>
                  <td v-for="key in allSystemKeys" :key="'ws-'+key">{{ item[key] ?? '-' }}</td>
                  <td v-for="key in allAttributeKeys" :key="'wa-'+key">{{ getAttrValue(item, key) }}</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div v-else class="json-viewer-container">
            <div class="json-pane"><h3>Published Raw</h3><pre><code>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</code></pre></div>
            <div class="json-pane"><h3>Working Raw</h3><pre><code>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</code></pre></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)
    const isJsonMode = ref(false)

    const filteredList = computed(() => {
      const q = localSearchQuery.value.trim().toLowerCase();
      if (!q) return mergedList.value;
      return mergedList.value.filter(g => g.TagNo.toLowerCase().includes(q));
    });

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      const groupMap = new Map();
      try {
        const keys = keyword.value.split(/[\s,]+/).filter(k => k);
        for (const k of keys) {
          const payload = { ProjectNo: projectNo.value, Keyword: k };
          const [pRes, wRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload).catch(() => []),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload).catch(() => [])
          ]);
          
          const process = (list, type) => {
            (Array.isArray(list) ? list : (list?.data || [])).forEach(i => {
              if (!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
              groupMap.get(i.TagIdx)[type].push(i);
            });
          };
          process(pRes, 'pubList'); process(wRes, 'wrkList');
        }
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => a.TagNo.localeCompare(b.TagNo));
      } finally { isLoading.value = false; }
    };

    const allSystemKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const ignore = ['Attributes', 'attributes', 'TagNo', 'TagIdx', 'EpId', 'ClsId', '_id', 'Deleted'];
      [...selectedItem.value.pubList, ...selectedItem.value.wrkList].forEach(i => {
        Object.keys(i).forEach(k => { if(!ignore.includes(k)) keys.add(k); });
      });
      return Array.from(keys).sort();
    });

    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      [...selectedItem.value.pubList, ...selectedItem.value.wrkList].forEach(i => {
        (i.Attributes || i.attributes || []).forEach(a => keys.add(a.ATT_ID));
      });
      return Array.from(keys).sort();
    });

    const getAttrValue = (item, attId) => {
      const a = (item.Attributes || item.attributes || []).find(x => x.ATT_ID === attId);
      return a ? (a.VALUE ?? a.VALUE_DBL ?? '-') : '-';
    };

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem, isJsonMode,
      allSystemKeys, allAttributeKeys, getAttrValue, fetchAndMergeData,
      openModal: (g) => { selectedItem.value = g; showModal.value = true; },
      closeModal: () => { showModal.value = false; }
    };
  }
}
</script>

