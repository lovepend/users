const colGridAttrDefs = ref([
    // ... 앞부분 컬럼 (PIC_NO, TYPE, TYPE_ID, REG_IDs) 생략 ...
    {
      field: 'TOTAL',
      headerName: 'DATA QTY TOTAL',
      minWidth: 80,
      flex: 1,
      aggFunc: 'sum',
      // 👇 천 단위 콤마 추가
      valueFormatter: params => params.value == null ? '' : Number(params.value).toLocaleString(),
      cellStyle: params => {
