<template>
  <div class="app-container">
    <header class="sticky-top">
      <div class="header-content">
        <h2 class="title">
          <span class="icon">🔍</span> 에러 코드 마스터
        </h2>
        <div class="search-bar">
          <input 
            type="text" 
            v-model="globalSearch" 
            placeholder="찾으시는 에러 메시지나 원인을 입력하세요..." 
            class="global-search-input"
          />
        </div>
      </div>
    </header>

    <main class="content-area">
      <div class="table-card">
        <table>
          <colgroup>
            <col style="width: 60px;">  <col style="width: 140px;"> <col style="width: 130px;"> <col style="width: 23%;">   <col style="width: 23%;">   <col style="width: 23%;">   </colgroup>
          
          <thead>
            <tr>
              <th v-for="col in columns" :key="col" class="sticky-th">
                <div class="th-content">
                  <span class="col-label">{{ col }}</span>
                  
                  <div v-if="col === '기능'" class="filter-group">
                    <input 
                      type="text" 
                      v-model="columnFilters[col]" 
                      class="column-filter-input"
                      placeholder="기능 필터"
                    />
                    <div class="dropdown-wrapper">
                      <button @click="toggleFuncList" class="dropdown-btn" title="기능 목록 보기">
                        ▼
                      </button>
                      <ul v-if="showFuncList" class="dropdown-menu">
                        <li @click="selectFunc('')">전체보기</li>
                        <li v-for="item in uniqueFuncs" :key="item" @click="selectFunc(item)">
                          {{ item }}
                        </li>
                      </ul>
                    </div>
                  </div>

                  <input 
                    v-else
                    type="text" 
                    v-model="columnFilters[col]" 
                    class="column-filter-input"
                    :placeholder="col + ' 필터'"
                  />
                </div>
              </th>
            </tr>
          </thead>

          <tbody>
            <tr v-if="filteredData.length === 0">
              <td :colspan="columns.length" class="no-data">데이터가 없습니다.</td>
            </tr>
            <tr v-for="(row, index) in filteredData" :key="index">
              <td v-for="col in columns" :key="col" :class="['cell', `col-${col}`]">
                <div v-html="highlightText(row[col])"></div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue';
import * as XLSX from 'xlsx';
import excelFileUrl from '@/assets/Errorcode.xlsx?url';

const rawData = ref([]);
const columns = ref(['No', '기능', 'Code', 'Message', '원인', '해결방법']);
const globalSearch = ref('');
const columnFilters = ref({ No: '', 기능: '', Code: '', Message: '', 원인: '', 해결방법: '' });

// 기능 목록 관련 상태
const showFuncList = ref(false);
const uniqueFuncs = ref([]);

const loadExcelData = async () => {
  try {
    const response = await fetch(excelFileUrl);
    const arrayBuffer = await response.arrayBuffer();
    const workbook = XLSX.read(arrayBuffer, { type: 'array' });
    const jsonData = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]]);
    rawData.value = jsonData;

    // '기능' 컬럼에서 중복 제거된 유니크 리스트 추출
    const funcs = jsonData
      .map(item => item['기능'])
      .filter((val, index, self) => val && self.indexOf(val) === index);
    uniqueFuncs.value = funcs.sort(); // 가나다순 정렬

  } catch (error) { console.error('Data Load Error:', error); }
};

// 기능 리스트 토글
const toggleFuncList = (e) => {
  e.stopPropagation();
  showFuncList.value = !showFuncList.value;
};

// 기능 선택 시 필터 적용
const selectFunc = (val) => {
  columnFilters.value['기능'] = val;
  showFuncList.value = false;
};

// 외부 클릭 시 드롭다운 닫기
const closeDropdown = () => { showFuncList.value = false; };

const filteredData = computed(() => {
  return rawData.value.filter(row => {
    const isColumnMatch = columns.value.every(col => {
      const fv = columnFilters.value[col]?.toLowerCase().trim();
      return !fv || String(row[col] || '').toLowerCase().includes(fv);
    });
    const sk = globalSearch.value.toLowerCase().trim();
    const isGlobalMatch = !sk || columns.value.some(col => String(row[col] || '').toLowerCase().includes(sk));
    return isColumnMatch && isGlobalMatch;
  });
});

const highlightText = (text) => {
  const strText = String(text || '');
  const keyword = globalSearch.value.trim();
  if (!keyword) return strText;
  const regex = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return strText.replace(regex, '<mark class="highlight">$1</mark>');
};

onMounted(() => {
  loadExcelData();
  window.addEventListener('click', closeDropdown);
});

onUnmounted(() => {
  window.removeEventListener('click', closeDropdown);
});
</script>

