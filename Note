.search-grid { display: flex; gap: 24px; align-items: flex-start; }
.w-20 { width: 240px; flex-shrink: 0; }
.flex-grow { flex: 1; }
.base-input { width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; }
.multi-input { height: 48px; min-height: 48px; resize: vertical; }
