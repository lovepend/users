<template>
  <div id="app">
    <header class="header">
      <h2 class="page-main-title">🏷️ 태그 번호 유효성 검사 대시보드</h2>
    </header>

    <div class="main-container">
      <div class="side-panel left-panel">
        <section class="panel-card">
          <h3 class="card-title">1. 입력 및 설정</h3>
          <div class="input-group">
            <label for="tagNoInputValidator">검사할 Tag No. 입력</label>
            <input id="tagNoInputValidator" v-model="tagNoForValidator" type="text" placeholder="태그 번호를 입력하세요" />
          </div>

          <div class="rules-header">
            <h4>규칙 리스트</h4>
            <div class="button-group">
              <button @click="addRule" class="btn-small btn-success">+ 추가</button>
              <button @click="showPasteModal = true" class="btn-small btn-info">붙여넣기</button>
            </div>
          </div>

          <div class="scroll-area rules-area">
            <table class="data-table">
              <thead>
                <tr>
                  <th width="60">ID</th>
                  <th width="50">구분자</th>
                  <th>정규식</th>
                  <th width="40"></th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center font-code">#{{ index + 1 }}</td>
                  <td><input type="text" v-model="rule.delimiter" maxlength="1" class="cell-input" /></td>
                  <td><input type="text" v-model="rule.regex" class="cell-input" /></td>
                  <td><button @click="removeRule(index)" class="btn-delete">×</button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="side-panel right-panel">
        <section class="panel-card result-card">
          <h3 class="card-title">2. 유효성 분석 결과</h3>
          
          <div class="status-banner" :class="isTagNoValid ? 'status-pass' : 'status-fail'">
            <div class="status-icon">{{ isTagNoValid ? '✅' : '❌' }}</div>
            <div class="status-text">
              <strong>{{ isTagNoValid ? '유효한 태그입니다' : '검사 실패' }}</strong>
              <div class="full-regex">Pattern: {{ combinedRegexString }}</div>
            </div>
          </div>

          <h4 class="sub-title">부분별 매칭 상세</h4>
          <div class="scroll-area analysis-area">
            <table class="data-table analysis-table">
              <thead>
                <tr>
                  <th>구성요소</th>
                  <th>매칭된 값</th>
                  <th>구분자</th>
                  <th>내용</th>
                  <th>결과</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(part, index) in tagParts" :key="index">
                  <td class="font-code">TAG-{{ index + 1 }}</td>
                  <td class="font-bold">{{ part.matchedValue || '(null)' }}</td>
                  <td :class="part.isDelimiterValid ? 'text-ok' : 'text-error'">{{ part.isDelimiterValid ? 'OK' : 'ERR' }}</td>
                  <td :class="part.isContentValid ? 'text-ok' : 'text-error'">{{ part.isContentValid ? 'OK' : 'ERR' }}</td>
                  <td>
                    <span class="badge" :class="part.isValid ? 'badge-ok' : 'badge-err'">
                      {{ part.isValid ? 'PASS' : 'FAIL' }}
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div v-if="!isTagNoValid" class="error-msg-box">
            <strong>에러 상세:</strong> {{ lastPartError || '패턴이 일치하지 않습니다.' }}
          </div>
        </section>
      </div>
    </div>

    <div v-if="showPasteModal" class="modal-overlay" @click.self="showPasteModal = false">
      <div class="modal-content">
        <h4>데이터 일괄 입력</h4>
        <textarea v-model="pasteData" placeholder="구분자[Tab]정규식 형태로 입력하세요." rows="8"></textarea>
        <div class="modal-btns">
          <button @click="applyPasteData" class="btn-info">적용</button>
          <button @click="showPasteModal = false">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'

export default {
  setup() {
    const tagNoForValidator = ref('AP330X01-')
    const lastPartError = ref(null)
    const showPasteModal = ref(false)
    const pasteData = ref('')

    const tagRules = ref([
      { delimiter: '', regex: '^$|^[A-Z]{2}$' },
      { delimiter: '', regex: '^[0123LCRIT]{3}$' },
      { delimiter: '', regex: '^[ABCDEFNVXS]{1}$' },
      { delimiter: '', regex: '^$|^[ABCDEFNVXS]{1}$' },
      { delimiter: '', regex: '^[0-9]{2}$' },
      { delimiter: '-', regex: '^$|^[APS1-9]{2}$' },
    ])

    const isRegexOptional = (regex) => {
      if (!regex || regex === '^$') return true;
      try { return new RegExp(`^${regex.replace(/^\^|\$/g, '')}$`).test(''); } catch { return false; }
    }

    const combinedRegexString = computed(() => {
      let parts = tagRules.value.map((r, i) => {
        let content = r.regex.replace(/^\^|\$/g, '');
        let p = isRegexOptional(r.regex) && content.includes('$|') ? `(?:${content.replace('$|', '')}|)` : `(?:${content})`;
        if (i > 0 && r.delimiter.trim()) {
          let d = r.delimiter.trim().replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
          return isRegexOptional(r.regex) ? `(?:${d}${p})?` : `(?:${d}${p})`;
        }
        return p;
      });
      return `^${parts.join('')}$`;
    })

    const isTagNoValid = computed(() => {
      try { return new RegExp(combinedRegexString.value).test(tagNoForValidator.value); } catch { return false; }
    })

    const tagParts = computed(() => {
      const parts = [];
      let currentStr = tagNoForValidator.value || '';
      let idx = 0;
      lastPartError.value = null;

      for (let i = 0; i < tagRules.value.length; i++) {
        const rule = tagRules.value[i];
        let val = null, dOk = true, cOk = false;
        const d = rule.delimiter.trim();
        
        if (i > 0 && d) {
          if (currentStr.substring(idx).startsWith(d)) idx += d.length;
          else if (!isRegexOptional(rule.regex)) dOk = false;
        }

        try {
          const m = new RegExp(`^(${rule.regex.replace(/^\^|\$/g, '')})`).exec(currentStr.substring(idx));
          if (m) { val = m[1]; idx += val.length; cOk = true; }
          else if (isRegexOptional(rule.regex)) cOk = true;
        } catch { cOk = false; }

        parts.push({ regex: rule.regex, matchedValue: val, isDelimiterValid: dOk, isContentValid: cOk, isValid: dOk && cOk });
        if (!dOk || !cOk) break;
      }
      return parts;
    })

    const addRule = () => tagRules.value.push({ delimiter: '', regex: '' });
    const removeRule = (i) => tagRules.value.splice(i, 1);
    const applyPasteData = () => {
      const rows = pasteData.value.trim().split('\n');
      tagRules.value = rows.map(r => ({ delimiter: r.split('\t')[0] || '', regex: r.split('\t')[1] || '' }));
      showPasteModal.value = false;
    }

    return { tagNoForValidator, tagRules, isTagNoValid, tagParts, combinedRegexString, lastPartError, addRule, removeRule, showPasteModal, pasteData, applyPasteData };
  }
}
</script>

