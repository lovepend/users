<template>
  <div id="app">
    <header class="header">
      <h2 class="page-main-title">🏷️ 태그 번호 유효성 검사 대시보드</h2>
    </header>

    <div class="main-container">
      <div class="side-panel left-panel">
        <section class="panel-card">
          <h3 class="card-title">1. 입력 및 규칙 설정</h3>
          <div class="input-group">
            <label for="tagNoInputValidator">검사할 Tag No. 입력</label>
            <input id="tagNoInputValidator" v-model="tagNoForValidator" type="text" placeholder="검증할 태그 번호를 입력하세요" />
          </div>

          <div class="rules-header">
            <h4>규칙 리스트 (구분자 + 정규식)</h4>
            <div class="button-group">
              <button @click="addRule" class="btn-small btn-success">+ 추가</button>
              <button @click="showPasteModal = true" class="btn-small btn-info">엑셀 붙여넣기</button>
            </div>
          </div>

          <div class="scroll-area rules-area">
            <table class="data-table">
              <thead>
                <tr>
                  <th width="50">No</th>
                  <th width="70">구분자</th>
                  <th>정규식 (Regex)</th>
                  <th width="40"></th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center font-code">#{{ index + 1 }}</td>
                  <td><input type="text" v-model="rule.delimiter" placeholder="없음" class="cell-input text-center" /></td>
                  <td><input type="text" v-model="rule.regex" placeholder="예: ^[A-Z]+$" class="cell-input" /></td>
                  <td><button @click="removeRule(index)" class="btn-delete">×</button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="side-panel right-panel">
        <section class="panel-card result-card">
          <h3 class="card-title">2. 유효성 분석 결과</h3>
          
          <div class="status-banner" :class="isTagNoValid ? 'status-pass' : 'status-fail'">
            <div class="status-icon">{{ isTagNoValid ? '✅' : '❌' }}</div>
            <div class="status-text">
              <strong>{{ isTagNoValid ? '최종 검증 통과' : '최종 검증 실패' }}</strong>
              <div class="full-regex">Pattern: {{ combinedRegexDisplay }}</div>
            </div>
          </div>

          <h4 class="sub-title">부분별 매칭 상세 분석</h4>
          <div class="scroll-area analysis-area">
            <table class="data-table analysis-table">
              <thead>
                <tr>
                  <th width="80">구성요소</th>
                  <th>추출된 값</th>
                  <th width="65">구분자</th>
                  <th width="65">내용</th>
                  <th width="75">결과</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(part, index) in tagParts" :key="index">
                  <td class="font-code">규칙 #{{ index + 1 }}</td>
                  <td class="font-bold">{{ part.matchedValue === '' ? '(빈값)' : (part.matchedValue || '-') }}</td>
                  <td :class="part.isDelimiterValid ? 'text-ok' : 'text-error'">{{ part.hasDelimiterRule ? (part.isDelimiterValid ? 'OK' : 'ERR') : '-' }}</td>
                  <td :class="part.isContentValid ? 'text-ok' : 'text-error'">{{ part.isContentValid ? 'OK' : 'ERR' }}</td>
                  <td><span class="badge" :class="part.isValid ? 'badge-ok' : 'badge-err'">{{ part.isValid ? 'PASS' : 'FAIL' }}</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div v-if="!isTagNoValid" class="error-msg-box">
            <strong>에러 분석:</strong> {{ analysisFeedback }}
          </div>
        </section>
      </div>
    </div>

    <div v-if="showPasteModal" class="modal-overlay" @click.self="showPasteModal = false">
      <div class="modal-content">
        <h4>엑셀 데이터 붙여넣기</h4>
        <p class="modal-desc">엑셀에서 [구분자], [정규식] 열을 복사해 붙여넣으세요. (구분자가 없어도 탭 공간은 유지됩니다)</p>
        <textarea v-model="pasteData" placeholder="여기에 붙여넣으세요..." rows="10"></textarea>
        <div class="modal-btns">
          <button @click="applyPasteData" class="btn-info">데이터 적용</button>
          <button @click="showPasteModal = false">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'

export default {
  setup() {
    const tagNoForValidator = ref('AA-11-BB-2222-C')
    const showPasteModal = ref(false)
    const pasteData = ref('')
    const tagRules = ref([
      { delimiter: '', regex: '^[A-Z]{2}$' },
      { delimiter: '-', regex: '^[0-9]{2}$' },
      { delimiter: '-', regex: '^[A-Z]{2}$' },
      { delimiter: '-', regex: '^[0-9]{4}$' },
      { delimiter: '-', regex: '^[A-Z]{1}$' },
    ])

    const canBeEmpty = (regexStr) => {
      try { return new RegExp(`^(${regexStr.replace(/^\^|\$/g, '')})$`).test(''); } catch { return false; }
    }

    const tagParts = computed(() => {
      const results = [];
      let currentStr = tagNoForValidator.value || '';
      let cursor = 0;

      for (let i = 0; i < tagRules.value.length; i++) {
        const rule = tagRules.value[i];
        const delim = rule.delimiter;
        const pureRegex = rule.regex.replace(/^\^|\$/g, '');
        let dOk = true, cOk = false, matchedVal = null;
        const hasDelim = delim !== '';

        if (hasDelim) {
          if (currentStr.substring(cursor).startsWith(delim)) {
            cursor += delim.length; dOk = true;
          } else { dOk = canBeEmpty(rule.regex); }
        }

        try {
          const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor));
          if (matcher) {
            matchedVal = matcher[1]; cursor += matchedVal.length; cOk = true;
          } else if (canBeEmpty(rule.regex)) {
            matchedVal = ''; cOk = true;
          }
        } catch { cOk = false; }

        results.push({ hasDelimiterRule: hasDelim, isDelimiterValid: dOk, isContentValid: cOk, matchedValue: matchedVal, isValid: dOk && cOk });
        if (!(dOk && cOk)) break;
      }
      return results;
    })

    const isTagNoValid = computed(() => {
      const allPartsPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid);
      if (!allPartsPass) return false;
      let usedLen = 0;
      tagParts.value.forEach((p, i) => {
        if (p.hasDelimiterRule && p.isDelimiterValid) {
          if (tagNoForValidator.value.substring(usedLen).startsWith(tagRules.value[i].delimiter)) {
            usedLen += tagRules.value[i].delimiter.length;
          }
        }
        if (p.matchedValue) usedLen += p.matchedValue.length;
      });
      return usedLen === (tagNoForValidator.value || '').length;
    })

    const applyPasteData = () => {
      if (!pasteData.value.trim()) return;
      const rows = pasteData.value.split('\n');
      const newRules = rows.map(row => {
        const cols = row.split('\t');
        let delim = cols[0] ? cols[0].trim() : '';
        let regex = cols[1] ? cols[1].trim() : '';
        // 보정: 탭이 없고 정규식 기호만 있는 경우
        if (cols.length === 1 && delim.includes('^')) { regex = delim; delim = ''; }
        return { delimiter: delim, regex: regex };
      }).filter(r => r.delimiter || r.regex);

      if (newRules.length) tagRules.value = newRules;
      showPasteModal.value = false;
      pasteData.value = '';
    }

    const combinedRegexDisplay = computed(() => tagRules.value.map(r => (r.delimiter ? `[${r.delimiter}]` : '') + `(${r.regex.replace(/^\^|\$/g, '')})`).join(''));
    const addRule = () => tagRules.value.push({ delimiter: '', regex: '' });
    const removeRule = (i) => tagRules.value.splice(i, 1);

    return { tagNoForValidator, tagRules, tagParts, isTagNoValid, combinedRegexDisplay, addRule, removeRule, showPasteModal, pasteData, applyPasteData };
  }
}
</script>

<style scoped>
