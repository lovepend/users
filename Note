import GC from '@mescius/spread-sheets-designer'
import { ApiCommon } from '@/utils/axios/api-common'
import { useEmployees } from '@/stores/app-employees'
const { setEmployeeInfo } = useEmployees()

const _EditorType = 'PopupFloatingEditor'

function UserSelectCellType(FIELD, NAME_FIELD, DEPT_FIELD) {
  this.field = FIELD
  this.nameField = NAME_FIELD
  this.deptField = DEPT_FIELD
  this.searchTimer = null
  this.originalValue = null // 기존 사번 보관
  this.selectedValue = null // 선택된 사번 보관
}

UserSelectCellType.prototype = new GC.Spread.Sheets.CellTypes.Base()

// 1. 셀 화면 표시: 이름(부서)
UserSelectCellType.prototype.paint = function (ctx, value, x, y, w, h, style, options) {
  const data = options.sheet.getDataItem(options.row)
  const name = data?.[this.nameField] ?? ''
  const dept = data?.[this.deptField] ?? ''
  const text = name ? `${name}${dept ? `(${dept})` : ''}` : ''
  GC.Spread.Sheets.CellTypes.Base.prototype.paint.apply(this, [ctx, text, x, y, w, h, style, options])
}

// 2. 에디터 생성: 셀 '위'에 띄울 플로팅 컨테이너
UserSelectCellType.prototype.createEditorElement = function (context) {
  this.selectedValue = null; // 초기화

  // 컨테이너 (셀 위치에 딱 맞게 배치될 상자)
  const container = document.createElement('div')
  container.setAttribute('gcUIElement', 'gcEditingInput')
  container.style.cssText = `
    position: fixed; 
    z-index: 20000; 
    background: white; 
    border: 2px solid #217346; 
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  `

  // 입력창
  const input = document.createElement('input')
  input.style.cssText = 'width: 100%; height: 100%; border: none; outline: none; padding: 0 4px; font-size: 13px;'
  input.type = 'text'
  container.appendChild(input)

  // 리스트박스
  const listbox = document.createElement('ul')
  listbox.style.cssText = `
    position: absolute; 
    top: 100%; left: -2px; width: calc(100% + 4px); 
    background: white; border: 1px solid black; 
    margin: 0; padding: 0; list-style: none; 
    display: none; max-height: 200px; overflow-y: auto;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  `
  container.appendChild(listbox)

  input.addEventListener('input', (e) => {
    if (this.searchTimer) clearTimeout(this.searchTimer)
    const keyword = e.target.value.trim()

    this.searchTimer = setTimeout(async () => {
      if (keyword.length < 1) { listbox.style.display = 'none'; return; }

      const response = await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: keyword }) ?? []
      listbox.innerHTML = ''

      if (response.length > 0) {
        listbox.style.display = 'block'
        response.forEach(item => {
          const li = document.createElement('li')
          li.style.cssText = 'padding: 5px 10px; cursor: pointer; font-size: 13px; border-bottom: 1px solid #eee;'
          li.innerText = `${item.EMP_NM}(${item.DEPT_NAME || ''})`
          
          li.onmouseover = () => { li.style.backgroundColor = '#0078d4'; li.style.color = 'white'; }
          li.onmouseout = () => { li.style.backgroundColor = 'white'; li.style.color = 'black'; }

          li.onmousedown = (ev) => {
            ev.preventDefault()
            this.selectedValue = item.EMP_NO // 사번 확정
            setEmployeeInfo({ ...item, code: item.EMP_NO })
            listbox.style.display = 'none'
            context.sheet.endEdit() // 편집 종료 트리거
          }
          listbox.appendChild(li)
        })
      } else {
        listbox.style.display = 'none'
      }
    }, 400)
  })

  // 에디터 위치는 updateEditor에서 정해지므로 일단 리턴
  setTimeout(() => input.focus(), 10)
  return container
}

// 3. 에디터 위치 결정: 셀 위에 팝업처럼 덧씌움
UserSelectCellType.prototype.updateEditor = function (editorContext, cellStyle, cellRect) {
  if (editorContext) {
    // 셀의 위치 정보를 받아와서 컨테이너 크기를 맞춤
    editorContext.style.width = `${cellRect.width}px`
    editorContext.style.height = `${cellRect.height}px`
    
    // SpreadJS가 기본적으로 제공하는 cellRect를 그대로 사용하여 '셀 위'에 배치
    return { width: cellRect.width, height: cellRect.height }
  }
}

// 4. 값 반환: 선택했다면 사번을, 아니면 기존 값을 반환
UserSelectCellType.prototype.getEditorValue = function (editorContext) {
  // 사용자가 리스트를 눌러서 확정한 사번이 있으면 반환, 없으면(ESC 등) 원본 유지
  return this.selectedValue || this.originalValue
}

// 5. 편집 시작 시 값 세팅
UserSelectCellType.prototype.setEditorValue = function (editorContext, value) {
  this.originalValue = value // 기존 사번 보관
  const input = editorContext.querySelector('input')
  input.value = '' // 입력창은 깨끗하게 시작
}

export default UserSelectCellType
