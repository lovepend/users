    // Only VALUE 중복 확인
    if (field === 'VALUE') {
      let isDuplicate = false
      const compareVal = String(newValue ?? '')
        .trim()
        .toUpperCase()
      grid.forEachNode(n => {
        if (n.data && n.id !== node.id) {
          const baseVal = String(n.data[field] ?? '')
            .trim()
            .toUpperCase()
          if (baseVal === compareVal) {
            isDuplicate = true
          }
        }
      })
      if (isDuplicate) {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning('This is the use of duplicate Value.')
        return
      }
