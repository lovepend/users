<template>
  <div id="app">
    <header class="header">
      <h2 class="page-main-title">🏷️ 태그 번호 유효성 검사 대시보드</h2>
    </header>

    <div class="main-container">
      <div class="side-panel left-panel">
        <section class="panel-card">
          <h3 class="card-title">1. 입력 및 규칙 설정</h3>
          <div class="input-group">
            <label for="tagNoInputValidator">검사할 Tag No. 입력</label>
            <input id="tagNoInputValidator" v-model="tagNoForValidator" type="text" placeholder="검증할 태그 번호를 입력하세요" />
          </div>

          <div class="rules-header">
            <h4>규칙 리스트 (정규식 조합)</h4>
            <div class="button-group">
              <button @click="addRule" class="btn-small btn-success">+ 추가</button>
              <button @click="showPasteModal = true" class="btn-small btn-info">엑셀 붙여넣기</button>
            </div>
          </div>

          <div class="scroll-area rules-area">
            <table class="data-table">
              <thead>
                <tr>
                  <th width="50">No</th>
                  <th width="70">구분자</th>
                  <th>정규식 (Regex)</th>
                  <th width="40"></th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center font-code">#{{ index + 1 }}</td>
                  <td><input type="text" v-model="rule.delimiter" placeholder="-" class="cell-input text-center" /></td>
                  <td><input type="text" v-model="rule.regex" placeholder="^[A-Z]+$" class="cell-input" /></td>
                  <td><button @click="removeRule(index)" class="btn-delete">×</button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="side-panel right-panel">
        <section class="panel-card result-card">
          <h3 class="card-title">2. 유효성 분석 결과</h3>
          
          <div class="status-banner" :class="isTagNoValid ? 'status-pass' : 'status-fail'">
            <div class="status-icon">{{ isTagNoValid ? '✅' : '❌' }}</div>
            <div class="status-text">
              <strong>{{ isTagNoValid ? '최종 검증 통과' : '최종 검증 실패' }}</strong>
              <div class="full-regex">결합된 정규식: {{ combinedRegexString }}</div>
            </div>
          </div>

          <h4 class="sub-title">부분별 매칭 상세 분석</h4>
          <div class="scroll-area analysis-area">
            <table class="data-table analysis-table">
              <thead>
                <tr>
                  <th width="80">구성요소</th>
                  <th>추출된 값</th>
                  <th width="60">구분자</th>
                  <th width="60">내용</th>
                  <th width="70">결과</th>
                </tr>
              </thead>
              <tbody>
                <tr v-if="tagParts.length === 0">
                  <td colspan="5" class="text-center" style="padding:20px; color:#999;">규칙을 추가하면 분석이 시작됩니다.</td>
                </tr>
                <tr v-for="(part, index) in tagParts" :key="index">
                  <td class="font-code">규칙 #{{ index + 1 }}</td>
                  <td class="font-bold">{{ part.matchedValue === '' ? '(빈값)' : (part.matchedValue || '-') }}</td>
                  <td :class="part.isDelimiterValid ? 'text-ok' : 'text-error'">{{ part.hasDelimiterRule ? (part.isDelimiterValid ? 'OK' : 'ERR') : '-' }}</td>
                  <td :class="part.isContentValid ? 'text-ok' : 'text-error'">{{ part.isContentValid ? 'OK' : 'ERR' }}</td>
                  <td>
                    <span class="badge" :class="part.isValid ? 'badge-ok' : 'badge-err'">
                      {{ part.isValid ? 'PASS' : 'FAIL' }}
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div v-if="!isTagNoValid" class="error-msg-box">
            <strong>분석 소견:</strong> {{ analysisFeedback }}
          </div>
        </section>
      </div>
    </div>

    <div v-if="showPasteModal" class="modal-overlay" @click.self="showPasteModal = false">
      <div class="modal-content">
        <h4>엑셀 데이터 붙여넣기</h4>
        <p class="modal-desc">엑셀의 [구분자], [정규식] 두 칼럼을 복사해 붙여넣으세요.</p>
        <textarea v-model="pasteData" placeholder="예시:&#10;-	^[0-9]+$&#10;/	^[A-Z]+$" rows="10"></textarea>
        <div class="modal-btns">
          <button @click="applyPasteData" class="btn-info">데이터 적용</button>
          <button @click="showPasteModal = false">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'

export default {
  setup() {
    const tagNoForValidator = ref('AP330X01-')
    const showPasteModal = ref(false)
    const pasteData = ref('')

    // 초기 규칙 예시
    const tagRules = ref([
      { delimiter: '', regex: '^[A-Z]{2}$' },
      { delimiter: '', regex: '^[0-9]{3}$' },
      { delimiter: '', regex: '^[A-Z]{1}$' },
      { delimiter: '', regex: '^[A-Z0-9]{0,1}$' },
      { delimiter: '', regex: '^[0-9]{2}$' },
      { delimiter: '-', regex: '^[A-Z0-9]{0,2}$' },
    ])

    // 정규식이 빈 값을 허용하는지 체크
    const isOptional = (regexStr) => {
      try {
        const r = new RegExp(`^(${regexStr.replace(/^\^|\$/g, '')})$`);
        return r.test('');
      } catch { return false; }
    }

    // 전체 결합 정규식 생성 로직
    const combinedRegexString = computed(() => {
      if (tagRules.value.length === 0) return '^.*$';
      let patterns = tagRules.value.map((r, i) => {
        let content = r.regex.replace(/^\^|\$/g, '');
        let delim = r.delimiter ? r.delimiter.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') : '';
        
        // 구분자가 있는 경우: (?:구분자(내용)) 형태, 내용이 옵셔널이면 전체 그룹도 옵셔널
        if (i > 0 && delim) {
          return isOptional(r.regex) ? `(?:${delim}(?:${content}))?` : `(?:${delim}(?:${content}))`;
        }
        return `(?:${content})`;
      });
      return `^${patterns.join('')}$`;
    })

    const isTagNoValid = computed(() => {
      try {
        return new RegExp(combinedRegexString.value).test(tagNoForValidator.value || '');
      } catch { return false; }
    })

    // 부분별 매칭 상세 분석 로직 (순차 파싱)
    const tagParts = computed(() => {
      const results = [];
      let currentString = tagNoForValidator.value || '';
      let cursor = 0;

      for (let i = 0; i < tagRules.value.length; i++) {
        const rule = tagRules.value[i];
        let matchedVal = null;
        let dOk = true;
        let cOk = false;
        const hasDelim = i > 0 && rule.delimiter.trim() !== '';
        const delim = rule.delimiter.trim();
        const contentRegexStr = rule.regex.replace(/^\^|\$/g, '');

        // 1. 구분자 체크
        if (hasDelim) {
          if (currentString.substring(cursor).startsWith(delim)) {
            cursor += delim.length;
            dOk = true;
          } else {
            // 구분자가 없는데 내용이 필수라면 에러, 내용이 옵셔널이면 일단 통과 시도
            dOk = isOptional(rule.regex); 
          }
        }

        // 2. 내용 매칭 (남은 문자열의 앞부분부터 정규식만큼 추출)
        try {
          const matchResult = new RegExp(`^(${contentRegexStr})`).exec(currentString.substring(cursor));
          if (matchResult) {
            matchedVal = matchResult[1];
            cursor += matchedVal.length;
            cOk = true;
          } else {
            // 매칭 실패 시 빈값 허용 여부 확인
            if (isOptional(rule.regex)) {
              matchedVal = '';
              cOk = true;
            } else {
              matchedVal = null;
              cOk = false;
            }
          }
        } catch (e) {
          cOk = false;
        }

        results.push({
          hasDelimiterRule: hasDelim,
          isDelimiterValid: dOk,
          isContentValid: cOk,
          matchedValue: matchedVal,
          isValid: dOk && cOk
        });

        // 현재 단계에서 실패하면 이후 단계는 분석 불가하므로 중단
        if (!(dOk && cOk)) break;
      }
      return results;
    })

    const analysisFeedback = computed(() => {
      if (isTagNoValid.value) return '모든 규칙이 일치합니다.';
      if (tagParts.value.length === 0) return '규칙 설정이 필요합니다.';
      
      const lastPart = tagParts.value[tagParts.value.length - 1];
      const partIdx = tagParts.value.length;
      
      if (!lastPart.isValid) {
        return `규칙 #${partIdx}에서 일치하지 않는 패턴이 발견되었습니다. (구분자 혹은 정규식 확인 필요)`;
      }
      
      // 모든 분석 단계는 통과했는데 전체가 False인 경우 (문자열이 남았을 때)
      if (tagNoForValidator.value && tagNoForValidator.value.length > 0) {
        return '설정된 규칙보다 입력된 태그 번호가 더 깁니다. 규칙을 추가하거나 입력값을 확인하세요.';
      }
      
      return '입력값이 규칙과 일치하지 않습니다.';
    })

    const addRule = () => tagRules.value.push({ delimiter: '', regex: '' });
    const removeRule = (i) => tagRules.value.splice(i, 1);

    // 엑셀 붙여넣기 (탭 기반 칼럼 분리)
    const applyPasteData = () => {
      const rows = pasteData.value.trim().split('\n');
      const newRules = rows.map(row => {
        const columns = row.split('\t');
        return {
          delimiter: columns[0] ? columns[0].trim() : '',
          regex: columns[1] ? columns[1].trim() : (columns[0] ? '' : '') 
        };
      }).filter(r => r.delimiter || r.regex);

      if (newRules.length > 0) tagRules.value = newRules;
      showPasteModal.value = false;
      pasteData.value = '';
    }

    return { tagNoForValidator, tagRules, isTagNoValid, tagParts, combinedRegexString, analysisFeedback, addRule, removeRule, showPasteModal, pasteData, applyPasteData };
  }
}
</script>

<style scoped>
/* (기존 스타일에서 스크롤 및 레이아웃 최적화 유지) */
