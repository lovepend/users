<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="input-box">
            <label class="field-label">Project No</label>
            <input v-model="projectNo" type="text" class="design-input" placeholder="P0001" />
          </div>
          <div class="input-box flex-grow">
            <label class="field-label">API Keywords (Space/Comma/Enter)</label>
            <textarea v-model="keyword" class="design-textarea" placeholder="조회 키워드를 입력하세요..."></textarea>
          </div>
          <div class="input-box">
            <label class="field-label">Result Filter (Multi Search)</label>
            <input v-model="localSearchQuery" type="text" class="design-input filter-highlight" placeholder="Tag No 멀티 검색..." />
          </div>
          <div class="btn-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="primary-gradient-btn">
              {{ isLoading ? '조회 중...' : '데이터 통합 조회' }}
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="result-count">Total Found: <strong>{{ filteredList.length }}</strong></div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn-action btn-danger-custom" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn-action btn-success-custom">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-outer-container">
        <table class="master-table">
          <thead>
            <tr class="header-row-top">
              <th rowspan="2" class="sticky-header sticky-col col-chk h-double">
                <div class="center-vh"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div>
              </th>
              <th rowspan="2" class="sticky-header sticky-col col-idx h-double">Idx</th>
              <th rowspan="2" class="sticky-header sticky-col col-tag h-double">Tag No</th>
              <th colspan="3" class="group-header pub-bg h-single">Published (Master)</th>
              <th colspan="3" class="group-header wrk-bg h-single">Working (Current)</th>
            </tr>
            <tr class="header-row-sub">
              <th class="sub-th pub-bg h-single">EP ID</th><th class="sub-th pub-bg h-single">CLS</th><th class="sub-th pub-bg h-single">Del</th>
              <th class="sub-th wrk-bg h-single">EP ID</th><th class="sub-th wrk-bg h-single">CLS</th><th class="sub-th wrk-bg h-single">Del</th>
            </tr>
          </thead>
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="data-group">
            <tr v-for="rowNum in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum">
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-td"><div class="center-vh"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div></td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-td clickable" @click="openModal(group)"><div class="center-vh font-bold">{{ group.TagIdx }}</div></td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-td clickable" @click="openModal(group)"><div class="cell-padding"><span class="tag-highlight" v-html="highlightText(group.TagNo)"></span></div></td>
              <td class="cell-pub data-td clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.EpId || 'null' }}</td>
              <td class="cell-pub data-td clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.ClsId || 'null' }}</td>
              <td class="cell-pub data-td clickable" @click="openModal(group)"><div class="center-vh"><span v-if="group.pubList[rowNum-1]" :class="['status-badge', group.pubList[rowNum-1].Deleted ? 'is-del' : 'is-active']">{{ group.pubList[rowNum-1].Deleted ? 'Y' : 'N' }}</span><span v-else class="null-txt">null</span></div></td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.EpId || 'null' }}</td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.ClsId || 'null' }}</td>
              <td class="cell-wrk data-td clickable" @click="openModal(group)"><div class="center-vh"><span v-if="group.wrkList[rowNum-1]" :class="['status-badge', group.wrkList[rowNum-1].Deleted ? 'is-del' : 'is-active']">{{ group.wrkList[rowNum-1].Deleted ? 'Y' : 'N' }}</span><span v-else class="null-txt">null</span></div></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-window">
        <div class="modal-header">
          <div class="title-area">
            <div class="main-title">📊 Full Data Comparison Analysis</div>
            <div class="meta-info-row">
              <span class="info-chip"><strong>TAG NO:</strong> {{ selectedItem?.TagNo }}</span>
              <span class="info-chip"><strong>TAG IDX:</strong> {{ selectedItem?.TagIdx }}</span>
            </div>
          </div>
          <div class="modal-actions">
            <button @click="isJsonMode = !isJsonMode" class="btn-mode-toggle">
              {{ isJsonMode ? '📋 Table View' : '📄 JSON View' }}
            </button>
            <button @click="closeModal" class="btn-modal-close">✕</button>
          </div>
        </div>
        <div class="modal-body">
          <div v-if="!isJsonMode" class="modal-table-container">
            <table class="analysis-table">
              <thead>
                <tr>
                  <th :colspan="allSystemKeys.length + 1" class="th-sys m-sticky-header m-sticky-left-base top-row">System Fields (Comparison)</th>
                  <th :colspan="allAttributeKeys.length" class="th-attr top-row">Attributes (Comparison)</th>
                </tr>
                <tr class="sub-header-row">
                  <th class="m-sticky-header m-sticky-col-tag">Tag No</th>
                  <th v-for="key in allSystemKeys" :key="'sys-h-'+key" class="m-sticky-header sys-header-cell">{{ key }}</th>
                  <th v-for="key in allAttributeKeys" :key="'attr-h-'+key" class="attr-header">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(row, idx) in unionModalRows" :key="'row-'+idx">
                  <td class="m-sticky-cell m-sticky-col-tag"><strong>{{ row.TagNo }}</strong></td>
                  <td v-for="key in allSystemKeys" :key="'sys-d-'+key" class="m-sticky-cell-dynamic">
                    <div class="union-cell">
                      <div class="u-pub" :title="'Published ' + key">{{ row.sysMap[key]?.pub || '-' }}</div>
                      <div class="u-wrk" :title="'Working ' + key">{{ row.sysMap[key]?.wrk || '-' }}</div>
                    </div>
                  </td>
                  <td v-for="key in allAttributeKeys" :key="'attr-d-'+key" class="attr-data-cell">
                    <div class="union-cell">
                      <div class="u-pub">{{ row.attrMap[key]?.pub || '-' }}</div>
                      <div class="u-wrk">{{ row.attrMap[key]?.wrk || '-' }}</div>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div v-else class="json-viewer-container">
             <div class="json-pane"><h3>Published Raw</h3><pre><code>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</code></pre></div>
             <div class="json-pane"><h3>Working Raw</h3><pre><code>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</code></pre></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)
    const isJsonMode = ref(false)

    // 메인 필터링
    const filteredList = computed(() => {
      const query = localSearchQuery.value.trim();
      if (!query) return mergedList.value;
      const searchKeywords = query.split(/[\s,\n]+/).map(k => k.trim().toLowerCase()).filter(k => k);
      return mergedList.value.filter(g => searchKeywords.some(kw => String(g.TagNo).toLowerCase().includes(kw)));
    });

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      const groupMap = new Map();
      try {
        const keys = keyword.value.split(/[\s,\n,]+/).map(k => k.trim()).filter(k => k);
        for (const k of keys) {
          const payload = { ProjectNo: projectNo.value, Keyword: k };
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload).catch(() => ({ data: [] })),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload).catch(() => ({ data: [] }))
          ]);
          const pData = Array.isArray(pubRes) ? pubRes : (pubRes?.data || []);
          const wData = Array.isArray(wrkRes) ? wrkRes : (wrkRes?.data || []);
          const merge = (list, type) => {
            list.forEach(i => {
              if (!i.TagIdx) return;
              if (!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
              groupMap.get(i.TagIdx)[type].push(i);
            });
          };
          merge(pData, 'pubList'); merge(wData, 'wrkList');
        }
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => String(a.TagNo).localeCompare(b.TagNo, undefined, { numeric: true }));
      } catch (e) { console.error(e); } finally { isLoading.value = false; }
    };

    // [중요] 모든 데이터 필드 키 추출 (System 필드)
    const allSystemKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const ignore = ['Attributes', 'attributes', 'TagNo', 'TagIdx', '_id'];
      const extract = (list) => list.forEach(item => {
        Object.keys(item).forEach(k => { if(!ignore.includes(k)) keys.add(k); });
      });
      extract(selectedItem.value.pubList); extract(selectedItem.value.wrkList);
      return Array.from(keys).sort();
    });

    // 어트리뷰트 키 추출
    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const extract = (list) => list.forEach(i => (i.Attributes || i.attributes || []).forEach(a => { if(a.ATT_ID) keys.add(a.ATT_ID) }));
      extract(selectedItem.value.pubList); extract(selectedItem.value.wrkList);
      return Array.from(keys).sort();
    });

    // 모달용 합집합 데이터 생성
    const unionModalRows = computed(() => {
      if (!selectedItem.value) return [];
      const { pubList, wrkList, TagNo } = selectedItem.value;
      const rowCount = Math.max(pubList.length, wrkList.length, 1);
      const rows = [];
      for (let i = 0; i < rowCount; i++) {
        const pub = pubList[i] || null;
        const wrk = wrkList[i] || null;
        const sysMap = {};
        const attrMap = {};
        
        // 시스템 필드 맵핑
        allSystemKeys.value.forEach(key => {
          sysMap[key] = { pub: pub?.[key] ?? '-', wrk: wrk?.[key] ?? '-' };
        });
        // 어트리뷰트 맵핑
        allAttributeKeys.value.forEach(key => {
          const getV = (item) => {
            const a = (item?.Attributes || item?.attributes || []).find(attr => attr.ATT_ID === key);
            return a ? (a.VALUE ?? a.VALUE_DBL ?? '-') : '-';
          };
          attrMap[key] = { pub: getV(pub), wrk: getV(wrk) };
        });
        rows.push({ TagNo, sysMap, attrMap });
      }
      return rows;
    });

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem, isJsonMode,
      allSystemKeys, allAttributeKeys, unionModalRows, fetchAndMergeData,
      highlightText: (t) => {
        const query = localSearchQuery.value.trim();
        if (!query) return t;
        const kwArr = query.split(/[\s,\n]+/).filter(k => k);
        let text = String(t);
        kwArr.forEach(kw => { text = text.replace(new RegExp(`(${kw})`, 'gi'), '<mark class="hl">$1</mark>'); });
        return text;
      },
      openModal: (g) => { selectedItem.value = g; showModal.value = true; isJsonMode.value = false; },
      closeModal: () => { showModal.value = false; },
      toggleAllSelect: () => { selectedIds.value = (selectedIds.value.length === filteredList.value.length) ? [] : filteredList.value.map(g => g.TagIdx) },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('삭제하시겠습니까?'),
      downloadExcel: () => alert('CSV 생성 중...')
    };
  }
}
</script>

