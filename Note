<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-square-check"
      :title="'Tag 통합 분석 조회 (Pub/Wrk)'"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-primary">Project No</span>
            <input
              type="text"
              placeholder="e.g. P0001"
              class="form-control form-control-sm"
              style="width: 100px;"
              v-model="manualProjNo"
            />
          </label>

          <label class="d-flex align-items-center gap-2">
            <span class="fw-500">Keyword</span>
            <input
              type="text"
              placeholder="Input Keyword"
              class="form-control form-control-sm"
              v-model="searchKeywordRef"
              @keyup.enter="onSearch"
            />
          </label>
          
          <button class="btn btn-xs btn-primary" @click="onSearch">Search</button>
        </div>

        <div class="form-check form-switch m-0 ms-2">
          <label class="form-check-label text-dark user-select-none cursor-pointer">
            <input class="form-check-input" type="checkbox" v-model="isWorkingRef" />
            <span :class="isWorkingRef ? 'text-warning fw-bold' : 'text-primary fw-bold'">
              {{ isWorkingLabel }} View
            </span>
          </label>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-heading p-0 m-0">
          <div class="w-100 h-100">
            <BasicToolBar
              @delete-data="deleteSelectedData"
              :showCreate="false"
              :showMultiCreate="false"
              :showDelete="isSetupAdmin"
              :isDisabledDeleteBtn="isDisabledDeleteBtn"
              :showSave="false"
            />
          </div>
        </div>
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue 
            v-bind="gridBindTagProps" 
            v-on="gridOnCommonProps('Tag')" 
          />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, watch, shallowRef, computed } from 'vue'
  import { storeToRefs } from 'pinia'

  // Library & Store
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppMenuStore } from '@/stores/app-menu'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import * as _ from 'lodash-es'

  // AG Grid Components
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
  import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'

  // Custom Components
  import { sAlert } from '@/utils/messages/alert-common'
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'

  const appPermission = useAppPermissionStore()
  const { isSetupAdmin } = storeToRefs(appPermission)
  const appMenu = useAppMenuStore()

  // 상태 관리
  const gridApi_TagData = shallowRef()
  const manualProjNo = ref(appMenu.currentProjNo || '') // 초기값은 스토어에서 가져오되 직접 수정 가능 
  const searchKeywordRef = ref('')
  const isWorkingRef = ref(false)
  const isWorkingLabel = ref('Published') [cite: 11]
  const tagDataListRef = ref([])
  const isDisabledDeleteBtn = ref(true)

  // 토글 변경 시 자동 재조회 [cite: 11]
  watch(isWorkingRef, newVal => {
    isWorkingLabel.value = newVal ? 'Working' : 'Published'
    if (gridApi_TagData.value && manualProjNo.value) getData()
  })

  const onSearch = () => getData()

  const getData = async () => {
    // 1. 프로젝트 번호 체크 (입력 칸의 값 기준)
    if (!manualProjNo.value) {
      sAlert.Warning(`Project No를 입력해주세요.`)
      return
    }

    gridApi_TagData.value.setGridOption('loading', true)

    // 2. 토글 상태에 따른 API URL 결정 
    const url = isWorkingRef.value ? `/api/Admin/Tool/GetWorkingData` : `/api/Admin/Tool/GetPublishedData`
    const sourceTag = isWorkingRef.value ? 'Working' : 'Published'

    try {
      // 3. API 호출 (수동 입력한 프로젝트 번호와 키워드 전달) 
      const jsonData = await axiosWrapper.post(url, {
        ProjectNo: manualProjNo.value.trim(),
        Keyword: searchKeywordRef.value.trim(),
      })

      if (_.isEmpty(jsonData)) {
        tagDataListRef.value = []
      } else {
        // 출처(Source) 칼럼 표시를 위한 데이터 맵핑
        tagDataListRef.value = jsonData
          .filter(item => !item.DELETED) [cite: 34]
          .map(item => ({
            ...item,
            Source: sourceTag 
          }))
      }
    } catch (error) {
      sAlert.Warning('데이터 조회 중 오류가 발생했습니다.')
      tagDataListRef.value = []
    } finally {
      gridApi_TagData.value.setGridOption('loading', false)
    }
  }

  // AG Grid 컬럼 정의
  const colDefs = ref([
    {
      headerName: 'Source',
      field: 'Source',
      minWidth: 100,
      maxWidth: 100,
      pinned: 'left', // 틀고정
      cellRenderer: params => {
        const isWrk = params.value === 'Working'
        return `<span class="badge" style="background-color: ${isWrk ? '#ed6c02' : '#0288d1'}; color: white; border-radius: 4px; padding: 2px 6px;">${params.value}</span>`
      }
    },
    { field: 'TagIdx', headerName: 'TagIdx', minWidth: 120, pinned: 'left' },
    { field: 'TagNo', headerName: 'TagNo', minWidth: 150, pinned: 'left' },
    { field: 'EpId', headerName: 'EP ID', minWidth: 100 },
    { field: 'ClsId', headerName: 'Class', minWidth: 100 },
    { field: 'TagDesc', headerName: 'Description', minWidth: 300, flex: 1 },
    { field: 'CHGE_DTM', headerName: 'Update Date', minWidth: 180, 
      valueFormatter: p => p.value ? new Date(p.value).toLocaleString() : '-' } [cite: 23, 29]
  ])

  const gridBindTagProps = computed(() => ({
    columnDefs: colDefs.value,
    rowData: tagDataListRef.value,
    style: 'width: 100%; height: 100%',
    class: 'ag-theme-custom',
    rowSelection: 'multiple',
    pagination: true,
    paginationPageSize: 50,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: {
      sortable: true,
      filter: true,
      resizable: true,
      floatingFilter: true, [cite: 26]
      // 여기서 배경색 처리를 통해 틀고정 영역 비침 방지
      cellStyle: { 'background-color': '#ffffff' } 
    }
  }))

  const onGridReady = params => {
    gridApi_TagData.value = params.api [cite: 44]
    // 페이지 로드 시 프로젝트 번호가 있으면 자동 조회
    if (manualProjNo.value && searchKeywordRef.value) getData()
  }

  const gridOnCommonProps = () => ({
    gridReady: onGridReady,
    selectionChanged: () => {
      const nodes = gridApi_TagData.value.getSelectedNodes()
      isDisabledDeleteBtn.value = nodes.length === 0
    }
  })

  const deleteSelectedData = async () => {
    const rows = gridApi_TagData.value.getSelectedRows()
    if (_.isEmpty(rows)) return [cite: 47]
    const confirm = await sAlert.Confirm('선택한 데이터를 삭제하시겠습니까?') [cite: 48]
    if (confirm.isConfirmed) {
      // 삭제 처리 로직...
      getData()
    }
  }

  defineOptions({
    name: 'PubWrkIntegratedGrid'
  })
</script>

<style scoped lang="scss">
  /* 틀고정 칼럼 경계선 및 비침 방지 스타일 */
  ::v-deep(.ag-pinned-left-cols-container) {
    border-right: 2px solid #ddd !important;
    background-color: #fff;
  }
  
  /* 배지 스타일 */
  ::v-deep(.badge) {
    font-weight: 600;
    font-size: 11px;
  }
</style>
