<template>
  <div id="app" class="admin-tool">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 관리 시스템</h2>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field w-20">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field w-50">
            <label>API Fetch Keywords <span class="label-hint">(데이터 호출용 - 공백/줄바꿈)</span></label>
            <textarea
              v-model="keyword"
              placeholder="호출할 태그들을 입력하세요..."
              class="base-input multi-input"
            ></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">
              <span v-if="!isLoading">데이터 호출</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
        
        <div class="local-search-bar">
          <div class="input-field flex-grow">
            <label>결과 내 다중 필터 <span class="label-hint">(공백 구분 입력 시 하이라이트 및 필터링)</span></label>
            <input 
              v-model="localSearchQuery" 
              type="text" 
              placeholder="화면에서 필터링할 키워드들..." 
              class="base-input highlight-input"
            />
          </div>
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="left-info">
          <span class="count-badge">조회 결과: <b>{{ filteredList.length }}</b> / {{ mergedList.length }}건</span>
        </div>
        <div class="right-actions">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">
            🗑 선택 삭제 ({{ selectedIds.length }})
          </button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <main class="content-panel">
        <div class="table-wrapper">
          <table class="modern-table">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="w-chk">
                  <input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" />
                </th>
                <th rowspan="2" class="sortable" @click="sortBy('TagIdx')">Idx ↕</th>
                <th rowspan="2" class="sortable" @click="sortBy('TagNo')">Tag No ↕</th>
                <th colspan="4" class="col-group pub">Published (Master)</th>
                <th colspan="4" class="col-group wrk">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th class="sortable" @click="sortBy('pub.EpId')">EP ID</th><th>CLS</th><th>Type</th><th>Status</th>
                <th class="sortable" @click="sortBy('wrk.EpId')">EP ID</th><th>CLS</th><th>Del</th><th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="item in filteredList" :key="item.TagIdx" 
                  :class="['data-row', { 'row-selected': selectedIds.includes(item.TagIdx) }]"
                  @click="openModal(item)">
                <td @click.stop>
                  <input type="checkbox" :value="item.TagIdx" v-model="selectedIds" />
                </td>
                <td>{{ item.TagIdx }}</td>
                <td v-html="highlightText(item.TagNo)"></td>
                
                <td>{{ item.pub?.EpId || '-' }}</td>
                <td>{{ item.pub?.ClsId || '-' }}</td>
                <td>{{ item.pub?.TagTypeId || '-' }}</td>
                <td>
                  <span v-if="item.pub" :class="['badge', item.pub.Deleted ? 'bg-red' : 'bg-green']">
                    {{ item.pub.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>

                <td>{{ item.wrk?.EpId || '-' }}</td>
                <td>{{ item.wrk?.ClsId || '-' }}</td>
                <td>
                  <span v-if="item.wrk" :class="item.wrk.DelYn ? 'text-red' : ''">{{ item.wrk.DelYn ? 'Y' : 'N' }}</span>
                </td>
                <td>
                  <span v-if="item.wrk" :class="['badge', item.wrk.Deleted ? 'bg-red' : 'bg-green']">
                    {{ item.wrk.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-card">
        <header class="modal-header">
          <h3>Tag Detail Info <small>#{{ selectedItem?.TagIdx }}</small></h3>
          <button @click="closeModal" class="close-btn">&times;</button>
        </header>
        <div class="modal-body" v-if="selectedItem">
          <div class="json-grid">
            <div class="json-box">
              <label>Published Data (Master)</label>
              <pre>{{ JSON.stringify(selectedItem.pub, null, 2) }}</pre>
            </div>
            <div class="json-box">
              <label>Working Data (Current)</label>
              <pre>{{ JSON.stringify(selectedItem.wrk, null, 2) }}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  name: 'TagIntegratedManager',
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const searched = ref(false)
    const selectedIds = ref([])
    const sortKey = ref('TagNo')
    const sortOrder = ref(1)

    // 모달 상태
    const showModal = ref(false)
    const selectedItem = ref(null)

    const filteredList = computed(() => {
      let list = [...mergedList.value]
      if (localSearchQuery.value.trim()) {
        const searchTerms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
        list = list.filter(item => {
          const tagNo = item.TagNo.toLowerCase()
          return searchTerms.some(term => tagNo.includes(term))
        })
      }
      list.sort((a, b) => {
        let valA = getNestedValue(a, sortKey.value)
        let valB = getNestedValue(b, sortKey.value)
        if (valA < valB) return -1 * sortOrder.value
        if (valA > valB) return 1 * sortOrder.value
        return 0
      })
      return list
    })

    const getNestedValue = (obj, path) => path.split('.').reduce((o, i) => (o ? o[i] : ''), obj)

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const searchTerms = localSearchQuery.value.split(/[\s,]+/).filter(t => t)
      let highlighted = String(text)
      searchTerms.forEach(term => {
        const regex = new RegExp(`(${term})`, 'gi')
        highlighted = highlighted.replace(regex, '<mark class="hl">$1</mark>')
      })
      return highlighted
    }

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      searched.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k.length > 0)
      const dataMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload),
          ])
          const pubData = pubRes?.data || pubRes
          const wrkData = wrkRes?.data || wrkRes

          if (Array.isArray(pubData)) {
            pubData.forEach(item => dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: item, wrk: null }))
          }
          if (Array.isArray(wrkData)) {
            wrkData.forEach(item => {
              const existing = dataMap.get(item.TagIdx)
              if (existing) existing.wrk = item
              else dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: null, wrk: item })
            })
          }
        }))
        mergedList.value = Array.from(dataMap.values())
      } catch (err) { alert('데이터 호출 실패') } 
      finally { isLoading.value = false }
    }

    const sortBy = (key) => {
      if (sortKey.value === key) sortOrder.value *= -1
      else { sortKey.value = key; sortOrder.value = 1; }
    }

    const isAllSelected = computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length)
    const toggleAllSelect = () => {
      if (isAllSelected.value) selectedIds.value = []
      else selectedIds.value = filteredList.value.map(i => i.TagIdx)
    }

    const openModal = (item) => {
      selectedItem.value = item
      showModal.value = true
    }

    const closeModal = () => {
      showModal.value = false
      selectedItem.value = null
    }

    const deleteSelected = () => {
      if(confirm(`${selectedIds.value.length}건을 삭제하시겠습니까?`)) {
        console.log("Delete IDs:", selectedIds.value);
        alert("삭제 로직 연결 필요");
      }
    }

    const downloadExcel = () => { /* 기존 엑셀 로직 */ }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, searched,
      selectedIds, isAllSelected, toggleAllSelect, sortBy, highlightText,
      openModal, closeModal, showModal, selectedItem, fetchAndMergeData, deleteSelected, downloadExcel
    }
  }
}
</script>

