.sub-header th { position: sticky; top: 40px; z-index: 49; background: #f8fafc; }

/* Idx, TagNo 고정 컬럼 (rowspan="2" 이므로 높이는 80px 자동 계산됨) */
.sticky-col { position: sticky; left: 0; z-index: 45; background: white !important; }
