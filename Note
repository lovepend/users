import GC from '@mescius/spread-sheets-designer'
import { ApiCommon } from '@/utils/axios/api-common'
import { useEmployees } from '@/stores/app-employees'
const { setEmployeeInfo } = useEmployees()

const _EditorType = 'UserEditor'

// 호버 스타일을 위한 CSS 추가 (한 번만 실행)
if (!document.getElementById('excel-dropdown-style')) {
  const style = document.createElement('style');
  style.id = 'excel-dropdown-style';
  style.innerHTML = `
    .excel-list-item { padding: 4px 8px; cursor: pointer; font-size: 13px; color: #000; }
    .excel-list-item:hover { background-color: #0078d4 !important; color: white !important; }
    .excel-list-container::-webkit-scrollbar { width: 8px; }
    .excel-list-container::-webkit-scrollbar-thumb { background: #cdcdcd; border-radius: 4px; }
    .excel-list-container::-webkit-scrollbar-thumb:hover { background: #a6a6a6; }
  `;
  document.head.appendChild(style);
}

function UserSelectCellType(FIELD, NAME_FIELD, DEPT_FIELD) {
  this.field = FIELD
  this.nameField = NAME_FIELD
  this.deptField = DEPT_FIELD
  this.searchTimer = null
  this.listbox = null
}

UserSelectCellType.prototype = new GC.Spread.Sheets.CellTypes.Base()

// 1. 셀 화면 렌더링: 사번은 숨기고 이름(부서)만 표시
UserSelectCellType.prototype.paint = function (ctx, value, x, y, w, h, style, options) {
  const sheet = options.sheet
  const data = sheet.getDataItem(options.row)
  const name = data?.[this.nameField] ?? ''
  const dept = data?.[this.deptField] ?? ''
  
  // 사번 대신 이름만 표시
  const text = name ? `${name}${dept ? `(${dept})` : ''}` : ''
  
  GC.Spread.Sheets.CellTypes.Base.prototype.paint.apply(this, [ctx, text, x, y, w, h, style, options])

  // 엑셀 스타일의 역삼각형 버튼 그리기
  ctx.save()
  const size = 12
  ctx.beginPath()
  ctx.fillStyle = '#666'
  ctx.moveTo(x + w - 15, y + (h / 2) - 3)
  ctx.lineTo(x + w - 5, y + (h / 2) - 3)
  ctx.lineTo(x + w - 10, y + (h / 2) + 4)
  ctx.fill()
  ctx.restore()
}

UserSelectCellType.prototype.createEditorElement = function (context) {
  const wrapper = document.createElement('div')
  wrapper.setAttribute('gcUIElement', 'gcEditingInput')
  wrapper.setAttribute('EditorType', _EditorType)
  wrapper.style.cssText = 'background: white; display: flex; align-items: center; border: 2px solid #0078d4; box-sizing: border-box;'

  // 입력창
  const input = document.createElement('input')
  input.style.cssText = 'width: calc(100% - 20px); border: none; outline: none; padding: 0 4px; font-size: 13px;'
  
  // 우측 역삼각형 버튼 (에디터용)
  const btn = document.createElement('div')
  btn.innerHTML = '▼'
  btn.style.cssText = 'width: 20px; font-size: 8px; color: #666; display: flex; align-items: center; justify-content: center; cursor: default;'

  // 드롭다운 컨테이너 (Body에 부착)
  const listbox = document.createElement('ul')
  listbox.className = 'excel-list-container'
  listbox.style.cssText = `
    position: absolute; display: none; background: white; border: 1px solid #bcbcbc;
    box-shadow: 2px 2px 3px rgba(0,0,0,0.1); z-index: 10000; padding: 0; margin: 0;
    list-style: none; max-height: 150px; overflow-y: auto; overflow-x: hidden;
  `
  document.body.appendChild(listbox)
  this.listbox = listbox

  let selectedInfo = null

  input.addEventListener('input', (e) => {
    const keyword = e.target.value.trim()
    if (this.searchTimer) clearTimeout(this.searchTimer)

    if (keyword.length < 1) {
      listbox.style.display = 'none'
      return
    }

    this.searchTimer = setTimeout(async () => {
      const response = await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: keyword })
      listbox.innerHTML = ''

      if (response && response.length > 0) {
        const rect = wrapper.getBoundingClientRect()
        listbox.style.width = `${rect.width}px`
        listbox.style.top = `${rect.bottom + window.scrollY}px`
        listbox.style.left = `${rect.left + window.scrollX}px`
        listbox.style.display = 'block'

        response.forEach(item => {
          const li = document.createElement('li')
          li.className = 'excel-list-item'
          li.innerText = `${item.EMP_NM}(${item.DEPT_NAME || ''})`
          
          li.onmousedown = (event) => {
            event.preventDefault()
            selectedInfo = item
            input.value = item.EMP_NM
            setEmployeeInfo({ ...item, code: item.EMP_NO })
            listbox.style.display = 'none'
            
            const sheet = GC.Spread.Sheets.findControl(wrapper.closest('.gc-spread-sheets')).getActiveSheet()
            sheet.endEdit()
          }
          listbox.appendChild(li)
        })
      } else {
        listbox.style.display = 'none'
      }
    }, 200)
  })

  wrapper.appendChild(input)
  wrapper.appendChild(btn)
  
  wrapper.getFinalValue = () => selectedInfo ? selectedInfo.EMP_NO : input.value
  return wrapper
}

UserSelectCellType.prototype.getEditorValue = function (editorContext) {
  return editorContext.getFinalValue()
}

UserSelectCellType.prototype.setEditorValue = function (editorContext, value) {
  const input = editorContext.querySelector('input')
  // value가 사번인 경우, 실제 이름으로 변환하는 로직은 호출하는 곳에서 데이터소스를 통해 관리되므로
  // 여기서는 사용자가 타이핑할 수 있게 빈 값을 주거나 현재 값을 유지합니다.
  input.value = '' 
}

UserSelectCellType.prototype.destroyEditorElement = function (editorContext) {
  if (this.listbox) {
    this.listbox.remove()
    this.listbox = null
  }
}

UserSelectCellType.prototype.updateEditor = function (editorContext, cellStyle, cellRect) {
  if (editorContext) {
    return { width: cellRect.width, height: cellRect.height }
  }
}

export default UserSelectCellType
