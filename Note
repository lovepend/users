<template>
  <div id="app" class="admin-tool">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 관리 시스템 <span class="badge-v">Merge View</span></h2>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field w-20">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field w-50">
            <label>API Fetch Keywords</label>
            <textarea v-model="keyword" placeholder="TAG-01..." class="base-input multi-input"></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">
              <span v-if="!isLoading">데이터 호출</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
        
        <div class="local-search-bar">
          <div class="input-field flex-grow">
            <label>결과 내 필터링 & 하이라이트</label>
            <input v-model="localSearchQuery" type="text" placeholder="검색어 입력..." class="base-input highlight-input" />
          </div>
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="left-info">
          <span class="count-badge">병합 그룹: <b>{{ filteredList.length }}</b>건</span>
        </div>
        <div class="right-actions">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <main class="content-panel">
        <div class="table-wrapper">
          <table class="modern-table merged-table">
            <thead>
              <tr class="main-header">
                <th class="w-chk"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
                <th class="sortable" @click="sortBy('TagIdx')">Idx</th>
                <th class="sortable" @click="sortBy('TagNo')">Tag No</th>
                <th colspan="3" class="col-group pub">Published (Master)</th>
                <th colspan="3" class="col-group wrk">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th colspan="3"></th> <th>EP ID</th><th>CLS</th><th>Status</th>
                <th>EP ID</th><th>CLS</th><th>Status</th>
              </tr>
            </thead>
            <tbody v-for="group in filteredList" :key="group.TagIdx">
              <tr v-for="(rowIdx) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowIdx">
                
                <template v-if="rowIdx === 1">
                  <td :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" @click.stop>
                    <input type="checkbox" :value="group.TagIdx" v-model="selectedIds" />
                  </td>
                  <td :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="cell-group-idx" @click="openModal(group)">
                    {{ group.TagIdx }}
                  </td>
                  <td :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="cell-group-tag" @click="openModal(group)" v-html="highlightText(group.TagNo)">
                  </td>
                </template>

                <td class="pub-td" @click="openModal(group)">{{ group.pubList[rowIdx-1]?.EpId || (rowIdx <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td" @click="openModal(group)">{{ group.pubList[rowIdx-1]?.ClsId || (rowIdx <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td" @click="openModal(group)">
                  <span v-if="group.pubList[rowIdx-1]" :class="['badge', group.pubList[rowIdx-1].Deleted ? 'bg-red' : 'bg-green']">
                    {{ group.pubList[rowIdx-1].Deleted ? 'Del' : 'Act' }}
                  </span>
                </td>

                <td class="wrk-td" @click="openModal(group)">{{ group.wrkList[rowIdx-1]?.EpId || (rowIdx <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td" @click="openModal(group)">{{ group.wrkList[rowIdx-1]?.ClsId || (rowIdx <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td" @click="openModal(group)">
                  <span v-if="group.wrkList[rowIdx-1]" :class="['badge', group.wrkList[rowIdx-1].Deleted ? 'bg-red' : 'bg-green']">
                    {{ group.wrkList[rowIdx-1].Deleted ? 'Del' : 'Act' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
        </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const sortKey = ref('TagNo')
    const sortOrder = ref(1)
    const showModal = ref(false)
    const selectedItem = ref(null)

    // 그룹화 로직 (N개 데이터 수집)
    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k.length > 0)
      const groupMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload),
          ])

          const getList = (res) => Array.isArray(res?.data || res) ? (res?.data || res) : []
          
          getList(pubRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          getList(wrkRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        mergedList.value = Array.from(groupMap.values())
      } catch (err) { alert('데이터 호출 실패') }
      finally { isLoading.value = false }
    }

    const filteredList = computed(() => {
      let list = [...mergedList.value]
      if (localSearchQuery.value.trim()) {
        const terms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
        list = list.filter(g => terms.some(term => g.TagNo.toLowerCase().includes(term)))
      }
      list.sort((a, b) => (a[sortKey.value] < b[sortKey.value] ? -1 * sortOrder.value : 1 * sortOrder.value))
      return list
    })

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const regex = new RegExp(`(${localSearchQuery.value.split(/[\s,]+/).filter(t=>t).join('|')})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, 
      selectedIds, showModal, selectedItem,
      fetchAndMergeData, highlightText,
      sortBy: (k) => { if(sortKey.value===k) sortOrder.value*=-1; else {sortKey.value=k; sortOrder.value=1} },
      openModal: (g) => { selectedItem.value = g; showModal.value = true },
      closeModal: () => { showModal.value = false },
      toggleAllSelect: () => { 
        if (filteredList.value.length === selectedIds.value.length) selectedIds.value = []
        else selectedIds.value = filteredList.value.map(i => i.TagIdx)
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('선택된 그룹을 삭제하시겠습니까?') && console.log(selectedIds.value)
    }
  }
}
</script>

<style scoped>
/* 기존 스타일은 유지하되 테이블 보더와 병합 UI 최적화 */
.merged-table { border-collapse: separate; border-spacing: 0; }
.merged-table tbody { border-bottom: 2px solid #cbd5e1; } /* 그룹 간 구분선 */

/* 병합된 셀 스타일 */
.cell-group-idx, .cell-group-tag { background-color: #f8fafc; font-weight: 700; border-right: 2px solid #e2e8f0 !important; }

/* 데이터 셀 스타일 */
.pub-td { background-color: #f0f7ff; }
.wrk-td { background-color: #fffcf0; }

.modern-table td { border: 1px solid #e2e8f0; padding: 10px; text-align: center; }
.sub-header th { background: #f1f5f9; font-size: 11px; padding: 5px; }

.badge { padding: 2px 6px; border-radius: 4px; color: white; font-size: 11px; }
.bg-green { background: #10b981; }
.bg-red { background: #ef4444; }

::v-deep .hl { background: #fef08a; font-weight: bold; }
.data-row:hover td { background-color: #f1f5f9; }
</style>
