<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-section">
          <div class="search-grid">
            <div class="input-group project-box">
              <label>Project No</label>
              <input v-model="projectNo" type="text" placeholder="P0001" class="base-input" />
            </div>
            
            <div class="input-group keyword-box">
              <label>API Fetch Keywords</label>
              <textarea v-model="keyword" placeholder="TAG-01, TAG-02..." class="base-input keyword-input"></textarea>
            </div>
            
            <div class="button-box">
              <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-large">
                <span v-if="!isLoading">데이터 통합 조회하기</span>
                <span v-else class="loader"></span>
              </button>
            </div>
          </div>
          
          <div class="filter-row">
            <input v-model="localSearchQuery" type="text" placeholder="결과 내 실시간 필터링 (Tag No)..." class="filter-input" />
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="stats">검색 결과: <b>{{ filteredList.length }}</b> 그룹</div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">CSV 내보내기</button>
        </div>
      </div>

      <div class="table-container">
        <table class="modern-table">
          <thead>
            <tr class="main-header">
              <th rowspan="2" class="sticky-col col-chk">
                <div class="center-content"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div>
              </th>
              <th rowspan="2" class="sticky-col col-idx sortable" @click="sortBy('TagIdx')">Idx ↕</th>
              <th rowspan="2" class="sticky-col col-tag sortable" @click="sortBy('TagNo')">Tag No ↕</th>
              <th colspan="3" class="pub-header">Published (Master)</th>
              <th colspan="3" class="wrk-header">Working (Current)</th>
            </tr>
            <tr class="sub-header">
              <th class="sortable" @click="sortByNested('pubList', 'EpId')">EP ID</th>
              <th>CLS</th>
              <th>Deleted</th>
              <th class="sortable" @click="sortByNested('wrkList', 'EpId')">EP ID</th>
              <th>CLS</th>
              <th>Deleted</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="tag-group-boundary">
            <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" 
                :key="group.TagIdx + '-' + rowNum" 
                class="data-row"
                @click="openModal(group)">
              
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-fixed" @click.stop>
                <div class="center-content"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-fixed">
                {{ group.TagIdx }}
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-fixed tag-text" v-html="highlightText(group.TagNo)">
              </td>

              <td class="cell-pub">{{ group.pubList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-pub">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-pub">
                <span v-if="group.pubList[rowNum-1]" :class="['status-badge', group.pubList[rowNum-1].Deleted ? 'is-true' : 'is-false']">
                  {{ group.pubList[rowNum-1].Deleted }}
                </span>
              </td>

              <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-wrk">
                <span v-if="group.wrkList[rowNum-1]" :class="['status-badge', group.wrkList[rowNum-1].Deleted ? 'is-true' : 'is-false']">
                  {{ group.wrkList[rowNum-1].Deleted }}
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const sortKey = ref('TagNo')
    const sortOrder = ref(1)

    // 데이터 호출 (이전 로직 유지)
    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      const keywords = keyword.value.split(/[\s,\n]+/).filter(k => k)
      const groupMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ])
          const getArr = (r) => r?.data || r || []
          getArr(pubRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          getArr(wrkRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        mergedList.value = Array.from(groupMap.values())
      } catch (e) { alert('조회 실패') }
      finally { isLoading.value = false }
    }

    // 정렬 로직
    const sortBy = (key) => {
      sortOrder.value = sortKey.value === key ? sortOrder.value * -1 : 1
      sortKey.value = key
    }

    const filteredList = computed(() => {
      let list = [...mergedList.value]
      if (localSearchQuery.value.trim()) {
        list = list.filter(g => g.TagNo.toLowerCase().includes(localSearchQuery.value.toLowerCase()))
      }
      list.sort((a, b) => (a[sortKey.value] < b[sortKey.value] ? -1 : 1) * sortOrder.value)
      return list
    })

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds,
      fetchAndMergeData, sortBy,
      highlightText: (t) => t, // 생략
      toggleAllSelect: () => { /* 생략 */ },
      isAllSelected: computed(() => false),
      openModal: (g) => { /* 모달 로직 */ }
    }
  }
}
</script>

