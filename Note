<template>
  <div :class="['error-code-container', themeClass]">
    <h2>에러 코드 뷰어</h2>
    
    <div class="search-bar">
      <input 
        type="text" 
        v-model="globalSearch" 
        placeholder="전체 검색어를 입력하세요..." 
        class="global-search-input"
      />
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th v-for="col in columns" :key="col">
              <div class="th-content">
                <span>{{ col }}</span>
                <input 
                  type="text" 
                  v-model="columnFilters[col]" 
                  :placeholder="`${col} 필터`" 
                  class="column-filter-input"
                />
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr v-if="filteredData.length === 0">
            <td :colspan="columns.length" class="no-data">표시할 데이터가 없습니다.</td>
          </tr>
          <tr v-for="(row, index) in filteredData" :key="index">
            <td v-for="col in columns" :key="col" v-html="highlightText(row[col])"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue';
import * as XLSX from 'xlsx';
import excelFileUrl from '@/assets/Errorcode.xlsx?url';

// --- 상태 관리 ---
const rawData = ref([]);
const columns = ref([]);
const globalSearch = ref('');
const columnFilters = ref({});
const themeClass = ref('light-theme'); // 기본값: 라이트

// --- 테마 로직 (Local Storage 연동) ---
const updateTheme = () => {
  const encodedOption = localStorage.getItem('dev_AppOption');
  if (encodedOption) {
    try {
      // Base64 디코딩 후 JSON 파싱
      const decoded = atob(encodedOption);
      const option = JSON.parse(decoded);
      
      // appThemeClass 값에 따라 클래스 설정 (dark 또는 light)
      themeClass.value = option.appThemeClass === 'dark' ? 'dark-theme' : 'light-theme';
    } catch (e) {
      console.error("테마 설정을 읽는 중 오류 발생:", e);
      themeClass.value = 'light-theme';
    }
  }
};

// --- 데이터 로드 로직 ---
const loadExcelData = async () => {
  try {
    const response = await fetch(excelFileUrl);
    const arrayBuffer = await response.arrayBuffer();
    const workbook = XLSX.read(arrayBuffer, { type: 'array' });
    const jsonData = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]]);
    rawData.value = jsonData;
    if (jsonData.length > 0) {
      columns.value = Object.keys(jsonData[0]);
      columns.value.forEach(col => columnFilters.value[col] = '');
    }
  } catch (error) {
    console.error('엑셀 로드 실패:', error);
  }
};

// --- 필터링 및 하이라이트 로직 ---
const filteredData = computed(() => {
  return rawData.value.filter(row => {
    for (const col of columns.value) {
      const fv = columnFilters.value[col]?.toLowerCase().trim();
      if (fv && !String(row[col] || '').toLowerCase().includes(fv)) return false;
    }
    const sk = globalSearch.value.toLowerCase().trim();
    return sk ? columns.value.some(col => String(row[col] || '').toLowerCase().includes(sk)) : true;
  });
});

const highlightText = (text) => {
  const safeText = String(text || '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#039;"}[m]));
  const keyword = globalSearch.value.trim();
  if (!keyword) return safeText;
  const regex = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return safeText.replace(regex, '<mark class="highlight">$1</mark>');
};

// --- 생명주기 관리 ---
onMounted(() => {
  loadExcelData();
  updateTheme(); // 초기 로드 시 테마 적용

  // 같은 창에서 localStorage가 변경될 때를 위한 이벤트 리스너 (필요 시)
  window.addEventListener('storage', updateTheme);
  
  // 만약 앱 내부에서 스토리지 변경 시 이벤트를 발생시키지 않는 경우를 대비한 주기적 체크 (선택사항)
  // setInterval(updateTheme, 1000); 
});

onUnmounted(() => {
  window.removeEventListener('storage', updateTheme);
});
</script>

<style scoped>
/* 공통 스타일 */
.error-code-container {
  padding: 20px;
  min-height: 100vh;
  transition: background-color 0.3s, color 0.3s;
}

/* 라이트 테마 (배경 흰색) */
.light-theme {
  background-color: #ffffff;
  color: #333333;
}
.light-theme th { background-color: #f8f9fa; color: #333; }
.light-theme td, .light-theme th { border: 1px solid #dee2e6; }
.light-theme .global-search-input, .light-theme .column-filter-input {
  background-color: #fff;
  color: #333;
  border: 1px solid #ccc;
}

/* 다크 테마 */
.dark-theme {
  background-color: #1e1e1e;
  color: #e0e0e0;
}
.dark-theme th { background-color: #2d2d2d; color: #fff; }
.dark-theme td, .dark-theme th { border: 1px solid #444; }
.dark-theme .global-search-input, .dark-theme .column-filter-input {
  background-color: #333;
  color: #fff;
  border: 1px solid #555;
}

/* 검색바 및 테이블 구조 */
.search-bar { margin-bottom: 20px; }
.global-search-input { width: 100%; max-width: 400px; padding: 10px; border-radius: 4px; }
.table-wrapper { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; min-width: 800px; }
th, td { padding: 12px; text-align: left; }
.th-content { display: flex; flex-direction: column; gap: 8px; }
.column-filter-input { padding: 4px 8px; font-size: 13px; border-radius: 4px; width: 100%; }

/* 하이라이트 스타일 */
:deep(mark.highlight) {
  background-color: #ffeb3b;
  color: #000;
  font-weight: bold;
  padding: 0 2px;
}
.dark-theme :deep(mark.highlight) {
  background-color: #ffd600;
}
</style>
