import GC from '@mescius/spread-sheets-designer'
import { ApiCommon } from '@/utils/axios/api-common'
import { useEmployees } from '@/stores/app-employees'
const { setEmployeeInfo } = useEmployees()

const _EditorType = 'ExcelStylePopupEditor'

// CSS: 캡처 화면과 동일한 드롭다운 및 버튼 스타일
if (!document.getElementById('excel-pure-style')) {
  const style = document.createElement('style');
  style.id = 'excel-pure-style';
  style.innerHTML = `
    .excel-btn-anchor {
      position: fixed; z-index: 15000; width: 18px; height: 18px;
      background: #e1e1e1; border: 1px solid #abadb3; 
      display: flex; align-items: center; justify-content: center; cursor: default;
    }
    .excel-btn-arrow {
      width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid #555;
    }
    .excel-dropdown-list {
      position: fixed; z-index: 16000; background: white;
      border: 1px solid black; box-sizing: border-box;
      padding: 0; margin: 0; list-style: none; overflow-y: auto; max-height: 200px;
    }
    .excel-dropdown-item {
      padding: 2px 8px; font-size: 13px; color: black; cursor: pointer; white-space: nowrap;
    }
    .excel-dropdown-item:hover {
      background-color: #0078d4 !important; color: white !important;
    }
  `;
  document.head.appendChild(style);
}

function UserSelectCellType(FIELD, NAME_FIELD, DEPT_FIELD) {
  this.field = FIELD
  this.nameField = NAME_FIELD
  this.deptField = DEPT_FIELD
  this.searchTimer = null
  this.elements = { btn: null, list: null };
  this.originalValue = null;
  this.selectedEmpNo = null;
}

UserSelectCellType.prototype = new GC.Spread.Sheets.CellTypes.Base()

// 셀 출력 (텍스트만 깔끔하게)
UserSelectCellType.prototype.paint = function (ctx, value, x, y, w, h, style, options) {
  const sheet = options.sheet
  const data = sheet.getDataItem(options.row)
  const name = data?.[this.nameField] ?? ''
  const dept = data?.[this.deptField] ?? ''
  const text = name ? `${name}${dept ? `(${dept})` : ''}` : ''
  GC.Spread.Sheets.CellTypes.Base.prototype.paint.apply(this, [ctx, text, x, y, w, h, style, options])
}

UserSelectCellType.prototype.createEditorElement = function (context) {
  // 1. 인풋 에디터 (셀 테두리 안에 존재)
  const input = document.createElement('input')
  input.setAttribute('gcUIElement', 'gcEditingInput')
  input.style.cssText = 'border: 2px solid #217346; outline: none; padding: 0 4px; box-sizing: border-box;'

  // 2. 우측 버튼 (셀 바깥에 배치하기 위해 body에 부착)
  const btn = document.createElement('div')
  btn.className = 'excel-btn-anchor'
  btn.innerHTML = '<div class="excel-btn-arrow"></div>'
  document.body.appendChild(btn)
  this.elements.btn = btn

  // 3. 리스트박스 (body 부착)
  const list = document.createElement('ul')
  list.className = 'excel-dropdown-list'
  list.style.display = 'none'
  document.body.appendChild(list)
  this.elements.list = list

  input.addEventListener('input', (e) => {
    if (this.searchTimer) clearTimeout(this.searchTimer)
    const keyword = e.target.value.trim()

    this.searchTimer = setTimeout(async () => {
      if (keyword.length < 1) { list.style.display = 'none'; return; }
      const response = await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: keyword }) ?? []
      list.innerHTML = ''

      if (response.length > 0) {
        const rect = input.getBoundingClientRect()
        // 캡처 화면처럼 리스트 위치 잡기
        list.style.width = `${rect.width}px`
        list.style.top = `${rect.bottom}px`
        list.style.left = `${rect.left}px`
        list.style.display = 'block'

        response.forEach(item => {
          const li = document.createElement('li')
          li.className = 'excel-dropdown-item'
          li.innerText = item.EMP_NM // 캡처처럼 이름만 표시하거나 부서 포함 가능
          
          li.onmousedown = (ev) => {
            ev.preventDefault()
            this.selectedEmpNo = item.EMP_NO
            input.value = item.EMP_NM
            setEmployeeInfo({ ...item, code: item.EMP_NO })
            list.style.display = 'none'
            context.sheet.endEdit()
          }
          list.appendChild(li)
        })
      }
    }, 500)
  })

  return input
}

// 에디터/버튼 위치 조정
UserSelectCellType.prototype.updateEditor = function (editorContext, cellStyle, cellRect) {
  if (editorContext && this.elements.btn) {
    const rect = editorContext.getBoundingClientRect()
    // 버튼을 셀 오른쪽에 살짝 걸치게 배치 (캡처화면 재현)
    this.elements.btn.style.top = `${rect.top}px`
    this.elements.btn.style.left = `${rect.right + 2}px`
    this.elements.btn.style.height = `${rect.height}px`
    
    return { width: cellRect.width, height: cellRect.height }
  }
}

UserSelectCellType.prototype.getEditorValue = function (editorContext) {
  return this.selectedEmpNo || this.originalValue
}

UserSelectCellType.prototype.setEditorValue = function (editorContext, value) {
  this.originalValue = value
  this.selectedEmpNo = null
  editorContext.value = ''
}

UserSelectCellType.prototype.destroyEditorElement = function (editorContext) {
  if (this.elements.btn) this.elements.btn.remove()
  if (this.elements.list) this.elements.list.remove()
}

export default UserSelectCellType
