<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="project-box">
            <div class="input-group">
              <label>Project No</label>
              <input v-model="projectNo" type="text" class="base-input unified-height" placeholder="P0001" />
            </div>
            <div class="filter-wrapper">
              <label class="sub-label">결과 내 실시간 필터</label>
              <input v-model="localSearchQuery" type="text" class="filter-input unified-height" placeholder="Tag No 검색..." />
            </div>
          </div>
          <div class="keyword-box">
            <label>API Fetch Keywords</label>
            <textarea v-model="keyword" class="base-input keyword-input" placeholder="키워드 입력 (공백/엔터/쉼표 구분)"></textarea>
          </div>
          <div class="button-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-large">
              {{ isLoading ? '조회 중...' : '데이터 통합 조회' }}
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="stats">조회 결과: <b>{{ filteredList.length }}</b>건</div>
        <div class="right-buttons">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-container">
        <div v-if="filteredList.length === 0 && !isLoading" class="no-data">
          조회된 데이터가 없습니다.
        </div>

        <table v-else class="modern-table">
          <thead>
            <tr class="main-header">
              <th rowspan="2" class="sticky-header sticky-col col-chk">
                <input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" />
              </th>
              <th rowspan="2" class="sticky-header sticky-col col-idx">Idx</th>
              <th rowspan="2" class="sticky-header sticky-col col-tag">Tag No</th>
              <th colspan="3" class="pub-header-top">Published (Master)</th>
              <th colspan="3" class="wrk-header-top">Working (Current)</th>
            </tr>
            <tr class="sub-header">
              <th class="sub-th">EP ID</th><th class="sub-th">CLS</th><th class="sub-th">Del</th>
              <th class="sub-th">EP ID</th><th class="sub-th">CLS</th><th class="sub-th">Del</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx">
            <tr v-for="rowNum in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum">
              
              <td v-if="rowNum === 1" 
                  :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  class="sticky-col col-chk group-fixed-cell">
                <div class="center-vh"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="rowNum === 1" 
                  :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  class="sticky-col col-idx group-fixed-cell clickable" @click="openModal(group)">
                <div class="center-vh font-bold">{{ group.TagIdx }}</div>
              </td>
              <td v-if="rowNum === 1" 
                  :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  class="sticky-col col-tag group-fixed-cell clickable tag-col-border" @click="openModal(group)">
                <div class="cell-content tag-text" v-html="highlightText(group.TagNo)"></div>
              </td>
              
              <td class="cell-pub data-cell clickable" @click="openModal(group)">
                <div class="cell-content">{{ group.pubList[rowNum-1]?.EpId || 'null' }}</div>
              </td>
              <td class="cell-pub data-cell clickable" @click="openModal(group)">
                <div class="cell-content">{{ group.pubList[rowNum-1]?.ClsId || 'null' }}</div>
              </td>
              <td class="cell-pub data-cell clickable" @click="openModal(group)">
                <div class="cell-content center-vh">
                  <span v-if="group.pubList[rowNum-1]" :class="['badge', group.pubList[rowNum-1].Deleted ? 'red' : 'green']">
                    {{ group.pubList[rowNum-1].Deleted ? 'Y' : 'N' }}
                  </span>
                  <span v-else class="is-null">null</span>
                </div>
              </td>
              
              <td class="cell-wrk data-cell clickable" @click="openModal(group)">
                <div class="cell-content">{{ group.wrkList[rowNum-1]?.EpId || 'null' }}</div>
              </td>
              <td class="cell-wrk data-cell clickable" @click="openModal(group)">
                <div class="cell-content">{{ group.wrkList[rowNum-1]?.ClsId || 'null' }}</div>
              </td>
              <td class="cell-wrk data-cell clickable" @click="openModal(group)">
                <div class="cell-content center-vh">
                  <span v-if="group.wrkList[rowNum-1]" :class="['badge', group.wrkList[rowNum-1].Deleted ? 'red' : 'green']">
                    {{ group.wrkList[rowNum-1].Deleted ? 'Y' : 'N' }}
                  </span>
                  <span v-else class="is-null">null</span>
                </div>
              </td>
            </tr>
            <tr class="group-divider"><td colspan="9"></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-content modal-xl">
        <div class="modal-header">
          <div class="header-left"><h3>상세 데이터 분석</h3><span class="tag-label">{{ selectedItem?.TagNo }}</span></div>
          <button @click="closeModal" class="btn-close">&times;</button>
        </div>
        <div class="modal-body modal-scroll">
          <div class="modal-table-wrapper">
            <table class="analysis-table">
              <thead>
                <tr>
                  <th colspan="5" class="h-info">기본정보</th>
                  <th :colspan="allAttributeKeys.length" class="h-attr">특성정보</th>
                </tr>
                <tr>
                  <th>Source</th><th>Tag No</th><th>EP ID</th><th>Class</th><th>Status</th>
                  <th v-for="key in allAttributeKeys" :key="key">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(row, idx) in modalRows" :key="idx">
                  <td><span :class="['label', row.source]">{{ row.source }}</span></td>
                  <td>{{ row.TagNo }}</td><td>{{ row.EpId }}</td><td>{{ row.ClsId }}</td>
                  <td class="text-center"><span :class="['badge', row.Deleted ? 'red' : 'green']">{{ row.Deleted ? 'Y' : 'N' }}</span></td>
                  <td v-for="key in allAttributeKeys" :key="key + idx">
                    <span v-if="row.attrMap[key] === undefined" class="is-empty"></span>
                    <span v-else :class="{ 'is-null-text': row.attrMap[key] === 'null' }">{{ row.attrMap[key] }}</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    const filteredList = computed(() => {
      const q = localSearchQuery.value.trim().toLowerCase();
      return q ? mergedList.value.filter(g => String(g.TagNo).toLowerCase().includes(q)) : mergedList.value;
    });

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      mergedList.value = [];
      const groupMap = new Map();
      try {
        const keys = keyword.value.split(/[\s,\n,]+/).map(k => k.trim()).filter(k => k);
        for (const k of keys) {
          const payload = { ProjectNo: projectNo.value, Keyword: k };
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload).catch(() => ({ data: [] })),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload).catch(() => ({ data: [] }))
          ]);
          const pList = Array.isArray(pubRes) ? pubRes : (pubRes?.data || []);
          const wList = Array.isArray(wrkRes) ? wrkRes : (wrkRes?.data || []);
          const addToGroup = (list, type) => {
            list.forEach(i => {
              if (!i.TagIdx) return;
              if (!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
              groupMap.get(i.TagIdx)[type].push(i);
            });
          };
          addToGroup(pList, 'pubList'); addToGroup(wList, 'wrkList');
        }
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => String(a.TagNo).localeCompare(b.TagNo, undefined, { numeric: true }));
      } catch (e) { console.error(e); } finally { isLoading.value = false; }
    };

    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const gather = (list) => list.forEach(row => {
        const attrs = row.Attributes || row.attributes || [];
        if (Array.isArray(attrs)) attrs.forEach(a => { if(a.ATT_ID) keys.add(a.ATT_ID); });
      });
      gather(selectedItem.value.pubList); gather(selectedItem.value.wrkList);
      return Array.from(keys).sort();
    });

    const modalRows = computed(() => {
      if (!selectedItem.value) return [];
      const process = (item, src) => {
        const attrMap = {};
        const rawAttrs = item.Attributes || item.attributes || [];
        if (Array.isArray(rawAttrs)) {
          rawAttrs.forEach(a => {
            if (a.ATT_ID) {
              let val = 'null';
              if (a.VALUE !== null && a.VALUE !== undefined && String(a.VALUE).trim() !== '') val = String(a.VALUE);
              else if (a.VALUE_DBL !== null && a.VALUE_DBL !== 0) val = String(a.VALUE_DBL);
              attrMap[a.ATT_ID] = val;
            }
          });
        }
        return { source: src, TagNo: item.TagNo || selectedItem.value.TagNo, EpId: item.EpId || 'null', ClsId: item.ClsId || item.Cls || 'null', Deleted: !!item.Deleted, attrMap };
      };
      const rows = [];
      selectedItem.value.pubList.forEach(i => rows.push(process(i, 'Published')));
      selectedItem.value.wrkList.forEach(i => rows.push(process(i, 'Working')));
      return rows;
    });

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem,
      allAttributeKeys, modalRows, fetchAndMergeData,
      highlightText: (t) => {
        const q = localSearchQuery.value.trim();
        return q ? String(t).replace(new RegExp(`(${q})`, 'gi'), '<mark class="hl">$1</mark>') : t;
      },
      openModal: (g) => { selectedItem.value = g; showModal.value = true; },
      closeModal: () => { showModal.value = false; },
      toggleAllSelect: () => {
        selectedIds.value = (selectedIds.value.length === filteredList.value.length) ? [] : filteredList.value.map(g => g.TagIdx);
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('삭제하시겠습니까?'),
      downloadExcel: () => alert('Excel 내보내기')
    };
  }
}
</script>

<style scoped>
