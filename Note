<template>
  <div id="app">
    <header class="header">
      <h2 class="page-main-title">🏷️ 태그 번호 유효성 검사</h2>
    </header>

    <div class="main-content-wrapper">
      <div class="panel tag-split-panel">
        <section class="input-section">
          <h3 class="panel-title">Tag Split (유효성 검사기)</h3>
          <div class="input-group">
            <label for="tagNoInputValidator">검사할 Tag No. 입력:</label>
            <input id="tagNoInputValidator" v-model="tagNoForValidator" type="text" placeholder="예: AA-BBB01-0001/A" />
          </div>

          <div class="overall-validation-result">
            <p class="validation-summary">
              상태: 
              <span :style="{ color: isTagNoValid ? '#28a745' : '#dc3545', fontWeight: 'bold' }">
                {{ isTagNoValid ? '✅ 유효함' : '❌ 유효하지 않음' }}
              </span>
            </p>
            <p class="regex-info">
              전체 정규식: <code class="combined-regex-code">{{ combinedRegexString }}</code>
            </p>
          </div>
        </section>

        <section class="rules-section">
          <div class="section-header">
            <h4>규칙 설정</h4>
            <div class="table-actions">
              <button @click="addRule" class="small-btn success-btn">+ 추가</button>
              <button @click="showPasteModal = true" class="small-btn info-btn">엑셀 붙여넣기</button>
            </div>
          </div>
          <div class="scrollable-table-wrapper">
            <table>
              <thead>
                <tr>
                  <th width="15%">ID</th>
                  <th width="15%">구분자</th>
                  <th>정규식</th>
                  <th width="10%">삭제</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center">TAG{{ String(index + 1).padStart(3, '0') }}</td>
                  <td><input type="text" v-model="rule.delimiter" maxlength="1" class="table-input" /></td>
                  <td><input type="text" v-model="rule.regex" class="table-input" /></td>
                  <td><button @click="removeRule(index)" class="delete-btn">×</button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="analysis-section">
          <h4 class="section-sub-title">부분별 분석 결과</h4>
          <div class="scrollable-table-wrapper">
            <table class="parts-analysis-table">
              <thead>
                <tr>
                  <th>구분</th>
                  <th>분리된 값</th>
                  <th>정규식</th>
                  <th>구분자</th>
                  <th>내용</th>
                  <th>종합</th>
                </tr>
              </thead>
              <tbody>
                <tr v-if="tagRules.length === 0">
                  <td colspan="6" class="no-rule-message">규칙을 설정해주세요.</td>
                </tr>
                <tr v-for="(part, index) in tagParts" :key="index">
                  <td class="font-small">TAG{{ String(index + 1).padStart(3, '0') }}</td>
                  <td class="font-bold">{{ part.matchedValue || '-' }}</td>
                  <td class="font-code">{{ part.regex }}</td>
                  <td :class="part.isDelimiterValid ? 'text-ok' : 'text-fail'">{{ part.isDelimiterValid ? 'OK' : 'ERR' }}</td>
                  <td :class="part.isContentValid ? 'text-ok' : 'text-fail'">{{ part.isContentValid ? 'OK' : 'ERR' }}</td>
                  <td :class="part.isValid ? 'text-ok' : 'text-fail'">{{ part.isValid ? 'PASS' : 'FAIL' }}</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div v-if="tagNoForValidator && !isTagNoValid" class="error-banner">
            ⚠️ <strong>검색 실패:</strong> {{ lastPartError || '규칙과 일치하지 않는 부분이 있습니다.' }}
          </div>
        </section>
      </div>
    </div>

    <div v-if="showPasteModal" class="modal-overlay" @click.self="showPasteModal = false">
      <div class="modal-content">
        <h4>엑셀 데이터 붙여넣기</h4>
        <textarea
          v-model="pasteData"
          placeholder="[구분자][Tab][정규식] 형태로 붙여넣으세요."
          rows="10"
          class="paste-textarea"
        ></textarea>
        <div class="modal-actions">
          <button @click="applyPasteData" class="action-btn success-btn">적용하기</button>
          <button @click="showPasteModal = false" class="action-btn cancel-btn">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
  import { ref, computed } from 'vue'

  export default {
    setup() {
      const tagNoForValidator = ref('AP330X01-')
      const combinedRegexError = ref(null)
      const lastPartError = ref(null)
      const showPasteModal = ref(false)
      const pasteData = ref('')

      const tagRules = ref([
        { delimiter: '', regex: '^$|^[A-Z]{2}$' },
        { delimiter: '', regex: '^[0123LCRIT]{3}$' },
        { delimiter: '', regex: '^[ABCDEFNVXS]{1}$' },
        { delimiter: '', regex: '^$|^[ABCDEFNVXS]{1}$' },
        { delimiter: '', regex: '^[0-9]{2}$' },
        { delimiter: '-', regex: '^$|^[APS1-9]{2}$' },
      ])

      const isRegexOptional = regexPattern => {
        const trimmed = regexPattern.trim()
        if (!trimmed || trimmed === '^$') return true
        if (trimmed.startsWith('^$|')) return true
        try {
          const cleanedRegex = trimmed.replace(/^\^/, '').replace(/\$$/, '')
          return new RegExp(`^${cleanedRegex}$`).test('')
        } catch (e) { return false }
      }

      const combinedRegexString = computed(() => {
        combinedRegexError.value = null
        if (tagRules.value.length === 0) return '^$'
        try {
          let regexParts = tagRules.value.map((rule, index) => {
            let content = rule.regex.trim().replace(/^\^/, '').replace(/\$$/, '')
            let contentPattern = isRegexOptional(rule.regex) && content.includes('$|') 
                                 ? `(?:${content.replace('$|', '')}|)` 
                                 : `(?:${content})`
            if (index > 0 && rule.delimiter.trim() !== '') {
              const escDelim = rule.delimiter.trim().replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
              return isRegexOptional(rule.regex) ? `(?:${escDelim}${contentPattern})?` : `(?:${escDelim}${contentPattern})`
            }
            return contentPattern
          })
          return `^${regexParts.join('')}$`
        } catch (e) {
          combinedRegexError.value = e.message
          return '.*'
        }
      })

      const isTagNoValid = computed(() => {
        try {
          return new RegExp(combinedRegexString.value).test(tagNoForValidator.value || '')
        } catch (e) { return false }
      })

      const tagParts = computed(() => {
        const parts = []
        let currentTagNo = tagNoForValidator.value || ''
        let currentIndex = 0
        lastPartError.value = null

        for (let i = 0; i < tagRules.value.length; i++) {
          const rule = tagRules.value[i]
          let matchedValue = null
          let isDelimiterValid = true
          let isContentValid = false
          
          const remaining = currentTagNo.substring(currentIndex)
          const delim = rule.delimiter.trim()
          const isOptional = isRegexOptional(rule.regex)

          if (i > 0 && delim !== '') {
            if (remaining.startsWith(delim)) {
              currentIndex += delim.length
            } else if (!isOptional) {
              isDelimiterValid = false
            }
          }

          try {
            const contentRegex = rule.regex.trim().replace(/^\^/, '').replace(/\$$/, '')
            const match = new RegExp(`^(${contentRegex})`).exec(currentTagNo.substring(currentIndex))
            if (match) {
              matchedValue = match[1]
              currentIndex += matchedValue.length
              isContentValid = true
            } else if (isOptional) {
              isContentValid = true
            }
          } catch (e) { isContentValid = false }

          parts.push({
            regex: rule.regex,
            matchedValue,
            isDelimiterValid,
            isContentValid,
            isValid: isDelimiterValid && isContentValid
          })
          if (!isDelimiterValid || !isContentValid) break
        }
        return parts
      })

      const addRule = () => tagRules.value.push({ delimiter: '', regex: '' })
      const removeRule = index => tagRules.value.splice(index, 1)
      const applyPasteData = () => {
        const rows = pasteData.value.trim().split('\n')
        const newRules = rows.map(row => {
          const cols = row.split('\t')
          return { delimiter: cols[0] || '', regex: cols[1] || '' }
        })
        if (newRules.length) tagRules.value = newRules
        showPasteModal.value = false
      }

      return { tagNoForValidator, combinedRegexString, isTagNoValid, tagParts, tagRules, addRule, removeRule, showPasteModal, pasteData, applyPasteData, lastPartError }
    }
  }
</script>

