<template>
  <div class="main-container">
    <div class="header-section">
      <div class="top-row">
        <h2 class="title">에러 코드</h2>
        <div class="search-box">
          <input 
            type="text" 
            v-model="globalSearch" 
            placeholder="전체 검색어 입력..." 
            class="global-input"
          />
        </div>
      </div>
    </div>

    <div class="table-outer-wrapper">
      <div class="table-inner-scroll">
        <table class="error-table">
          <colgroup>
            <col style="width: 60px;">
            <col style="width: 150px;">
            <col style="width: 130px;">
            <col style="width: 25%;">
            <col style="width: 25%;">
            <col style="width: 25%;">
          </colgroup>
          <thead>
            <tr>
              <th v-for="col in columns" :key="col" class="fixed-th">
                <div class="th-content">
                  <span class="col-name">{{ col }}</span>
                  
                  <div v-if="col === '기능'" class="filter-group">
                    <input type="text" v-model="columnFilters[col]" class="filter-input" placeholder="필터" />
                    <div class="combo-wrapper" @click.stop>
                      <button @click="toggleFuncList" class="combo-btn">▼</button>
                      <ul v-if="showFuncList" class="combo-menu">
                        <li @click="selectFunc('')">전체보기</li>
                        <li v-for="item in uniqueFuncs" :key="item" @click="selectFunc(item)">{{ item }}</li>
                      </ul>
                    </div>
                  </div>

                  <input v-else type="text" v-model="columnFilters[col]" class="filter-input" placeholder="필터" />
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr v-if="filteredData.length === 0">
              <td :colspan="columns.length" class="no-result">데이터가 없습니다.</td>
            </tr>
            <tr v-for="(row, idx) in filteredData" :key="idx">
              <td v-for="col in columns" :key="col" :class="['data-cell', `col-${col}`]">
                <div v-html="highlightText(row[col])"></div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue';
import * as XLSX from 'xlsx';
import excelFileUrl from '@/assets/Errorcode.xlsx?url';

const rawData = ref([]);
const columns = ['No', '기능', 'Code', 'Message', '원인', '해결방법'];
const globalSearch = ref('');
const columnFilters = ref({ No: '', 기능: '', Code: '', Message: '', 원인: '', 해결방법: '' });
const showFuncList = ref(false);
const uniqueFuncs = ref([]);

const loadExcelData = async () => {
  try {
    const res = await fetch(excelFileUrl);
    const buf = await res.arrayBuffer();
    const wb = XLSX.read(buf, { type: 'array' });
    const data = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
    rawData.value = data;
    uniqueFuncs.value = [...new Set(data.map(item => item['기능']))].filter(Boolean).sort();
  } catch (err) { console.error(err); }
};

const toggleFuncList = () => (showFuncList.value = !showFuncList.value);
const selectFunc = (val) => {
  columnFilters.value['기능'] = val;
  showFuncList.value = false;
};
const closeDropdown = () => (showFuncList.value = false);

onMounted(() => {
  loadExcelData();
  window.addEventListener('click', closeDropdown);
});
onUnmounted(() => window.removeEventListener('click', closeDropdown));

const filteredData = computed(() => {
  return rawData.value.filter(row => {
    const colMatch = columns.every(c => !columnFilters.value[c] || String(row[c]||'').toLowerCase().includes(columnFilters.value[c].toLowerCase()));
    const gMatch = !globalSearch.value || columns.some(c => String(row[c]||'').toLowerCase().includes(globalSearch.value.toLowerCase()));
    return colMatch && gMatch;
  });
});

const highlightText = (t) => {
  const s = String(t || '');
  const k = globalSearch.value.trim();
  if (!k) return s;
  const re = new RegExp(`(${k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return s.replace(re, '<mark class="hl">$1</mark>');
};
</script>

