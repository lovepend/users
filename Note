<template>
  <div id="app">
    <h2 class="page-main-title">🔍 태그 통합 조회 시스템 (Multi-Keyword)</h2>

    <div class="main-content-wrapper">
      <div class="panel full-panel">
        <h3 class="panel-title">키워드 기반 데이터 조회 및 분석</h3>

        <div class="search-controls">
          <div class="input-group-container">
            <div class="input-item">
              <label>Project No</label>
              <input v-model="projectNo" type="text" placeholder="프로젝트 No..." class="custom-input" />
            </div>
            <div class="input-item" style="flex: 2;">
              <label>Keywords (공백/줄바꿈으로 구분)</label>
              <textarea
                v-model="keyword"
                placeholder="TAG01 TAG02..."
                class="custom-input multi-input"
                @keyup.ctrl.enter="fetchAndMergeData"
              ></textarea>
            </div>
            <button @click="fetchAndMergeData" :disabled="isLoading" class="search-btn">
              {{ isLoading ? '조회 중...' : '통합 검색' }}
            </button>
          </div>
        </div>

        <div class="action-bar" v-if="mergedList.length > 0">
          <div class="filter-group">
            <label>상태 필터:</label>
            <select v-model="filterStatus" class="custom-select">
              <option value="all">전체 보기</option>
              <option value="deleted">삭제된 항목만</option>
              <option value="active">사용 중인 항목만</option>
            </select>
          </div>
          <button @click="downloadExcel" class="excel-btn">📥 엑셀 다운로드</button>
        </div>

        <div v-if="errorMessage" class="message error-message">⚠️ {{ errorMessage }}</div>

        <div class="table-container" v-if="filteredList.length > 0">
          <table class="data-table">
            <thead>
              <tr>
                <th rowspan="2">Tag Index</th>
                <th rowspan="2">Tag No</th>
                <th colspan="4" class="pub-header">Published (Master)</th>
                <th colspan="4" class="wrk-header">Working (Current)</th>
              </tr>
              <tr>
                <th class="pub-bg">EP ID/IC</th>
                <th class="pub-bg">CLS_ID</th>
                <th class="pub-bg">TypeID</th>
                <th class="pub-bg">Status</th>
                <th class="wrk-bg">EP ID/IC</th>
                <th class="wrk-bg">CLS_ID</th>
                <th class="wrk-bg">DelYN</th>
                <th class="wrk-bg">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="item in filteredList" :key="item.TagIdx" @click="openModal(item)" class="clickable-row">
                <td class="idx-cell">{{ item.TagIdx }}</td>
                <td class="tag-no-cell">{{ item.TagNo }}</td>
                <td class="pub-bg">{{ item.pub?.EpId || '-' }}</td>
                <td class="pub-bg">{{ item.pub?.ClsId || '-' }}</td>
                <td class="pub-bg">{{ item.pub?.TagTypeId || '-' }}</td>
                <td class="pub-bg">
                  <span v-if="item.pub" :class="item.pub.Deleted ? 'status-red' : 'status-green'">
                    {{ item.pub.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>
                <td class="wrk-bg">{{ item.wrk?.EpId || '-' }}</td>
                <td class="wrk-bg">{{ item.wrk?.ClsId || '-' }}</td>
                <td class="wrk-bg">
                  <span v-if="item.wrk" :class="item.wrk.DelYn ? 'status-red' : ''">
                    {{ item.wrk.DelYn ? 'Y' : 'N' }}
                  </span>
                </td>
                <td class="wrk-bg">
                  <span v-if="item.wrk" :class="item.wrk.Deleted ? 'status-red' : 'status-green'">
                    {{ item.wrk.Deleted ? 'Deleted' : 'Active' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div v-else-if="searched && !isLoading" class="message no-results-message">데이터가 없습니다.</div>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-content">
        <div class="modal-header">
          <h4>Tag 상세 정보 비교 (TagIdx: {{ selectedItem?.TagIdx }})</h4>
          <button @click="closeModal" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" v-if="selectedItem">
          <div class="modal-grid">
            <div class="grid-section">
              <h5>[Master - Published]</h5>
              <pre>{{ JSON.stringify(selectedItem.pub, null, 2) }}</pre>
            </div>
            <div class="grid-section">
              <h5>[Current - Working]</h5>
              <pre>{{ JSON.stringify(selectedItem.wrk, null, 2) }}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  name: 'TagIntegratedManager',
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const errorMessage = ref('')
    const searched = ref(false)
    const filterStatus = ref('all')

    // 모달 관련 상태
    const showModal = ref(false)
    const selectedItem = ref(null)

    const filteredList = computed(() => {
      if (filterStatus.value === 'deleted') {
        return mergedList.value.filter(item => item.pub?.Deleted || item.wrk?.Deleted || item.wrk?.DelYn)
      } else if (filterStatus.value === 'active') {
        return mergedList.value.filter(item => !item.pub?.Deleted && !item.wrk?.Deleted)
      }
      return mergedList.value
    })

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      errorMessage.value = ''
      searched.value = true
      mergedList.value = [] // 이전 결과 초기화

      const keywords = keyword.value
        .split(/[\s,\n]+/)
        .map(k => k.trim())
        .filter(k => k.length > 0)

      const dataMap = new Map()

      try {
        const fetchPromises = keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload),
          ])

          const pubData = pubRes?.data || pubRes
          const wrkData = wrkRes?.data || wrkRes

          if (Array.isArray(pubData)) {
            pubData.forEach(item => {
              if (!dataMap.has(item.TagIdx)) {
                dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: item, wrk: null })
              } else {
                dataMap.get(item.TagIdx).pub = item
              }
            })
          }
          if (Array.isArray(wrkData)) {
            wrkData.forEach(item => {
              if (dataMap.has(item.TagIdx)) {
                dataMap.get(item.TagIdx).wrk = item
              } else {
                dataMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pub: null, wrk: item })
              }
            })
          }
        })

        await Promise.all(fetchPromises)
        mergedList.value = Array.from(dataMap.values())
      } catch (err) {
        errorMessage.value = '데이터 호출 실패'
      } finally {
        isLoading.value = false
      }
    }

    const downloadExcel = () => {
      let csvContent = '\uFEFFTagIdx,TagNo,Pub_EpId,Pub_ClsId,Pub_Deleted,Wrk_EpId,Wrk_ClsId,Wrk_DelYn,Wrk_Deleted\n'
      filteredList.value.forEach(item => {
        const row = [
          item.TagIdx,
          `"${item.TagNo}"`, // TagNo에 특수문자 대비 따옴표 처리
          item.pub?.EpId || '',
          item.pub?.ClsId || '',
          item.pub?.Deleted || 'false',
          item.wrk?.EpId || '',
          item.wrk?.ClsId || '',
          item.wrk?.DelYn || 'false',
          item.wrk?.Deleted || 'false',
        ]
        csvContent += row.join(',') + '\n'
      })
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' })
      const link = document.createElement('a')
      link.href = URL.createObjectURL(blob)
      link.setAttribute('download', `Tag_Export_${new Date().getTime()}.csv`)
      link.click()
    }

    const openModal = (item) => {
      selectedItem.value = item
      showModal.value = true
    }

    const closeModal = () => {
      showModal.value = false
      selectedItem.value = null
    }

    // 중요: 모든 변수와 함수를 return 해야 템플릿에서 쓸 수 있습니다.
    return {
      projectNo, keyword, mergedList, filteredList, isLoading, errorMessage, searched,
      filterStatus, showModal, selectedItem,
      fetchAndMergeData, downloadExcel, openModal, closeModal
    }
  }
}
</script>

<style scoped>
/* 기존 스타일 유지 + 추가 보완 */
.multi-input {
  min-height: 40px;
  height: 40px;
  transition: height 0.2s;
}
.multi-input:focus {
  height: 100px; /* 클릭(포커스) 시 입력창이 늘어나도록 설정 */
}
/* ... 기존 스타일 소스 그대로 유지 ... */
</style>
