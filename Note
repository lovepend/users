            <CheckBox
              v-if="checkDemo.showHidden"
              id="tpl-cb-conditional"
              label="조건부 표시"
              v-model:value="checkDemo.conditional"
            />
          </div>
          <div class="tpl-check-demo__meta">
            <button
              type="button"
              class="tpl-btn tpl-btn--sm tpl-btn--ghost"
              @click="checkDemo.showHidden = !checkDemo.showHidden"
            >
              {{ checkDemo.showHidden ? '숨김 항목 접기' : '숨김 항목 보기' }}
            </button>
            <span v-if="checkDemo.lastEvent" class="tpl-check-demo__log">{{ checkDemo.lastEvent }}</span>
          </div>
        </section>

        <section class="template__section" id="tpl-section-selectbox" aria-labelledby="section-selectbox-title">
          <h2 id="section-selectbox-title" class="template__section-title">SelectBox</h2>
          <p class="template__section-desc">
            라벨 왼쪽, 네이티브 드롭다운 오른쪽. 값이 있을 때 드롭다운
            <strong>왼쪽</strong>에 초기화(×) 버튼이 보입니다. <code class="tpl-code">update:value</code> ·
            <code class="tpl-code">change</code> (선택된 항목의 <code class="tpl-code">id</code>).
          </p>
          <div class="tpl-check-demo tpl-field-demo">
            <SelectBox
