<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="project-box">
            <div class="input-group">
              <label>Project No</label>
              <input v-model="projectNo" type="text" class="base-input unified-height" />
            </div>
            <div class="filter-wrapper">
              <label class="sub-label">결과 내 실시간 필터</label>
              <input v-model="localSearchQuery" type="text" class="filter-input unified-height" />
            </div>
          </div>
          <div class="keyword-box">
            <label>API Fetch Keywords</label>
            <textarea v-model="keyword" class="base-input keyword-input"></textarea>
          </div>
          <div class="button-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-large">
              데이터 통합 조회
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="stats">조회 결과: <b>{{ filteredList.length }}</b>건</div>
        <div class="right-buttons">
          <button @click="deleteSelected" class="btn btn-danger">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-container">
        <table class="modern-table">
          <thead>
            <tr class="main-header">
              <th rowspan="2" class="sticky-header sticky-col col-chk border-bottom-none">
                <div class="center-content"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div>
              </th>
              <th rowspan="2" class="sticky-header sticky-col col-idx border-bottom-none">Idx</th>
              <th rowspan="2" class="sticky-header sticky-col col-tag border-bottom-none">Tag No</th>
              
              <th colspan="3" class="pub-header-top h-40">Published (Master)</th>
              <th colspan="3" class="wrk-header-top h-40">Working (Current)</th>
            </tr>
            <tr class="sub-header">
              <th class="pub-sub h-40">EP ID</th>
              <th class="pub-sub h-40">CLS</th>
              <th class="pub-sub h-40">Deleted</th>
              <th class="wrk-sub h-40">EP ID</th>
              <th class="wrk-sub h-40">CLS</th>
              <th class="wrk-sub h-40">Deleted</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-tbody">
            <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum">
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-fixed border-right">
                <div class="cell-content center"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-fixed clickable border-right" @click="openModal(group)">
                <div class="cell-content center font-bold">{{ group.TagIdx }}</div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-fixed clickable border-bold-right" @click="openModal(group)">
                <div class="cell-content tag-text" v-html="highlightText(group.TagNo)"></div>
              </td>

              <td class="cell-pub clickable" @click="openModal(group)"><div class="cell-content">{{ group.pubList[rowNum-1]?.EpId || '-' }}</div></td>
              <td class="cell-pub clickable" @click="openModal(group)"><div class="cell-content">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</div></td>
              <td class="cell-pub clickable" @click="openModal(group)">
                <div class="cell-content center">
                  <span v-if="group.pubList[rowNum-1]" :class="['badge', group.pubList[rowNum-1].Deleted ? 'red' : 'green']">{{ group.pubList[rowNum-1].Deleted }}</span>
                </div>
              </td>
              <td class="cell-wrk clickable" @click="openModal(group)"><div class="cell-content">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</div></td>
              <td class="cell-wrk clickable" @click="openModal(group)"><div class="cell-content">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</div></td>
              <td class="cell-wrk clickable" @click="openModal(group)">
                <div class="cell-content center">
                  <span v-if="group.wrkList[rowNum-1]" :class="['badge', group.wrkList[rowNum-1].Deleted ? 'red' : 'green']">{{ group.wrkList[rowNum-1].Deleted }}</span>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드 입력 필수');
      isLoading.value = true;
      const groupMap = new Map();
      try {
        const keywords = keyword.value.split(/[\s,\n]+/).filter(k => k.trim());
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key.trim() };
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ]);
          const pData = pubRes?.data || pubRes || [];
          const wData = wrkRes?.data || wrkRes || [];
          pData.forEach(i => {
            if(!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
            groupMap.get(i.TagIdx).pubList.push(i);
          });
          wData.forEach(i => {
            if(!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
            groupMap.get(i.TagIdx).wrkList.push(i);
          });
        }));
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => String(a.TagNo).localeCompare(b.TagNo));
      } finally { isLoading.value = false; }
    };

    const filteredList = computed(() => {
      if (!localSearchQuery.value) return mergedList.value;
      return mergedList.value.filter(g => String(g.TagNo).toLowerCase().includes(localSearchQuery.value.toLowerCase()));
    });

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem,
      fetchAndMergeData,
      highlightText: (t) => t, 
      openModal: (g) => { console.log(g); alert('상세 모달 오픈'); },
      toggleAllSelect: () => { /* 전체선택 로직 */ },
      isAllSelected: computed(() => false)
    }
  }
}
</script>

