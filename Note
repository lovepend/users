<template>
  <div class="panel panel-expandable m-0 p-0 h-100" style="display: flex; flex-direction: column;">
    <PageTitle icon="fa-search-plus" :title="'Tag 통합 분석 및 비교'">
      <template #actions>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <div class="input-group input-group-sm" style="width: 160px;">
            <span class="input-group-text bg-light">Proj</span>
            <input v-model="manualProjNo" class="form-control" placeholder="TE1002" />
          </div>
          <div class="input-group input-group-sm" style="width: 180px;">
            <span class="input-group-text bg-light">RegType</span>
            <input v-model="regTypeId" class="form-control" placeholder="101TEST" />
          </div>
          <div class="form-check form-check-inline m-0 ms-1">
            <input class="form-check-input" type="checkbox" v-model="containDeleted" id="chkDel" />
            <label class="form-check-label small" for="chkDel">삭제포함</label>
          </div>
          <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>
        </div>
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 flex-grow-1" style="height: calc(100vh - 180px); min-height: 400px; overflow: hidden;">
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
        :animateRows="true"
        :headerHeight="40"
        :rowHeight="32"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, shallowRef } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import { axiosWrapper } from '@/utils/axios/axios-wrapper';
import { sAlert } from '@/utils/messages/alert-common';

// --- State ---
const manualProjNo = ref('TE1002');
const regTypeId = ref('101TEST');
const containDeleted = ref(true);

const gridApi = shallowRef(null);
const columnDefs = ref([]);
const rowData = ref([]);
const diffMap = ref(new Map());

const defaultColDef = {
  sortable: true,
  filter: true,
  resizable: true,
  minWidth: 130,
  floatingFilter: true
};

const onGridReady = (params) => {
  gridApi.value = params.api;
};

/**
 * 🕵️‍♂️ 데이터 자동 탐색 (응답 객체 내에서 PubData가 있는 지점을 찾음)
 */
const findTarget = (obj) => {
  if (!obj || typeof obj !== 'object') return null;
  if (obj.PubData && Array.isArray(obj.PubData)) return obj;
  for (const key in obj) {
    const found = findTarget(obj[key]);
    if (found) return found;
  }
  return null;
};

// --- Logic ---
const onSearch = async () => {
  try {
    if (gridApi.value) gridApi.value.showLoadingOverlay();

    const res = await axiosWrapper.post('/api/Data/GetPubWrkData', {
      ProjectNo: manualProjNo.value.trim(),
      REG_TYPE_ID: regTypeId.value.trim(),
      ContainDeleted: containDeleted.value
    });

    const target = findTarget(res);
    if (!target) {
      sAlert.Error('데이터 구조 분석 실패');
      if (gridApi.value) gridApi.value.hideOverlay();
      return;
    }

    const { PubData = [], WrkData = [], DiffData = [] } = target;

    // 1. 상태 및 차이점 매핑 (DiffData 기준)
    const statusMap = {};
    const newDiffMap = new Map();
    DiffData.forEach(d => {
      statusMap[d.TAG_IDX] = d.Status;
      if (d.Property) {
        d.Property.forEach(p => {
          if (p.PUB_VALUE !== p.WRK_VALUE) {
            newDiffMap.set(`${d.TAG_IDX}_${p.PROP_ID}`, true);
          }
        });
      }
    });
    diffMap.value = newDiffMap;

    // 2. 평면화 가공 (Source 정보 추가)
    const process = (list, type) => list.map(item => {
      const row = { 
        ...item, 
        _SOURCE: type, // 출처 필드
        _STATUS: statusMap[item.TAG_IDX] || '' // 상태 필드
      };
      if (item.ATTRIBUTES) {
        item.ATTRIBUTES.forEach(a => { row[a.ATT_ID] = a.VALUE; });
      }
      return row;
    });

    const merged = [...process(PubData, 'PUBLISH'), ...process(WrkData, 'WORKING')];

    // 3. 정렬 (같은 TAG_IDX끼리 묶기)
    merged.sort((a, b) => {
      if (a.TAG_IDX === b.TAG_IDX) return a._SOURCE === 'PUBLISH' ? -1 : 1;
      return String(a.TAG_IDX).localeCompare(String(b.TAG_IDX));
    });

    // 4. 컬럼 정의 생성
    const pinnedFields = ['_SOURCE', '_STATUS', 'TAG_NO', 'TAG_IDX'];
    const keys = new Set(pinnedFields);
    merged.forEach(r => Object.keys(r).forEach(k => {
      if (!['_id', 'ATTRIBUTES'].includes(k)) keys.add(k);
    }));

    const newCols = Array.from(keys).map(key => {
      let hName = key;
      if (key === '_SOURCE') hName = '데이터 출처';
      if (key === '_STATUS') hName = '상태(Diff)';

      return {
        field: key,
        headerName: hName,
        pinned: pinnedFields.includes(key) ? 'left' : null,
        cellStyle: (p) => {
          // 출처 컬럼 스타일
          if (key === '_SOURCE') {
            return p.value === 'PUBLISH' 
              ? { backgroundColor: '#e8f0fe', fontWeight: 'bold', color: '#1a73e8' } 
              : { backgroundColor: '#e6f4ea', fontWeight: 'bold', color: '#1e8e3e' };
          }
          // 차이점 강조 스타일
          if (diffMap.value.has(`${p.data.TAG_IDX}_${key}`)) {
            return { backgroundColor: '#fff9db', color: '#d94111', fontWeight: 'bold' };
          }
          return null;
        }
      };
    });

    // 5. 그리드 데이터 주입
    columnDefs.value = newCols;
    rowData.value = merged;

    if (gridApi.value) {
      gridApi.value.hideOverlay();
      gridApi.value.setGridOption('columnDefs', newCols);
      gridApi.value.setGridOption('rowData', merged);
    }
  } catch (err) {
    console.error(err);
    sAlert.Error('조회 실패');
  }
};
</script>

<style scoped>
/* AG-Grid 테마 깨짐 방지 */
.ag-theme-alpine {
  --ag-header-background-color: #f1f3f4;
  --ag-border-color: #dee2e6;
}

/* 상단 영역 고정 및 그리드 스크롤 확보 */
.panel-body {
  display: flex;
  flex-direction: column;
}
</style>
