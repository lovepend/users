<template>
  <div class="panel m-0 h-100">
    <div class="panel-heading p-0 border-bottom" style="background-color: var(--bg11)">
      <div class="h-30px align-content-center px-3">
        <span v-if="pageLabelRef" class="text-warning fw-600">
          {{ pageLabelRef }}
        </span>
      </div>
    </div>

    <span v-if="!isSetupAdmin" class="just-view">
      {{ $t('DataSettingNavBar_vue.justViewPermission') }}
    </span>
    <div v-else class="panel-heading m-0 p-0" style="background-color: var(--bg11)">
      <div class="w-100 h-100">
        <template v-if="mainOrgFocusDataRef?.PROJ_NO && mainOrgFocusDataRef.PROJ_NO === currentProjNo">
          <BasicToolBar v-bind="toolbarBindRef" v-on="toolbarEventsRef" />
        </template>
        <template v-else-if="mainOrgFocusDataRef?.PROJ_NO">
          <div class="h-30px align-content-center px-3">
            <span class="text-warning fw-600">OOTB Tag Type cannot be modified.</span>
          </div>
        </template>
      </div>
    </div>
    <div class="panel-body overflow-hidden m-0 p-0 h-100">
      <ag-grid-vue v-bind="gridBindRef" v-on="gridEvents" />
    </div>
  </div>
</template>
<script setup>
  // Library - Common
  import { ref, shallowRef, computed, onMounted, watch } from 'vue'
  import { useRoute } from 'vue-router'
  import { storeToRefs } from 'pinia'

  // Store
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppMenuStore } from '@/stores/app-menu'

  // Custom Component
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
  import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'
  import AgComboEditor from '@/components/aggrid/AgComboEditor.vue'

  // Helpers
  import { ApiCommon } from '@/utils/axios/api-common'
  import { dataUtil as DU } from '@/utils/functions/data-utility'
  import { sAlert } from '@/utils/messages/alert-common'
  import global from '@/constants/enums/global'
  import * as _ from 'lodash-es'

  const route = useRoute()
  const { isSetupAdmin } = storeToRefs(useAppPermissionStore())
  const { currentProjNo, currentEpId } = storeToRefs(useAppMenuStore())

  const _Emits = defineEmits(['show-overlay', 'hide-overlay', 'on-main-save-data', 'on-sub-refresh'])
  const _Props = defineProps({
    MAIN_FOCUS_DATA: { type: Object, required: false, default: () => ({}) },
    MAIN_ORG_FOCUS_DATA: { type: Object, required: false, default: () => ({}) },
    CLASS_LIST_IN_USE: { type: Array, required: false, default: () => [] },
  })

  const mainFocusDataRef = computed(() => _Props.MAIN_FOCUS_DATA)
  const mainOrgFocusDataRef = computed(() => _Props.MAIN_ORG_FOCUS_DATA)
  const inUseClsListRef = computed(() => _Props.CLASS_LIST_IN_USE)
  watch(mainOrgFocusDataRef, item => {
    // onInitialize()
    onRefresh()
  })

  const firstFocusIDRef = computed(() => {
    const [hashPath = '', hashQuery = ''] = (route.hash ?? '').split('?')
    const hashParam = new URLSearchParams(hashQuery)
    if (hashPath === '#linked') {
      return hashParam.get('att_id')
    }
    return null
  })
  const pageLabelRef = computed(() => {
    const { TYPE_ID: cName, DESC: cDesc } = mainFocusDataRef.value ?? {}
    const { TYPE_ID: oName, DESC: oDesc } = mainOrgFocusDataRef.value ?? {}
    if (!oName) {
      return ''
    }

    const txtCDesc = cDesc ?? ''
    const txtCName = cName ? ` ( ${cName} )` : ''
    const txtCLabel = !cDesc && !cName ? '' : `${txtCDesc}${txtCName}`
    const txtODesc = oDesc ?? ''
    const txtOName = oName ? ` ( ${oName} )` : ''
    const txtOLabel = !oDesc && !oName ? '' : `${txtODesc}${txtOName}`

    return oName && oName !== cName ? `${txtCLabel} <= ${txtOLabel}` : `${txtCLabel}`
  })
  const gridContextRef = computed(() => {
    const { TYPE_ID: tagTypeId } = mainOrgFocusDataRef.value ?? {}
    const txtKey = tagTypeId ? 'TYPE ID : ' : ''
    const txtVal = tagTypeId || ''
    return { customKey: txtKey, customValue: txtVal }
  })
  const onShowOverlay = config => _Emits('show-overlay', config)
  const onHideOverlay = () => _Emits('hide-overlay')
  const onShowLoading = () => gridRef.value?.setGridOption('loading', true)
  const onHideLoading = () => gridRef.value?.setGridOption('loading', false)

  // TOOLBAR BUTTON
  const isShowCreateBtn = shallowRef(isSetupAdmin.value)
  const isShowDeleteBtn = shallowRef(isSetupAdmin.value)
  const isDisabledDeleteBtn = shallowRef(true)
  const toolbarBindRef = computed(() => ({
    showCreate: isShowCreateBtn.value,
    showMultiCreate: isShowCreateBtn.value,
    showDelete: isShowDeleteBtn.value,
    isDisabledDeleteBtn: isDisabledDeleteBtn.value,
    createTooltip: 'After creating data, click the Save button.',
    deleteTooltip: 'It will be deleted immediately.',
  }))
  const toolbarEventsRef = computed(() => ({
    createData: onCreateRows,
    createMultiData: onCreateMultiRows,
    deleteData: onDeleteRows,
  }))

  // MODIFIED DATA
  const isEditedRef = ref(false)

  // FOCUS DATA
  const prevIndexRef = shallowRef(-1)
  const focusDataRef = ref(null)
  const focusDataOrgRef = computed(() => {
    const focusData = focusDataRef.value
    const rowId = focusData?._ROW_ID
    if (rowId) {
      const dataDict = gridDataOrgDictRef.value
      return dataDict?.[rowId]
    }
    return undefined
  })
  const focusAttDataRef = computed(() => attDictRef.value?.[focusDataRef.value?.ATT_ID])

  // SUB INFOS
  const isPreLoadedRef = shallowRef(false) // 필요 정보의 로드 완료 여부
  const isPreErrorRef = shallowRef(false) // 필요 정보 로드중 에러 여부
  const prePromiseRef = shallowRef() // 필요 정보 로드 Promise
  const attListRef = shallowRef([]) // Attribute 목록 ( REG_EXPS가 있는 ATTS )
  const attDictRef = shallowRef({}) // Attribute 전체 Dict.

  // GRID
  const gridKeyRef = shallowRef(0) // Grid Refresh용
  const gridRef = shallowRef()
  const gridDataRef = ref([])
  // 데이터 원본 확인용
  const gridDataOrgRef = shallowRef([])
  const gridDataOrgDictRef = shallowRef({}) // 데이터 원본 확인용 { _ROW_ID: data, ... }
  const gridDataRenderedRef = shallowRef(false)
  // prettier-ignore
  const gridColDefsRef = ref([
    {
      suppressHeaderMenuButton: true,
      minWidth: 30,
      maxWidth: 30,
      pinned: 'left',
      lockPinned: true,
      lockVisible: true,
      lockPosition: 'left',
      suppressMovable: true,
      resizable: false,
      sortable: false,
      editable: false,
      filter: false,
      rowDrag: (params) => {
        return (
          !params.node.group &&
          mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value
        )
      },
    },
    {
      suppressHeaderMenuButton: true,
      headerCheckboxSelectionFilteredOnly: true,
      minWidth: 30,
      maxWidth: 30,
      pinned: 'left',
      lockPinned: true,
      lockVisible: true,
      lockPosition: 'left',
      suppressMovable: true,
      resizable: false,
      sortable: false,
      editable: false,
      filter: 'agSetColumnFilter',
      filterValueGetter: params => params.node.selected,
      filterParams: {
        suppressSorting: true,
        refreshValuesOnOpen: true,
      },
      checkboxSelection: (params) => {
        return (
          !params.node.group &&
          mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value
        )
      },
      headerCheckboxSelection: (params) => mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value,
    },
    {
      field: 'SEQ',
      headerName: 'SEQ',
      cellDataType: 'number',
      minWidth: 55,
      maxWidth: 55,
      pinned: 'left',
      lockPinned: true,
      lockVisible: true,
      lockPosition: 'left',
      suppressMovable: true,
      resizable: false,
      editable: false,
      // valueParser: params => isNaN(params.newValue) ? 0 : Number(params.newValue),
      // cellEditor: 'agNumberCellEditor',
      // cellEditorParams: {
      //   min: 0,
      //   max: 10000,
      //   step: 1,
      // },
    },
    {
      field: 'ATT_ID',
      headerName: 'Attribute',
      pinned: 'left',
      lockPinned: true,
      lockVisible: true,
      lockPosition: 'left',
      minWidth: 90,
      width: 90,
      flex: 5,
      // headerClass: 'text-center',  // 헤더도 가운데 정렬 하려면 필요함
      tooltipValueGetter: params => params.valueFormatted || params.value,
      cellStyle: params => {
        const value = params.value;
        if (value) {
          const attInfo = attDictRef.value?.[value]
          if (!attInfo) {
            return {
              color: '#ff0000',
              textDecoration: 'line-through',
            }
          }
        }
      },
      cellRenderer: params => {
        const dataItem     = params.data;
        const displayValue = params.valueFormatted || params.value || '';
        const editableDef  = params.colDef?.editable;
        const editable     = (
          DU.isFunction(editableDef) ? editableDef(params) : editableDef
        );
        const queryParam = {};
        const projNo = dataItem?.PROJ_NO || currentProjNo.value;
        if (projNo) {
          queryParam.proj_no = projNo;
          if (currentEpId.value && projNo === currentProjNo.value) {
            queryParam.ep_id = currentEpId.value;
          }
          if (dataItem?.ATT_ID) {
            queryParam.att_id = dataItem.ATT_ID;
          }
        }
        return makeComboRender({
          value    : displayValue,
          editable : editable,
          linkUrl  : '/attribute-setup',
          linkParam: queryParam,
        });
      },
      singleClickEdit: false,
      cellEditorPopup: true,
      cellEditorPopupPosition: 'over',
      cellEditor: 'AgComboEditor', // 'agRichSelectCellEditor'
      cellEditorParams: (params) => {
        const grid = params.api
        const value = params.value
        const existsList = []
        grid.forEachNode(node => {
          if (node.data?.ATT_ID && node.data?.ATT_ID !== value) {
            existsList.push(node.data?.ATT_ID)
          }
        })

        let values = attListRef.value.filter(v => !existsList.includes(v.ATT_ID))
        // let values = attListRef.value;
        // const tagUseClsList = inUseClsListRef.value ?? [];
        // if (tagUseClsList.length) {
        //   // 사용되는 모든 Class의 ATT_ID를 포함
        //   const attUseSet = new Set(tagUseClsList.reduce((acc, cur) => {
        //     acc.push(...(cur?.LNK_ATT ?? []).map(({ATT_ID})=>ATT_ID).filter(v=>v))
        //     return acc;
        //   }, []))
        //   // 사용되는 모든 Class의 공통 ATT_ID
        //   // const [ minSets, ...othSets ] = tagUseClsList.map(v=>(v.LNK_ATT ?? []).map(({ATT_ID})=>ATT_ID).filter(v=>v)).map(v=>(new Set(v))).sort((n,p)=>n.size-p.size)
        //   // const attUseSet = Array.from(minSets).filter(v=>othSets.every(s=>s.has(v)))
        //   values = values.filter(({ATT_ID})=>attUseSet.has(ATT_ID))
        // }
        return {
          values            : values,
          searchType        : 'matchAny',
          highlightMatch    : true,
          valueListMaxHeight: 200,
          valueListMaxWidth : 200,
          // AgComboEditor Parameters
          placeholder         : 'Select Attribute', // Default = ''
          code                : 'ATT_ID',  // Default = 'code'
          label               : 'label', // Default = 'label'
          pushTags            : false,   // Default = false
          multiple            : false,   // Default = false
          multipleCheck       : false,   // Default = false
          treeSelect          : false,   // Default = false
          closeOnSelect       : false,   // Default = true
          deselectFromDropdown: false,   // Default = false
          returnOrigin        : false,   // Default = false
          applySelected       : true,    // Default = false
          // getOptionLabel      : (v) => (`${v.label} (${v.code})`),
        }
      },
    },
    {
      field: 'DESC',
      headerName: 'Description',
      minWidth: 120,
      flex: 4,
      editable: false,
      cellClass: 'agReadOnly',
      cellRenderer: params => {
        const dataItem = params.data;
        const attInfo = attDictRef.value?.[dataItem?.ATT_ID];
        return attInfo?.DESC ?? ''
      },
    },
    {
      field: 'CL_ID',
      headerName: 'Code',
      minWidth: 90,
      flex: 2,
      editable: false,
      cellClass: 'agReadOnly',
      cellRenderer: params => {
        const dataItem     = params.data;
        const editableDef  = params.colDef?.editable;
        const editable     = (
          DU.isFunction(editableDef) ? editableDef(params) : editableDef
        );
        const attInfo = attDictRef.value?.[dataItem?.ATT_ID];
        const clId = attInfo?.CL_ID;

        const queryParam = {};
        const projNo = dataItem?.PROJ_NO || currentProjNo.value;
        if (projNo) {
          queryParam.proj_no = projNo;
          if (currentEpId.value && projNo === currentProjNo.value) {
            queryParam.ep_id = currentEpId.value;
          }
          if (clId) {
            queryParam.cl_id = clId;
          }
        }
        return makeComboRender({
          value    : clId,
          editable : editable,
          linkUrl  : '/code-setup',
          linkParam: queryParam,
        });
      },
    },
    {
      field: 'DL_VAL',
      headerName: 'Separator',
      width: 60,
    },
    {
      field: 'IS_SEQ',
      headerName: 'Sequence',
      cellDataType: 'boolean', // Use Using valueParser
      width: 60,
      filter: 'agSetColumnFilter',
      cellStyle: { justifyItems: 'center' },
      valueParser: params => Boolean(params.newValue), // Use editable
      // cellEditor: 'agCheckboxCellEditor',
    },
    {
      field: 'START',
      headerName: 'Start',
      cellDataType: 'number',
      minWidth: 55,
      maxWidth: 55,
      resizable: false,
      headerTooltip: params => {
        return `${params.colDef.field}<br>Start Must be greater than 0 and less than 100`
      },
      valueParser: params => {
        const defaultValue = null; // NaN
        if (DU.isSafeJsNumber(params.newValue)) {
          const newValue = Number(params.newValue);
          const minVal = params.colDef.cellEditorParams?.min ?? null;
          const maxVal = params.colDef.cellEditorParams?.max ?? null;
          if (
            (minVal !== null && minVal > newValue) ||
            (maxVal !== null && maxVal < newValue)
          ) { return defaultValue; }
          return newValue;
        }
        return defaultValue;
      },
      // cellEditor: 'agNumberCellEditor',
      cellEditorParams: {
        min: 0,
        max: 100,
        step: 1,
      },
    },
    {
      field: 'LENGTH',
      headerName: 'Length',
      cellDataType: 'number',
      minWidth: 65,
      maxWidth: 65,
      resizable: false,
      headerTooltip: params => {
        return `${params.colDef.field}<br>Length Must be greater than 0 and less than 100`
      },
      valueParser: params => {
        const defaultValue = null; // NaN
        if (DU.isSafeJsNumber(params.newValue)) {
          const newValue = Number(params.newValue);
          const minVal = params.colDef.cellEditorParams?.min ?? null;
          const maxVal = params.colDef.cellEditorParams?.max ?? null;
          if (
            (minVal !== null && minVal > newValue) ||
            (maxVal !== null && maxVal < newValue)
          ) { return defaultValue; }
          return newValue;
        }
        return defaultValue;
      },
      // cellEditor: 'agNumberCellEditor',
      cellEditorParams: {
        min: 0,
        max: 100,
        step: 1,
      },
    },
    {
      field: 'REG_EXPS',
      headerName: 'Reg_Exps',
      minWidth: 150,
      flex: 5,
      tooltipValueGetter: params => {
        const value = params.value
        if (value) {
          let isInvalid = false
          try {
            new RegExp(value)
          } catch (e) {
            isInvalid = true
          }
          if (isInvalid) {
            return `"${value}" This format is a regular expression pattern that does not conform to the grammar.`
          }
        }
        return value;
      },
      cellStyle: params => {
        const value = params.value;
        if (value) {
          const dataItem = params.data;
          const attId = dataItem?.ATT_ID;
          const attInfo = attDictRef.value?.[attId]
          const orgVal = attInfo?.REG_EXPS
          if (attInfo && orgVal !== value) {
            const cellClass = (
              DU.isFunction(params.colDef.cellClass)
            ) ? params.colDef.cellClass(params) : params.colDef.cellClass
            if (!cellClass) {
              return {
                color: '#0000ee',
              }
            }
          }
        }
        return {
          color: '',
        }
      },
      cellRenderer: params => {
        const dataItem = params.data
        const value = params.value
        if (!dataItem || !value) { return }
        const editableDef  = params.colDef?.editable;
        const editable     = (
          DU.isFunction(editableDef) ? editableDef(params) : editableDef
        );
        if (editable) {
          const attId = dataItem.ATT_ID
          const attInfo = attDictRef.value?.[attId]
          const orgVal = attInfo?.REG_EXPS
          if (attInfo && (orgVal ?? '') !== (value ?? '')) {
            const wrap = document.createElement('div')
            const span = document.createElement('span')
            const btn  = document.createElement('button')
            const icon = document.createElement('i')
            span.textContent = value
            wrap.className = 'd-flex align-items-center w-100 h-100'
            span.className = 'flex-1 text-ellipsis'
            icon.className = 'fa fa-undo'
            btn.type = 'button'
            btn.className = 'btn btn-xs btn-outline-primary shadow-none p-0 w-20px h-20px'
            btn.onclick = () => {
              params.node.setDataValue(params.colDef.field, orgVal)
            }
            btn.append(icon);
            wrap.append(span, btn);
            return wrap
          }
        }
        return value;
      }
    },
  ])

  onMounted(() => {
    onPreInitialize()
  })

  const onPreInitialize = async function () {
    let preResolve
    isPreLoadedRef.value = false
    isPreErrorRef.value = false
    prePromiseRef.value = new Promise(r => (preResolve = r))
    const onFinally = function (SUCCESS) {
      isPreLoadedRef.value = true
      isPreErrorRef.value = SUCCESS !== true
      if (preResolve) {
        preResolve()
      }
      onHideOverlay()
    }

    onShowOverlay()
    const projNo = currentProjNo.value
    if (!projNo) {
      sAlert.Warning(`Project를  선택해주세요`)
      return onFinally(false)
    }

    try {
      await getAttributeList()
    } catch (error) {
      const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
      sAlert.Error(backMsg)
      return onFinally(false)
    }

    return onFinally(true)
  }

  const onRefresh = function () {
    gridKeyRef.value += 1
  }
  const onInitialize = async function () {
    const isPreLoaded = isPreLoadedRef.value
    const isPreError = isPreErrorRef.value
    const prePromise = prePromiseRef.value
    if (!isPreLoaded) {
      if (isPreError) {
        return
      }
      if (prePromise) {
        await prePromise
        if (isPreErrorRef.value) {
          return
        }
      }
    }

    const onFinally = function () {
      if (gridDataRenderedRef.value) {
        setTimeout(() => {
          setFocusData()
          gridRef.value?.refreshCells({ force: true, suppressFlash: true })
        }, 10)
      }
      gridDataRenderedRef.value = true

      onHideLoading()
      // onHideOverlay()
    }

    // onShowOverlay()
    onShowLoading()

    prevIndexRef.value = -1
    focusDataRef.value = null
    isEditedRef.value = false
    gridDataRef.value = []
    gridDataOrgRef.value = []
    gridDataOrgDictRef.value = {}

    const mainFocusData = mainFocusDataRef.value
    const mainOrgFocusData = mainOrgFocusDataRef.value
    if (!mainOrgFocusData || !mainFocusData) {
      return onFinally()
    }

    if (!mainFocusData.LNK_CODE) {
      mainFocusData.LNK_CODE = []
    }

    const { LNK_CODE: cLnkCode } = mainFocusData

    const cusValues = []
    const orgValues = []
    const orgValuesDict = {}
    const lnkCode = _.sortBy(cLnkCode, ['SEQ', 'ATT_ID']) // SEQ에 따른 컬럼 순서 적용
    lnkCode.forEach((item, index) => {
      const rowId = `VAL_${String(index).padStart(6, '0')}`
      orgValuesDict[rowId] = { ...item, _ROW_ID: rowId }
      orgValues.push(orgValuesDict[rowId])
      cusValues.push({ ...item, _ROW_ID: rowId })
    })
    gridDataRef.value = cusValues
    gridDataOrgRef.value = orgValues
    gridDataOrgDictRef.value = orgValuesDict

    return onFinally()
  }

  const getAttributeList = async function () {
    attDictRef.value = {}
    attListRef.value = []

    const projNo = currentProjNo.value
    if (!projNo) {
      sAlert.Warning(`Project를  선택해주세요`)
      return
    }

    const response = await ApiCommon.postAttributesGet({ ProjectNo: projNo })

    const basicDict = {}
    const basicList = []
    response?.forEach(v => {
      if (!v.DELETED && v.ATT_ID) {
        basicDict[v.ATT_ID] = {
          ATT_ID: v.ATT_ID,
          PROJ_NO: v.PROJ_NO,
          CL_ID: v.CL_ID,
          DESC: v.DESC,
          FORMAT: v.FORMAT,
          REG_EXPS: v.REG_EXPS,
          code: v.ATT_ID,
          label: `(${v.ATT_ID}) ${v.DESC ?? ''}`,
        }
        if (v.REG_EXPS) {
          basicList.push(basicDict[v.ATT_ID])
        }
      }
    })

    attDictRef.value = basicDict
    attListRef.value = basicList
  }

  const onCreateRows = function () {
    insertRows(1)
  }

  const onCreateMultiRows = function (rowCount) {
    insertRows(rowCount)
  }

  const insertRows = function (rowCount) {
    const mainOrgFocusData = mainOrgFocusDataRef.value
    if (!mainOrgFocusData) {
      sAlert.Warning('Select a row from the Tag Type list to add values.')
      return
    }

    const grid = gridRef.value
    grid.stopEditing()
    onShowLoading()

    let maxSeq = 0
    grid.forEachNode(node => {
      const seq = Number(node.data?.SEQ)
      if (!isNaN(seq) && seq > maxSeq) {
        maxSeq = seq
      }
    })

    const addRows = []
    for (let i = 0; i < rowCount; i++) {
      const newId = `NEW_VAL_${Math.random().toString(36).substring(2, 12)}`
      addRows.push({
        STATUS: 'A',
        ATT_ID: null,
        DL_VAL: '',
        IS_SEQ: false,
        LENGTH: null,
        REG_EXPS: '',
        SEQ: (maxSeq += 1),
        START: null,
        _ROW_ID: newId,
      })
    }
    if (addRows.length) {
      gridDataRef.value.push(...addRows)
      const lastIndex = grid.getDisplayedRowCount()
      const result = grid.applyTransaction({ add: addRows, addIndex: lastIndex })
      grid.refreshCells({ force: true, suppressFlash: true })
      grid.setNodesSelected({
        nodes: result.add,
        newValue: true,
      })
      grid.ensureIndexVisible(lastIndex, 'bottom')
      isEditedRef.value = true
    }
    onHideLoading()
  }

  const onDeleteRows = function () {
    const grid = gridRef.value
    const selectedRows = grid?.getSelectedRows()
    if (!selectedRows || !selectedRows.length) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }
    gridDataRef.value = gridDataRef.value.filter(({ _ROW_ID }) => {
      return !selectedRows.some(v => v._ROW_ID === _ROW_ID)
    })
    gridDataOrgRef.value = gridDataOrgRef.value.filter(({ _ROW_ID }) => {
      return !selectedRows.some(v => v._ROW_ID === _ROW_ID)
    })

    isEditedRef.value = true
    setFocusData()
  }

  const setFocusData = function () {
    const grid = gridRef.value
    const selections = grid?.getCellRanges()
    let rowIndex = -1
    let rowData = null
    if (selections && selections.length) {
      rowIndex = selections[0]?.startRow?.rowIndex ?? -1
      rowData = grid?.getDisplayedRowAtIndex(rowIndex)?.data
    }
    prevIndexRef.value = rowIndex
    focusDataRef.value = rowData
  }

  // GRID /////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////
  const onStopEditing = function () {
    gridRef.value?.stopEditing()
  }

  const makeComboRender = function (PARAMS) {
    const { value, editable, linkUrl, linkParam } = PARAMS ?? {}
    const wrap = document.createElement('div')
    const span = document.createElement('span')
    const icon = document.createElement('i')
    const link = document.createElement(linkUrl && !DU.isArray(linkParam) ? 'a' : 'span')
    wrap.className = 'd-flex align-items-center w-100 h-100'
    span.className = 'flex-1 text-ellipsis'
    icon.className = editable ? 'fa fa-xs fa-caret-down p-1 text-blue' : ''
    link.textContent = value
    if (linkUrl) {
      link.href = 'javascript:void(0)'
      if (DU.isArray(linkParam)) {
        link.textContent = ''
        linkParam.forEach(v => {
          const { value: subValue, ...subParam } = v
          const subLink = document.createElement('a')
          subLink.href = 'javascript:void(0)'
          subLink.textContent = subValue
          subLink.onclick = () => {
            const args = new URLSearchParams(subParam)
            window.open(`.${linkUrl}?${args.toString()}`, '_blank', '')
          }
          link.append(subLink, ', ')
        })
        if (link.lastChild.nodeType == Node.TEXT_NODE) {
          link.lastChild.remove()
        }
      } else {
        link.onclick = () => {
          const args = new URLSearchParams(linkParam)
          window.open(`.${linkUrl}?${args.toString()}`, '_blank', '')
        }
      }
    }
    span.append(link)
    wrap.append(span, icon)
    return wrap
  }

  const makeCellClass = function (params) {
    if (params.node.group) {
      return
    }
    const field = params.colDef?.field
    const value = params.value
    const rowIdField = '_ROW_ID'
    const orgData = gridDataOrgDictRef.value?.[params.data?.[rowIdField]]
    const orgValue = orgData?.[field]
    if (field) {
      if (orgData) {
        if (Array.isArray(orgValue)) {
          if (Array.isArray(value)) {
            if (orgValue.join(',') !== value.join(',')) {
              return 'hasWork'
            }
          } else {
            if (value) {
              return 'hasWork'
            } else {
              return 'hasWorkEmpty'
            }
          }
        } else {
          // Diff Value
          if (value != orgValue) {
            return !value ? 'hasWorkEmpty' : 'hasWork'
          }
        }
      } else {
        // New Rows
        return 'hasWorkEmpty'
      }
    }
    return
  }

  const onGetRowId = function (params) {
    return params.data?._ROW_ID
  }

  const onGridReady = function (params) {
    gridRef.value = params.api
    onInitialize()
  }

  const onFirstDataRendered = function (params) {
    const focusId = firstFocusIDRef.value
    if (focusId) {
      const grid = params.api
      grid.forEachNode(node => {
        if (node.data?.ATT_ID === focusId) {
          grid.setRowNodeExpanded(node, true, true, true)
          grid.ensureNodeVisible(node, 'middle')
          if (mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value) {
            node.setSelected(true)
          }
          prevIndexRef.value = node.rowIndex
          focusDataRef.value = node.data
        }
      })
    }
  }

  const onCellFocused = async function (params) {
    const grid = params.api
    const rowIndex = params.rowIndex
    const prevIndex = prevIndexRef.value
    if (prevIndex !== rowIndex) {
      prevIndexRef.value = rowIndex
      focusDataRef.value = grid.getDisplayedRowAtIndex(rowIndex)?.data
    }
  }

  const onRowSelected = function (params) {
    const selectedRows = params.api.getSelectedRows()
    isDisabledDeleteBtn.value = !selectedRows.length
  }

  const onRowDragEnd = function (params) {
    let i = 0
    const grid = params.api
    grid.forEachNode(node => {
      if (node.data) {
        node.data.SEQ = i += 1
      }
    })
    isEditedRef.value = true
    grid.refreshCells({ force: true, suppressFlash: true })
  }

  const onCellValueChanged = function (params) {
    const grid = params.api
    const node = params.node
    const dataItem = params.data
    const field = params.colDef.field
    const oldValue = params.oldValue
    const newValue = params.newValue
    const source = params.source

    const excludedFields = [''] // 제외할 필드 목록
    // 모든 필드에 대해 trim 적용
    if (dataItem) {
      Object.keys(dataItem).forEach(key => {
        if (DU.isString(dataItem[key]) && !excludedFields.includes(key)) {
          dataItem[key] = dataItem[key].trim()
        }
      })
    }

    if (field === 'ATT_ID') {
      let isDuplicate = false
      const compareVal = String(newValue ?? '')
        .trim()
        .toUpperCase()
      grid.forEachNode(n => {
        if (n.data && n.id !== node.id) {
          const baseVal = String(n.data[field] ?? '')
            .trim()
            .toUpperCase()
          if (baseVal === compareVal) {
            isDuplicate = true
          }
        }
      })
      if (isDuplicate) {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning('This is the use of duplicate names.')
        return
      }

      const attInfo = attDictRef.value?.[compareVal]
      if (attInfo) {
        node.setDataValue('REG_EXPS', attInfo.REG_EXPS)
      } else {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning(`"${newValue}" is Invalid Attribute.`)
        return
      }

      const focusData = focusDataRef.value
      if (focusData?._ROW_ID === dataItem._ROW_ID) {
        focusDataRef.value = { ...dataItem }
      }
    } else if (field === 'REG_EXPS') {
      let isInvalid = false
      try {
        new RegExp(newValue)
      } catch (e) {
        console.error(error)
        isInvalid = true
      }
      if (isInvalid) {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning(
          `"${newValue}" This format is a regular expression pattern that does not conform to the grammar.`
        )
        return
      }
    }

    isEditedRef.value = true
    if (!source) {
      return
    } // 코드에 의한 변경은 처리하지 않음

    if (field == 'IS_SEQ') {
      if (newValue == true) {
        grid.forEachNode(n => {
          if (n.data && n.id !== node.id) {
            n.setDataValue(field, false)
          }
        })
      }
    }

    node.setSelected(true)
    // makeComboRender생성을 위한 refresh
    grid.refreshCells({
      rowNodes: [node],
      columns: ['DESC', 'CL_ID'],
      force: true,
    })
  }

  // Keydown 단축키 Ctrl + S 저장 단축키
  const onKeyDown = event => {
    if (event.ctrlKey && event.key === 's') {
      event.preventDefault() //브라우저 기본 저장 동작 방지
      _Emits('on-main-save-data')
    }
  }

  const gridBindRef = ref({
    key: gridKeyRef,
    columnDefs: gridColDefsRef,
    rowData: gridDataRef,
    class: `ag-theme-custom w-100 h-100`,
    rowSelection: 'multiple',
    isRowSelectable: params => {
      return mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value
    },
    rowDragManaged: true,
    enableFillHandle: true,
    enableRangeSelection: true,
    suppressRowClickSelection: true,
    rowMultiSelectWithClick: true,
    suppressLastEmptyLineOnPaste: true,
    columnHoverHighlight: true,
    tooltipShowDelay: 0,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
    pagination: false,
    paginationPageSize: 100,
    paginationPageSizeSelector: [100, 500, 1000],
    context: gridContextRef,
    loadingOverlayComponent: AggridLoadingOverlay,
    loadingOverlayComponentParams: {
      loadingMessage: 'Loading...',
    },
    statusBar: {
      statusPanels: [
        { statusPanel: 'agTotalRowCountComponent' },
        { statusPanel: 'agFilteredRowCountComponent' },
        { statusPanel: 'agSelectedRowCountComponent' },
        {
          statusPanel: 'AgDetailStatusBar',
          statusPanelParams: { customStyle: { 'background-color': '#e4dbe9' } },
          align: 'left',
        },
      ],
    },
    defaultColDef: {
      // wrapHeaderText: true,
      // autoHeaderHeight: true,
      editable: params => mainOrgFocusDataRef.value?.PROJ_NO === currentProjNo.value,
      cellClass: makeCellClass,
      headerTooltip: params => params.colDef.field,
      tooltipComponent: class {
        elem = document.createElement('div')
        init(params) {
          let value = params.value
          if (params.location === 'header' && DU.isFunction(value)) {
            value = value(params)
          }
          this.elem.className = DU.isNullOrEmpty(value) ? '' : 'ag-tooltip'
          this.elem.innerHTML = value ?? ''
        }
        getGui() {
          return this.elem
        }
      },
      floatingFilter: true,
      filter: 'agMultiColumnFilter',
      filterParams: {
        filters: [
          {
            filter: 'agTextColumnFilter',
            filterParams: { buttons: ['reset'] },
          },
          {
            filter: 'agSetColumnFilter',
            filterParams: {
              buttons: ['reset'],
              valueFormatter: params => params.value,
              comparator: (a, b) => {
                const valA = parseInt(a)
                const valB = parseInt(b)
                if (valA === valB) return 0
                return valA > valB ? 1 : -1
              },
            },
          },
          {
            filter: 'AgCustomFilter',
            filterParams: { buttons: ['reset'] },
          },
        ],
      },
      filterValueGetter: params => params.data[params.colDef.field],
    },
    getRowId: onGetRowId,
  })

  const gridEvents = {
    firstDataRendered: onFirstDataRendered,
    cellValueChanged: onCellValueChanged,
    rowSelected: onRowSelected,
    cellFocused: onCellFocused,
    rowDragEnd: onRowDragEnd,
    gridReady: onGridReady,
    keydown: onKeyDown,
  }

  defineOptions({
    name: 'TagTypeLnkCode',
    components: { AgDetailStatusBar, AgCustomFilter, AgComboEditor },
  })
  defineExpose({
    IS_EDITED: isEditedRef,
    DATA_LIST: gridDataRef,
    FOCUS_ATT_DATA: focusAttDataRef,
    ON_REFRESH: onRefresh,
    ON_STOP_EDITING: onStopEditing,
  })
</script>

<style scoped lang="scss">
  .just-view {
    color: var(--txt03);
    background-color: var(--bg11);
    padding: 6px 8px 6px 8px;
    width: 100%;
    text-align: center;
    font-weight: 500;
  }
</style>
