<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-square-check"
      :title="'Tag 통합 분석 및 조회' + (currentProjNo ? ` [ ${currentProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-2 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-500">Keyword</span>
            <input
              type="text"
              placeholder="Input Keyword"
              class="form-control form-control-sm p-1"
              style="min-height: 1rem"
              v-model="searchKeywordRef"
              @keyup.enter="onSearch"
            />
          </label>
          <button class="btn btn-xs btn-primary" @click="onSearch">Search</button>
        </div>
        <div class="form-check form-switch m-0">
          <label class="form-check-label text-dark user-select-none cursor-pointer">
            <input class="form-check-input" type="checkbox" v-model="isWorkingRef" />
            <span :class="isWorkingRef ? 'text-warning fw-bold' : 'text-primary fw-bold'">
              {{ isWorkingLabel }} View
            </span>
          </label>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-heading p-0 m-0">
          <div class="w-100 h-100">
            <BasicToolBar
              @delete-data="deleteSelectedData"
              :showCreate="false"
              :showMultiCreate="false"
              :showDelete="isSetupAdmin"
              :isDisabledDeleteBtn="isDisabledDeleteBtn"
              :showSave="false"
            />
          </div>
        </div>
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue 
            v-bind="gridBindTagProps" 
            v-on="gridOnCommonProps('Tag')" 
          />
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, watch, shallowRef, onBeforeMount, computed } from 'vue'
  import { storeToRefs } from 'pinia'

  // Store & Library
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppMenuStore } from '@/stores/app-menu'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import * as _ from 'lodash-es'

  // AG Grid Components
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
  import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'

  // Custom Components
  import { sAlert } from '@/utils/messages/alert-common'
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'

  const appPermission = useAppPermissionStore()
  const { isSetupAdmin } = storeToRefs(appPermission)
  const { currentProjNo } = storeToRefs(useAppMenuStore())

  const gridApi_TagData = shallowRef()
  const searchKeywordRef = ref('')
  const isWorkingRef = ref(false)
  const isWorkingLabel = ref('Published')
  const tagDataListRef = ref([])
  const isDisabledDeleteBtn = ref(true)

  // 1. 토글 변경 시 자동 재조회 
  watch(isWorkingRef, newVal => {
    isWorkingLabel.value = newVal ? 'Working' : 'Published'
    if (gridApi_TagData.value) getData()
  })

  // 2. 프로젝트 변경 시 재조회 [cite: 13]
  watch(currentProjNo, () => {
    getData()
  })

  const onSearch = () => getData()

  const getData = async () => {
    if (!currentProjNo.value) {
      sAlert.Warning(`Project를 선택해주세요`)
      return
    }

    gridApi_TagData.value.setGridOption('loading', true)

    // 토글 상태에 따른 URL 분기 [cite: 32]
    const url = isWorkingRef.value ? `/api/Admin/Tool/GetWorkingData` : `/api/Admin/Tool/GetPublishedData`
    const sourceTag = isWorkingRef.value ? 'Working' : 'Published'

    try {
      const jsonData = await axiosWrapper.post(url, {
        ProjectNo: currentProjNo.value,
        Keyword: searchKeywordRef.value.trim(),
      })

      if (_.isEmpty(jsonData)) {
        tagDataListRef.value = []
      } else {
        // 데이터 매핑: 출처(Source) 정보 주입 [cite: 34]
        tagDataListRef.value = jsonData
          .filter(item => !item.DELETED)
          .map(item => ({
            ...item,
            Source: sourceTag // 그리드 뷰용 가상 칼럼 데이터
          }))
      }
    } catch (error) {
      sAlert.Warning('Data Load Failed: ' + error.message)
      tagDataListRef.value = []
    } finally {
      gridApi_TagData.value.setGridOption('loading', false)
    }
  }

  // AG Grid 설정 [cite: 27, 28, 29]
  const colDefs = ref([
    {
      headerName: 'Source',
      field: 'Source',
      minWidth: 110,
      maxWidth: 110,
      pinned: 'left',
      cellRenderer: params => {
        const color = params.value === 'Working' ? '#ffc107' : '#0d6efd'
        return `<span class="badge" style="background-color: ${color}; color: white; width: 80px;">${params.value}</span>`
      },
      filter: 'agSetColumnFilter'
    },
    { field: 'TagIdx', headerName: 'TagIdx', minWidth: 100, flex: 1 },
    { field: 'TagNo', headerName: 'TagNo', minWidth: 150, flex: 1 },
    { field: 'EpId', headerName: 'EpId', minWidth: 80 },
    { field: 'ClsId', headerName: 'ClsId', minWidth: 120 },
    { field: 'TagDesc', headerName: 'Description', minWidth: 250, flex: 2 },
    { 
      field: 'CHGE_DTM', 
      headerName: 'Update Date', 
      minWidth: 180,
      valueFormatter: params => params.value ? new Date(params.value).toLocaleString() : '-'
    }
  ])

  const gridBindTagProps = computed(() => ({
    columnDefs: colDefs.value,
    rowData: tagDataListRef.value,
    style: 'width: 100%; height: 100%',
    class: 'ag-theme-custom',
    rowSelection: 'multiple',
    pagination: true,
    paginationPageSize: 100,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: {
      sortable: true,
      filter: true,
      resizable: true,
      floatingFilter: true
    }
  }))

  const onGridReady = params => {
    gridApi_TagData.value = params.api
    if (currentProjNo.value) getData()
  }

  const gridOnCommonProps = () => ({
    gridReady: onGridReady,
    selectionChanged: () => {
      const selectedNodes = gridApi_TagData.value.getSelectedNodes()
      isDisabledDeleteBtn.value = selectedNodes.length === 0
    }
  })

  const deleteSelectedData = async () => {
    const selectedRows = gridApi_TagData.value.getSelectedRows()
    if (_.isEmpty(selectedRows)) return
    
    const confirm = await sAlert.Confirm('선택한 데이터를 삭제하시겠습니까?')
    if (confirm.isConfirmed) {
      // 삭제 로직 구현부
      sAlert.Success('삭제되었습니다.')
      getData()
    }
  }

  defineOptions({
    name: 'PubWrkDataSingleGrid',
    components: { AgDetailStatusBar, AgCustomFilter }
  })
</script>

<style scoped lang="scss">
  /* 배지 가독성을 위한 스타일 */
  ::v-deep(.badge) {
    display: inline-block;
    padding: 0.35em 0.65em;
    font-size: 0.75em;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    white-space: nowrap;
    vertical-align: baseline;
    border-radius: 0.25rem;
  }
</style>
