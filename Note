  /* AG Grid Row Pinning */
  .modal-body-dashboard .ag-floating-bottom {
    background-color: color-mix(in srgb, transparent, var(--ag-foreground-color) 15%);
    /* Top Border 색상 */
    overflow-y: hidden !important;
    /* 세로 스크롤 유무 */
  }

  .ag-floating-bottom-viewport {
    background-color: #ced4da;
    /* 세로 스크롤 영역 색상 */
  }

  .modal-body-dashboard .rag-pinned {
    background-color: #ced4da;
    /* Pinned Row 색상 */
  }

  .modal-body-dashboard .rag-pinned:hover {
    --ag-accent-color: #ced4da;
    /* Pinned Row Hover 색상 관련 */
    --ag-row-hover-color: color-mix(in srgb, transparent, var(--ag-accent-color) 12%);
    /* Pinned Row Hover 색상 관련 */
  }
</style>
