import GC from '@mescius/spread-sheets-designer'
import { ApiCommon } from '@/utils/axios/api-common'
import { useEmployees } from '@/stores/app-employees'
const { setEmployeeInfo } = useEmployees()

const _EditorType = 'ExcelListEditor'

// 엑셀 스타일 드롭다운 CSS (호버 및 스크롤바)
if (!document.getElementById('excel-list-style')) {
  const style = document.createElement('style');
  style.id = 'excel-list-style';
  style.innerHTML = `
    .excel-dropdown-item { padding: 4px 10px; cursor: pointer; font-size: 13px; color: black; background: white; }
    .excel-dropdown-item:hover { background-color: #0078d4 !important; color: white !important; }
    .excel-list-box { 
      border: 1px solid #808080; box-shadow: 2px 2px 3px rgba(0,0,0,0.2); 
      background: white; overflow-y: auto; z-index: 10000; 
    }
    .excel-list-box::-webkit-scrollbar { width: 14px; }
    .excel-list-box::-webkit-scrollbar-thumb { background: #cdcdcd; border: 3px solid white; border-radius: 7px; }
  `;
  document.head.appendChild(style);
}

function UserSelectCellType(FIELD, NAME_FIELD, DEPT_FIELD) {
  this.field = FIELD
  this.nameField = NAME_FIELD
  this.deptField = DEPT_FIELD
  this.searchTimer = null
  this.listbox = null
}

UserSelectCellType.prototype = new GC.Spread.Sheets.CellTypes.Base()

// 1. 평상시 화면: 사번을 숨기고 이름(부서)만 텍스트로 표시
UserSelectCellType.prototype.paint = function (ctx, value, x, y, w, h, style, options) {
  const sheet = options.sheet
  const data = sheet.getDataItem(options.row)
  const name = data?.[this.nameField] ?? ''
  const dept = data?.[this.deptField] ?? ''
  const text = name ? `${name}${dept ? `(${dept})` : ''}` : ''
  
  // 기본 텍스트 렌더링 (사번은 내부 value에만 존재)
  GC.Spread.Sheets.CellTypes.Base.prototype.paint.apply(this, [ctx, text, x, y, w, h, style, options])
}

// 2. 더블 클릭 시 에디터 생성: 엑셀 목록 상자 디자인
UserSelectCellType.prototype.createEditorElement = function (context) {
  const wrapper = document.createElement('div')
  wrapper.setAttribute('gcUIElement', 'gcEditingInput')
  wrapper.setAttribute('EditorType', _EditorType)
  wrapper.style.cssText = 'background: white; display: flex; border: 1px solid #217346; box-sizing: border-box;'

  // 입력창 (엑셀 편집창)
  const input = document.createElement('input')
  input.style.cssText = 'flex: 1; border: none; outline: none; padding: 0 4px; font-family: Calibri, sans-serif; font-size: 13px;'
  
  // 우측 엑셀 드롭다운 버튼 (사각형 안의 역삼각형)
  const btn = document.createElement('div')
  btn.style.cssText = `
    width: 18px; background-color: #f0f0f0; border-left: 1px solid #808080;
    display: flex; align-items: center; justify-content: center; cursor: default;
  `
  const arrow = document.createElement('div')
  arrow.style.cssText = 'width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid #333;'
  btn.appendChild(arrow)

  // 목록 컨테이너 (Body에 부착하여 잘림 방지)
  const listbox = document.createElement('div')
  listbox.className = 'excel-list-box'
  listbox.style.cssText = 'position: absolute; display: none; max-height: 160px; list-style: none;'
  document.body.appendChild(listbox)
  this.listbox = listbox

  let selectedEmpNo = ''

  // 입력 시 API 호출 및 리스트 표시
  input.addEventListener('input', (e) => {
    const keyword = e.target.value.trim()
    if (this.searchTimer) clearTimeout(this.searchTimer)

    if (keyword.length < 1) {
      listbox.style.display = 'none'
      return
    }

    this.searchTimer = setTimeout(async () => {
      const response = await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: keyword })
      listbox.innerHTML = ''

      if (response && response.length > 0) {
        const rect = wrapper.getBoundingClientRect()
        listbox.style.width = `${rect.width}px`
        listbox.style.top = `${rect.bottom + window.scrollY}px`
        listbox.style.left = `${rect.left + window.scrollX}px`
        listbox.style.display = 'block'

        response.forEach(item => {
          const div = document.createElement('div')
          div.className = 'excel-dropdown-item'
          div.innerText = `${item.EMP_NM}(${item.DEPT_NAME || ''})`
          
          div.onmousedown = (event) => {
            event.preventDefault()
            selectedEmpNo = item.EMP_NO
            input.value = item.EMP_NM
            setEmployeeInfo({ ...item, code: item.EMP_NO })
            listbox.style.display = 'none'
            
            // SpreadJS 편집 종료
            const sheet = GC.Spread.Sheets.findControl(wrapper.closest('.gc-spread-sheets')).getActiveSheet()
            sheet.endEdit()
          }
          listbox.appendChild(div)
        })
      } else {
        listbox.style.display = 'none'
      }
    }, 250)
  })

  wrapper.appendChild(input)
  wrapper.appendChild(btn)
  
  // 편집 완료 시 반환될 사번 값 저장
  wrapper.getFinalValue = () => selectedEmpNo || input.value
  return wrapper
}

UserSelectCellType.prototype.getEditorValue = function (editorContext) {
  return editorContext.getFinalValue()
}

UserSelectCellType.prototype.setEditorValue = function (editorContext, value) {
  const input = editorContext.querySelector('input')
  // 편집 시작 시 기존 내용을 지우거나, 이름 필드를 찾아서 세팅할 수 있으나 
  // 보통 입력 시 바로 검색되도록 빈 값을 권장합니다.
  input.value = '' 
}

UserSelectCellType.prototype.updateEditor = function (editorContext, cellStyle, cellRect) {
  if (editorContext) {
    return { width: cellRect.width, height: cellRect.height }
  }
}

UserSelectCellType.prototype.destroyEditorElement = function (editorContext) {
  if (this.listbox) {
    this.listbox.remove()
    this.listbox = null
  }
}

export default UserSelectCellType
