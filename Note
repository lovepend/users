<template>
  <div id="app" class="admin-tool">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 관리 시스템</h2>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field w-20">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field flex-grow">
            <label>API Fetch Keywords <span class="label-hint">(공백/줄바꿈 구분)</span></label>
            <textarea v-model="keyword" placeholder="TAG-01..." class="base-input multi-input"></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">
              <span v-if="!isLoading">데이터 호출</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
        
        <div class="local-search-bar">
          <div class="input-field flex-grow">
            <label>결과 내 필터링 & 하이라이트</label>
            <input v-model="localSearchQuery" type="text" placeholder="검색어 입력..." class="base-input highlight-input" />
          </div>
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="left-info">
          <span class="count-badge">병합 그룹: <b>{{ filteredList.length }}</b>건</span>
        </div>
        <div class="right-actions">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <main class="content-panel">
        <div class="table-wrapper">
          <table class="modern-table">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="w-chk"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
                <th rowspan="2">Idx</th>
                <th rowspan="2">Tag No</th>
                <th colspan="3" class="pub-header">Published (Master)</th>
                <th colspan="3" class="wrk-header">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th>EP ID</th><th>CLS</th><th>Stat</th>
                <th>EP ID</th><th>CLS</th><th>Stat</th>
              </tr>
            </thead>
            
            <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-body">
              <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum" class="data-row">
                
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="chk-cell">
                  <input type="checkbox" :value="group.TagIdx" v-model="selectedIds" />
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="group-cell" @click="openModal(group)">
                  {{ group.TagIdx }}
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="group-cell tag-no" @click="openModal(group)" v-html="highlightText(group.TagNo)">
                </td>

                <td class="pub-td" @click="openModal(group)">{{ group.pubList[rowNum-1]?.EpId || (rowNum <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td" @click="openModal(group)">{{ group.pubList[rowNum-1]?.ClsId || (rowNum <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td" @click="openModal(group)">
                  <span v-if="group.pubList[rowNum-1]" :class="['badge', group.pubList[rowNum-1].Deleted ? 'bg-red' : 'bg-green']">
                    {{ group.pubList[rowNum-1].Deleted ? 'D' : 'A' }}
                  </span>
                </td>

                <td class="wrk-td" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.EpId || (rowNum <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.ClsId || (rowNum <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td" @click="openModal(group)">
                  <span v-if="group.wrkList[rowNum-1]" :class="['badge', group.wrkList[rowNum-1].Deleted ? 'bg-red' : 'bg-green']">
                    {{ group.wrkList[rowNum-1].Deleted ? 'D' : 'A' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-card">
        <header class="modal-header">
          <h3>Tag Group Detail <small>#{{ selectedItem?.TagIdx }}</small></h3>
          <button @click="closeModal" class="close-btn">&times;</button>
        </header>
        <div class="modal-body">
          <div class="modal-grid-content">
            <div class="data-box">
              <h4 class="text-pub">Published ({{ selectedItem?.pubList.length }})</h4>
              <div class="json-list">
                <pre v-for="(p, i) in selectedItem?.pubList" :key="'p'+i">{{ p }}</pre>
              </div>
            </div>
            <div class="data-box">
              <h4 class="text-wrk">Working ({{ selectedItem?.wrkList.length }})</h4>
              <div class="json-list">
                <pre v-for="(w, i) in selectedItem?.wrkList" :key="'w'+i">{{ w }}</pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  name: 'TagManager',
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    // 데이터 호출 및 그룹화
    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k)
      const groupMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ])
          const pubData = Array.isArray(pubRes?.data || pubRes) ? (pubRes?.data || pubRes) : []
          const wrkData = Array.isArray(wrkRes?.data || wrkRes) ? (wrkRes?.data || wrkRes) : []

          pubData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          wrkData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        // 태그 번호 기준 오름차순 정렬 후 저장
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => a.TagNo.localeCompare(b.TagNo))
      } catch (e) { alert('데이터 로드 실패') }
      finally { isLoading.value = false }
    }

    // 결과 내 필터링
    const filteredList = computed(() => {
      if (!localSearchQuery.value.trim()) return mergedList.value
      const searchTerms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
      return mergedList.value.filter(g => searchTerms.some(t => g.TagNo.toLowerCase().includes(t)))
    })

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const regex = new RegExp(`(${localSearchQuery.value.split(/[\s,]+/).filter(t=>t).join('|')})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    const openModal = (group) => {
      selectedItem.value = group
      showModal.value = true
    }

    const closeModal = () => {
      showModal.value = false
      selectedItem.value = null
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading,
      selectedIds, showModal, selectedItem,
      fetchAndMergeData, highlightText, openModal, closeModal,
      toggleAllSelect: () => {
        if (selectedIds.value.length === filteredList.value.length) selectedIds.value = []
        else selectedIds.value = filteredList.value.map(g => g.TagIdx)
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('삭제하시겠습니까?') && console.log(selectedIds.value),
      downloadExcel: () => alert('엑셀 로직 연결')
    }
  }
}
</script>

