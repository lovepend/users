  font-weight: bold;
  font-size: 12px;
  color: #555;
}

.column-filter-input {
  padding: 4px 6px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 11px;
}

/* 정렬 스타일 */
