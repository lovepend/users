<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-search-plus" :title="'Tag 분석 및 비교'">
      <template #actions>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <input v-model="manualProjNo" class="form-control form-control-sm" style="width:100px" placeholder="ProjNo" />
          <input v-model="regTypeId" class="form-control form-control-sm" style="width:120px" placeholder="RegType" />
          <button class="btn btn-xs btn-primary" @click="onSearch">조회</button>
        </div>
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0" style="height: calc(100vh - 150px)">
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        :loadingOverlayComponent="loadingOverlayComponent"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, shallowRef } from 'vue';
import { axiosWrapper } from '@/utils/axios/axios-wrapper';
import { sAlert } from '@/utils/messages/alert-common';
import { AgGridVue } from 'ag-grid-vue3';

// 상태 관리
const manualProjNo = ref('TE1002');
const regTypeId = ref('101TEST');
const containDeleted = ref(true);

const gridApi = shallowRef(null);
const columnDefs = ref([]);
const rowData = ref([]);
const diffMap = ref(new Map());

const defaultColDef = {
  sortable: true,
  filter: true,
  resizable: true,
  minWidth: 100
};

const onGridReady = (params) => {
  gridApi.value = params.api;
};

// 🎨 차이점 강조 스타일
const getCellStyle = (p) => {
  const key = `${p.data.TAG_IDX}_${p.colDef.field}`;
  if (diffMap.value.has(key)) {
    return { backgroundColor: '#fff9db', color: '#d94111', fontWeight: 'bold' };
  }
  return null;
};

const onSearch = async () => {
  if (gridApi.value) gridApi.value.showLoadingOverlay();

  try {
    const res = await axiosWrapper.post('/api/Data/GetPubWrkData', {
      ProjectNo: manualProjNo.value,
      REG_TYPE_ID: regTypeId.value,
      ContainDeleted: containDeleted.value
    });

    const result = res.data || res;
    const { PubData = [], WrkData = [], DiffData = [] } = result;

    if (PubData.length === 0 && WrkData.length === 0) {
      sAlert.Info('조회된 데이터가 없습니다.');
      rowData.value = [];
      return;
    }

    // 1. 상태 및 차이점 맵 생성
    const newDiffMap = new Map();
    const statusMap = new Map();

    DiffData.forEach(d => {
      statusMap.set(d.TAG_IDX, d.Status);
      if (d.Property) {
        d.Property.forEach(p => {
          if (p.PUB_VALUE !== p.WRK_VALUE) {
            newDiffMap.set(`${d.TAG_IDX}_${p.PROP_ID}`, true);
          }
        });
      }
    });
    diffMap.value = newDiffMap;

    // 2. 데이터 평면화 (ATTRIBUTES -> Root)
    const transform = (list, type) => {
      return list.map(item => {
        const flat = { 
          ...item, 
          EditType: type, 
          Status: statusMap.get(item.TAG_IDX) || '' 
        };
        if (item.ATTRIBUTES) {
          item.ATTRIBUTES.forEach(attr => {
            flat[attr.ATT_ID] = attr.VALUE ?? ''; // null 방어
          });
        }
        delete flat.ATTRIBUTES;
        return flat;
      });
    };

    const merged = [...transform(PubData, 'Publish'), ...transform(WrkData, 'Working')];

    // 3. TAG_IDX 기준 정렬 (쌍으로 보이게)
    merged.sort((a, b) => {
      if (a.TAG_IDX === b.TAG_IDX) return a.EditType === 'Publish' ? -1 : 1;
      return String(a.TAG_IDX).localeCompare(String(b.TAG_IDX));
    });

    // 4. 컬럼 자동 생성
    const fixedFields = ['EditType', 'Status', 'TAG_NO', 'TAG_IDX', 'CLS_ID', 'DELETED'];
    const allKeys = new Set();
    merged.forEach(row => Object.keys(row).forEach(k => k !== '_id' && allKeys.add(k)));

    const newCols = Array.from(allKeys).sort((a, b) => {
      const aIdx = fixedFields.indexOf(a), bIdx = fixedFields.indexOf(b);
      if (aIdx > -1 && bIdx > -1) return aIdx - bIdx;
      if (aIdx > -1) return -1;
      if (bIdx > -1) return 1;
      return a.localeCompare(b);
    }).map(key => ({
      field: key,
      headerName: key,
      pinned: fixedFields.includes(key) ? 'left' : null,
      cellStyle: getCellStyle
    }));

    // 🔥 핵심: 그리드 API를 통해 데이터와 컬럼을 강제로 주입
    columnDefs.value = newCols;
    rowData.value = merged;
    
    if (gridApi.value) {
      gridApi.value.setGridOption('columnDefs', newCols);
      gridApi.value.setGridOption('rowData', merged);
      gridApi.value.hideOverlay();
    }

  } catch (e) {
    console.error(e);
    sAlert.Error('데이터 로드 실패');
  }
};
</script>
