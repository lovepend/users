              placeholder="항목 선택"
              @change="onFormSelectChange"
            />
          </div>
          <p class="tpl-field-demo__state">
            선택 id:
            <code class="tpl-code">{{ formDemo.selectId === '' ? '(없음)' : String(formDemo.selectId) }}</code>
          </p>
        </section>

        <section class="template__section" id="tpl-section-inputbox" aria-labelledby="section-inputbox-title">
          <h2 id="section-inputbox-title" class="template__section-title">InputBox</h2>
          <p class="template__section-desc">
            라벨 왼쪽, 입력 필드 오른쪽. <code class="tpl-code">icon</code>은 필드 안쪽 왼쪽에 표시됩니다. 값이 있으면
            오른쪽 ×로 지울 수 있습니다. <code class="tpl-code">update:value</code> ·
            <code class="tpl-code">input</code> · <code class="tpl-code">clear</code>.
          </p>
          <div class="tpl-check-demo tpl-field-demo">
            <InputBox
              id="tpl-in-keywords"
              label="검색어"
              v-model:value="formDemo.inputText"
              icon="fa-search"
              @input="onFormInputDemo"
              @clear="onFormInputClear"
            />
            <InputBox id="tpl-in-plain" label="메모" v-model:value="formDemo.inputMemo" />
          </div>
          <p class="tpl-field-demo__state">
            마지막 이벤트:
            <span class="tpl-check-demo__log">{{ formDemo.lastForm || '—' }}</span>
          </p>
        </section>

        <section class="template__section" id="tpl-section-switchbox" aria-labelledby="section-switchbox-title">
          <h2 id="section-switchbox-title" class="template__section-title">SwitchBox</h2>
          <p class="template__section-desc">
            라벨 왼쪽, 세그먼트 형 버튼 오른쪽.
            <code class="tpl-code">list</code>의 <code class="tpl-code">id</code>가
            <code class="tpl-code">value</code>와 일치하는 항목이 선택됩니다.
            <code class="tpl-code">update:value</code> · <code class="tpl-code">change</code>.
          </p>
          <div class="tpl-check-demo tpl-field-demo">
            <SwitchBox
              label="보기"
              :list="formDemo.switchList"
              v-model:value="formDemo.switchId"
              @change="onFormSwitchChange"
            />
            <SwitchBox
              label="비활성 포함"
              :list="formDemo.switchListDisabled"
              v-model:value="formDemo.switchId2"
              :disabled="false"
            />
          </div>
          <p class="tpl-field-demo__state">
            보기 id:
            <code class="tpl-code">{{ String(formDemo.switchId) }}</code> · 샘플2 id:
            <code class="tpl-code">{{ String(formDemo.switchId2) }}</code>
          </p>
        </section>

        <section class="template__section" id="tpl-section-toast" aria-labelledby="section-toast-title">
          <h2 id="section-toast-title" class="template__section-title">Toast</h2>
          <p class="template__section-desc">
            <code class="tpl-code">useToast()</code> 로 전역 토스트를 띄웁니다. 실제 표시는 루트의
            <code class="tpl-code">ToastContainer</code>가 담당합니다(앱에 마운트되어 있어야 합니다).
            <code class="tpl-code">okText</code> / <code class="tpl-code">cancelText</code>가 없으면 우측 하단, 있으면
            화면 중앙 모달입니다.
          </p>
          <div class="tpl-check-demo tpl-toast-demo">
            <div class="tpl-toast-demo__buttons" role="group" aria-label="토스트 유형 테스트">
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--ghost" @click="showTplToastDefault">
                기본
              </button>
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--ghost" @click="showTplToastSuccess">
                성공 · 3초
              </button>
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--ghost" @click="showTplToastFail">실패</button>
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--ghost" @click="showTplToastWarningCorner">
                주의 · 우하단 · 3.5초
              </button>
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--ghost" @click="showTplToastWarning">
                주의 · 모달
              </button>
              <button type="button" class="tpl-btn tpl-btn--sm tpl-btn--primary" @click="showTplToastConfirm">
                확인/취소
              </button>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { reactive, ref } from 'vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'
  import ButtonsComponent from '@/components/editors/button/ButtonsComponent.vue'
  import DefaultCard from '@/components/default/DefaultCard.vue'
  import CheckBox from '@/components/default/editors/CheckBox.vue'
  import SelectBox from '@/components/default/editors/SelectBox.vue'
  import InputBox from '@/components/default/editors/InputBox.vue'
  import SwitchBox from '@/components/default/editors/SwitchBox.vue'
  import { useToast } from '@/composables/useToast'

  const toast = useToast()

  const activeTab1 = ref('list')
  const activeTab2 = ref('a')

  const example1 = {
    title: {
      icon: 'fa-list',
      title: '재고 현황',
      subtitle: '창고별 집계 · 실시간 반영',
    },
    tabs: [
      { id: 'list', name: '목록', icon: 'fa-list' },
      { id: 'chart', name: '차트', icon: 'fa-pie-chart' },
      { id: 'pivot', name: '피벗', icon: 'fa-location-arrow' },
    ],
  }

  const example2 = {
    tabs: [
      { id: 'a', name: '탭 A' },
      { id: 'b', name: '탭 B' },
      { id: 'c', name: '탭 C' },
    ],
  }

  const example3 = {
    title: {
      title: '엑셀/그리드 영역',
      subtitle: 'contents 슬롯에 붙이면 됨',
    },
  }

  const miniRows = [
    { code: 'SKU-001', name: '부품 A', qty: 120, status: '정상' },
    { code: 'SKU-002', name: '부품 B', qty: 8, status: '부족' },
    { code: 'SKU-003', name: '부품 C', qty: 540, status: '정상' },
    { code: 'SKU-004', name: '부품 D', qty: 0, status: '품절' },
  ]

  const clickedButtonId = ref(null)
  const buttonData0 = ref([
    { id: 'test', text: '', color: 'var(--btn08)', align: 'right', icon: 'fa-plus' },
    {
      id: 'replace',
      text: 'Replace',
      color: 'var(--btn07)',
      align: 'right',
      icon: 'fa-arrows-rotate',
      children: [
        { id: 'fromWorking', text: 'From Working', color: 'var(--btn07)', icon: 'fa-pencil' },
        { id: 'fromPublish', text: 'From Publish', color: 'var(--btn07)', icon: 'fa-pencil' },
      ],
    },
    { id: 'refresh', text: 'Refresh', color: 'var(--btn05)', align: 'right', icon: 'fa-rotate-right' },
  ])
  const buttonData1 = ref([
    {
      id: 'replace',
      text: 'Replace',
      color: 'var(--btn07)',
      align: 'right',
      icon: 'fa-arrows-rotate',
      children: [
        { id: 'fromWorking', text: 'From Working', color: 'var(--btn07)', icon: 'fa-pencil' },
        { id: 'fromPublish', text: 'From Publish', color: 'var(--btn07)', icon: 'fa-pencil' },
      ],
    },
    { id: 'utility', text: 'Utility', color: 'var(--btn02)', align: 'right', icon: 'fa-wrench' },
    { id: 'adapter', text: 'Adapter', color: 'var(--btn02)', align: 'right', icon: 'fa-plug' },
    { id: 'refresh', text: 'Refresh', color: 'var(--btn05)', align: 'right', icon: 'fa-rotate-right' },
  ])
  const buttonData2 = ref([
    {
      id: 'new',
      text: 'New',
      color: 'var(--btn03)',
      align: 'left',
      icon: 'fa-plus',
      children: [
        { id: 'create', text: 'Create', color: 'var(--btn03)', icon: 'fa-plus' },
        { id: 'multi', text: 'Multi Create', color: 'var(--btn03)', icon: 'fa-plus', disabled: true },
        { id: 'copy', text: 'Copy', color: 'var(--btn03)', icon: 'fa-copy' },
      ],
    },
    { id: 'delete', text: 'Delete', color: 'var(--btn04)', align: 'left', icon: 'fa-minus' },
    { id: 'save', text: 'Save', color: 'var(--btn04)', align: 'left', icon: 'fa-check', disabled: true },
    { id: 'publish', text: 'Publish', color: 'var(--btn06)', align: 'left', icon: 'fa-flag' },
    { id: 'revision', text: 'Revision', color: 'var(--btn07)', align: 'left', icon: 'fa-clock-rotate-left' },
    {
      id: 'excel',
      text: 'Excel',
      color: 'var(--btn07)',
      align: 'left',
      icon: 'fa-file-excel',
      children: [
        { id: 'import', text: 'Import', color: 'var(--btn07)', icon: 'fa-file-import' },
        { id: 'export', text: 'Export', color: 'var(--btn07)', icon: 'fa-file-export' },
      ],
    },
    { id: 'utility', text: 'Utility', color: 'var(--btn02)', align: 'right', icon: 'fa-wrench' },
    { id: 'adapter', text: 'Adapter', color: 'var(--btn02)', align: 'right', icon: 'fa-plug' },
    { id: 'test', text: '', color: 'var(--btn08)', align: 'right', icon: 'fa-plus' },
    {
      id: 'replace',
      text: 'Replace',
      color: 'var(--btn07)',
      align: 'right',
      icon: 'fa-arrows-rotate',
      children: [
        { id: 'fromWorking', text: 'From Working', color: 'var(--btn07)', icon: 'fa-pencil' },
        { id: 'fromPublish', text: 'From Publish', color: 'var(--btn07)', icon: 'fa-pencil' },
      ],
    },
    { id: 'refresh', text: 'Refresh', color: 'var(--btn05)', align: 'right', icon: 'fa-rotate-right' },
  ])

  function colLabel(n) {
    return String.fromCharCode(64 + n)
  }

  function onTabChange(label, id) {
    // 데모용; 필요 시 로깅
    void label
    void id
  }

  const checkDemo = reactive({
    agree: true,
    news: false,
    conditional: true,
    showHidden: false,
    lastEvent: '',
  })

  function onCheckDemoChange(key, checked) {
    checkDemo.lastEvent = `${key} → ${checked ? '선택' : '해제'} (${new Date().toLocaleTimeString()})`
  }

  const formDemo = reactive({
    selectList: Array.from({ length: 20 }, (_, i) => ({
      id: `opt-${i + 1}`,
      label: `옵션 ${String(i + 1).padStart(2, '0')}`,
      disabled: i === 6,
    })),
    selectId: 'opt-3',
    inputText: '데모',
    inputMemo: '',
    switchList: [
      { id: 'day', label: '일' },
      { id: 'week', label: '주' },
      { id: 'month', label: '월' },
    ],
    switchListDisabled: [
      { id: 'a', label: 'A' },
      { id: 'b', label: 'B', disabled: true },
      { id: 'c', label: 'C' },
    ],
    switchId: 'week',
    switchId2: 'a',
    lastForm: '',
  })

  function onFormSelectChange(v) {
    formDemo.lastForm = `SelectBox change: ${String(v)}`
  }

  function onFormInputDemo(v) {
    formDemo.lastForm = `InputBox input: ${v}`
  }

  function onFormInputClear() {
    formDemo.lastForm = 'InputBox clear'
  }

  function onFormSwitchChange(v) {
    formDemo.lastForm = `SwitchBox change: ${String(v)}`
  }

  const handleButtonClick = (e, buttonId) => {
    clickedButtonId.value = buttonId
    console.log(`버튼 클릭: ${buttonId}`)
  }

  function showTplToastDefault() {
    toast.show({
      title: '기본 알림',
      content: 'Toast 기본 타입입니다. 제목·내용·코드를 표시할 수 있습니다.',
      code: 'TOAST_001',
    })
  }

  function showTplToastSuccess() {
    toast.success({
      title: '저장 완료',
      content: '변경 사항이 정상적으로 저장되었습니다.',
      duration: 3000,
    })
  }

  function showTplToastFail() {
    toast.fail({
      title: '요청 실패',
      content: '서버와 통신 중 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.',
      code: 'ERR_500',
    })
  }

  function showTplToastWarningCorner() {
    toast.warning({
      title: '주의 알림',
      content: '확인 버튼 없이 우측 하단에만 표시되는 warning 타입입니다. 잠시 후 자동으로 닫힙니다.',
      duration: 3500,
    })
  }

  function showTplToastWarning() {
    toast.warning({
      title: '입력 확인',
      content: '필수 항목을 모두 입력해 주세요.',
      okText: '확인',
      onOk: () => {
        toast.success({
          title: '확인됨',
          content: '확인 버튼을 눌렀습니다.',
          duration: 2000,
        })
      },
    })
  }

  function showTplToastConfirm() {
    toast.show({
      title: '삭제 확인',
      content: '선택한 항목을 삭제할까요? 이 작업은 되돌릴 수 없습니다.',
      code: 'CONFIRM_DELETE',
      okText: '삭제',
      cancelText: '취소',
      onOk: () => {
        toast.fail({
          title: '삭제됨',
          content: '삭제 처리되었습니다.',
          duration: 2000,
        })
      },
      onCancel: () => {
        toast.show({
          title: '취소됨',
          content: '삭제를 취소했습니다.',
          duration: 2000,
        })
      },
    })
  }
</script>

