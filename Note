{
      field: 'TOTAL',
      headerName: 'DATA QTY TOTAL',
      minWidth: 80,
      flex: 1,
      aggFunc: 'sum',
      // 👇 천 단위 콤마
      valueFormatter: params => params.value == null ? '' : Number(params.value).toLocaleString(),
      // 👇 우측 정렬 및 Pinned Row 스타일 적용
      cellStyle: params => {
        const style = { textAlign: 'right' } // 기본적으로 우측 정렬
        
        if (params.node.rowPinned) {
          style.fontWeight = 'bold'
          style.border = 'none'
        }
        return style
      },
    },
    {
      field: 'EXIST',
      headerName: 'DATA EXIST',
