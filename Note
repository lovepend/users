    {
      field: 'VALUE',
      headerName: 'VALUE',
      minWidth: 160,
      flex: 2,
      editable: true,
      cellDataType: 'object',
      valueParser: params => {
        const { newValue } = params
        return newValue ? newValue.split(',') : null
      },
      valueFormatter: params => {
        const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'

        if (isPbsField) {
          if (!params.value || (typeof params.value === 'string' && params.value.trim() === '')) {
            return ''
          }

          let tagIdxsToConvert = []
          if (typeof params.value === 'string') {
            tagIdxsToConvert = params.value.split(',').map(item => item.trim())
          } else if (Array.isArray(params.value)) {
            tagIdxsToConvert = params.value.map(item => String(item).trim())
          } else {
            tagIdxsToConvert = [String(params.value).trim()]
          }

          const transformedCodes = tagIdxsToConvert
            .map(tagIdx => {
              const code = getCodeByTagIdx(tagIdx)
              return code
            })
            .filter(code => code !== undefined && code !== null)

          const finalDisplayValue = transformedCodes.join(', ')
          return finalDisplayValue
        }

        return Array.isArray(params.value) ? params.value.join(', ') : params.value
      },
      cellEditorSelector: params => {
        const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE
        // 'BOOL' 타입은 여기에서 에디터 반환 X(렌더러가 직접 처리)
        if (val_type === 'BOOL') {
          return undefined
        }

        const clIdExists = !!params.data.CL_ID
        const operatorIsIN = params.data.OPER === 'IN'
        const isEpField = params.data.ATT_ID === 'EP_IC' || params.data.ATT_ID === 'EP_ID'
        const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'

        let editorSourceData = []
        if (isPbsField) {
          if (params.data.ATT_ID === 'ASSEMBLY_NAME') {
            editorSourceData = Object.values(assemblyPbsComboData.value).map(item => item.display) // CODE 값을 에디터에 표시
          } else if (params.data.ATT_ID === 'SYSTEM_NAME') {
            editorSourceData = Object.values(systemPbsComboData.value).map(item => item.display) // CODE 값을 에디터에 표시
          }
        } else if (isEpField) {
          // EP_IC 또는 EP_ID이면 epOfProjectCombo.value 사용
          editorSourceData = epOfProjectCombo.value
        } else if (clIdExists) {
          // 그 외 CL_ID가 존재하면 기존의 getValueFromCode 사용
          editorSourceData = getValueFromCode(params.data.CL_ID)
        } else {
          // CL_ID도 없고 EP 필드도 아니면 에디터 소스 데이터 X
          editorSourceData = []
        }

        // 에디터 컴포넌트 결정
        if ((isEpField || clIdExists || isPbsField) && operatorIsIN) {
          // PBS 필드 조건 추가
          // PvMapAttEditor (CODE, CODE_NM, EP_ID를 그대로 listData에 전달)
          let pvMapListData = []
          if (isPbsField) {
            pvMapListData = Object.values(
              params.data.ATT_ID === 'ASSEMBLY_NAME' ? assemblyPbsComboData.value : systemPbsComboData.value
            ).map(item => item.display) // CODE 값을 PvMapAttEditor에 전달
          } else if (isEpField) {
            pvMapListData = epOfProjectCombo.value // EP_ID 자체를 전달
          } else if (clIdExists) {
            pvMapListData = getValueFromCode(params.data.CL_ID)
          }

          // PvMapAttEditor로 전달될 초기 값 (initialValue)을 TAG_IDX가 아닌 CODE 값으로 변환.
          let initialPvMapValue = null
          if (params.value) {
            // params.value에는 TAG_IDX(들)이 콤마로 구분된 문자열로 들어 있음
            const tagIdxs = String(params.value)
              .split(',')
              .map(s => s.trim())
            const codes = tagIdxs.map(tagIdx => getCodeByTagIdx(tagIdx)).filter(c => c !== undefined && c !== null)
            initialPvMapValue = codes.join(', ') // CODE 값을 콤마로 구분된 문자열로 PvMapAttEditor에 전달
          }

          return {
            component: 'PvMapAttEditor',
            params: {
              listData: pvMapListData, // 실제 표시할 CODE/EP_ID/CODE_NM 값들을 전달
              isMultiple: true,
              isPushNew: true,
              placeholder: 'Select VALUE',
              value: initialPvMapValue,
            },
          }
        } else if (isEpField || clIdExists || isPbsField) {
          // PBS 필드 조건 추가 (IN이 아닌 경우)
          // agRichSelectCellEditor (formatValue 추가)
          return {
            component: 'agRichSelectCellEditor',
            params: {
              values: editorSourceData, // 이 배열에는 CODE/EP_ID/CODE_NM 값들이 들어있음 (표시값)
              valueListGap: 5,
              allowTyping: true,
              filterList: true,
              highlightMatch: true,
              valueListMaxHeight: 220,
              // agRichSelectCellEditor에 'formatValue'를 추가하여 실제 셀 값(TAG_IDX/EP_ID/CODE_ID)을 CODE/EP_ID/CODE_NM으로 변환하여 에디터 필드에 표시
              formatValue: value => {
                // value는 셀의 실제 저장된 값 (TAG_IDX, EP_ID, CODE_ID)
                if (isPbsField) {
                  return getCodeByTagIdx(value) || value
                }
                return value
              },
            },
          }
        } else {
          // 모든 조건에 해당하지 않을 경우 agTextCellEditor
          return {
            component: 'agTextCellEditor',
          }
        }
      },
      valueSetter: params => {
        const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE
        if (val_type === 'BOOL') {
          params.data.VALUE = params.newValue
          return true
        }

        const { newValue, data } = params
        const isPbsField = data.ATT_ID === 'ASSEMBLY_NAME' || data.ATT_ID === 'SYSTEM_NAME'
        // console.log('valueSetter newValue', newValue)
        let valueToStore = newValue // isPbsField가 아닐 경우, newValue를 그대로 저장

        if (isPbsField) {
          let codesToConvert = []

          // newValue가 문자열이고 내용이 있는 경우, 콤마로 분리하여 CODE 배열 생성
          if (typeof newValue === 'string' && newValue.trim() !== '') {
            codesToConvert = newValue.split(',').map(item => item.trim())
          } else if (Array.isArray(newValue)) {
            // CODE 배열로 넘어오는 경우
            codesToConvert = newValue.map(item => String(item).trim())
          } else if (newValue === null || newValue === undefined) {
            // 값이 없는 경우
            codesToConvert = []
          }

          if (codesToConvert.length > 0) {
            const targetComboData =
              data.ATT_ID === 'ASSEMBLY_NAME' ? assemblyPbsComboData.value : systemPbsComboData.value

            // 각 CODE를 TAG_IDX로 변환
            const tagIdxArray = codesToConvert.map(code => {
              const found = Object.values(targetComboData).find(item => item.display === code)
              return found ? found.value : code // 찾으면 TAG_IDX, 못 찾으면 원본 CODE
            })

            // 변환된 TAG_IDX 배열을 콤마로 구분된 문자열로 합쳐서 저장
            valueToStore = tagIdxArray.join(',')
          } else {
            // 선택된 값이 없거나 비어있는 경우, 빈 문자열로 저장하여 null이나 undefined 방지
            valueToStore = ''
          }
        }
        // isPbsField가 아닌 경우는 valueToStore가 초기값 newValue를 그대로 유지

        if (typeof valueToStore === 'string') {
          valueToStore = valueToStore
            .split(',')
            .map(s => s.trim())
            .filter(s => s.length > 0) // 빈 토큰 제거
            .join(',')
        }
        data.VALUE = valueToStore // 최종 변환된 값 또는 원본 newValue를 data.VALUE에 저장
        return true // 변경 적용
      },
      cellRenderer: params => {
        // valueFormatter가 이미 적절하게 값을 포맷팅했으므로, makeComboRender가 params.valueFormatted를 사용하도록 임시 변수를 전달.
        const isEpField = params.data.ATT_ID === 'EP_IC' || params.data.ATT_ID === 'EP_ID'
        const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'
        const isCodeListField = params.data.CL_ID

        // PbsField인 경우, valueFormatter가 이미 CODE 문자열로 만들어주었으므로,
        // makeComboRender가 params.value 대신 params.valueFormatted를 사용
        if (isPbsField || isEpField || isCodeListField) {
          // makeComboRender는 params.value를 직접 사용하므로, valueFormatted를 전달하기 위한 꼼수
          const tempParams = {
            ...params,
            value: params.valueFormatted, // makeComboRender가alueFormatted참조
          }
          return makeComboRender(tempParams)
        } else {
          // PBS, EP, CL_ID가 없는 경우, 기본 값 렌더링
          return params.value ? `<div>${params.value}</div>` : undefined
        }
      },
      cellRendererSelector: params => {
        const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE

        // VAL_TYPE이 'BOOL'인 경우 agCheckboxCellRenderer 적용
        if (val_type === 'BOOL') {
          return {
            component: 'agCheckboxCellRenderer',
            // agCheckboxCellRenderer는 별도의 params 없이 boolean 값을 직접 렌더링하고 토글
          }
        }
      },
      // cellRenderer: params => {
      //   return params.data.CL_ID ? makeComboRender(params) : params.value ? `<div>${params.value}</div>` : undefined
      // },
      singleClickEdit: true, // 단일 클릭으로 편집 가능
      // cellEditorPopup: true, // 팝업으로 편집기 표시
      // cellEditorPopupPosition: 'over' // 팝업 위치 설정
    },
