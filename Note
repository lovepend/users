<template>
  <div class="app-wrapper">
    <header class="fixed-top-bar">
      <div class="header-inner">
        <h2 class="main-title">에러 코드</h2>
        <div class="global-search-wrapper">
          <input 
            type="text" 
            v-model="globalSearch" 
            placeholder="전체 컬럼 내용 검색..." 
            class="global-search-input"
          />
        </div>
      </div>
    </header>

    <div class="scroll-body">
      <div class="table-card">
        <table class="error-table">
          <colgroup>
            <col style="width: 60px;">
            <col style="width: 150px;">
            <col style="width: 130px;">
            <col style="width: 25%;">
            <col style="width: 25%;">
            <col style="width: 25%;">
          </colgroup>
          <thead>
            <tr>
              <th v-for="col in columns" :key="col" class="sticky-header">
                <div class="th-content">
                  <span class="label">{{ col }}</span>
                  
                  <div v-if="col === '기능'" class="filter-group">
                    <input 
                      type="text" 
                      v-model="columnFilters[col]" 
                      class="filter-input"
                      placeholder="필터"
                    />
                    <div class="dropdown-container">
                      <button @click.stop="toggleFuncList" class="combo-btn">▼</button>
                      <ul v-if="showFuncList" class="combo-list">
                        <li @click="selectFunc('')">전체보기</li>
                        <li v-for="item in uniqueFuncs" :key="item" @click="selectFunc(item)">
                          {{ item }}
                        </li>
                      </ul>
                    </div>
                  </div>

                  <input 
                    v-else
                    type="text" 
                    v-model="columnFilters[col]" 
                    class="filter-input"
                    placeholder="필터"
                  />
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr v-if="filteredData.length === 0">
              <td :colspan="columns.length" class="empty-msg">데이터를 찾을 수 없습니다.</td>
            </tr>
            <tr v-for="(row, idx) in filteredData" :key="idx">
              <td v-for="col in columns" :key="col" :class="['data-cell', `col-${col}`]">
                <div v-html="highlightText(row[col])"></div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue';
import * as XLSX from 'xlsx';

// src/assets/Errorcode.xlsx 파일을 읽어옵니다.
import excelFileUrl from '@/assets/Errorcode.xlsx?url';

// --- 상태 관리 ---
const rawData = ref([]);
const columns = ['No', '기능', 'Code', 'Message', '원인', '해결방법'];
const globalSearch = ref('');
const columnFilters = ref({ No: '', 기능: '', Code: '', Message: '', 원인: '', 해결방법: '' });

const showFuncList = ref(false);
const uniqueFuncs = ref([]);

// --- 엑셀 데이터 로드 ---
const loadExcelData = async () => {
  try {
    const response = await fetch(excelFileUrl);
    const arrayBuffer = await response.arrayBuffer();
    const workbook = XLSX.read(arrayBuffer, { type: 'array' });
    const jsonData = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]]);
    
    rawData.value = jsonData;

    // '기능' 컬럼에서 중복 제거된 목록 추출
    const funcs = [...new Set(jsonData.map(item => item['기능']))].filter(Boolean);
    uniqueFuncs.value = funcs.sort();
  } catch (error) {
    console.error('엑셀 로드 에러:', error);
  }
};

// --- 기능 필터 콤보박스 로직 ---
const toggleFuncList = () => {
  showFuncList.value = !showFuncList.value;
};

const selectFunc = (val) => {
  columnFilters.value['기능'] = val;
  showFuncList.value = false;
};

const closeDropdown = () => {
  showFuncList.value = false;
};

// --- 필터링 로직 ---
const filteredData = computed(() => {
  return rawData.value.filter(row => {
    // 컬럼별 필터
    const isColumnMatch = columns.every(col => {
      const fv = columnFilters.value[col]?.toLowerCase().trim();
      return !fv || String(row[col] || '').toLowerCase().includes(fv);
    });
    // 전체 검색
    const sk = globalSearch.value.toLowerCase().trim();
    const isGlobalMatch = !sk || columns.some(col => 
      String(row[col] || '').toLowerCase().includes(sk)
    );
    return isColumnMatch && isGlobalMatch;
  });
});

// --- 검색어 하이라이트 ---
const highlightText = (text) => {
  const strText = String(text || '');
  const keyword = globalSearch.value.trim();
  if (!keyword) return strText;
  const regex = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return strText.replace(regex, '<mark class="hl">$1</mark>');
};

// --- 생명주기 ---
onMounted(() => {
  loadExcelData();
  window.addEventListener('click', closeDropdown);
});

onUnmounted(() => {
  window.removeEventListener('click', closeDropdown);
});
</script>

