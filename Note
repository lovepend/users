<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="header-container">
          <div class="header-top">
            <h2 class="main-title">Tag Manager <span class="sub-title">v2.5 Group Focus</span></h2>
          </div>
          <div class="search-grid">
            <div class="project-box">
              <div class="input-group">
                <label>Project No</label>
                <input v-model="projectNo" type="text" placeholder="P0001" class="base-input unified-height" />
              </div>
              <div class="filter-wrapper">
                <label class="sub-label">결과 내 필터</label>
                <input v-model="localSearchQuery" type="text" placeholder="Tag No 검색..." class="filter-input unified-height" />
              </div>
            </div>
            <div class="keyword-box">
              <label>API Fetch Keywords</label>
              <textarea v-model="keyword" placeholder="Enter keywords (Space/Line separated)..." class="base-input"></textarea>
            </div>
            <div class="button-box">
              <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-modern">
                <span v-if="!isLoading">조회하기</span>
                <span v-else class="spinner"></span>
              </button>
            </div>
          </div>
        </div>
      </header>

      <div class="action-bar-wrapper" v-if="mergedList.length > 0">
        <div class="action-bar">
          <div class="stats">조회된 그룹: <b>{{ filteredList.length }}</b>건 (선택: {{ selectedIds.length }})</div>
          <div class="right-buttons">
            <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
            <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
          </div>
        </div>
      </div>

      <div class="table-card-wrapper">
        <div class="table-container">
          <table class="modern-table auto-layout">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="sticky-header sticky-col col-chk">
                  <div class="center-vh"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div>
                </th>
                <th rowspan="2" class="sticky-header sticky-col col-idx">Idx</th>
                <th rowspan="2" class="sticky-header sticky-col col-tag">Tag No</th>
                <th colspan="3" class="header-group pub-group h-40">Published (Master)</th>
                <th colspan="3" class="header-group wrk-group h-40">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th class="h-40">EP ID</th><th class="h-40">CLS</th><th class="h-40">Deleted</th>
                <th class="h-40">EP ID</th><th class="h-40">CLS</th><th class="h-40">Deleted</th>
              </tr>
            </thead>
            
            <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-row-segment">
              <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum" class="data-row">
                
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-fixed">
                  <div class="cell-content center-vh"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-fixed clickable" @click="openModal(group)">
                  <div class="cell-content center-vh font-bold text-gray auto-width">{{ group.TagIdx }}</div>
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-fixed clickable" @click="openModal(group)">
                  <div class="cell-content tag-text auto-width" v-html="highlightText(group.TagNo)"></div>
                </td>

                <td class="cell-pub clickable" @click="openModal(group)"><div class="cell-content">{{ group.pubList[rowNum-1]?.EpId || '-' }}</div></td>
                <td class="cell-pub clickable" @click="openModal(group)"><div class="cell-content">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</div></td>
                <td class="cell-pub clickable" @click="openModal(group)">
                  <div class="cell-content center-vh">
                    <span v-if="group.pubList[rowNum-1]" :class="['badge-modern', group.pubList[rowNum-1].Deleted ? 'is-true' : 'is-false']">{{ group.pubList[rowNum-1].Deleted }}</span>
                    <span v-else>-</span>
                  </div>
                </td>
                <td class="cell-wrk clickable" @click="openModal(group)"><div class="cell-content">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</div></td>
                <td class="cell-wrk clickable" @click="openModal(group)"><div class="cell-content">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</div></td>
                <td class="cell-wrk clickable" @click="openModal(group)">
                  <div class="cell-content center-vh">
                    <span v-if="group.wrkList[rowNum-1]" :class="['badge-modern', group.wrkList[rowNum-1].Deleted ? 'is-true' : 'is-false']">{{ group.wrkList[rowNum-1].Deleted }}</span>
                    <span v-else>-</span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-content-modern">
        <div class="modal-header-modern">
          <h3>Detail Analysis <small>#{{ selectedItem?.TagNo }}</small></h3>
          <button @click="closeModal" class="btn-close-modern">&times;</button>
        </div>
        <div class="modal-body-modern">
          <div class="modal-grid-modern">
            <div class="data-pane"><h4>Published</h4><pre>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</pre></div>
            <div class="data-pane"><h4>Working</h4><pre>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</pre></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    // [기능] 데이터 호출 및 그룹 병합
    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      selectedIds.value = [];
      const groupMap = new Map();

      try {
        const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k);
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key };
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ]);
          const pData = pubRes?.data || pubRes || [];
          const wData = wrkRes?.data || wrkRes || [];

          pData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] });
            groupMap.get(item.TagIdx).pubList.push(item);
          });
          wData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] });
            groupMap.get(item.TagIdx).wrkList.push(item);
          });
        }));
        mergedList.value = Array.from(groupMap.values()).sort((a, b) => String(a.TagNo).localeCompare(String(b.TagNo)));
      } catch (e) { alert('데이터 조회 실패'); } finally { isLoading.value = false; }
    };

    // [기능] 필터/하이라이트/체크박스
    const filteredList = computed(() => {
      if (!localSearchQuery.value.trim()) return mergedList.value;
      const q = localSearchQuery.value.toLowerCase();
      return mergedList.value.filter(g => String(g.TagNo).toLowerCase().includes(q));
    });

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text;
      const regex = new RegExp(`(${localSearchQuery.value.trim()})`, 'gi');
      return String(text).replace(regex, '<mark class="hl">$1</mark>');
    };

    const toggleAllSelect = () => {
      if (selectedIds.value.length === filteredList.value.length) selectedIds.value = [];
      else selectedIds.value = filteredList.value.map(g => g.TagIdx);
    };

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem,
      fetchAndMergeData, highlightText, toggleAllSelect,
      openModal: (g) => { selectedItem.value = g; showModal.value = true; },
      closeModal: () => { showModal.value = false; },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('정말 삭제하시겠습니까?'),
      downloadExcel: () => alert('CSV 다운로드를 시작합니다.')
    };
  }
}
</script>

