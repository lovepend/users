<template>
  <div id="app" class="admin-tool">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 관리 시스템</h2>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field w-20">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field flex-grow">
            <label>API Fetch Keywords</label>
            <textarea v-model="keyword" placeholder="TAG-01..." class="base-input multi-input"></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">조회</button>
          </div>
        </div>
        
        <div class="local-search-bar">
          <input v-model="localSearchQuery" type="text" placeholder="결과 내 필터링..." class="base-input highlight-input" />
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="left-info">그룹: <b>{{ filteredList.length }}</b>건</div>
        <div class="right-actions">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <main class="content-panel">
        <div class="scroll-container">
          <table class="modern-table">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="sticky-col chk-col"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
                <th rowspan="2" class="sticky-col idx-col">Idx</th>
                <th rowspan="2" class="sticky-col tag-col">Tag No</th>
                <th colspan="3" class="pub-header">Published (Master)</th>
                <th colspan="3" class="wrk-header">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th>EP ID</th><th>CLS</th><th>Deleted</th>
                <th>EP ID</th><th>CLS</th><th>Deleted</th>
              </tr>
            </thead>
            
            <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-body">
              <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  :key="group.TagIdx + '-' + rowNum" 
                  class="data-row"
                  @click="openModal(group)"> <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col chk-col" @click.stop>
                  <input type="checkbox" :value="group.TagIdx" v-model="selectedIds" />
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col idx-col group-cell">
                  {{ group.TagIdx }}
                </td>
                <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col tag-col group-cell tag-no" v-html="highlightText(group.TagNo)">
                </td>

                <td class="pub-td">{{ group.pubList[rowNum-1]?.EpId || (rowNum <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td">{{ group.pubList[rowNum-1]?.ClsId || (rowNum <= group.pubList.length ? '-' : '') }}</td>
                <td class="pub-td">
                  <span v-if="group.pubList[rowNum-1]" :class="['status-text', group.pubList[rowNum-1].DelYn === 'Y' ? 'is-deleted' : 'is-active']">
                    {{ group.pubList[rowNum-1].DelYn === 'Y' ? 'True' : 'False' }}
                  </span>
                </td>

                <td class="wrk-td">{{ group.wrkList[rowNum-1]?.EpId || (rowNum <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td">{{ group.wrkList[rowNum-1]?.ClsId || (rowNum <= group.wrkList.length ? '-' : '') }}</td>
                <td class="wrk-td">
                  <span v-if="group.wrkList[rowNum-1]" :class="['status-text', group.wrkList[rowNum-1].DelYn === 'Y' ? 'is-deleted' : 'is-active']">
                    {{ group.wrkList[rowNum-1].DelYn === 'Y' ? 'True' : 'False' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-card">
        <header class="modal-header">
          <h3>Tag Group Detail <small>#{{ selectedItem?.TagIdx }}</small></h3>
          <button @click="closeModal" class="close-btn">&times;</button>
        </header>
        <div class="modal-body">
          <div class="modal-grid-content">
            <div class="data-box">
              <h4 class="text-pub">Published ({{ selectedItem?.pubList.length }})</h4>
              <pre v-for="(p, i) in selectedItem?.pubList" :key="'p'+i" class="json-pre">{{ p }}</pre>
            </div>
            <div class="data-box">
              <h4 class="text-wrk">Working ({{ selectedItem?.wrkList.length }})</h4>
              <pre v-for="(w, i) in selectedItem?.wrkList" :key="'w'+i" class="json-pre">{{ w }}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k)
      const groupMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ])
          const pubData = pubRes?.data || pubRes || []
          const wrkData = wrkRes?.data || wrkRes || []

          if(Array.isArray(pubData)) pubData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          if(Array.isArray(wrkData)) wrkData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => a.TagNo.localeCompare(b.TagNo))
      } catch (e) { alert('데이터 호출 실패') }
      finally { isLoading.value = false }
    }

    const filteredList = computed(() => {
      if (!localSearchQuery.value.trim()) return mergedList.value
      const terms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
      return mergedList.value.filter(g => terms.some(t => g.TagNo.toLowerCase().includes(t)))
    })

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const regex = new RegExp(`(${localSearchQuery.value.split(/[\s,]+/).filter(t=>t).join('|')})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading,
      selectedIds, showModal, selectedItem,
      fetchAndMergeData, highlightText,
      openModal: (g) => { console.log("Modal Open!", g); selectedItem.value = g; showModal.value = true },
      closeModal: () => { showModal.value = false },
      toggleAllSelect: () => {
        if (selectedIds.value.length === filteredList.value.length) selectedIds.value = []
        else selectedIds.value = filteredList.value.map(g => g.TagIdx)
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => alert('삭제 ID: ' + selectedIds.value),
      downloadExcel: () => alert('엑셀 다운로드')
    }
  }
}
</script>

<style scoped>
.container { padding: 20px; height: 100vh; display: flex; flex-direction: column; box-sizing: border-box; background: #f1f5f9; }

/* 1. 검색 패널 고정 */
.search-panel { background: white; padding: 20px; border-radius: 12px; margin-bottom: 15px; flex-shrink: 0; }
