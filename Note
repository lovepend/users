<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="header-top">
          <h2 class="title">🔍 Tag Integrated Management <span class="version-tag">v2.0</span></h2>
        </div>
        <div class="search-section">
          <div class="search-row">
            <div class="input-group project-no">
              <label>Project No</label>
              <input v-model="projectNo" type="text" placeholder="P0001" />
            </div>
            <div class="input-group keywords">
              <label>API Fetch Keywords</label>
              <textarea v-model="keyword" placeholder="Enter tags (space/newline separated)..."></textarea>
            </div>
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch">
              <span v-if="!isLoading">조회하기</span>
              <span v-else class="spinner"></span>
            </button>
          </div>
          <div class="filter-row">
            <input v-model="localSearchQuery" type="text" placeholder="결과 내 실시간 필터링 및 하이라이트..." class="filter-input" />
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="stats">
          Total Groups: <span class="highlight">{{ filteredList.length }}</span>
        </div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn btn-outline-danger" :disabled="selectedIds.length === 0">
            🗑 선택 삭제 ({{ selectedIds.length }})
          </button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-container">
        <table class="sticky-table">
          <thead>
            <tr class="main-header">
              <th rowspan="2" class="sticky-col col-chk"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
              <th rowspan="2" class="sticky-col col-idx">Idx</th>
              <th rowspan="2" class="sticky-col col-tag">Tag No</th>
              <th colspan="3" class="header-group pub">Published (Master)</th>
              <th colspan="3" class="header-group wrk">Working (Current)</th>
            </tr>
            <tr class="sub-header">
              <th>EP ID</th><th>CLS</th><th>Deleted</th>
              <th>EP ID</th><th>CLS</th><th>Deleted</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx">
            <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" 
                :key="group.TagIdx + '-' + rowNum" 
                @click="openModal(group)"
                class="data-row">
              
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk" @click.stop>
                <input type="checkbox" :value="group.TagIdx" v-model="selectedIds" />
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-id">
                {{ group.TagIdx }}
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-tag" v-html="highlightText(group.TagNo)">
              </td>

              <td class="cell-pub">{{ group.pubList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-pub">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-pub">
                <span v-if="group.pubList[rowNum-1]" :class="['status-dot', group.pubList[rowNum-1].DelYn === 'Y' ? 'deleted' : 'active']">
                  {{ group.pubList[rowNum-1].DelYn === 'Y' ? 'True' : 'False' }}
                </span>
              </td>

              <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-wrk">
                <span v-if="group.wrkList[rowNum-1]" :class="['status-dot', group.wrkList[rowNum-1].DelYn === 'Y' ? 'deleted' : 'active']">
                  {{ group.wrkList[rowNum-1].DelYn === 'Y' ? 'True' : 'False' }}
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-backdrop" @click.self="closeModal">
      <div class="modal-window">
        <div class="modal-head">
          <h3>Tag Detail Analysis <small>#{{ selectedItem?.TagNo }}</small></h3>
          <button @click="closeModal" class="close-x">&times;</button>
        </div>
        <div class="modal-body">
          <div class="data-split">
            <div class="split-pane">
              <h4 class="pub-label">Published Records</h4>
              <div class="json-wrapper">
                <pre v-for="(p, i) in selectedItem?.pubList" :key="'p'+i">{{ JSON.stringify(p, null, 2) }}</pre>
              </div>
            </div>
            <div class="split-pane">
              <h4 class="wrk-label">Working Records</h4>
              <div class="json-wrapper">
                <pre v-for="(w, i) in selectedItem?.wrkList" :key="'w'+i">{{ JSON.stringify(w, null, 2) }}</pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
// ... (Setup 로직은 이전과 동일하며, openModal 함수 등 리턴 확인 완료)
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k)
      const groupMap = new Map()

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ])
          const pubData = pubRes?.data || pubRes || []
          const wrkData = wrkRes?.data || wrkRes || []

          if(Array.isArray(pubData)) pubData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          if(Array.isArray(wrkData)) wrkData.forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => a.TagNo.localeCompare(b.TagNo))
      } catch (e) { alert('로드 실패') }
      finally { isLoading.value = false }
    }

    const filteredList = computed(() => {
      if (!localSearchQuery.value.trim()) return mergedList.value
      const terms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
      return mergedList.value.filter(g => terms.some(t => g.TagNo.toLowerCase().includes(t)))
    })

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const regex = new RegExp(`(${localSearchQuery.value.split(/[\s,]+/).filter(t=>t).join('|')})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading,
      selectedIds, showModal, selectedItem,
      fetchAndMergeData, highlightText,
      openModal: (g) => { selectedItem.value = g; showModal.value = true; },
      closeModal: () => { showModal.value = false },
      toggleAllSelect: () => {
        if (selectedIds.value.length === filteredList.value.length) selectedIds.value = []
        else selectedIds.value = filteredList.value.map(g => g.TagIdx)
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('정말 삭제하시겠습니까?'),
      downloadExcel: () => alert('CSV 준비 중')
    }
  }
}
</script>

