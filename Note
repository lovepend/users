<template>
  <div id="app">
    <h2 class="page-main-title">🔍 태그 통합 데이터 검색 (Pub + Wrk)</h2>

    <div class="main-content-wrapper">
      <div class="panel full-panel">
        <h3 class="panel-title">키워드 기반 데이터 매칭 조회</h3>

        <div class="search-controls">
          <div class="input-group inline-group">
            <label for="projectNo">Project No:</label>
            <input id="projectNo" v-model="projectNo" type="text" placeholder="TE1002" />
          </div>
          <div class="input-group inline-group">
            <label for="keyword">Keyword:</label>
            <input 
              id="keyword" 
              v-model="keyword" 
              type="text" 
              placeholder="태그 번호 입력 (예: 6802)" 
              @keyup.enter="fetchAndMergeData"
            />
          </div>
          <button @click="fetchAndMergeData" :disabled="isLoading" class="action-btn primary-btn search-btn">
            {{ isLoading ? '조회 중...' : '통합 검색' }}
          </button>
        </div>

        <div v-if="errorMessage" class="message error-message">{{ errorMessage }}</div>

        <div class="table-container" v-if="mergedList.length > 0">
          <table class="data-table">
            <thead>
              <tr>
                <th rowspan="2">Tag Index</th>
                <th rowspan="2">Tag No</th>
                <th colspan="4" class="header-group pub-bg">Published Data (Master)</th>
                <th colspan="4" class="header-group wrk-bg">Working Data (Current)</th>
              </tr>
              <tr>
                <th class="pub-bg">EP_ID / IC</th>
                <th class="pub-bg">CLS_ID</th>
                <th class="pub-bg">TypeID</th>
                <th class="pub-bg">Deleted</th>
                <th class="wrk-bg">EP_ID / IC</th>
                <th class="wrk-bg">CLS_ID</th>
                <th class="wrk-bg">DelYN</th>
                <th class="wrk-bg">Deleted</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="item in mergedList" :key="item.TagIdx">
                <td class="idx-cell">{{ item.TagIdx }}</td>
                <td class="tag-no-cell"><strong>{{ item.TagNo }}</strong></td>
                
                <td class="pub-bg">{{ item.pub?.EpId || '-' }} / {{ item.pub?.EpIc || '-' }}</td>
                <td class="pub-bg">{{ item.pub?.ClsId || '-' }}</td>
                <td class="pub-bg">{{ item.pub?.TagTypeId || '-' }}</td>
                <td class="pub-bg">
                  <span :class="item.pub?.Deleted ? 'status-red' : 'status-green'">
                    {{ item.pub ? (item.pub.Deleted ? 'Yes' : 'No') : '-' }}
                  </span>
                </td>

                <td class="wrk-bg">{{ item.wrk?.EpId || '-' }} / {{ item.wrk?.EpIc || '-' }}</td>
                <td class="wrk-bg">{{ item.wrk?.ClsId || '-' }}</td>
                <td class="wrk-bg">
                   <span :class="item.wrk?.DelYn ? 'status-red' : ''">
                    {{ item.wrk ? (item.wrk.DelYn ? 'Yes' : 'No') : '-' }}
                  </span>
                </td>
                <td class="wrk-bg">
                  <span :class="item.wrk?.Deleted ? 'status-red' : 'status-green'">
                    {{ item.wrk ? (item.wrk.Deleted ? 'Yes' : 'No') : '-' }}
                  </span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div v-else-if="searched && !isLoading" class="message no-results-message">
          검색 결과가 없습니다.
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref } from 'vue';
import { axiosWrapper } from '@/utils/axios/axios-wrapper';

export default {
  setup() {
    const projectNo = ref('TE1002');
    const keyword = ref('');
    const mergedList = ref([]);
    const isLoading = ref(false);
    const errorMessage = ref('');
    const searched = ref(false);

    const fetchAndMergeData = async () => {
      if (!keyword.value) {
        alert("키워드를 입력해주세요.");
        return;
      }

      isLoading.value = true;
      errorMessage.value = '';
      mergedList.value = [];
      searched.value = true;

      try {
        const payload = {
          ProjectNo: projectNo.value,
          Keyword: keyword.value
        };

        // API 2개를 동시에 호출
        const [pubRes, wrkRes] = await Promise.all([
          axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
          axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
        ]);

        // 데이터 병합 로직 (TagIdx 기준)
        const map = new Map();

        // 1. Published Data 매핑
        if (Array.isArray(pubRes)) {
          pubRes.forEach(item => {
            map.set(item.TagIdx, {
              TagIdx: item.TagIdx,
              TagNo: item.TagNo,
              pub: item,
              wrk: null
            });
          });
        }

        // 2. Working Data 매핑 (기존 Pub 데이터가 있으면 병합, 없으면 신규 생성)
        if (Array.isArray(wrkRes)) {
          wrkRes.forEach(item => {
            if (map.has(item.TagIdx)) {
              map.get(item.TagIdx).wrk = item;
            } else {
              map.set(item.TagIdx, {
                TagIdx: item.TagIdx,
                TagNo: item.TagNo,
                pub: null,
                wrk: item
              });
            }
          });
        }

        // Map을 배열로 변환하여 저장
        mergedList.value = Array.from(map.values());

      } catch (error) {
        console.error("Data fetch error:", error);
        errorMessage.value = "데이터를 불러오는 중 오류가 발생했습니다.";
      } finally {
        isLoading.value = false;
      }
    };

    return {
      projectNo,
      keyword,
      mergedList,
      isLoading,
      errorMessage,
      searched,
      fetchAndMergeData
    };
  }
};
</script>

