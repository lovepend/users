<template>
  <div class="panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    <PageTitle
      icon="fa-search-plus"
      :title="'Tag 통합 분석 및 속성 비교' + (selectedProjNo ? ` [ ${selectedProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-3 ms-auto me-2">
          <div class="d-flex align-items-center gap-2" style="min-width: 250px">
            <span class="fw-bold text-dark text-nowrap">Project No</span>
            <div class="flex-grow-1 dropdown custom-dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center bg-white shadow-sm"
                type="button"
                data-bs-toggle="dropdown"
              >
                <span class="text-truncate">{{ selectedProjNo || '프로젝트 선택' }}</span>
              </button>
              <ul
                class="dropdown-menu shadow-lg p-0"
                style="max-height: 400px; min-width: 250px; overflow: hidden; margin-top: 5px"
              >
                <li class="p-2 bg-light border-bottom">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projSearchQuery"
                    placeholder="프로젝트 검색..."
                    @click.stop
                  />
                </li>
                <div style="max-height: 300px; overflow-y: auto" class="py-1">
                  <li v-for="proj in filteredProjectOptions" :key="proj.value">
                    <div
                      class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 cursor-pointer"
                      @click="selectedProjNo = proj.value"
                    >
                      <input
                        type="checkbox"
                        class="form-check-input mt-0"
                        :checked="selectedProjNo === proj.value"
                        @click.stop="selectedProjNo = proj.value"
                      />
                      <span>{{ proj.text }}</span>
                    </div>
                  </li>
                </div>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2" style="min-width: 280px">
            <span class="fw-bold text-nowrap">Register ID</span>
            <div class="flex-grow-1 dropdown custom-dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center bg-white shadow-sm"
                type="button"
                data-bs-toggle="dropdown"
                :disabled="!selectedProjNo"
              >
                <span class="text-truncate">{{
                  !selectedProjNo ? '프로젝트를 먼저 선택하세요' : selectedRegTypeId || 'ID 선택'
                }}</span>
              </button>
              <ul
                v-if="selectedProjNo"
                class="dropdown-menu shadow-lg p-0"
                style="max-height: 400px; min-width: 280px; overflow: hidden; margin-top: 5px"
              >
                <li class="p-2 bg-light border-bottom">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="regSearchQuery"
                    placeholder="Register ID 검색..."
                    @click.stop
                  />
                </li>
                <div style="max-height: 300px; overflow-y: auto" class="py-1">
                  <li v-for="reg in filteredRegOptions" :key="reg.TYPE_ID">
                    <div
                      class="dropdown-item d-flex align-items-center gap-2 py-2 px-3 cursor-pointer"
                      @click="selectedRegTypeId = reg.TYPE_ID"
                    >
                      <input
                        type="checkbox"
                        class="form-check-input mt-0"
                        :checked="selectedRegTypeId === reg.TYPE_ID"
                        @click.stop="selectedRegTypeId = reg.TYPE_ID"
                      />
                      <span>{{ reg.TYPE_ID }}</span>
                    </div>
                  </li>
                  <li v-if="filteredRegOptions.length === 0" class="text-center py-2 text-muted small">
                    데이터가 없습니다.
                  </li>
                </div>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2 border-start ps-3 ms-2">
            <span class="fw-bold text-nowrap">조회 대상</span>
            <div class="form-check form-check-inline mb-0" v-for="opt in ['Publish', 'Working', 'Merged']" :key="opt">
              <input class="form-check-input" type="radio" :id="opt" :value="opt" v-model="selectedType" />
              <label class="form-check-label" :for="opt">{{ opt }}</label>
            </div>
          </div>

          <div class="form-check mb-0 border-start ps-3">
            <input class="form-check-input" type="checkbox" id="delCheck" v-model="containDeleted" />
            <label class="form-check-label fw-bold" for="delCheck">삭제 포함</label>
          </div>

          <button class="btn btn-xs btn-primary shadow-sm px-3" @click="onSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>
        </div>
      </template>
    </PageTitle>

    <div class="bg-light border-bottom px-3 py-1 d-flex align-items-center gap-3">
      <div class="d-flex align-items-center gap-2">
        <span class="fw-bold text-info text-nowrap small"><i class="fa fa-columns"></i> 헤더 필터</span>
        <input
          type="text"
          class="form-control form-control-sm border-info"
          style="width: 200px"
          v-model="headerFilterQuery"
          placeholder="표시할 컬럼"
        />
      </div>
      <div class="d-flex align-items-center gap-2">
        <span class="fw-bold text-success text-nowrap small"><i class="fa fa-filter"></i> 결과 필터</span>
        <input
          type="text"
          class="form-control form-control-sm border-success"
          style="width: 200px"
          v-model="localFilterQuery"
          placeholder="결과 내 검색"
        />
      </div>
    </div>

    <div class="panel-body flex-grow-1 overflow-hidden m-0 p-0 h-100">
      <ag-grid-vue
        v-bind="gridBindProps"
        @grid-ready="onGridReady"
        @cell-clicked="onCellClicked"
        class="ag-theme-alpine w-100 h-100"
      />
    </div>

    <div v-if="showJsonModal" class="custom-modal-overlay" @click.self="showJsonModal = false">
      <div class="custom-modal-window shadow-lg">
        <div class="modal-header-dark">
          <span class="fw-bold text-white"><i class="fa fa-code me-2"></i>Row Data (JSON)</span>
          <button @click="showJsonModal = false" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content bg-dark overflow-auto p-3">
          <pre
            class="m-0 text-white"
            style="white-space: pre-wrap; font-size: 13px"
          ><code>{{ selectedJsonData }}</code></pre>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
  import { ref, computed, shallowRef, watch, onMounted } from 'vue'
  import { storeToRefs } from 'pinia'
  import { axiosWrapper } from '@/utils/axios/axios-wrapper'
  import { sAlert } from '@/utils/messages/alert-common'
  import { useAppMenuStore } from '@/stores/app-menu'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import PageTitle from '@/components/toolBar/PageTitle.vue'

  import 'ag-grid-enterprise'
  import 'ag-grid-community/styles/ag-grid.css'
  import 'ag-grid-community/styles/ag-theme-alpine.css'

  const appMenu = useAppMenuStore()
  const { currentProjNo } = storeToRefs(appMenu)

  const projectOptions = ref([])
  const regOptions = ref([])
  const selectedProjNo = ref('')
  const selectedRegTypeId = ref('')
  const projSearchQuery = ref('')
  const regSearchQuery = ref('')

  const selectedType = ref('Working')
  const containDeleted = ref(false)
  const localFilterQuery = ref('')
  const headerFilterQuery = ref('')

  const showJsonModal = ref(false)
  const selectedJsonData = ref('')

  const gridApi = shallowRef()
  const rawDataList = ref([])
  const diffMap = ref(new Map())
  const dynamicCols = ref([])

  /** 1. 초기 프로젝트 목록 로드 **/
  const fetchProjectList = async () => {
    try {
      const res = await axiosWrapper.get('/api/Project/Get')
      projectOptions.value = res.map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
      // 초기값 세팅 (있을 경우)
      if (currentProjNo.value) selectedProjNo.value = currentProjNo.value
    } catch (e) {
      console.error('Project List Load Error', e)
    }
  }

  /** 2. 프로젝트 선택 시 Register ID 목록 로드 (Watcher) **/
  watch(selectedProjNo, async newVal => {
    selectedRegTypeId.value = '' // 프로젝트 변경 시 선택된 ID 초기화
    regOptions.value = []

    if (!newVal) return

    try {
      // 프로젝트 번호를 파라미터로 전달하여 해당 프로젝트의 Register 리스트 호출
      const res = await axiosWrapper.get('/api/Register/Get', { ProjectNo: newVal })
      regOptions.value = res
    } catch (e) {
      console.error('Register List Load Error', e)
      sAlert.Error('Register 목록을 불러오지 못했습니다.')
    }
  })

  const filteredProjectOptions = computed(() => {
    const q = projSearchQuery.value.toLowerCase()
    return projectOptions.value.filter(p => p.text.toLowerCase().includes(q))
  })

  const filteredRegOptions = computed(() => {
    const q = regSearchQuery.value.toLowerCase()
    return regOptions.value.filter(r => r.TYPE_ID.toLowerCase().includes(q))
  })

  /** 3. 데이터 조회 및 그리드 로직 (기존 유지) **/
  const onSearch = async () => {
    if (!selectedProjNo.value || !selectedRegTypeId.value) {
      return sAlert.Warning('Project No와 Register ID를 선택하세요.')
    }
    if (gridApi.value) gridApi.value.setGridOption('loading', true)

    try {
      const payload = {
        ProjectNo: selectedProjNo.value,
        REG_TYPE_ID: selectedRegTypeId.value,
        Type: selectedType.value,
        ContainDeleted: containDeleted.value,
      }

      const res = await axiosWrapper.post('/api/Data/GetMergedData', payload)
      const rootKey = selectedRegTypeId.value
      const resultData = res[rootKey]

      if (!resultData) {
        rawDataList.value = []
        return sAlert.Info('조회된 데이터가 없습니다.')
      }

      const newDiffMap = new Map()
      if (resultData.DiffData) {
        resultData.DiffData.forEach(diff => {
          ;(diff.Property || []).forEach(prop => {
            if (prop.PUB_VALUE !== prop.WRK_VALUE) {
              newDiffMap.set(`${diff.TAG_IDX}_${prop.PROP_ID}`, { pub: prop.PUB_VALUE, wrk: prop.WRK_VALUE })
            }
          })
        })
      }
      diffMap.value = newDiffMap

      let sourceData = []
      if (selectedType.value === 'Working') sourceData = resultData.WrkData || []
      else if (selectedType.value === 'Publish') sourceData = resultData.PubData || []
      else sourceData = resultData.MergeData || []

      const processed = sourceData.map(item => {
        const flat = { ...item }
        if (Array.isArray(item.ATTRIBUTES)) {
          item.ATTRIBUTES.forEach(attr => {
            flat[attr.ATT_ID] = attr.VALUE
          })
        }
        return flat
      })

      const fixedFields = ['TAG_NO', 'TAG_IDX', 'CLS_ID', 'EP_ID', 'TAG_DESC']
      const allKeys = new Set()
      processed.forEach(row =>
        Object.keys(row).forEach(k => {
          if (k !== 'ATTRIBUTES' && k !== '_id') allKeys.add(k)
        })
      )

      dynamicCols.value = Array.from(allKeys)
        .sort((a, b) => {
          const aIdx = fixedFields.indexOf(a),
            bIdx = fixedFields.indexOf(b)
          if (aIdx > -1 && bIdx > -1) return aIdx - bIdx
          if (aIdx > -1) return -1
          if (bIdx > -1) return 1
          return a.localeCompare(b)
        })
        .map(key => ({
          headerName: key,
          field: key,
          minWidth: 150,
          pinned: ['TAG_NO', 'TAG_IDX', 'CLS_ID'].includes(key) ? 'left' : null,
          cellRenderer: diffCellRenderer,
          cellStyle: getCellStyle,
          tooltipValueGetter: p => {
            const diff = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
            return diff ? `[차이발생]\nPublish: ${diff.pub ?? 'null'}\nWorking: ${diff.wrk ?? 'null'}` : null
          },
        }))

      rawDataList.value = processed
    } catch (e) {
      sAlert.Error('데이터 로드 실패')
    } finally {
      if (gridApi.value) gridApi.value.setGridOption('loading', false)
    }
  }

  /** 셀 스타일/렌더러 (기존 유지) **/
  const diffCellRenderer = p => {
    let val = String(p.value ?? '')
    const kw = localFilterQuery.value.trim().toLowerCase()
    if (kw && val.toLowerCase().includes(kw)) {
      const regex = new RegExp(`(${kw})`, 'gi')
      val = val.replace(regex, `<mark class="bg-warning text-dark fw-bold">$1</mark>`)
    }
    const diffInfo = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
    return diffInfo
      ? `<div class="diff-wrapper"><i class="fa fa-exclamation-circle text-warning me-1"></i>${val}</div>`
      : val
  }

  const getCellStyle = p => {
    let style = {}
    if (p.colDef.field === 'TAG_NO')
      style = { cursor: 'pointer', color: '#0d6efd', textDecoration: 'underline', fontWeight: 'bold' }
    const diffInfo = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
    if (diffInfo) {
      style.backgroundColor = '#fff9db'
      style.fontWeight = 'bold'
      style.color = '#d94111'
    }
    return style
  }

  /** 그리드 바인딩 (Enterprise 기능 포함) **/
  const gridBindProps = computed(() => ({
    columnDefs: filteredColumns.value,
    rowData: filteredData.value,
    pagination: true,
    paginationPageSize: 100,
    loadingOverlayComponent: AggridLoadingOverlay,
    defaultColDef: { sortable: true, filter: true, resizable: true },
    enableRangeSelection: true,
    enableFillHandle: true,
    rowSelection: 'multiple',
    suppressRowClickSelection: true,
  }))

  const filteredColumns = computed(() => {
    if (!headerFilterQuery.value.trim()) return dynamicCols.value
    const keywords = headerFilterQuery.value
      .split(/[,\s\n]+/)
      .filter(k => k.trim())
      .map(k => k.toLowerCase())
    const alwaysVisible = ['tag_no', 'tag_idx', 'cls_id']
    const pinnedCols = dynamicCols.value.filter(col => alwaysVisible.includes(col.field.toLowerCase()))
    const matchedCols = []
    keywords.forEach(kw => {
      dynamicCols.value.forEach(col => {
        const fieldName = col.field.toLowerCase()
        if (
          !alwaysVisible.includes(fieldName) &&
          fieldName.includes(kw) &&
          !matchedCols.find(m => m.field === col.field)
        ) {
          matchedCols.push(col)
        }
      })
    })
    return [...pinnedCols, ...matchedCols]
  })

  const filteredData = computed(() => {
    if (!localFilterQuery.value.trim()) return rawDataList.value
    const kw = localFilterQuery.value.toLowerCase()
    return rawDataList.value.filter(row => Object.values(row).some(val => String(val).toLowerCase().includes(kw)))
  })

  const onGridReady = p => {
    gridApi.value = p.api
  }
  const onCellClicked = p => {
    if (p.colDef.field === 'TAG_NO' && p.data) {
      selectedJsonData.value = JSON.stringify(p.data, null, 2)
      showJsonModal.value = true
    }
  }

  onMounted(fetchProjectList)
</script>

<style scoped lang="scss">
  .custom-dropdown {
    .dropdown-toggle::after {
      margin-left: auto;
    }
    .dropdown-menu {
      border: 1px solid #cbd5e1;
      left: 0 !important;
    }
    .dropdown-item {
      transition: background 0.2s;
      &.active-proj {
        background-color: #f1f5f9;
        font-weight: bold;
      }
    }
    .custom-check-box {
      display: flex;
      align-items: center;
      padding-left: 5px;
    }
    .form-check-input {
      width: 16px;
      height: 16px;
      cursor: pointer;
      border-radius: 3px;
    }
  }

  .custom-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .custom-modal-window {
    background: #fff;
    width: 800px;
    height: 70%;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .modal-header-dark {
    background: #0f172a;
    color: #fff;
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .modal-body-content {
    flex-grow: 1;
    min-height: 0;
  }

  ::v-deep(.diff-wrapper) {
    display: flex;
    align-items: center;
  }
  :deep(.ag-theme-alpine) {
    --ag-font-size: 12px;
    .ag-header-cell {
      border-right: 1px solid #dee2e6 !important;
    }
    .ag-cell {
      border-right: 1px solid #f1f3f5 !important;
    }
  }
</style>
