<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-search-plus" :title="'Tag 분석 및 비교'">
      <template #actions>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <input v-model="manualProjNo" class="form-control form-control-sm" style="width:100px" placeholder="ProjNo" />
          <input v-model="regTypeId" class="form-control form-control-sm" style="width:120px" placeholder="RegType" />
          <button class="btn btn-xs btn-primary" @click="onSearch">조회</button>
        </div>
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0" style="height: calc(100vh - 160px); min-height: 500px;">
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, shallowRef } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import { axiosWrapper } from '@/utils/axios/axios-wrapper';
import { sAlert } from '@/utils/messages/alert-common';

// 상태 관리
const manualProjNo = ref('TE1002');
const regTypeId = ref('101TEST');
const containDeleted = ref(true);

const gridApi = shallowRef(null);
const columnDefs = ref([]);
const rowData = ref([]);
const diffMap = ref(new Map());

const defaultColDef = {
  sortable: true,
  filter: true,
  resizable: true,
  minWidth: 120
};

const onGridReady = (params) => {
  gridApi.value = params.api;
};

// 데이터 조회 및 가공
const onSearch = async () => {
  try {
    if (gridApi.value) gridApi.value.showLoadingOverlay();

    const res = await axiosWrapper.post('/api/Data/GetPubWrkData', {
      ProjectNo: manualProjNo.value,
      REG_TYPE_ID: regTypeId.value,
      ContainDeleted: containDeleted.value
    });

    // 1. 데이터 경로 찾기 (가장 안전한 방식)
    const result = res.data || res;
    const { PubData = [], WrkData = [], DiffData = [] } = result;

    if (PubData.length === 0 && WrkData.length === 0) {
      sAlert.Info('조회된 데이터가 없습니다.');
      rowData.value = [];
      return;
    }

    // 2. 차이점 맵 생성 (DiffData 기준)
    const newDiffMap = new Map();
    const statusMap = new Map();
    DiffData.forEach(d => {
      statusMap.set(d.TAG_IDX, d.Status);
      if (d.Property) {
        d.Property.forEach(p => {
          if (p.PUB_VALUE !== p.WRK_VALUE) {
            newDiffMap.set(`${d.TAG_IDX}_${p.PROP_ID}`, true);
          }
        });
      }
    });
    diffMap.value = newDiffMap;

    // 3. 데이터 평면화 (ATTRIBUTES -> Root)
    const transform = (list, sourceName) => {
      return list.map(item => {
        const flat = { 
          ...item, 
          SOURCE: sourceName, // [출처]
          STATUS: statusMap.get(item.TAG_IDX) || '' // [상태]
        };
        if (item.ATTRIBUTES) {
          item.ATTRIBUTES.forEach(attr => {
            flat[attr.ATT_ID] = attr.VALUE ?? ''; 
          });
        }
        return flat;
      });
    };

    const merged = [...transform(PubData, 'PUBLISH'), ...transform(WrkData, 'WORKING')];

    // 4. TAG_IDX 기준 정렬
    merged.sort((a, b) => {
      if (a.TAG_IDX === b.TAG_IDX) return a.SOURCE === 'PUBLISH' ? -1 : 1;
      return String(a.TAG_IDX).localeCompare(String(b.TAG_IDX));
    });

    // 5. 컬럼 생성 (출처와 상태를 맨 앞으로)
    const fixedFields = ['SOURCE', 'STATUS', 'TAG_NO', 'TAG_IDX'];
    const allKeys = new Set(fixedFields);
    merged.forEach(row => Object.keys(row).forEach(k => {
      if (!['_id', 'ATTRIBUTES'].includes(k)) allKeys.add(k);
    }));

    const newCols = Array.from(allKeys).map(key => ({
      field: key,
      headerName: key === 'SOURCE' ? '[출처]' : (key === 'STATUS' ? '[상태]' : key),
      pinned: fixedFields.includes(key) ? 'left' : null,
      cellStyle: (p) => {
        // 출처 컬럼 색상 (Publish는 파랑, Working은 초록)
        if (key === 'SOURCE') {
          return p.value === 'PUBLISH' 
            ? { backgroundColor: '#e3f2fd', color: '#0d47a1', fontWeight: 'bold' } 
            : { backgroundColor: '#e8f5e9', color: '#1b5e20', fontWeight: 'bold' };
        }
        // 차이가 있는 셀 강조
        if (diffMap.value.has(`${p.data.TAG_IDX}_${key}`)) {
          return { backgroundColor: '#fff9db', color: '#d94111', fontWeight: 'bold' };
        }
        return null;
      }
    }));

    // 6. 반영
    columnDefs.value = newCols;
    rowData.value = merged;

    if (gridApi.value) {
      gridApi.value.hideOverlay();
    }

  } catch (e) {
    console.error('Data Error:', e);
    sAlert.Error('데이터 로드 중 오류가 발생했습니다.');
  }
};
</script>

<style scoped>
/* AG-Grid 테마 설정 */
.ag-theme-alpine {
  border: 1px solid #dee2e6;
}
</style>
