<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="project-box">
            <label>Project No</label>
            <input v-model="projectNo" type="text" class="base-input unified-height" />
            <label class="sub-label">실시간 필터</label>
            <input v-model="localSearchQuery" type="text" class="filter-input unified-height" />
          </div>
          <div class="keyword-box">
            <label>API Keywords</label>
            <textarea v-model="keyword" class="base-input keyword-input"></textarea>
          </div>
          <div class="button-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-large">조회하기</button>
          </div>
        </div>
      </header>

      <div class="table-container">
        <table class="modern-table">
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-tbody">
            <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum" @click="openModal(group)" class="clickable-row">
               <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-idx group-fixed">
                 {{ group.TagIdx }}
               </td>
               <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-tag group-fixed">
                 <span v-html="highlightText(group.TagNo)"></span>
               </td>
               <td class="cell-pub">{{ group.pubList[rowNum-1]?.EpId || '-' }}</td>
               <td class="cell-pub">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</td>
               <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</td>
               <td class="cell-wrk">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-content modal-xl">
        <div class="modal-header">
          <div class="header-title">
            <h3>상세 데이터 비교 분석</h3>
            <span class="tag-badge">{{ selectedItem?.TagNo }}</span>
          </div>
          <div class="header-actions">
            <button @click="toggleJsonView" class="btn-toggle-json">
              {{ isJsonMode ? '📊 테이블로 보기' : '{} JSON 원본보기' }}
            </button>
            <button @click="closeModal" class="btn-close">&times;</button>
          </div>
        </div>

        <div class="modal-body modal-scroll">
          <div v-if="!isJsonMode" class="modal-table-wrapper">
            <table class="analysis-table">
              <thead>
                <tr>
                  <th colspan="5" class="header-section-basic">기본 정보 (System Info)</th>
                  <th :colspan="allAttributeKeys.length" class="header-section-attr">특성 정보 (Attributes)</th>
                </tr>
                <tr>
                  <th class="w-80">Source</th>
                  <th class="w-150">Tag No</th> <th class="w-120">EP ID</th>
                  <th class="w-100">Class</th>  <th class="w-60">삭제</th>
                  <th v-for="key in allAttributeKeys" :key="key" class="attr-key">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(row, idx) in modalRows" :key="idx" :class="row.source">
                  <td><span :class="['label', row.source]">{{ row.source }}</span></td>
                  <td class="font-bold">{{ row.TagNo }}</td>
                  <td>{{ row.EpId }}</td>
                  <td>{{ row.ClsId }}</td>
                  <td><span :class="['badge', row.Deleted ? 'red' : 'green']">{{ row.Deleted }}</span></td>
                  <td v-for="key in allAttributeKeys" :key="key + idx" :class="{ 'empty': !row.attrMap[key] }">
                    {{ row.attrMap[key] || '-' }}
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div v-else class="json-viewer-container">
            <div class="json-split">
              <div class="json-box">
                <h4>Published Raw Data</h4>
                <pre>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</pre>
              </div>
              <div class="json-box">
                <h4>Working Raw Data</h4>
                <pre>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'

export default {
  setup() {
    const showModal = ref(false)
    const selectedItem = ref(null)
    const isJsonMode = ref(false) // JSON 뷰 전환 상태

    // [로직] Attributes 합집합 추출 (ATT_ID 기준)
    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const extract = (list) => list.forEach(item => {
        // item.attributes가 배열인지 확인 후 순회
        if (Array.isArray(item.attributes)) {
          item.attributes.forEach(attr => {
            if (attr.ATT_ID) keys.add(attr.ATT_ID);
          });
        }
      });
      extract(selectedItem.value.pubList);
      extract(selectedItem.value.wrkList);
      return Array.from(keys).sort();
    });

    // [로직] 모달 로우 데이터 생성 (TagNo, ClsId 추가 및 attrMap 매핑 수정)
    const modalRows = computed(() => {
      if (!selectedItem.value) return [];
      const mapData = (item, source) => {
        const attrMap = {};
        // ⭐ 배열 형태의 attributes를 { ATT_ID: VALUE } 객체로 변환
        if (Array.isArray(item.attributes)) {
          item.attributes.forEach(a => {
            if (a.ATT_ID) attrMap[a.ATT_ID] = a.VALUE;
          });
        }
        return {
          source,
          TagNo: item.TagNo || selectedItem.value.TagNo, // 기본정보 보강
          EpId: item.EpId || '-',
          ClsId: item.ClsId || '-', // 기본정보 보강
          Deleted: !!item.Deleted,
          attrMap // 변환된 객체 저장
        };
      };

      const rows = [];
      selectedItem.value.pubList.forEach(i => rows.push(mapData(i, 'Published')));
      selectedItem.value.wrkList.forEach(i => rows.push(mapData(i, 'Working')));
      return rows;
    });

    return {
      showModal, selectedItem, isJsonMode,
      allAttributeKeys, modalRows,
      toggleJsonView: () => { isJsonMode.value = !isJsonMode.value; },
      openModal: (g) => { 
        selectedItem.value = g; 
        showModal.value = true; 
        isJsonMode.value = false; // 열 때 기본은 테이블 뷰
      },
      closeModal: () => { showModal.value = false; }
    };
  }
}
</script>

