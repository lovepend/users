// 화면에 있는 첫 번째 SpreadJS 호스트 요소를 찾아 버전 출력
var spreadElement = document.querySelector('.gc-spread-sheets') || document.querySelector('[gcui-id]');
if (spreadElement) {
    var spread = GC.Spread.Sheets.findControl(spreadElement);
    console.log("Version:", spread.version());
} else {
    console.log("스프레드 요소를 찾을 수 없습니다.");
}
