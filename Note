<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="input-box proj-box">
            <label class="field-label">Project No</label>
            <input v-model="projectNo" type="text" class="design-input" placeholder="P0001" />
          </div>
          <div class="input-box kw-box">
            <label class="field-label">API Keywords (Space/Comma/Enter)</label>
            <textarea v-model="keyword" class="design-textarea" placeholder="조회 키워드를 입력하세요..."></textarea>
          </div>
          <div class="input-box filter-box">
            <label class="field-label">Result Filter</label>
            <input v-model="localSearchQuery" type="text" class="design-input filter-highlight" placeholder="Tag No 필터..." />
          </div>
          <div class="btn-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="primary-gradient-btn">
              {{ isLoading ? '조회 중...' : '데이터 통합 조회' }}
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="result-count">Total Groups: <strong>{{ filteredList.length }}</strong></div>
        <div class="button-group">
          <button @click="deleteSelected" class="btn-action btn-danger-custom" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn-action btn-success-custom">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-outer-container">
        <table class="master-table">
          <thead>
            <tr class="header-row-top">
              <th rowspan="2" class="m-sticky-th m-sticky-left col-chk h-double"><div class="center-vh"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></div></th>
              <th rowspan="2" class="m-sticky-th m-sticky-left col-idx h-double">Idx</th>
              <th rowspan="2" class="m-sticky-th m-sticky-left col-tag h-double">Tag No</th>
              <th colspan="3" class="m-sticky-th pub-bg h-single">Published (Master)</th>
              <th colspan="3" class="m-sticky-th wrk-bg h-single">Working (Current)</th>
            </tr>
            <tr class="header-row-sub">
              <th class="m-sticky-th sub-th pub-bg h-single">EP ID</th><th class="m-sticky-th sub-th pub-bg h-single">CLS</th><th class="m-sticky-th sub-th pub-bg h-single">Del</th>
              <th class="m-sticky-th sub-th wrk-bg h-single">EP ID</th><th class="m-sticky-th sub-th wrk-bg h-single">CLS</th><th class="m-sticky-th sub-th wrk-bg h-single">Del</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="data-group-body">
            <tr v-for="(item, pIdx) in group.pubList" :key="'p-'+group.TagIdx+'-'+pIdx" class="row-pub">
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-chk group-cell">
                <div class="center-vh"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-idx group-cell clickable" @click="openModal(group)">
                <div class="center-vh font-bold">{{ group.TagIdx }}</div>
              </td>
              <td v-if="pIdx === 0" :rowspan="group.pubList.length + group.wrkList.length" class="m-sticky-td col-tag group-cell clickable" @click="openModal(group)">
                <div class="cell-padding"><span class="tag-highlight" v-html="highlightText(group.TagNo)"></span></div>
              </td>
              <td class="data-td clickable" @click="openModal(group)">{{ item.EpId || '-' }}</td>
              <td class="data-td clickable" @click="openModal(group)">{{ item.ClsId || '-' }}</td>
              <td class="data-td clickable center-vh" @click="openModal(group)">
                <span :class="['status-badge', item.Deleted ? 'is-del' : 'is-active']">{{ item.Deleted ? 'Y' : 'N' }}</span>
              </td>
              <td colspan="3" class="empty-cell" v-if="group.pubList.length > 0 && pIdx === 0 && group.wrkList.length === 0"></td>
            </tr>
            <tr v-for="(item, wIdx) in group.wrkList" :key="'w-'+group.TagIdx+'-'+wIdx" class="row-wrk">
              <td colspan="3" class="empty-cell" v-if="wIdx === 0 && group.pubList.length > 0 && false"></td> <td class="empty-cell"></td><td class="empty-cell"></td><td class="empty-cell"></td>
              <td class="data-td clickable" @click="openModal(group)">{{ item.EpId || '-' }}</td>
              <td class="data-td clickable" @click="openModal(group)">{{ item.ClsId || '-' }}</td>
              <td class="data-td clickable center-vh" @click="openModal(group)">
                <span :class="['status-badge', item.Deleted ? 'is-del' : 'is-active']">{{ item.Deleted ? 'Y' : 'N' }}</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-window">
        <div class="modal-header">
          <div class="title-area">
            <div class="main-title">🔍 Data Detail Analysis</div>
            <div class="meta-info-row">
              <span class="info-chip tag-main"><strong>TAG:</strong> {{ selectedItem?.TagNo }}</span>
              <span class="info-chip"><strong>IDX:</strong> {{ selectedItem?.TagIdx }}</span>
            </div>
          </div>
          <div class="modal-actions">
            <button @click="isJsonMode = !isJsonMode" class="btn-mode-toggle">
              {{ isJsonMode ? '📋 Table View' : '📄 JSON View' }}
            </button>
            <button @click="closeModal" class="btn-modal-close">✕</button>
          </div>
        </div>
        <div class="modal-body">
          <div v-if="!isJsonMode" class="modal-table-container">
            <table class="analysis-table auto-layout">
              <thead>
                <tr>
                  <th class="f-sticky-th f-sticky-left f-col-src">Source</th>
                  <th class="f-sticky-th f-sticky-left f-col-tag">Tag No</th>
                  <th class="f-sticky-th f-sticky-left f-col-epid">EP ID</th>
                  <th class="f-sticky-th f-sticky-left f-col-cls">Class</th>
                  <th v-for="key in allSystemKeys" :key="'sh-'+key" class="f-sticky-th sys-h">{{ key }}</th>
                  <th v-for="key in allAttributeKeys" :key="'ah-'+key" class="f-sticky-th attr-h">{{ key }}</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(item, idx) in selectedItem?.pubList" :key="'p-det-'+idx" class="row-pub">
                  <td class="f-sticky-td f-sticky-left f-col-src"><span class="badge pub">PUBLISHED</span></td>
                  <td class="f-sticky-td f-sticky-left f-col-tag"><strong>{{ item.TagNo }}</strong></td>
                  <td class="f-sticky-td f-sticky-left f-col-epid">{{ item.EpId || '-' }}</td>
                  <td class="f-sticky-td f-sticky-left f-col-cls">{{ item.ClsId || '-' }}</td>
                  <td v-for="key in allSystemKeys" :key="'ps-'+key">{{ item[key] ?? '-' }}</td>
                  <td v-for="key in allAttributeKeys" :key="'pa-'+key">{{ getAttrValue(item, key) }}</td>
                </tr>
                <tr v-for="(item, idx) in selectedItem?.wrkList" :key="'w-det-'+idx" class="row-wrk">
                  <td class="f-sticky-td f-sticky-left f-col-src"><span class="badge wrk">WORKING</span></td>
                  <td class="f-sticky-td f-sticky-left f-col-tag"><strong>{{ item.TagNo }}</strong></td>
                  <td class="f-sticky-td f-sticky-left f-col-epid">{{ item.EpId || '-' }}</td>
                  <td class="f-sticky-td f-sticky-left f-col-cls">{{ item.ClsId || '-' }}</td>
                  <td v-for="key in allSystemKeys" :key="'ws-'+key">{{ item[key] ?? '-' }}</td>
                  <td v-for="key in allAttributeKeys" :key="'wa-'+key">{{ getAttrValue(item, key) }}</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div v-else class="json-viewer-container">
             <div class="json-pane">
               <h3 class="json-title pub-title">Published Data</h3>
               <pre><code>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</code></pre>
             </div>
             <div class="json-pane">
               <h3 class="json-title wrk-title">Working Data</h3>
               <pre><code>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</code></pre>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)
    const isJsonMode = ref(false)

    const filteredList = computed(() => {
      const q = localSearchQuery.value.trim().toLowerCase();
      if (!q) return mergedList.value;
      const kws = q.split(/[\s,]+/).filter(k => k);
      return mergedList.value.filter(g => kws.some(kw => String(g.TagNo).toLowerCase().includes(kw)));
    });

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return alert('키워드를 입력하세요.');
      isLoading.value = true;
      const groupMap = new Map();
      try {
        const keys = keyword.value.split(/[\s,]+/).filter(k => k);
        for (const k of keys) {
          const payload = { ProjectNo: projectNo.value, Keyword: k };
          const [pRes, wRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload).catch(() => []),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload).catch(() => [])
          ]);
          
          const process = (list, type) => {
            (Array.isArray(list) ? list : (list?.data || [])).forEach(i => {
              if (!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] });
              groupMap.get(i.TagIdx)[type].push(i);
            });
          };
          process(pRes, 'pubList'); process(wRes, 'wrkList');
        }
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => String(a.TagNo).localeCompare(b.TagNo));
      } finally { isLoading.value = false; }
    };

    const allSystemKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      const ignore = ['Attributes', 'attributes', 'TagNo', 'TagIdx', 'EpId', 'ClsId', '_id', 'Deleted', 'UpdatedDate'];
      [...selectedItem.value.pubList, ...selectedItem.value.wrkList].forEach(i => {
        Object.keys(i).forEach(k => { if(!ignore.includes(k)) keys.add(k); });
      });
      return Array.from(keys).sort();
    });

    const allAttributeKeys = computed(() => {
      if (!selectedItem.value) return [];
      const keys = new Set();
      [...selectedItem.value.pubList, ...selectedItem.value.wrkList].forEach(i => {
        (i.Attributes || i.attributes || []).forEach(a => keys.add(a.ATT_ID));
      });
      return Array.from(keys).sort();
    });

    const getAttrValue = (item, attId) => {
      const a = (item.Attributes || item.attributes || []).find(x => x.ATT_ID === attId);
      return a ? (a.VALUE ?? a.VALUE_DBL ?? '-') : '-';
    };

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading, selectedIds, showModal, selectedItem, isJsonMode,
      allSystemKeys, allAttributeKeys, getAttrValue, fetchAndMergeData,
      highlightText: (t) => {
        const q = localSearchQuery.value.trim();
        if (!q) return t;
        const kws = q.split(/[\s,]+/).filter(k => k);
        let res = String(t);
        kws.forEach(k => { res = res.replace(new RegExp(`(${k})`, 'gi'), '<mark class="hl">$1</mark>'); });
        return res;
      },
      openModal: (g) => { selectedItem.value = g; showModal.value = true; isJsonMode.value = false; },
      closeModal: () => { showModal.value = false; },
      toggleAllSelect: () => { selectedIds.value = selectedIds.value.length === filteredList.value.length ? [] : filteredList.value.map(g => g.TagIdx) },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('정말 삭제하시겠습니까?'),
      downloadExcel: () => alert('CSV 다운로드를 시작합니다.')
    };
  }
}
</script>

