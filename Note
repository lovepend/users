<template>
  <div id="app">
    <header class="header">
      <h2 class="page-main-title">🏷️ 태그 번호 유효성 검사 대시보드</h2>
    </header>

    <div class="main-container">
      <div class="side-panel left-panel">
        <section class="panel-card">
          <h3 class="card-title">1. 입력 및 규칙 설정</h3>
          <div class="input-group">
            <label for="tagNoInputValidator">검사할 Tag No. 입력</label>
            <input id="tagNoInputValidator" v-model="tagNoForValidator" type="text" placeholder="검증할 태그 번호를 입력하세요" />
          </div>

          <div class="rules-header">
            <h4>규칙 리스트 (구분자 + 정규식)</h4>
            <div class="button-group">
              <button @click="addRule" class="btn-small btn-success">+ 추가</button>
              <button @click="showPasteModal = true" class="btn-small btn-info">엑셀 붙여넣기</button>
            </div>
          </div>

          <div class="scroll-area rules-area">
            <table class="data-table">
              <thead>
                <tr>
                  <th width="50">No</th>
                  <th width="70">구분자</th>
                  <th>정규식 (Regex)</th>
                  <th width="40"></th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center font-code">#{{ index + 1 }}</td>
                  <td><input type="text" v-model="rule.delimiter" placeholder="없음" class="cell-input text-center" /></td>
                  <td><input type="text" v-model="rule.regex" placeholder="예: ^[A-Z]+$" class="cell-input" /></td>
                  <td><button @click="removeRule(index)" class="btn-delete">×</button></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div class="side-panel right-panel">
        <section class="panel-card result-card">
          <h3 class="card-title">2. 유효성 분석 결과</h3>
          
          <div class="status-banner" :class="isTagNoValid ? 'status-pass' : 'status-fail'">
            <div class="status-icon">{{ isTagNoValid ? '✅' : '❌' }}</div>
            <div class="status-text">
              <strong>{{ isTagNoValid ? '최종 검증 통과' : '최종 검증 실패' }}</strong>
              <div class="full-regex">결합된 패턴: {{ combinedRegexDisplay }}</div>
            </div>
          </div>

          <h4 class="sub-title">부분별 매칭 상세 분석</h4>
          <div class="scroll-area analysis-area">
            <table class="data-table analysis-table">
              <thead>
                <tr>
                  <th width="80">구성요소</th>
                  <th>추출된 내용</th>
                  <th width="70">구분자</th>
                  <th width="70">내용</th>
                  <th width="80">결과</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(part, index) in tagParts" :key="index">
                  <td class="font-code">규칙 #{{ index + 1 }}</td>
                  <td class="font-bold">
                    <span v-if="part.matchedValue === ''" class="text-muted">(빈값)</span>
                    <span v-else>{{ part.matchedValue }}</span>
                  </td>
                  <td :class="part.isDelimiterValid ? 'text-ok' : 'text-error'">
                    {{ part.hasDelimiterRule ? (part.isDelimiterValid ? 'OK' : 'ERR') : '-' }}
                  </td>
                  <td :class="part.isContentValid ? 'text-ok' : 'text-error'">
                    {{ part.isContentValid ? 'OK' : 'ERR' }}
                  </td>
                  <td>
                    <span class="badge" :class="part.isValid ? 'badge-ok' : 'badge-err'">
                      {{ part.isValid ? 'PASS' : 'FAIL' }}
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div v-if="!isTagNoValid" class="error-msg-box">
            <strong>분석 소견:</strong> {{ analysisFeedback }}
          </div>
        </section>
      </div>
    </div>

    <div v-if="showPasteModal" class="modal-overlay" @click.self="showPasteModal = false">
      <div class="modal-content">
        <h4>엑셀 데이터 일괄 입력</h4>
        <textarea v-model="pasteData" placeholder="구분자[Tab]정규식 형태로 입력하세요." rows="10"></textarea>
        <div class="modal-btns">
          <button @click="applyPasteData" class="btn-info">적용</button>
          <button @click="showPasteModal = false">닫기</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'

export default {
  setup() {
    const tagNoForValidator = ref('AP330X01-')
    const showPasteModal = ref(false)
    const pasteData = ref('')
    const tagRules = ref([
      { delimiter: '', regex: '^[A-Z]{2}$' },
      { delimiter: '', regex: '^[0-9]{3}$' },
      { delimiter: '', regex: '^[A-Z]{1}$' },
      { delimiter: '', regex: '^[A-Z]{0,1}$' },
      { delimiter: '', regex: '^[0-9]{2}$' },
      { delimiter: '-', regex: '^[A-Z0-9]{0,2}$' },
    ])

    const canBeEmpty = (regexStr) => {
      try { return new RegExp(`^(${regexStr.replace(/^\^|\$/g, '')})$`).test(''); } catch { return false; }
    }

    const tagParts = computed(() => {
      const results = [];
      let currentStr = tagNoForValidator.value || '';
      let cursor = 0;

      for (let i = 0; i < tagRules.value.length; i++) {
        const rule = tagRules.value[i];
        const delim = rule.delimiter;
        const pureRegex = rule.regex.replace(/^\^|\$/g, '');
        
        let dOk = true;
        let cOk = false;
        let matchedVal = null;
        const hasDelim = delim !== '';

        // 1. 구분자 확인
        if (hasDelim) {
          if (currentStr.substring(cursor).startsWith(delim)) {
            cursor += delim.length;
            dOk = true;
          } else {
            // 구분자가 없어도 내용이 옵셔널이면 통과 가능
            dOk = canBeEmpty(rule.regex);
          }
        }

        // 2. 내용 확인
        try {
          const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor));
          if (matcher) {
            matchedVal = matcher[1];
            cursor += matchedVal.length;
            cOk = true;
          } else if (canBeEmpty(rule.regex)) {
            matchedVal = '';
            cOk = true;
          }
        } catch { cOk = false; }

        results.push({
          hasDelimiterRule: hasDelim,
          isDelimiterValid: dOk,
          isContentValid: cOk,
          matchedValue: matchedVal,
          isValid: dOk && cOk
        });

        if (!(dOk && cOk)) break;
      }
      return results;
    })

    const isTagNoValid = computed(() => {
      if (tagParts.value.length !== tagRules.value.length) return false;
      if (!tagParts.value.every(p => p.isValid)) return false;
      
      // 글자 수 검증 (모든 규칙을 통과한 뒤 남은 글자가 없어야 함)
      let totalUsed = 0;
      tagParts.value.forEach((p, i) => {
        if (p.hasDelimiterRule && p.isDelimiterValid && tagNoForValidator.value.substring(totalUsed).startsWith(tagRules.value[i].delimiter)) {
            totalUsed += tagRules.value[i].delimiter.length;
        }
        if (p.matchedValue) totalUsed += p.matchedValue.length;
      });
      return totalUsed === (tagNoForValidator.value || '').length;
    })

    const combinedRegexDisplay = computed(() => {
      return tagRules.value.map(r => (r.delimiter ? `[${r.delimiter}]` : '') + `(${r.regex.replace(/^\^|\$/g, '')})`).join(' + ');
    })

    const analysisFeedback = computed(() => {
      if (isTagNoValid.value) return '모든 규칙이 일치합니다.';
      if (tagParts.value.length < tagRules.value.length) return `규칙 #${tagParts.value.length + (tagParts.value.every(p=>p.isValid)?1:0)} 구간에서 일치하는 데이터를 찾지 못했습니다.`;
      return '태그 번호 구성이 규칙과 맞지 않거나 글자 수가 남습니다.';
    })

    const addRule = () => tagRules.value.push({ delimiter: '', regex: '' });
    const removeRule = (i) => tagRules.value.splice(i, 1);
    const applyPasteData = () => {
      const rows = pasteData.value.trim().split('\n');
      tagRules.value = rows.map(row => {
        const cols = row.split('\t');
        return { delimiter: cols[0]?.trim() || '', regex: cols[1]?.trim() || '' };
      }).filter(r => r.delimiter || r.regex);
      showPasteModal.value = false;
    }

    return { tagNoForValidator, tagRules, tagParts, isTagNoValid, combinedRegexDisplay, analysisFeedback, addRule, removeRule, showPasteModal, pasteData, applyPasteData };
  }
}
</script>

