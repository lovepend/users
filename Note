<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-search-plus" :title="'Tag 통합 분석 조회' + (manualProjNo ? ` [ ${manualProjNo} ]` : '')">
      <template #actions>
        <div class="d-flex align-items-center gap-3 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold text-primary">Project No</span>
            <input type="text" class="form-control form-control-sm" style="width: 80px;" v-model="manualProjNo" />
          </label>
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold">조회 키워드</span>
            <textarea class="form-control form-control-sm" style="width: 180px; height: 31px; resize: none;" v-model="searchKeywordRef" placeholder="공백/엔터 구분"></textarea>
          </label>
          <button class="btn btn-xs btn-primary" @click="onSearch">조회</button>
          <div class="ms-3 ps-3 border-start d-flex align-items-center gap-2">
            <span class="fw-bold text-success"><i class="fa-filter"></i> 결과 필터</span>
            <input type="text" class="form-control form-control-sm border-success" style="width: 180px;" v-model="localFilterQuery" placeholder="필터 키워드" />
          </div>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <div class="panel m-0 p-0 h-100">
        <div class="panel-heading p-0 m-0">
          <div class="w-100 h-100">
            <BasicToolBar :showCreate="false" :showMultiCreate="false" :showSave="false" :showDelete="isSetupAdmin" :isDisabledDeleteBtn="isDisabledDeleteBtn" />
          </div>
        </div>
        <div class="panel-body overflow-hidden m-0 p-0 h-100">
          <ag-grid-vue v-bind="gridBindProps" @grid-ready="onGridReady" @selection-changed="onSelectionChanged" @cell-clicked="onCellClicked" />
        </div>
      </div>
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">{{ selectedRow?.Source }}</span>
            <span class="fw-bold text-white">Detail Analysis: {{ selectedRow?.TagNo }}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-xs" :class="isJsonMode ? 'btn-info' : 'btn-outline-info'" @click="isJsonMode = !isJsonMode">
              {{ isJsonMode ? 'Switch to Table' : 'Switch to JSON' }}
            </button>
            <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
          </div>
        </div>
        
        <div class="modal-body-content">
          <div v-if="!isJsonMode" class="h-100 w-100">
            <ag-grid-vue v-bind="modalGridBindProps" class="ag-theme-alpine w-100 h-100" />
          </div>
          <div v-else class="h-100 w-100 json-container">
            <pre class="json-content"><code>{{ JSON.stringify(selectedRow, null, 2) }}</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
import { storeToRefs } from 'pinia'
import { useAppPermissionStore } from '@/stores/app-permission'
import { useAppMenuStore } from '@/stores/app-menu'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import * as _ from 'lodash-es'

import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import { sAlert } from '@/utils/messages/alert-common'
import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

const { isSetupAdmin } = storeToRefs(useAppPermissionStore())
const appMenu = useAppMenuStore()

const gridApi = shallowRef()
const manualProjNo = ref(appMenu.currentProjNo || '')
const searchKeywordRef = ref('')
const localFilterQuery = ref('')
const rawDataList = ref([])
const isDisabledDeleteBtn = ref(true)

// 모달 및 뷰 모드 상태
const showModal = ref(false)
const isJsonMode = ref(false) // 기본은 테이블 뷰
const selectedRow = ref(null)

// --- 필터 및 하이라이트 ---
const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
  return rawDataList.value.filter(i => {
    const target = `${i.TagNo} ${i.EpId} ${i.ClsId} ${i.TagDesc}`.toLowerCase()
    return kws.some(kw => target.includes(kw))
  })
})

const highlightRenderer = (params) => {
  if (!params.value || !localFilterQuery.value.trim()) return params.value
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k)
  let text = String(params.value)
  kws.forEach(kw => { text = text.replace(new RegExp(`(${kw})`, 'gi'), `<mark class="filter-highlight">$1</mark>`) })
  return text
}

// --- 서버 데이터 조회 ---
const onSearch = () => getData()
const getData = async () => {
  if (!manualProjNo.value) return sAlert.Warning(`Project No를 입력하세요.`)
  gridApi.value.setGridOption('loading', true)
  const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
  let combined = []

  try {
    for (const key of searchKeys) {
      const payload = { ProjectNo: manualProjNo.value.trim(), Keyword: key }
      const [p, w] = await Promise.allSettled([
        axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
        axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
      ])
      if (p.status === 'fulfilled' && p.value) combined.push(...p.value.map(i => ({ ...i, Source: 'Published' })))
      if (w.status === 'fulfilled' && w.value) combined.push(...w.value.map(i => ({ ...i, Source: 'Working' })))
    }
    rawDataList.value = _.sortBy(combined.filter(i => !i.DELETED), ['TagNo', 'Source'])
  } finally { gridApi.value.setGridOption('loading', false) }
}

// --- 모달 AG Grid 설정 (셀 단위 분리) ---
const modalGridBindProps = computed(() => {
  if (!selectedRow.value) return {}
  const rows = []
  const ignore = ['Attributes', 'attributes', 'Source']
  
  // 1. 일반 속성 행 추가
  Object.entries(selectedRow.value).forEach(([k, v]) => {
    if (!ignore.includes(k)) rows.push({ category: 'System', key: k, value: typeof v === 'object' ? JSON.stringify(v) : v })
  })
  
  // 2. 어트리뷰트 리스트 행 추가 (셀 분리)
  const attrs = selectedRow.value.Attributes || selectedRow.value.attributes || []
  attrs.forEach(a => {
    rows.push({ category: 'Attribute', key: a.ATT_ID || 'N/A', value: a.VALUE ?? a.VALUE_DBL ?? '-' })
  })

  return {
    columnDefs: [
      { headerName: 'Category', field: 'category', pinned: 'left', width: 110, cellStyle: { background: '#f1f5f9', fontWeight: '600' } },
      { headerName: 'ID / Key', field: 'key', pinned: 'left', width: 220 },
      { headerName: 'Value', field: 'value', flex: 1, cellStyle: { color: '#0369a1' } }
    ],
    rowData: rows,
    defaultColDef: { sortable: true, filter: true, resizable: true },
    headerHeight: 32,
    rowHeight: 30
  }
})

const onCellClicked = (p) => { if (p.column.getColId() === 'Source') { selectedRow.value = p.data; showModal.value = true; isJsonMode.value = false; } }
const closeModal = () => { showModal.value = false; selectedRow.value = null; }

// --- 메인 그리드 설정 ---
const colDefs = [
  { headerName: 'Source', field: 'Source', minWidth: 100, pinned: 'left', cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'};color:white;cursor:pointer;">${p.value}</span>` },
  { field: 'TagIdx', headerName: 'TagIdx', minWidth: 100, pinned: 'left' },
  { field: 'TagNo', headerName: 'TagNo', minWidth: 160, pinned: 'left', cellRenderer: highlightRenderer },
  { field: 'EpId', headerName: 'EP ID', minWidth: 100, cellRenderer: highlightRenderer },
  { field: 'ClsId', headerName: 'Class', minWidth: 100, cellRenderer: highlightRenderer },
  { field: 'TagDesc', headerName: 'Description', minWidth: 300, flex: 1, cellRenderer: highlightRenderer }
]
const gridBindProps = computed(() => ({
  columnDefs: colDefs, rowData: filteredData.value, style: 'width: 100%; height: 100%', class: 'ag-theme-custom',
  pagination: true, paginationPageSize: 100, loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true, cellStyle: { background: '#fff' } }
}))

const onGridReady = p => { gridApi.value = p.api }
const onSelectionChanged = () => { isDisabledDeleteBtn.value = gridApi.value.getSelectedNodes().length === 0 }

defineOptions({ name: 'PubWrkFinalManager' })
</script>

<style scoped lang="scss">
/* 모달 레이아웃 최적화 */
.custom-modal-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center;
}
.custom-modal-window {
  background: #fff; width: 900px; height: 85%; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}
.modal-header-dark {
  background: #0f172a; color: #fff; padding: 10px 16px; display: flex; justify-content: space-between; align-items: center;
}
.modal-body-content { flex: 1; overflow: hidden; background: #fff; position: relative; }

/* JSON 뷰 스타일 */
.json-container {
  padding: 15px; background: #1e293b; overflow: auto;
}
.json-content {
  margin: 0; color: #f1f5f9; font-family: 'Consolas', monospace; font-size: 13px; line-height: 1.5;
}

/* 필터 하이라이트 */
::v-deep(.filter-highlight) {
  background-color: #ffeb3b; color: #000; padding: 0 2px; border-radius: 2px; font-weight: bold;
}

/* 그리드 스타일 보정 */
::v-deep(.ag-pinned-left-cols-container) { border-right: 1.5px solid #cbd5e1 !important; background: #fff; }
::v-deep(.badge) { font-size: 11px; font-weight: bold; padding: 3px 8px; border-radius: 4px; }
</style>
