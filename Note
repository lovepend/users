/* 2. 데이터 영역 (스크롤의 핵심) */
.content-panel { flex-grow: 1; background: white; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; border: 1px solid #e2e8f0; }
.scroll-container { flex-grow: 1; overflow: auto; position: relative; } /* 여기가 스크롤되는 구간 */

