{
      field: 'TOTAL',
      headerName: 'DATA QTY TOTAL',
      minWidth: 80,
      flex: 1,
      aggFunc: 'sum',
      // 1. 내장 숫자 타입 사용 (자동 우측 정렬)
      type: 'numericColumn', 
      // 2. 가장 심플한 콤마 표시법
      valueFormatter: params => params.value?.toLocaleString() ?? '0',
      cellStyle: params => {
        if (params.node.rowPinned) {
          return { fontWeight: 'bold', border: 'none', textAlign: 'right' }
        }
        return { textAlign: 'right' }
      },
    },
