.status-icon { font-size: 1.8rem; margin-right: 15px; }
.full-regex { font-size: 0.75rem; opacity: 0.8; margin-top: 5px; word-break: break-all; font-family: monospace; }
.badge { padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: bold; }
.badge-ok { background: #38a169; color: white; }
.badge-err { background: #e53e3e; color: white; }
.text-ok { color: #38a169; font-weight: bold; text-align: center; }
.text-error { color: #e53e3e; font-weight: bold; text-align: center; }
.btn-small { padding: 5px 12px; border-radius: 4px; border: none; cursor: pointer; font-size: 0.8rem; font-weight: bold; margin-left: 5px; }
.btn-success { background: #28a745; color: white; }
.btn-info { background: #17a2b8; color: white; }
.btn-delete { background: none; border: none; color: #dc3545; font-size: 1.2rem; cursor: pointer; }
