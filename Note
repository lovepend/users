{
  field: 'VALUE',
  headerName: 'VALUE',
  minWidth: 160,
  flex: 2,
  editable: true,
  cellDataType: 'object',
  valueParser: params => {
    const { newValue, data } = params
    if (!newValue) return null
    
    // OPER이 EQ일 때는 공백을 제거하지 않고 분리만 수행
    const isEq = data.OPER === 'EQ'
    if (typeof newValue === 'string') {
      return isEq ? newValue.split(',') : newValue.split(',').map(item => item.trim())
    }
    return newValue
  },
  valueFormatter: params => {
    const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'
    const isEq = params.data.OPER === 'EQ'

    if (isPbsField) {
      if (!params.value || (typeof params.value === 'string' && params.value.trim() === '')) {
        return ''
      }

      let tagIdxsToConvert = []
      if (typeof params.value === 'string') {
        // EQ인 경우 trim() 제외하고 분리
        tagIdxsToConvert = isEq ? params.value.split(',') : params.value.split(',').map(item => item.trim())
      } else if (Array.isArray(params.value)) {
        tagIdxsToConvert = params.value.map(item => isEq ? String(item) : String(item).trim())
      } else {
        tagIdxsToConvert = [isEq ? String(params.value) : String(params.value).trim()]
      }

      const transformedCodes = tagIdxsToConvert
        .map(tagIdx => {
          const code = getCodeByTagIdx(tagIdx)
          return code
        })
        .filter(code => code !== undefined && code !== null)

      // EQ일 때는 콤마 뒤에 강제 공백(', ')을 넣지 않고 원본 구분자(콤마)만 사용하거나 선택값 그대로 유지
      return isEq ? transformedCodes.join(',') : transformedCodes.join(', ')
    }

    return Array.isArray(params.value) 
      ? params.value.join(isEq ? ',' : ', ') 
      : params.value
  },
  cellEditorSelector: params => {
    const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE
    if (val_type === 'BOOL') {
      return undefined
    }

    const clIdExists = !!params.data.CL_ID
    const operatorIsIN = params.data.OPER === 'IN'
    const isEpField = params.data.ATT_ID === 'EP_IC' || params.data.ATT_ID === 'EP_ID'
    const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'

    let editorSourceData = []
    if (isPbsField) {
      if (params.data.ATT_ID === 'ASSEMBLY_NAME') {
        editorSourceData = Object.values(assemblyPbsComboData.value).map(item => item.display)
      } else if (params.data.ATT_ID === 'SYSTEM_NAME') {
        editorSourceData = Object.values(systemPbsComboData.value).map(item => item.display)
      }
    } else if (isEpField) {
      editorSourceData = epOfProjectCombo.value
    } else if (clIdExists) {
      editorSourceData = getValueFromCode(params.data.CL_ID)
    } else {
      editorSourceData = []
    }

    if ((isEpField || clIdExists || isPbsField) && operatorIsIN) {
      let pvMapListData = []
      if (isPbsField) {
        pvMapListData = Object.values(
          params.data.ATT_ID === 'ASSEMBLY_NAME' ? assemblyPbsComboData.value : systemPbsComboData.value
        ).map(item => item.display)
      } else if (isEpField) {
        pvMapListData = epOfProjectCombo.value
      } else if (clIdExists) {
        pvMapListData = getValueFromCode(params.data.CL_ID)
      }

      let initialPvMapValue = null
      if (params.value) {
        const isEq = params.data.OPER === 'EQ'
        const tagIdxs = String(params.value).split(',')
        const finalTagIdxs = isEq ? tagIdxs : tagIdxs.map(s => s.trim())
        
        const codes = finalTagIdxs
          .map(tagIdx => getCodeByTagIdx(tagIdx))
          .filter(c => c !== undefined && c !== null)
        
        initialPvMapValue = isEq ? codes.join(',') : codes.join(', ')
      }

      return {
        component: 'PvMapAttEditor',
        params: {
          listData: pvMapListData,
          isMultiple: true,
          isPushNew: true,
          placeholder: 'Select VALUE',
          value: initialPvMapValue,
        },
      }
    } else if (isEpField || clIdExists || isPbsField) {
      return {
        component: 'agRichSelectCellEditor',
        params: {
          values: editorSourceData,
          valueListGap: 5,
          allowTyping: true,
          filterList: true,
          highlightMatch: true,
          valueListMaxHeight: 220,
          formatValue: value => {
            if (isPbsField) {
              return getCodeByTagIdx(value) || value
            }
            return value
          },
        },
      }
    } else {
      return {
        component: 'agTextCellEditor',
      }
    }
  },
  valueSetter: params => {
    const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE
    if (val_type === 'BOOL') {
      params.data.VALUE = params.newValue
      return true
    }

    const { newValue, data } = params
    const isPbsField = data.ATT_ID === 'ASSEMBLY_NAME' || data.ATT_ID === 'SYSTEM_NAME'
    const isEq = data.OPER === 'EQ'
    let valueToStore = newValue

    if (isPbsField) {
      let codesToConvert = []

      if (typeof newValue === 'string' && newValue !== '') {
        // EQ일 때는 trim() 없이 분리만 수행
        codesToConvert = isEq ? newValue.split(',') : newValue.split(',').map(item => item.trim())
      } else if (Array.isArray(newValue)) {
        codesToConvert = newValue.map(item => isEq ? String(item) : String(item).trim())
      } else {
        codesToConvert = []
      }

      if (codesToConvert.length > 0) {
        const targetComboData = data.ATT_ID === 'ASSEMBLY_NAME' ? assemblyPbsComboData.value : systemPbsComboData.value

        const tagIdxArray = codesToConvert.map(code => {
          // 데이터 매핑 시에도 공백 포함된 원본 값으로 매칭 시도
          const found = Object.values(targetComboData).find(item => item.display === code)
          return found ? found.value : code
        })

        valueToStore = tagIdxArray.join(',')
      } else {
        valueToStore = ''
      }
    }

    // 최종 저장 문자열 처리
    if (typeof valueToStore === 'string' && valueToStore !== '') {
      const tokens = valueToStore.split(',')
      // EQ일 때는 각 요소의 trim()을 수행하지 않음
      valueToStore = isEq 
        ? tokens.join(',') 
        : tokens.map(s => s.trim()).filter(s => s.length > 0).join(',')
    }

    data.VALUE = valueToStore
    return true
  },
  cellRenderer: params => {
    const isEpField = params.data.ATT_ID === 'EP_IC' || params.data.ATT_ID === 'EP_ID'
    const isPbsField = params.data.ATT_ID === 'ASSEMBLY_NAME' || params.data.ATT_ID === 'SYSTEM_NAME'
    const isCodeListField = params.data.CL_ID

    if (isPbsField || isEpField || isCodeListField) {
      const tempParams = {
        ...params,
        value: params.valueFormatted,
      }
      return makeComboRender(tempParams)
    } else {
      return params.value ? `<div>${params.value}</div>` : undefined
    }
  },
  cellRendererSelector: params => {
    const val_type = LinkedAttrListRef.value.find(elem => elem.ATT_ID == params.data.ATT_ID)?.VAL_TYPE
    if (val_type === 'BOOL') {
      return {
        component: 'agCheckboxCellRenderer',
      }
    }
  },
  singleClickEdit: true,
}
