<template>
  <div class="panel panel-inverse" style="height: 100vh; display: flex; flex-direction: column;">
    <div class="panel-heading d-flex align-items-center justify-content-between" style="background: #2d353c; color: #fff; padding: 10px 15px;">
      <h4 class="panel-title m-0">Tag 분석 및 속성 비교 (Debug Mode)</h4>
      <div class="d-flex align-items-center gap-2">
        <input v-model="manualProjNo" class="form-control form-control-sm" style="width:120px" placeholder="프로젝트" />
        <input v-model="regTypeId" class="form-control form-control-sm" style="width:150px" placeholder="REG_TYPE_ID" />
        <button class="btn btn-xs btn-primary" @click="onSearch">조회</button>
      </div>
    </div>

    <div class="panel-body flex-grow-1 p-0" style="position: relative;">
      <div v-if="rowData.length === 0" class="position-absolute w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-light" style="z-index: 10;">
        <i class="fa fa-database fa-3x text-gray-400 mb-3"></i>
        <p class="text-gray-600">데이터를 불러오는 중이거나 조건에 맞는 데이터가 없습니다.</p>
      </div>
      
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="columnDefs"
        :rowData="rowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, shallowRef } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import { axiosWrapper } from '@/utils/axios/axios-wrapper';
import { sAlert } from '@/utils/messages/alert-common';

// --- State ---
const manualProjNo = ref('TE1002');
const regTypeId = ref('101TEST');
const containDeleted = ref(true);

const gridApi = shallowRef(null);
const columnDefs = ref([]);
const rowData = ref([]);
const diffMap = ref(new Map());

const defaultColDef = {
  sortable: true,
  filter: true,
  resizable: true,
  minWidth: 130
};

const onGridReady = (params) => {
  gridApi.value = params.api;
};

// --- Logic ---
const onSearch = async () => {
  try {
    if (gridApi.value) gridApi.value.showLoadingOverlay();

    const payload = {
      ProjectNo: manualProjNo.value.trim(),
      REG_TYPE_ID: regTypeId.value.trim(),
      ContainDeleted: containDeleted.value
    };

    const res = await axiosWrapper.post('/api/Data/GetPubWrkData', payload);
    
    // 🔍 [데이터 추출 핵심] 
    // 어떤 형태로 오든 PubData가 들어있는 객체를 찾아냄
    let targetData = null;
    if (res.PubData) targetData = res;
    else if (res.data && res.data.PubData) targetData = res.data;
    else if (res.data && res.data.data && res.data.data.PubData) targetData = res.data.data;
    
    // 💡 위 조건에도 불구하고 못 찾았다면, 리턴받은 res 자체를 콘솔에 찍어 구조 확인
    console.log('📦 최종 타겟 데이터:', targetData);

    if (!targetData) {
      console.error('❌ 가공 실패: PubData 구조를 찾을 수 없습니다.', res);
      sAlert.Error('데이터 구조 분석 실패 (Console 확인)');
      if (gridApi.value) gridApi.value.hideOverlay();
      return;
    }

    const pubSource = targetData.PubData || [];
    const wrkSource = targetData.WrkData || [];
    const diffSource = targetData.DiffData || [];

    // 1. Status 및 차이점 매핑 생성
    const statusMap = {};
    const newDiffMap = new Map();
    
    diffSource.forEach(d => {
      statusMap[d.TAG_IDX] = d.Status;
      if (d.Property) {
        d.Property.forEach(p => {
          if (p.PUB_VALUE !== p.WRK_VALUE) {
            newDiffMap.set(`${d.TAG_IDX}_${p.PROP_ID}`, true);
          }
        });
      }
    });
    diffMap.value = newDiffMap;

    // 2. 평면화 가공
    const flatten = (list, type) => {
      return list.map(item => {
        const row = { 
          ...item, 
          EditType: type, 
          Status: statusMap[item.TAG_IDX] || '' 
        };
        if (item.ATTRIBUTES && Array.isArray(item.ATTRIBUTES)) {
          item.ATTRIBUTES.forEach(attr => {
            row[attr.ATT_ID] = attr.VALUE;
          });
        }
        return row;
      });
    };

    const merged = [...flatten(pubSource, 'Publish'), ...flatten(wrkSource, 'Working')];

    if (merged.length === 0) {
      sAlert.Info('조회된 데이터가 없습니다.');
      rowData.value = [];
      if (gridApi.value) gridApi.value.hideOverlay();
      return;
    }

    // 3. TAG_IDX 정렬
    merged.sort((a, b) => {
      if (a.TAG_IDX === b.TAG_IDX) return a.EditType === 'Publish' ? -1 : 1;
      return String(a.TAG_IDX).localeCompare(String(b.TAG_IDX));
    });

    // 4. 컬럼 정의
    const fixed = ['EditType', 'Status', 'TAG_NO', 'TAG_IDX', 'CLS_ID', 'DELETED'];
    const allKeys = new Set(fixed);
    merged.forEach(row => Object.keys(row).forEach(k => {
      if (k !== 'ATTRIBUTES' && k !== '_id') allKeys.add(k);
    }));

    const newCols = Array.from(allKeys).map(key => ({
      field: key,
      headerName: key,
      pinned: fixed.includes(key) ? 'left' : null,
      cellStyle: (p) => {
        if (diffMap.value.has(`${p.data.TAG_IDX}_${key}`)) {
          return { backgroundColor: '#fff9db', color: '#d94111', fontWeight: 'bold' };
        }
        return null;
      }
    }));

    // 5. 그리드 반영
    columnDefs.value = newCols;
    rowData.value = merged;

    if (gridApi.value) {
      gridApi.value.hideOverlay();
      gridApi.value.setGridOption('columnDefs', newCols);
      gridApi.value.setGridOption('rowData', merged);
    }

  } catch (err) {
    console.error('💥 API 호출 에러:', err);
    sAlert.Error('조회 중 에러 발생');
  }
};
</script>

<style scoped>
.ag-theme-alpine {
  --ag-header-background-color: #f8f9fa;
  --ag-row-hover-color: #e9ecef;
}
</style>
