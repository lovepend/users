<template>
  <div id="app" class="admin-tool">
    <div class="main-layout">
      <header class="dashboard-header">
        <div class="search-grid">
          <div class="input-group project-box">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001" class="base-input" />
            <div class="filter-wrapper">
              <label class="sub-label">결과 내 필터</label>
              <input v-model="localSearchQuery" type="text" placeholder="Tag No 필터..." class="filter-input" />
            </div>
          </div>
          
          <div class="input-group keyword-box">
            <label>API Fetch Keywords</label>
            <textarea v-model="keyword" placeholder="TAG-01, TAG-02..." class="base-input keyword-input"></textarea>
          </div>
          
          <div class="button-box">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn-fetch-large">
              <span v-if="!isLoading">데이터 통합 조회하기</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
      </header>

      <div class="action-bar" v-if="mergedList.length > 0">
        <div class="stats">검색 결과: <b>{{ filteredList.length }}</b> 그룹</div>
        <div class="right-buttons">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <div class="table-container">
        <table class="modern-table">
          <thead>
            <tr class="main-header">
              <th rowspan="2" class="sticky-col col-chk"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
              <th rowspan="2" class="sticky-col col-idx">Idx</th>
              <th rowspan="2" class="sticky-col col-tag">Tag No</th>
              <th colspan="3" class="pub-header">Published (Master)</th>
              <th colspan="3" class="wrk-header">Working (Current)</th>
            </tr>
            <tr class="sub-header">
              <th>EP ID</th><th>CLS</th><th>Deleted</th>
              <th>EP ID</th><th>CLS</th><th>Deleted</th>
            </tr>
          </thead>
          
          <tbody v-for="group in filteredList" :key="group.TagIdx" class="group-tbody">
            <tr v-for="(rowNum) in Math.max(group.pubList.length, group.wrkList.length, 1)" :key="group.TagIdx + '-' + rowNum">
              
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" class="sticky-col col-chk group-fixed border-right">
                <div class="cell-content center"><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  class="sticky-col col-idx group-fixed clickable border-right" @click="openModal(group)">
                <div class="cell-content center">{{ group.TagIdx }}</div>
              </td>
              <td v-if="rowNum === 1" :rowspan="Math.max(group.pubList.length, group.wrkList.length, 1)" 
                  class="sticky-col col-tag group-fixed clickable border-bold-right" @click="openModal(group)">
                <div class="cell-content tag-text" v-html="highlightText(group.TagNo)"></div>
              </td>

              <td class="cell-pub clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-pub clickable" @click="openModal(group)">{{ group.pubList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-pub clickable" @click="openModal(group)">
                <span v-if="group.pubList[rowNum-1]" :class="['badge', group.pubList[rowNum-1].Deleted ? 'red' : 'green']">
                  {{ group.pubList[rowNum-1].Deleted }}
                </span>
              </td>

              <td class="cell-wrk clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.EpId || '-' }}</td>
              <td class="cell-wrk clickable" @click="openModal(group)">{{ group.wrkList[rowNum-1]?.ClsId || '-' }}</td>
              <td class="cell-wrk clickable" @click="openModal(group)">
                <span v-if="group.wrkList[rowNum-1]" :class="['badge', group.wrkList[rowNum-1].Deleted ? 'red' : 'green']">
                  {{ group.wrkList[rowNum-1].Deleted }}
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-content">
        <div class="modal-header">
          <h3>상세 정보 확인 <small>#{{ selectedItem?.TagNo }}</small></h3>
          <button @click="closeModal" class="btn-close">&times;</button>
        </div>
        <div class="modal-body">
          <div class="modal-grid">
            <div class="data-pane">
              <h4 class="pub-title">Published Data</h4>
              <pre>{{ JSON.stringify(selectedItem?.pubList, null, 2) }}</pre>
            </div>
            <div class="data-pane">
              <h4 class="wrk-title">Working Data</h4>
              <pre>{{ JSON.stringify(selectedItem?.wrkList, null, 2) }}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const showModal = ref(false)
    const selectedItem = ref(null)

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      const groupMap = new Map()
      try {
        const keywords = keyword.value.split(/[\s,\n]+/).filter(k => k)
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload)
          ])
          const pData = pubRes?.data || pubRes || []
          const wData = wrkRes?.data || wrkRes || []
          
          pData.forEach(i => {
            if(!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] })
            groupMap.get(i.TagIdx).pubList.push(i)
          })
          wData.forEach(i => {
            if(!groupMap.has(i.TagIdx)) groupMap.set(i.TagIdx, { TagIdx: i.TagIdx, TagNo: i.TagNo, pubList: [], wrkList: [] })
            groupMap.get(i.TagIdx).wrkList.push(i)
          })
        }))
        mergedList.value = Array.from(groupMap.values()).sort((a,b) => a.TagNo.localeCompare(b.TagNo))
      } finally { isLoading.value = false }
    }

    const openModal = (group) => {
      console.log('Opening Modal:', group) // 디버깅용
      selectedItem.value = group
      showModal.value = true
    }

    const closeModal = () => { showModal.value = false }

    const highlightText = (text) => {
      if (!localSearchQuery.value) return text
      const regex = new RegExp(`(${localSearchQuery.value})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, isLoading, selectedIds, showModal, selectedItem,
      fetchAndMergeData, openModal, closeModal, highlightText,
      filteredList: computed(() => {
        if (!localSearchQuery.value) return mergedList.value
        return mergedList.value.filter(g => g.TagNo.toLowerCase().includes(localSearchQuery.value.toLowerCase()))
      }),
      toggleAllSelect: () => {
        if (selectedIds.value.length === mergedList.value.length) selectedIds.value = []
        else selectedIds.value = mergedList.value.map(g => g.TagIdx)
      },
      isAllSelected: computed(() => mergedList.value.length > 0 && selectedIds.value.length === mergedList.value.length)
    }
  }
}
</script>

