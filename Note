<template>
  <div id="app" class="admin-tool">
    <div class="container">
      <header class="page-header">
        <h2 class="title">🔍 태그 통합 관리 시스템 <span class="badge-v">Group Mode</span></h2>
      </header>

      <section class="search-panel">
        <div class="search-grid">
          <div class="input-field w-20">
            <label>Project No</label>
            <input v-model="projectNo" type="text" placeholder="P0001..." class="base-input" />
          </div>
          <div class="input-field w-50">
            <label>API Fetch Keywords <span class="label-hint">(공백/줄바꿈 구분)</span></label>
            <textarea v-model="keyword" placeholder="TAG-01..." class="base-input multi-input"></textarea>
          </div>
          <div class="action-field">
            <button @click="fetchAndMergeData" :disabled="isLoading" class="btn btn-primary">
              <span v-if="!isLoading">데이터 호출</span>
              <span v-else class="loader"></span>
            </button>
          </div>
        </div>
        
        <div class="local-search-bar">
          <div class="input-field flex-grow">
            <label>결과 내 필터링 & 하이라이트</label>
            <input v-model="localSearchQuery" type="text" placeholder="검색어 입력..." class="base-input highlight-input" />
          </div>
        </div>
      </section>

      <div class="control-bar" v-if="mergedList.length > 0">
        <div class="left-info">
          <span class="count-badge">그룹 수: <b>{{ filteredList.length }}</b>개</span>
        </div>
        <div class="right-actions">
          <button @click="deleteSelected" class="btn btn-danger" :disabled="selectedIds.length === 0">🗑 선택 삭제 ({{ selectedIds.length }})</button>
          <button @click="downloadExcel" class="btn btn-success">📥 CSV 내보내기</button>
        </div>
      </div>

      <main class="content-panel">
        <div class="table-wrapper">
          <table class="modern-table">
            <thead>
              <tr class="main-header">
                <th rowspan="2" class="w-chk"><input type="checkbox" :checked="isAllSelected" @change="toggleAllSelect" /></th>
                <th rowspan="2" class="sortable" @click="sortBy('TagIdx')">Idx ↕</th>
                <th rowspan="2" class="sortable" @click="sortBy('TagNo')">Tag No ↕</th>
                <th colspan="2" class="col-group pub">Published (Master)</th>
                <th colspan="2" class="col-group wrk">Working (Current)</th>
              </tr>
              <tr class="sub-header">
                <th>레코드 수</th><th>대표 EP ID</th>
                <th>레코드 수</th><th>대표 EP ID</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="group in filteredList" :key="group.TagIdx" 
                  :class="['data-row', { 'row-selected': selectedIds.includes(group.TagIdx) }]"
                  @click="openModal(group)">
                <td @click.stop><input type="checkbox" :value="group.TagIdx" v-model="selectedIds" /></td>
                <td>{{ group.TagIdx }}</td>
                <td v-html="highlightText(group.TagNo)"></td>
                
                <td :class="group.pubList.length > 1 ? 'text-bold' : ''">
                  {{ group.pubList.length }} 건
                </td>
                <td>{{ group.pubList[0]?.EpId || '-' }}</td>

                <td :class="group.wrkList.length > 1 ? 'text-bold' : ''">
                  {{ group.wrkList.length }} 건
                </td>
                <td>{{ group.wrkList[0]?.EpId || '-' }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <div v-if="showModal" class="modal-overlay" @click.self="closeModal">
      <div class="modal-card wide-modal">
        <header class="modal-header">
          <h3>Tag Group Detail <small>Idx: {{ selectedItem?.TagIdx }} | TagNo: {{ selectedItem?.TagNo }}</small></h3>
          <button @click="closeModal" class="close-btn">&times;</button>
        </header>
        <div class="modal-body" v-if="selectedItem">
          <div class="group-detail-grid">
            <div class="detail-section">
              <h4 class="pub-title">📢 Published Records ({{ selectedItem.pubList.length }})</h4>
              <div v-for="(item, idx) in selectedItem.pubList" :key="'pub-'+idx" class="json-item">
                <div class="item-label">Record #{{ idx + 1 }}</div>
                <pre>{{ JSON.stringify(item, null, 2) }}</pre>
              </div>
              <div v-if="selectedItem.pubList.length === 0" class="no-data">데이터 없음</div>
            </div>

            <div class="detail-section">
              <h4 class="wrk-title">🛠 Working Records ({{ selectedItem.wrkList.length }})</h4>
              <div v-for="(item, idx) in selectedItem.wrkList" :key="'wrk-'+idx" class="json-item">
                <div class="item-label">Record #{{ idx + 1 }}</div>
                <pre>{{ JSON.stringify(item, null, 2) }}</pre>
              </div>
              <div v-if="selectedItem.wrkList.length === 0" class="no-data">데이터 없음</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'

export default {
  setup() {
    const projectNo = ref('')
    const keyword = ref('')
    const localSearchQuery = ref('')
    const mergedList = ref([])
    const isLoading = ref(false)
    const selectedIds = ref([])
    const sortKey = ref('TagNo')
    const sortOrder = ref(1)
    const showModal = ref(false)
    const selectedItem = ref(null)

    const filteredList = computed(() => {
      let list = [...mergedList.value]
      if (localSearchQuery.value.trim()) {
        const searchTerms = localSearchQuery.value.toLowerCase().split(/[\s,]+/).filter(t => t)
        list = list.filter(g => searchTerms.some(term => g.TagNo.toLowerCase().includes(term)))
      }
      list.sort((a, b) => {
        let vA = a[sortKey.value], vB = b[sortKey.value]
        return vA < vB ? -1 * sortOrder.value : vA > vB ? 1 * sortOrder.value : 0
      })
      return list
    })

    const fetchAndMergeData = async () => {
      if (!keyword.value.trim()) return
      isLoading.value = true
      selectedIds.value = []
      const keywords = keyword.value.split(/[\s,\n]+/).map(k => k.trim()).filter(k => k.length > 0)
      const groupMap = new Map() // TagIdx 기준 그룹화

      try {
        await Promise.all(keywords.map(async (key) => {
          const payload = { ProjectNo: projectNo.value, Keyword: key }
          const [pubRes, wrkRes] = await Promise.all([
            axiosWrapper.post('/api/Admin/Tool/GetPublishedData', payload),
            axiosWrapper.post('/api/Admin/Tool/GetWorkingData', payload),
          ])

          const getList = (res) => Array.isArray(res?.data || res) ? (res?.data || res) : []
          
          // 데이터 그룹화 로직 (누락 없이 배열에 push)
          getList(pubRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).pubList.push(item)
          })
          getList(wrkRes).forEach(item => {
            if (!groupMap.has(item.TagIdx)) groupMap.set(item.TagIdx, { TagIdx: item.TagIdx, TagNo: item.TagNo, pubList: [], wrkList: [] })
            groupMap.get(item.TagIdx).wrkList.push(item)
          })
        }))
        mergedList.value = Array.from(groupMap.values())
      } catch (err) { alert('데이터 호출 실패') }
      finally { isLoading.value = false }
    }

    const highlightText = (text) => {
      if (!localSearchQuery.value.trim()) return text
      const regex = new RegExp(`(${localSearchQuery.value.split(/[\s,]+/).filter(t=>t).join('|')})`, 'gi')
      return String(text).replace(regex, '<mark class="hl">$1</mark>')
    }

    const sortBy = (key) => {
      if (sortKey.value === key) sortOrder.value *= -1
      else { sortKey.value = key; sortOrder.value = 1 }
    }

    return {
      projectNo, keyword, localSearchQuery, mergedList, filteredList, isLoading,
      selectedIds, sortKey, sortOrder, showModal, selectedItem,
      fetchAndMergeData, sortBy, highlightText,
      openModal: (g) => { selectedItem.value = g; showModal.value = true },
      closeModal: () => { showModal.value = false; selectedItem.value = null },
      toggleAllSelect: () => { 
        if (filteredList.value.length === selectedIds.value.length) selectedIds.value = []
        else selectedIds.value = filteredList.value.map(i => i.TagIdx)
      },
      isAllSelected: computed(() => filteredList.value.length > 0 && selectedIds.value.length === filteredList.value.length),
      deleteSelected: () => confirm('정말 삭제하시겠습니까?') && console.log(selectedIds.value)
    }
  }
}
</script>

