{
  field: 'DESC',
  headerName: 'Description',
  minWidth: 120,
  flex: 4,
  editable: false,
  cellClass: 'agReadOnly',
  // 추가: 필터와 검색이 이 값을 참조하도록 설정
  valueGetter: params => {
    const dataItem = params.data;
    const attInfo = attDictRef.value?.[dataItem?.ATT_ID];
    return attInfo?.DESC ?? '';
  },
  // cellRenderer는 그대로 두거나, valueGetter가 있으면 params.value로 간단히 사용 가능
  cellRenderer: params => params.value 
},



{
  field: 'CL_ID',
  headerName: 'Code',
  minWidth: 90,
  flex: 2,
  editable: false,
  cellClass: 'agReadOnly',
  // 추가: 실제 데이터 모델에는 없더라도 ATT_ID를 통해 찾아온 CL_ID를 필터에 제공
  valueGetter: params => {
    const dataItem = params.data;
    const attInfo = attDictRef.value?.[dataItem?.ATT_ID];
    return attInfo?.CL_ID ?? '';
  },
  cellRenderer: params => {
    const dataItem = params.data;
    const editableDef = params.colDef?.editable;
    const editable = (
      DU.isFunction(editableDef) ? editableDef(params) : editableDef
    );
    
    // valueGetter 덕분에 이제 params.value에 clId가 들어있습니다.
    const clId = params.value; 

    const queryParam = {};
    const projNo = dataItem?.PROJ_NO || currentProjNo.value;
    if (projNo) {
      queryParam.proj_no = projNo;
      if (currentEpId.value && projNo === currentProjNo.value) {
        queryParam.ep_id = currentEpId.value;
      }
      if (clId) {
        queryParam.cl_id = clId;
      }
    }
    return makeComboRender({
      value: clId,
      editable: editable,
      linkUrl: '/code-setup',
      linkParam: queryParam,
    });
  },
},
