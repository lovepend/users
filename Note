                @tab-change="onTabChange('예시1', $event)"
              >
                <template #header-right>
                  <ButtonsComponent :buttons="buttonData0" @button-click="handleButtonClick" />
                </template>
                <template #actions>
                  <CheckBox
                    id="tpl-cb-agree"
                    label="약관 동의"
                    v-model:value="checkDemo.agree"
                    @change="onCheckDemoChange('agree', $event)"
                  />
                </template>
                <div class="tpl-mini-grid" role="table" aria-label="샘플 데이터">
                  <div class="tpl-mini-grid__head tpl-mini-grid__row">
                    <span>코드</span><span>항목</span><span>수량</span><span>상태</span>
                  </div>
                  <div v-for="row in miniRows" :key="row.code" class="tpl-mini-grid__row">
                    <span>{{ row.code }}</span
