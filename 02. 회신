<template>
  <div class="d-flex flex-column h-100 bg-white main-container">
    <div class="p-3 border-bottom shadow-sm bg-light control-header">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Project</span>
            <div class="dropdown custom-dropdown-container">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle text-start d-flex justify-content-between align-items-center bg-white project-btn"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <span class="text-truncate">
                  {{ selectedProject ? selectedProject : '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-lg project-menu">
                <li class="px-2 pb-2 border-bottom mb-2">
                  <input 
                    type="text" 
                    class="form-control form-control-sm" 
                    v-model="projectSearchKeyword" 
                    placeholder="프로젝트 검색..." 
                    @click.stop 
                  />
                </li>
                <div class="project-list-scroll">
                  <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO">
                    <button class="dropdown-item rounded-2 py-2" @click="selectedProject = proj.PROJ_NO">
                      <div class="d-flex flex-column">
                        <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                        <small class="text-muted text-truncate">{{ proj.DESC }}</small>
                      </div>
                    </button>
                  </li>
                  <li v-if="filteredProjectList.length === 0" class="text-center py-3 text-muted">
                    검색 결과가 없습니다.
                  </li>
                </div>
              </ul>
            </div>
          </div>

          <button 
            class="btn btn-sm btn-primary px-3 shadow-sm btn-search" 
            @click="onSearch" 
            :disabled="!selectedProject || loading"
          >
            <i class="fa" :class="loading ? 'fa-spinner fa-spin' : 'fa-search me-1'"></i> 비교 분석 실행
          </button>
        </div>

        <div class="d-flex align-items-center gap-2 filter-box">
          <span class="fw-bold text-success text-nowrap"><i class="fa fa-filter me-1"></i>멀티 필터</span>
          <textarea 
            class="form-control form-control-sm border-success custom-textarea-filter" 
            v-model="attributeFilter" 
            rows="1" 
            placeholder="TYPE_ID 입력 (엔터/쉼표)"
          ></textarea>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 grid-wrapper">
      <ag-grid-vue
        class="ag-theme-alpine w-100 h-100"
        :columnDefs="columnDefs"
        :rowData="gridRowData"
        :defaultColDef="defaultColDef"
        @grid-ready="onGridReady"
        :loadingOverlayComponent="'AggridLoadingOverlay'"
        :isExternalFilterPresent="isExternalFilterPresent"
        :doesExternalFilterPass="doesExternalFilterPass"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'

const route = useRoute()

// --- 상태 관리 ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProject = ref('')
const attributeFilter = ref('')
const loading = ref(false)
const gridApi = shallowRef(null)
const gridRowData = ref([])

const urlEpId = computed(() => route.query.ep_id || 'TeEP')

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
    if (route.query.project_no) selectedProject.value = route.query.project_no
  } catch (e) { console.error(e) }
})

const onSearch = async () => {
  if (!selectedProject.value) return sAlert.Warning('프로젝트를 선택하세요.')
  loading.value = true
  gridApi.value?.showLoadingOverlay()

  try {
    const config = { headers: { 'Projectno': selectedProject.value, 'Ep_id': urlEpId.value } }
    const payload = { ProjectNo: selectedProject.value, ContainDeleted: false }

    const [regRes, attrRes] = await Promise.all([
      axiosWrapper.post('/api/Register/Get', payload, config),
      axiosWrapper.post('/api/Attributes/Get', payload, config)
    ])

    const masterMap = new Map((attrRes || []).map(a => [a.ATT_ID, a]))

    const processed = (regRes || []).map(reg => {
      const lnkAtts = reg.LNK_ATT || []
      let mismatchIds = []
      
      lnkAtts.forEach(lnk => {
        const mst = masterMap.get(lnk.ATT_ID)
        if (mst && lnk.UOM_ID !== mst.UOM_ID) {
          mismatchIds.push(lnk.ATT_ID)
        }
      })

      return {
        ...reg,
        CONDITION: mismatchIds.length > 0 ? 'Mismatch' : 'Match',
        DIFF_LIST: mismatchIds.join(', ')
      }
    })

    gridRowData.value = processed
  } catch (e) {
    sAlert.Error('데이터 조회 중 오류 발생')
  } finally {
    loading.value = false
    gridApi.value?.hideOverlay()
  }
}

// --- 그리드 정의 ---
const defaultColDef = { sortable: true, filter: true, resizable: true, floatingFilter: true }
const columnDefs = computed(() => [
  { 
    headerName: '상태', field: 'CONDITION', width: 110, pinned: 'left',
    cellRenderer: p => `<span class="badge bg-${p.value === 'Mismatch' ? 'danger' : 'success'}">${p.value}</span>`,
    cellStyle: { display: 'flex', alignItems: 'center', justifyContent: 'center' }
  },
  { headerName: 'TYPE_ID', field: 'TYPE_ID', width: 200, pinned: 'left', filter: 'agTextColumnFilter' },
  { headerName: '다른값 속성 목록', field: 'DIFF_LIST', flex: 1, minWidth: 200, cellStyle: { color: '#dc3545', fontWeight: 'bold' } },
  { headerName: 'Description', field: 'DESC', flex: 1.5, minWidth: 250 },
])

const onGridReady = (params) => {
  gridApi.value = params.api
  params.api.sizeColumnsToFit()
}

// --- 필터링 로직 ---
const isExternalFilterPresent = () => attributeFilter.value.trim() !== ''
const doesExternalFilterPass = (node) => {
  const kw = attributeFilter.value.toLowerCase()
  return (node.data.TYPE_ID || '').toLowerCase().includes(kw) || (node.data.DIFF_LIST || '').toLowerCase().includes(kw)
}

watch(attributeFilter, () => gridApi.value?.onFilterChanged())
</script>

