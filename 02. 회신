<template>
  <div class="d-flex flex-column vh-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light flex-shrink-0">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2">
                  {{ selectedProject || '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 번호/명 검색..."
                    @click.stop
                  />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="d-flex align-items-center w-100 m-0" style="cursor: pointer" @click="selectedProject = proj.PROJ_NO">
                    <span class="text-truncate">
                      <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                      <small class="text-muted ms-1">({{ proj.DESC }})</small>
                    </span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <button
            class="btn btn-sm btn-primary px-3 shadow-sm"
            @click="onSearch"
            :disabled="!selectedProject || loading"
          >
            <i class="fa me-1" :class="loading ? 'fa-spinner fa-spin' : 'fa-search'"></i>비교 조회
          </button>

          <div class="view-mode-toggle-container ms-3">
            <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
              <input type="radio" class="btn-check" id="modeSimple" value="simple" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeSimple">간편 조회</label>

              <input type="radio" class="btn-check" id="modeDetail" value="detail" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeDetail">상세 조회</label>
            </div>
          </div>
        </div>

        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-success text-nowrap"><i class="fa fa-filter me-1"></i>멀티 필터</span>
          <textarea
            class="form-control form-control-sm border-success custom-textarea-filter"
            v-model="attributeFilter"
            rows="1"
            placeholder="TYPE_ID 입력 (엔터/쉼표 구분)"
          ></textarea>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden position-relative">
      <ag-grid-vue
        style="width: 100%; height: 100%"
        class="ag-theme-alpine"
        v-bind="gridOptions"
        @grid-ready="onGridReady"
      />
    </div>
  </div>
</template>

<script setup>
/* AG-Grid 테마 필수 CSS */
import 'ag-grid-community/styles/ag-grid.css';
import 'ag-grid-community/styles/ag-theme-alpine.css';

import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

const route = useRoute()

const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProject = ref('')
const attributeFilter = ref('')
const viewMode = ref('simple')
const loading = ref(false)

const gridApi = shallowRef()
const gridRowData = ref([])

const urlEpId = computed(() => route.query.ep_id || 'TeEP')

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw))
})

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

// --- 비교 로직 변경 반영 ---
const onSearch = async () => {
  if (!selectedProject.value) return sAlert.Warning('프로젝트를 선택하세요.')
  loading.value = true
  gridApi.value?.setGridOption('loading', true)

  try {
    const config = { headers: { Projectno: selectedProject.value, Ep_id: urlEpId.value } }
    const [regRes, attrRes] = await Promise.all([
      axiosWrapper.post('/api/Register/Get', { ProjectNo: selectedProject.value }, config),
      axiosWrapper.post('/api/Attributes/Get', { ProjectNo: selectedProject.value }, config),
    ])

    const masterMap = new Map((attrRes || []).map(a => [a.ATT_ID, a]))

    const processed = (regRes || []).map(reg => {
      const lnkAtts = reg.LNK_ATT || []
      let diffIds = []
      let diffDetails = []

      lnkAtts.forEach(lnk => {
        const mst = masterMap.get(lnk.ATT_ID)
        if (mst && (mst.UOM_ID && mst.UOM_ID.trim() !== '')) {
          // [새 로직]: 마스터에는 UOM이 있는데, 레지스터에는 없거나 비어있는 경우만 체크
          const registerUom = lnk.UOM_ID || ''
          
          if (registerUom.trim() === '') {
            diffIds.push(lnk.ATT_ID)
            diffDetails.push(`${lnk.ATT_ID} (마스터:${mst.UOM_ID} → 레지스터:비어있음)`)
          }
        }
      })

      return {
        ...reg,
        CONDITION: diffIds.length > 0 ? 'Diff' : 'Pass',
        DIFF_LIST: diffIds.join(', '),
        DIFF_DETAIL: diffDetails.join(' | '),
      }
    })

    gridRowData.value = processed
  } catch (e) { sAlert.Error('조회 실패') }
  finally {
    loading.value = false
    gridApi.value?.setGridOption('loading', false)
  }
}

const columnDefs = computed(() => [
  {
    headerName: 'Condition', field: 'CONDITION', width: 110, pinned: 'left',
    cellStyle: p => ({
      color: p.value === 'Diff' ? '#dc3545' : '#198754',
      fontWeight: 'bold', textAlign: 'center',
      backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8',
    }),
  },
  { headerName: 'TYPE_ID', field: 'TYPE_ID', width: 180, pinned: 'left' },
  { headerName: 'Description', field: 'DESC', width: 250 },
  {
    headerName: 'UOM 누락 목록', 
    field: 'DIFF_LIST', width: 180,
    cellStyle: { color: '#dc3545', fontWeight: 'bold', fontSize: '11px' },
  },
  {
    headerName: '누락 상세 정보',
    field: 'DIFF_DETAIL', flex: 1, minWidth: 350,
    cellStyle: { fontSize: '12px', color: '#0d6efd' },
    hide: viewMode.value === 'simple'
  },
])

const gridOptions = computed(() => ({
  columnDefs: columnDefs.value,
  rowData: gridRowData.value,
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true },
  isExternalFilterPresent: () => attributeFilter.value.trim() !== '',
  doesExternalFilterPass: node => {
    const kws = attributeFilter.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
    const target = String(node.data.TYPE_ID || '').toLowerCase()
    return kws.length === 0 || kws.some(kw => target.includes(kw))
  },
}))

const onGridReady = p => { gridApi.value = p.api }
watch(attributeFilter, () => gridApi.value?.onFilterChanged())
</script>

