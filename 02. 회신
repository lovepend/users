<template>
  <div class="template__page panel panel-expandable m-0 p-0 h-100 d-flex flex-column bg-white">
    
    <PageTitle
      class="template__page-head border-bottom"
      icon="fa-search-plus"
      :title="'Tag 통합 분석 및 속성 비교' + (selectedProjNo ? ` [ ${selectedProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center flex-wrap gap-2 ms-auto me-2">
          
          <div class="d-flex align-items-center gap-2 me-2">
            <span class="fw-bold text-dark text-nowrap small">Project</span>
            <div class="dropdown custom-single-select" style="min-width: 220px">
              <button
                class="btn btn-sm btn-white border dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center shadow-sm"
                type="button"
                data-bs-toggle="dropdown"
              >
                <span class="text-truncate">{{ selectedProjNo || 'Select Project' }}</span>
              </button>
              <ul class="dropdown-menu shadow-lg p-0" style="max-height: 400px; min-width: 250px; overflow: hidden;">
                <li class="p-2 bg-light border-bottom">
                  <input type="text" class="form-control form-control-sm" v-model="projSearchQuery" placeholder="Search..." @click.stop />
                </li>
                <div style="max-height: 300px; overflow-y: auto">
                  <li v-for="proj in filteredProjectOptions" :key="proj.value">
                    <div class="dropdown-item d-flex align-items-center gap-2 py-2 cursor-pointer"
                         :class="{ 'active-proj': selectedProjNo === proj.value }" @click="selectProject(proj.value)">
                      <i class="fa fa-check text-primary" v-if="selectedProjNo === proj.value"></i>
                      <i class="fa fa-circle-o text-muted" v-else></i>
                      <span>{{ proj.text }}</span>
                    </div>
                  </li>
                </div>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2 px-2 border-start">
            <span class="fw-bold text-nowrap small">조회 키워드</span>
            <textarea 
              class="form-control form-control-sm" 
              style="width: 180px; height: 31px; resize: none; font-size: 11px;"
              v-model="searchKeywordRef" 
              placeholder="Tag No (공백/엔터)"
            ></textarea>
            <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch">
              <i class="fa fa-search me-1"></i>조회
            </button>
          </div>

          <div class="d-flex align-items-center gap-2 px-2 border-start">
            <span class="fw-bold text-success text-nowrap small"><i class="fa fa-filter"></i> 필터</span>
            <input type="text" class="form-control form-control-sm border-success" 
                   style="width: 140px;" v-model="localFilterQuery" placeholder="결과 내 검색" />
          </div>

          <div class="d-flex align-items-center gap-2 px-2 border-start">
            <span class="fw-bold text-primary text-nowrap small"><i class="fa fa-columns"></i> 컬럼</span>
            <input type="text" class="form-control form-control-sm border-primary" 
                   style="width: 120px;" v-model="columnFilterQuery" placeholder="컬럼명 검색" />
          </div>
        </div>
      </template>
    </PageTitle>

    <div class="template__stack panel-body flex-grow-1 overflow-hidden m-0 p-0 h-100 bg-light">
      <ag-grid-vue
        v-bind="gridBindProps"
        class="ag-theme-alpine w-100 h-100"
        @grid-ready="onGridReady"
        @cell-clicked="onCellClicked"
      />
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window shadow-lg">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">{{ selectedRow?.Source }}</span>
            <span class="fw-bold">Detail View: {{ selectedRow?.TAG_NO }}</span>
          </div>
          <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
        </div>
        <div class="modal-body-content overflow-auto">
          <div class="modal-grid-container ag-theme-alpine h-100">
            <ag-grid-vue v-bind="modalGridBindProps" class="w-100 h-100" />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { storeToRefs } from 'pinia'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sortBy } from 'lodash-es'
import { useAppMenuStore } from '@/stores/app-menu'
import { sAlert } from '@/utils/messages/alert-common'
import PageTitle from '@/components/toolBar/PageTitle.vue'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

import 'ag-grid-enterprise'
import 'ag-grid-community/styles/ag-grid.css'
import 'ag-grid-community/styles/ag-theme-alpine.css'

const router = useRouter()
const appMenu = useAppMenuStore()
const { currentProjNo } = storeToRefs(appMenu)

const gridApi = shallowRef()
const projectOptions = ref([])
const selectedProjNo = ref('')
const projSearchQuery = ref('')
const searchKeywordRef = ref('')
const localFilterQuery = ref('')
const columnFilterQuery = ref('')
const rawDataList = ref([])
const dynamicAttCols = ref([])
const dynamicRemainingCols = ref([])
const showModal = ref(false)
const selectedRow = ref(null)

// 프로젝트 목록 로드
onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectOptions.value = res.map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
    if (currentProjNo.value) selectedProjNo.value = currentProjNo.value
  } catch (e) { console.error(e) }
})

const filteredProjectOptions = computed(() => {
  if (!projSearchQuery.value.trim()) return projectOptions.value
  return projectOptions.value.filter(p => p.text.toLowerCase().includes(projSearchQuery.value.toLowerCase()))
})

const selectProject = val => { selectedProjNo.value = val }

// 데이터 조회 로직
const onSearch = async () => {
  if (!selectedProjNo.value) return sAlert.Warning('Project No를 선택하세요.')
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
    let combined = []

    for (const key of searchKeys) {
      const payload = { ProjectNo: selectedProjNo.value, Keyword: key }
      const [p, w] = await Promise.allSettled([
        axiosWrapper.post('/api/Data/SearchPublishData', payload),
        axiosWrapper.post('/api/Data/SearchWorkingData', payload),
      ])
      if (p.status === 'fulfilled' && p.value) {
        const data = Array.isArray(p.value) ? p.value : [p.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Published' })))
      }
      if (w.status === 'fulfilled' && w.value) {
        const data = Array.isArray(w.value) ? w.value : [w.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Working' })))
      }
    }

    const allAttIds = new Set()
    const allKeys = new Set()
    const fixedKeys = ['Source', 'DELETED', 'TAG_IDX', 'TAG_NO', 'EP_ID', 'CLS_ID', 'ATTRIBUTES', '_id']

    combined.forEach(item => {
      ;(item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
      Object.keys(item).forEach(k => { if (!fixedKeys.includes(k) && typeof item[k] !== 'object') allKeys.add(k) })
    })

    const processedData = combined.map(item => {
      const flatItem = { ...item, TAG_IDX: item.TAG_IDX ?? '-' }
      allAttIds.forEach(id => {
        const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
        flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
      })
      return flatItem
    })

    // 동적 컬럼 정의
    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id, field: `ATT_${id}`, minWidth: 130, headerClass: 'att-column-header',
      cellRenderer: highlightRenderer,
      cellStyle: p => ({ background: '#fff9db', color: p.value === 'null' ? '#adb5bd' : '#000' }),
    }))
    
    dynamicRemainingCols.value = Array.from(allKeys).sort().map(k => ({ 
      headerName: k, field: k, minWidth: 150, cellRenderer: highlightRenderer 
    }))
    
    rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
  } catch (err) { sAlert.Error('조회 실패') } 
  finally { if (gridApi.value) gridApi.value.setGridOption('loading', false) }
}

const highlightRenderer = p => {
  const val = p.value === null || p.value === undefined ? '' : String(p.value)
  if (!val || !localFilterQuery.value.trim()) return val
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k)
  let text = val
  kws.forEach(kw => {
    const escapedKw = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    text = text.replace(new RegExp(`(${escapedKw})`, 'gi'), `<mark class="filter-highlight">$1</mark>`)
  })
  return text
}

// 메인 컬럼 정의 (TAG_IDX 고정 포함)
const mainColDefs = computed(() => {
  const cols = [
    { headerName: '', width: 45, pinned: 'left', checkboxSelection: true, headerCheckboxSelection: true, sortable: false, filter: false, floatingFilter: false },
    {
      headerName: 'Source', field: 'Source', width: 100, pinned: 'left',
      cellRenderer: p => `<span class="badge" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'}; color:white; font-size:10px;">${p.value}</span>`,
    },
    { field: 'TAG_IDX', headerName: 'Tag Idx', width: 90, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'TAG_NO', headerName: 'Tag No', width: 170, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'CLS_ID', headerName: 'Class', width: 130, pinned: 'left', cellRenderer: highlightRenderer, cellStyle: { cursor: 'pointer', color: '#0d6efd', fontWeight: 'bold' } },
    ...dynamicAttCols.value,
    ...dynamicRemainingCols.value
  ]
  return cols.filter(c => {
    if (!columnFilterQuery.value.trim() || c.pinned) return true
    return c.headerName.toLowerCase().includes(columnFilterQuery.value.toLowerCase())
  })
})

const gridBindProps = computed(() => ({
  columnDefs: mainColDefs.value,
  rowData: filteredData.value,
  pagination: true,
  paginationPageSize: 100,
  rowSelection: 'multiple',
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { 
    sortable: true, filter: 'agTextColumnFilter', floatingFilter: true, resizable: true 
  },
}))

const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const query = localFilterQuery.value.toLowerCase()
  return rawDataList.value.filter(i => Object.values(i).some(v => String(v).toLowerCase().includes(query)))
})

const onGridReady = p => { gridApi.value = p.api }
const onCellClicked = p => { if(p.column.getColId() === 'Source') { selectedRow.value = p.data; showModal.value = true; } }
const closeModal = () => { showModal.value = false }
</script>

