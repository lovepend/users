<script setup>
import { shallowRef } from 'vue'
import { saveAs } from 'file-saver'
import GC from '@mescius/spread-sheets-designer'

// 언어 리소스 import
import GCLangResKO from '@/lang/spread/spread_language_KO'
import GCLangResEN from '@/lang/spread/spread_language_EN'
import GCLangResJA from '@/lang/spread/spread_language_JA'
import GCLangResCN from '@/lang/spread/spread_language_CN'

window.GC = GC

const DesignerRef = shallowRef(null)
const SpreadRef = shallowRef(null)

// 테이블 순번 관리를 위한 변수
let tableCount = 1;

/**
 * 디자이너 초기화
 */
const initDesigner = function (designer) {
  DesignerRef.value = designer
  SpreadRef.value = designer.getWorkbook()
  
  // 초기 시트 설정
  const spread = SpreadRef.value;
  if (spread) {
    const sheet = spread.getActiveSheet();
    sheet.name("Merged Data");
  }
}

/**
 * 1. API 호출 및 데이터 뿌리기 (값만 붙여넣기 + 체크박스)
 */
const loadData = async () => {
  const spread = SpreadRef.value;
  if (!spread) return;

  const sheet = spread.getActiveSheet();

  try {
    const response = await fetch('/api/Data/GetMergedData', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Projectno': 'TE1002'
      },
      body: JSON.stringify({
        "ProjectNo": "TE1002",
        "REG_TYPE_ID": "101TEST",
        "Type": "Merged"
      })
    });

    const resData = await response.json();
    const firstKey = Object.keys(resData)[0];
    const listData = resData[firstKey]?.WrkData || [];

    if (listData.length === 0) {
      alert("조회된 데이터가 없습니다.");
      return;
    }

    sheet.suspendPaint();

    // 시작 위치 계산 (기존 데이터 아래로 배치)
    const usedRange = sheet.getUsedRange(GC.Spread.Sheets.UsedRangeType.data);
    const startRow = usedRange ? usedRange.row + usedRange.rowCount + 2 : 1;
    const currentTableName = `Table${tableCount++}`;

    // 2D 배열 생성 (값만 추출)
    // 첫 컬럼은 체크박스용 false값
    const headers = [["선택", "태그 번호", "설명", "클래스 ID", "상태"]];
    const bodyValues = listData.map(item => [
      false, 
      item.TAG_NO,
      item.TAG_DESC,
      item.CLS_ID,
      item.TAG_NO_PASSED
    ]);

    // 값 입력
    sheet.setArray(startRow, 0, headers);
    sheet.setArray(startRow + 1, 0, bodyValues);

    // 표(Table) 정의
    const table = sheet.tables.add(
      currentTableName, 
      startRow, 0, 
      bodyValues.length + 1, 
      headers[0].length, 
      GC.Spread.Sheets.Tables.TableThemes.medium2
    );

    // 맨 앞 컬럼 체크박스 셀타입 적용
    const checkboxCell = new GC.Spread.Sheets.CellTypes.CheckBox();
    sheet.getRange(startRow + 1, 0, bodyValues.length, 1).cellType(checkboxCell);

    // 컬럼 사이즈 조정
    sheet.setColumnWidth(0, 45);
    sheet.setColumnWidth(1, 150);
    sheet.setColumnWidth(2, 250);

    sheet.resumePaint();
    console.log(`${currentTableName} 생성 및 데이터 바인딩 완료`);

  } catch (error) {
    console.error("API 로드 에러:", error);
  }
};

/**
 * 2. 체크박스 선택된 데이터 추출 (CRUD용)
 */
const getCheckedData = () => {
  const spread = SpreadRef.value;
  const sheet = spread.getActiveSheet();
  const tables = sheet.tables.all();
  
  let allSelected = [];
  
  tables.forEach(table => {
    const range = table.range();
    for (let i = 1; i < range.rowCount; i++) {
      const isChecked = sheet.getValue(range.row + i, range.col);
      if (isChecked) {
        allSelected.push({
          row: range.row + i,
          tagNo: sheet.getValue(range.row + i, range.col + 1),
          desc: sheet.getValue(range.row + i, range.col + 2)
        });
      }
    }
  });

  console.log("선택된 데이터:", allSelected);
  alert(allSelected.length + "건이 선택되었습니다. 콘솔을 확인하세요.");
};

// --- 기존 로직 유지 ---
const _SpreadVersion = '18.0.7'
const DownloadTypeRef = shallowRef('KO')
const LanguageTypeRef = shallowRef('KO')
const _LangType = { KO: 'KO', EN: 'EN', JA: 'JA', CN: 'CN' }

const onDownloadLocaleResource = function () {
  const languageType = DownloadTypeRef.value
  if (!languageType || !_LangType[languageType]) return
  try {
    let version = _SpreadVersion
    const spread = SpreadRef.value
    if (spread) {
      const spreadInfo = spread.toJSON()
      const spreadVersion = spreadInfo?.version
      if (spreadVersion) version = spreadVersion
    }
    const resource = GC.Spread.Sheets.Designer.getResources()
    const resourceJson = JSON.stringify(resource)
    let sourceJson = `const version = "${version}";\nconst locale = "${languageType}";\nexport default \`${resourceJson}\`;`
    
    // 이스케이프 처리
    sourceJson = sourceJson.replaceAll('\\', '\\\\').replaceAll('${', '&#36;{')
    
    saveAs(new Blob([sourceJson], { type: 'text/javascript;charset=utf-8' }), `spread_language_${languageType}.js`)
  } catch (error) {
    console.error(error)
    alert(error.message)
  }
}

const spreadLocalization = function (LOCALE) {
  const resMap = { 'KO': GCLangResKO, 'JA': GCLangResJA, 'CN': GCLangResCN, 'EN': GCLangResEN };
  const cultureMap = { 'KO': 'ko-kr', 'JA': 'ja-jp', 'CN': 'zh-cn', 'EN': 'en-us' };
  
  const res = resMap[LOCALE] || GCLangResEN;
  GC.Spread.Sheets.Designer.setResources(JSON.parse(res));
  GC.Spread.Common.CultureManager.culture(cultureMap[LOCALE] || 'en-us');
  
  return GC.Spread.Sheets.Designer.DefaultConfig;
}

const onChangeLocale = function () {
  const config = spreadLocalization(LanguageTypeRef.value)
  if (config && DesignerRef.value) {
    DesignerRef.value.setConfig(config)
  }
}
</script>

<template>
  <div class="w-100 h-100" style="display: flex; flex-direction: column">
    <div class="d-flex justify-content-between align-items-center p-2">
      <div class="d-flex gap-2">
        <label class="d-inline-block p-2 bg-indigo-200 h-35px">
          <span class="me-2">Language </span>
          <select v-model="LanguageTypeRef" @change="onChangeLocale">
            <option :value="_LangType.KO">한국어</option>
            <option :value="_LangType.EN">English</option>
            <option :value="_LangType.JA">日本語</option>
            <option :value="_LangType.CN">中文</option>
          </select>
        </label>

        <button class="btn-load" @click="loadData">데이터 조회 (Table 생성)</button>
        <button class="btn-check" @click="getCheckedData">선택 데이터 확인</button>
      </div>

      <div class="d-inline-block p-2 bg-indigo-200 h-35px">
        <select v-model="DownloadTypeRef" class="me-2">
          <option :value="_LangType.KO">한국어</option>
          <option :value="_LangType.EN">English</option>
          <option :value="_LangType.JA">日本語</option>
          <option :value="_LangType.CN">中文</option>
        </select>
        <button class="p-0 px-2" style="font-size: 12px" @click="onDownloadLocaleResource">언어 리소스 다운로드</button>
      </div>
    </div>
    
    <gc-spread-designer class="flex-grow-1" @designerInitialized="initDesigner" />
  </div>
</template>

<style scoped>
.h-35px { height: 35px; display: flex; align-items: center; border-radius: 4px; }
.flex-grow-1 { flex-grow: 1; }
