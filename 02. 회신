<template>
  <div style="display: flex; gap: 20px; height: 100vh; padding: 20px;">
    <!-- 왼쪽: Tag Data Grid -->
    <div style="flex: 1; display: flex; flex-direction: column;">
      <h3>Tag Data List</h3>
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="colDefs_TagData"
        :rowData="tagDataList"
        @grid-ready="onGridReady_TagData"
        @row-clicked="onRowClicked"
        :rowSelection="'single'"
      />
    </div>

    <!-- 오른쪽: Attribute Grid -->
    <div style="flex: 1; display: flex; flex-direction: column;">
      <h3>Attribute Grid ({{ context.customValue || '선택된 태그 없음' }})</h3>
      <ag-grid-vue
        style="width: 100%; height: 100%;"
        class="ag-theme-alpine"
        :columnDefs="colDefs_Atts"
        :rowData="tagAttListRef"
        @grid-ready="onGridReady_Atts"
      />
    </div>
  </div>
</template>

<script setup>
import { ref, onMounted } from 'vue';
import { AgGridVue } from 'ag-grid-vue3';
import axios from 'axios';
import _ from 'lodash';

// --- State 관리 ---
const tagDataList = ref([]);        // 왼쪽 그리드 데이터
const tagAttListRef = ref([]);      // 오른쪽 그리드 데이터 (Attributes)
const gridApi_TagData = ref(null);
const gridApi_Atts = ref(null);
const isWorkingRef = ref(false);    // Working 데이터 여부
const context = ref({ customValue: '' });

// --- 컬럼 정의 ---
const colDefs_TagData = ref([
  { field: 'TAG_NO', headerName: 'Tag No', checkboxSelection: true },
  { field: 'TAG_DESC', headerName: 'Description' },
  { field: 'STATUS', headerName: 'Status' },
]);

const colDefs_Atts = ref([
  { field: 'ATT_ID', headerName: 'Attribute ID', flex: 1 },
  { field: 'VALUE', headerName: 'Value', flex: 1, editable: true },
  { field: 'VALUE_DBL', headerName: 'Value (Double)', flex: 1 },
  { field: 'UOM_ID', headerName: 'UOM', flex: 1 },
]);

// --- 그리드 초기화 ---
const onGridReady_TagData = (params) => {
  gridApi_TagData.value = params.api;
  getData(); // 초기 데이터 로드
};

const onGridReady_Atts = (params) => {
  gridApi_Atts.value = params.api;
};

// --- 데이터 로드 (API 호출) ---
const getData = async () => {
  try {
    // isWorkingRef 값에 따라 동적으로 URL 변경
    const url = isWorkingRef.value 
      ? '/api/Data/SearchWorkingData' 
      : '/api/Data/SearchPublishData';

    const response = await axios.get(url);
    tagDataList.value = response.data;
  } catch (error) {
    console.error('Data Load Error:', error);
  }
};

// --- 행 클릭 이벤트 (오른쪽 그리드 데이터 채우기) ---
const onRowClicked = (event) => {
  const selectedData = event.data;
  
  // 1. 헤더 정보 업데이트
  context.value.customValue = selectedData.TAG_NO;

  // 2. 오른쪽 그리드 데이터 가공 및 할당
  // API 응답 구조상 'ATTRIBUTES' (대문자)에 데이터가 들어있음
  if (selectedData && selectedData.ATTRIBUTES) {
    // 깊은 복사를 통해 참조를 끊고 할당
    tagAttListRef.value = _.cloneDeep(selectedData.ATTRIBUTES);
  } else {
    tagAttListRef.value = [];
  }

  console.log('Selected Attributes:', tagAttListRef.value);
};

// --- 필요한 경우 Working 모드 전환 ---
const toggleMode = () => {
  isWorkingRef.value = !isWorkingRef.value;
  getData();
};
</script>

