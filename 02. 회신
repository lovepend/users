<template>
  <div ref="_PageWrapperRef" class="panel panel-expandable m-0 p-0 h-100 position-relative">
    <div class="panel-heading m-0 p-0">
      <div class="w-100 h-100 d-block position-relative">
        <div class="py-1 px-2 mb-1">
          <label class="form-label m-0 text-blue cursor-pointer">
            <input v-model="_IsChangesOnly" type="checkbox" class="form-check-input" />
            Changes Only
          </label>
        </div>
      </div>
    </div>
    <div class="panel-body p-0 h-100">
      <ag-grid-vue class="w-100 h-100" v-bind="_GridBindProps" v-on="_GridOnProps" />
    </div>
  </div>
</template>

<script setup>
import { onMounted, watch, unref, shallowRef, ref, computed, getCurrentInstance } from 'vue'
import { format as fns_format } from 'date-fns'
import { useRoute } from 'vue-router'
import { storeToRefs } from 'pinia'

import { useAppAuthenticationStore } from '@/stores/app-authentication'
import { useAppMenuStore } from '@/stores/app-menu'
import { useEmployees } from '@/stores/app-employees'

import { sAlert } from '@/utils/messages/alert-common'
import { ApiCommon } from '@/utils/axios/api-common'
import { useContentLoading } from '@/composables/useContentLoading'
import { createBaseInformation } from '@/utils/baseInformation/base-attribute'
import global from '@/constants/enums/global'

const _Field = global.field
const { selectMenu } = storeToRefs(useAppMenuStore())
const { userInfo } = storeToRefs(useAppAuthenticationStore())
const { getEmployeeById, getNameDeptKey } = useEmployees()
const route = useRoute()

///////////////////////////////////////////////////////////////////////////////
//#region import Component, Modal 사용시 필수 설정
defineOptions({ name: 'CompareRevisions' })
const _Props = defineProps({
  title: { type: [String, Object], required: false, default: null },
  proj_no: { type: [String, Object], required: false, default: null },
  reg_type_id: { type: [String, Object], required: false, default: null },
  revisions: { type: [Object], required: false, default: null },
  var_isModal: { type: [Boolean], required: false, default: null },
  fn_onActionApply: { type: [Function], required: false, default: null },
  fn_onActionClose: { type: [Function], required: false, default: null },
  fn_onShowOverlay: { type: [Function], required: false, default: null },
  fn_onHideOverlay: { type: [Function], required: false, default: null },
  fn_onSetAutoHeight: { type: [Function], required: false, default: null },
})

const _PageWrapperRef = shallowRef(null)
const _IsModalPage = _Props.var_isModal ?? false
const _IsOwnerPage = (() => {
  const cur = getCurrentInstance()?.type
  return !cur?.__prop && cur?.__name === useRoute().matched[0]?.components.default?.__name
})()

const onShowOverlay = function () {
  const { fn_onShowOverlay: fn } = _Props
  if (fn && typeof fn?.call === 'function') return fn.call(this)
  const pageWrapper = _PageWrapperRef.value
  useContentLoading.startLoading(pageWrapper ? { target: pageWrapper } : null)
}
const onHideOverlay = function () {
  const { fn_onHideOverlay: fn } = _Props
  if (fn && typeof fn?.call === 'function') return fn.call(this)
  useContentLoading.stopLoading()
}
const onActionClose = function () {
  const { fn_onActionClose: fn } = _Props
  if (fn && typeof fn?.call === 'function') return fn.call(this)
}
defineExpose({ onClickApply: () => onActionClose(), onClickClose: () => onActionClose() })
//#endregion

//#region Received - Props
const _CurrProjNoRef = computed(() => (_IsModalPage || !_IsOwnerPage) ? unref(_Props.proj_no) : route.query?.proj_no)
const _CurrRegTypeIdRef = computed(() => (_IsModalPage || !_IsOwnerPage) ? unref(_Props.reg_type_id) : route.query?.reg_type_id)
const _CurrRevisionsRef = computed(() => (_IsModalPage || !_IsOwnerPage) ? unref(_Props.revisions) : route.query?.revisions)
watch([_CurrProjNoRef, _CurrRegTypeIdRef], () => onInitialize())
watch(_CurrRevisionsRef, () => onInitialize(true))
//#endregion

/************************************
 * LIFECYCLE
 * ***********************************/
onMounted(() => {
  if (sAlert?.isVisible()) sAlert.close()
  onInitialize()
})

/************************************
 * GLOBAL & DATA
 * ***********************************/
const _Revision1Ref = computed(() => _CurrRevisionsRef.value?.[0] || null)
const _Revision2Ref = computed(() => _CurrRevisionsRef.value?.[1] || null)
const _BaseColsRef = shallowRef([])
const _BaseAttrRef = shallowRef({})
const _Rev1DataIdxRef = shallowRef({})
const _Rev2DataIdxRef = shallowRef({})
const _OrgDataListRef = shallowRef([])
const _ModDataListRef = shallowRef([])
const _IsChangesOnly = shallowRef(true)
watch(_IsChangesOnly, item => onShowChangesData(item))

/************************************
 * EXCEL STYLES (화면 색상과 매칭)
 * ***********************************/
const excelStyles = [
  { id: 'sfore_A', font: { color: '#008000', bold: true } },
  { id: 'sback_A', interior: { color: '#E8F5E9', pattern: 'Solid' } },
  { id: 'sfore_D', font: { color: '#FF0000', strikeThrough: true } },
  { id: 'sback_D', interior: { color: '#FFEBEE', pattern: 'Solid' } },
  { id: 'sfore_M', font: { color: '#0000FF' } },
  { id: 'sback_M', interior: { color: '#E3F2FD', pattern: 'Solid' } },
  { id: 'text-center', alignment: { horizontal: 'Center' } },
  { id: 'align-content-center', alignment: { vertical: 'Center' } }
]

/************************************
 * GRID FUNCTIONS
 * ***********************************/
const makeCellClass = function (params) {
  const data = params.data
  const value = params.value
  const attId = params.column.colId
  const classes = ['align-content-center', 'border-0']
  const statId = '_CHG_STATUS'
  const status = data?.[statId]
  const empty = (value ?? '') == '' ? '_Empty' : ''

  if (attId === statId) {
    classes.push('text-center', 'sback_Status')
    if (status) classes.push(`sfore_${status}${empty}`)
  } else {
    // 엑셀 스타일 적용을 위해 M 상태일 때 배경색 클래스 추가 로직을 cellClass로 이동
    if (status === 'A' || status === 'D') {
      classes.push(`sfore_${status}${empty}`, `sback_${status}${empty}`)
    } else if (status === 'M') {
      const tagIdx = data?.[_Field.TAG_IDX]
      const val1 = _Rev1DataIdxRef.value?.[tagIdx]?.[attId] ?? ''
      const val2 = _Rev2DataIdxRef.value?.[tagIdx]?.[attId] ?? ''
      if (val1 !== val2) {
        classes.push(`sfore_M${empty}`, `sback_M${empty}`)
      }
    }
  }
  return classes
}

const makeCellRenderer = function (params) {
  const data = params.data
  const attId = params.column.colId
  const tagIdx = data?.[_Field.TAG_IDX]
  if (!data || !tagIdx) return params.value ?? ''
  
  const status = data?._CHG_STATUS
  const data1 = _Rev1DataIdxRef.value?.[tagIdx]
  const data2 = _Rev2DataIdxRef.value?.[tagIdx]
  
  let val1 = data1?.[attId] ?? ''
  let val2 = data2?.[attId] ?? ''

  // 사용자 정보 포맷팅
  if ([_Field.PIC_NO, _Field.CRTER_NO, _Field.CHGER_NO].includes(attId)) {
    const keyInfo = getNameDeptKey(attId)
    val1 = data1 ? `${data1[keyInfo.NAME]}(${data1[keyInfo.DEPT]})` : ''
    val2 = data2 ? `${data2[keyInfo.NAME]}(${data2[keyInfo.DEPT]})` : ''
  }

  // 변경 상태에 따른 클래스 추출 (단순화)
  const isDiff = val1 !== val2
  let fcClass = '', bgClass = ''
  if (status === 'A' || status === 'D') {
    fcClass = `sfore_${status}`; bgClass = `sback_${status}`
  } else if (status === 'M' && isDiff) {
    fcClass = 'sfore_M'; bgClass = 'sback_M'
  }

  return `
    <div class="position-absolute top-0 bottom-0 start-0 end-0">
      <span class="d-block h-25px px-1 ${fcClass} ${bgClass}">${val1}</span>
      <span class="d-block h-25px px-1">${val2}</span>
    </div>
  `
}

const _ColDefsRef = ref([])
const _GridBindProps = ref({
  columnDefs: _ColDefsRef,
  rowData: _DataListRef,
  getRowId: params => params.data?.TAG_IDX,
  rowHeight: 50,
  class: 'ag-theme-custom',
  excelStyles: excelStyles, // 엑셀 스타일 등록
  defaultColDef: {
    cellClass: makeCellClass,
    cellRenderer: makeCellRenderer,
    minWidth: 80,
    filter: 'agMultiColumnFilter',
    floatingFilter: true,
  },
  defaultExcelExportParams: {
    fileName: `Revision_Compare_${fns_format(new Date(), 'yyyyMMdd')}.xlsx`,
    // 엑셀에는 현재 리비전 값(val1)만 내보내거나, 두 값을 합쳐서 내보낼 수 있습니다.
    processCellCallback: (params) => {
      // HTML이 아닌 순수 텍스트만 내보내도록 설정
      return params.value;
    }
  },
  autoSizeStrategy: { type: 'fitCellContents' },
  suppressRowTransform: true,
})

const _GridOnProps = {
  gridReady: params => { _GridRef.value = params.api }
}
const _GridRef = shallowRef(null)

/************************************
 * DATA INITIALIZE FUNCTIONS
 * ***********************************/
const onInitialize = async function (DATA_UPDATE) {
  try {
    onShowOverlay()
    const projNo = _CurrProjNoRef.value
    const regId = _CurrRegTypeIdRef.value
    if (!projNo || !regId || !_Revision1Ref.value || !_Revision2Ref.value) return

    if (!DATA_UPDATE || _ColDefsRef.value.length === 0) {
      const baseMaster = await createBaseInformation(projNo, regId, false, false)
      _BaseColsRef.value = baseMaster.getBaseColsByReg(projNo, regId)
      _BaseAttrRef.value = baseMaster.getBaseAttrByReg(projNo, regId)
      createColDefs()
    }
    await setRevisionData(1)
    await setRevisionData(2)
    await getCompareData()
  } catch (error) {
    sAlert.Error(`Failed to Load - ${error.message}`)
  } finally {
    onHideOverlay()
  }
}

const createColDefs = function () {
  const _DefaultCols = [
    { field: '_CHG_STATUS', headerName: 'Changed', cellClass: 'text-center' },
    { field: _Field.REV_NO, headerName: 'Revision No' },
    { field: 'STAGE', headerName: 'Stage' },
    { field: 'REASON', headerName: 'Reason' },
  ]
  const baseColDefs = _BaseColsRef.value.map(item => ({
    field: item.ATT_ID, 
    headerName: item.DESC,
    hide: [_Field._ID, _Field.PROJ_NO, _Field.REG_TYPE_ID].includes(item.ATT_ID)
  }))
  _ColDefsRef.value = _DefaultCols.concat(baseColDefs)
}

const setRevisionData = async function (REV_NUM) {
  const projNo = _CurrProjNoRef.value
  const regId = _CurrRegTypeIdRef.value
  const revInfo = REV_NUM === 1 ? _Revision1Ref.value : _Revision2Ref.value
  
  const response = await ApiCommon.postDataGetRevData({
    ProjectNo: projNo, REG_TYPE_ID: regId,
    Revision: revInfo.REV, Version: revInfo.VER ?? '',
  }) || []

  const newDataIndex = {}
  for (const dataItem of response) {
    const tagIdx = dataItem.TAG_IDX
    const newDataItem = { ...dataItem }
    
    // Attribute Flattening 로직 (기존 로직 유지)
    if (dataItem[_Field.ATTRIBUTES]) {
      dataItem[_Field.ATTRIBUTES].forEach(attr => {
        newDataItem[attr.ATT_ID] = String(attr.VALUE ?? '').trim()
      })
    }
    
    // 날짜 및 사용자 정보 처리
    if (dataItem[_Field.PIC_NO]) {
      const emp = await getEmployeeById(dataItem[_Field.PIC_NO])
      const keyInfo = getNameDeptKey(_Field.PIC_NO)
      newDataItem[keyInfo.NAME] = emp.EMP_NM
      newDataItem[keyInfo.DEPT] = emp.DEPT_NAME
    }
    
    newDataItem[_Field.REV_NO] = revInfo.REV_NO
    newDataIndex[tagIdx] = newDataItem
  }
  
  if (REV_NUM === 1) _Rev1DataIdxRef.value = newDataIndex
  else _Rev2DataIdxRef.value = newDataIndex
}

const getCompareData = async function () {
  const rev1DataIdx = _Rev1DataIdxRef.value
  const rev2DataIdx = _Rev2DataIdxRef.value
  const tagIdxSet = new Set([...Object.keys(rev1DataIdx), ...Object.keys(rev2DataIdx)])
  
  const modDataList = [], orgDataList = []
  tagIdxSet.forEach(tagIdx => {
    const data1 = rev1DataIdx[tagIdx], data2 = rev2DataIdx[tagIdx]
    let status = !data1 ? 'D' : !data2 ? 'A' : null
    
    if (!status) {
      // 필드 비교 로직
      const isDiff = Object.keys(_BaseAttrRef.value).some(id => (data1[id] ?? '') !== (data2[id] ?? ''))
      if (isDiff) status = 'M'
    }

    const dataItem = { ...(data1 || data2), TAG_IDX: tagIdx, _CHG_STATUS: status }
    orgDataList.push(dataItem)
    if (status) modDataList.push(dataItem)
  })

  _OrgDataListRef.value = orgDataList
  _ModDataListRef.value = modDataList
  onShowChangesData(_IsChangesOnly.value)
}

const onShowChangesData = (IS_MOD) => {
  _DataListRef.value = IS_MOD ? _ModDataListRef.value : _OrgDataListRef.value
}
</script>
