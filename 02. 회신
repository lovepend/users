<template>
  <div class="d-flex flex-column h-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <span class="text-truncate me-2">{{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}</span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="검색..." @click.stop />
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <span>{{ proj.PROJ_NO }} <small>({{ proj.DESC }})</small></span>
                  </label>
                </li>
              </ul>
            </div>
          </div>
          <button class="btn btn-sm btn-primary px-3 shadow-sm" @click="onSearch" :disabled="selectedProjects.length === 0">비교 조회</button>
          
          <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border ms-3">
            <input type="radio" class="btn-check" id="m1" value="simple" v-model="viewMode" /><label class="btn btn-sm rounded-pill px-3" for="m1">간편</label>
            <input type="radio" class="btn-check" id="m2" value="detail" v-model="viewMode" /><label class="btn btn-sm rounded-pill px-3" for="m2">상세</label>
          </div>
        </div>

        <div class="d-flex align-items-center gap-2">
          <textarea class="form-control form-control-sm border-success custom-textarea-filter" v-model="attributeFilter" rows="1" placeholder="MAP_ID 입력"></textarea>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue v-bind="gridOptions" @grid-ready="onGridReady" @cell-clicked="onCellClicked" />
    </div>

    <div class="modal fade" id="diffDetailModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg">
          <div class="modal-header bg-dark text-white py-2">
            <h6 class="modal-title">상세 데이터 비교 [<span class="text-warning">{{ selectedMapId }}</span>]</h6>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body p-0 d-flex flex-column" style="height: 70vh;">
            <div class="bg-light p-2 border-bottom d-flex gap-2">
              <button v-for="tab in ARRAY_FIELDS" :key="tab" 
                      class="btn btn-sm border shadow-sm px-3"
                      :class="activeTab === tab ? 'btn-primary' : 'btn-white'"
                      @click="activeTab = tab">
                {{ tab }}
              </button>
            </div>
            <div class="flex-grow-1">
              <ag-grid-vue 
                style="width: 100%; height: 100%;"
                class="ag-theme-alpine"
                :columnDefs="modalColumnDefs"
                :rowData="modalRowData"
                :defaultColDef="{ resizable: true, sortable: true, filter: true }"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import * as bootstrap from 'bootstrap'

const route = useRoute()
let detailModal = null

// --- State ---
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')

const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

// 모달 관련 State
const selectedMapId = ref('')
const activeTab = ref('MAP_ATT')
const modalRowData = ref([])
const fullRowData = ref(null) // 클릭된 시점의 행 전체 데이터

const ARRAY_FIELDS = ['MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']
const COMPARE_FIELDS = ['DESC', 'REG_TYPE_ID', 'CATEGORY', 'TOOL_ID', 'TOOL_TYPE', ...ARRAY_FIELDS]

// 필드별 고유 키 매핑
const KEY_MAP = {
  'MAP_ATT': 'ATT_ID',
  'MAP_CLS': 'OBJ_CLS_ID',
  'MAP_TMPLS': 'TMPL_ID',
  'MAP_RELS': 'REL_ID'
}

onMounted(async () => {
  detailModal = new bootstrap.Modal(document.getElementById('diffDetailModal'))
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Projectno: route.query.project_no } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

// --- 데이터 가공 로직 ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)

  try {
    const results = await Promise.all(selectedProjects.value.map(p => 
      axiosWrapper.post('/api/AdapterDataMapping/Get', { ProjectNo: p }, { headers: { Projectno: p } }).catch(() => [])
    ))

    const dataMap = new Map()
    results.forEach((projectData, idx) => {
      const pNo = selectedProjects.value[idx]
      projectData.forEach(item => {
        if (!dataMap.has(item.MAP_ID)) dataMap.set(item.MAP_ID, { MAP_ID: item.MAP_ID, projects: {} })
        const info = { EXIST: true }
        COMPARE_FIELDS.forEach(f => info[f] = item[f])
        dataMap.get(item.MAP_ID).projects[pNo] = info
      })
    })

    gridRowData.value = Array.from(dataMap.values()).map(row => {
      let diffs = []
      COMPARE_FIELDS.forEach(f => {
        const vals = selectedProjects.value.map(p => JSON.stringify(row.projects[p]?.[f] || ''))
        if (new Set(vals).size > 1) diffs.push(f)
      })
      const res = { MAP_ID: row.MAP_ID, CONDITION: diffs.length > 0 ? 'Diff' : 'Pass', DIFF_INFO: diffs.join(', ') }
      selectedProjects.value.forEach(p => res[p] = row.projects[p] || { EXIST: false })
      return res
    })
    dynamicCols.value = [...selectedProjects.value]
  } finally { gridApi.value?.setGridOption('loading', false) }
}

// --- 모달 로직 ---
const onCellClicked = (p) => {
  if (p.column.getColId() === 'DIFF_INFO' && p.value) {
    fullRowData.value = p.data
    selectedMapId.value = p.data.MAP_ID
    detailModal.show()
  }
}

// 탭 전환 시 모달 데이터 재구성
watch([activeTab, fullRowData], () => {
  if (!fullRowData.value) return
  
  const keyField = KEY_MAP[activeTab.value]
  const combinedItems = new Map()

  // 모든 프로젝트의 해당 배열 데이터를 순회하며 Key ID 기준으로 취합
  dynamicCols.value.forEach(pNo => {
    let rawData = fullRowData.value[pNo]?.[activeTab.value]
    if (!rawData) return

    // MAP_CLS인 경우 ITEMS 내부를 참조하도록 예외처리
    let list = activeTab.value === 'MAP_CLS' ? (rawData.ITEMS || []) : (Array.isArray(rawData) ? rawData : [])

    list.forEach(item => {
      const id = item[keyField]
      if (!combinedItems.has(id)) combinedItems.set(id, { [keyField]: id })
      combinedItems.get(id)[pNo] = item
    })
  })

  modalRowData.value = Array.from(combinedItems.values())
})

const modalColumnDefs = computed(() => {
  const keyField = KEY_MAP[activeTab.value]
  const cols = [{ headerName: keyField, field: keyField, pinned: 'left', width: 180, cellClass: 'bg-light fw-bold' }]

  dynamicCols.value.forEach(pNo => {
    cols.push({
      headerName: pNo,
      marryChildren: true,
      children: [
        {
          headerName: 'Detail Info',
          valueGetter: p => {
            const data = p.data[pNo]
            if (!data) return '-'
            // Key Field 제외한 나머지 정보를 문자열로 표현
            return Object.entries(data)
              .filter(([k]) => k !== keyField)
              .map(([k, v]) => `${k}: ${v}`)
              .join(' | ')
          },
          width: 400,
          tooltipValueGetter: p => p.value,
          cellStyle: p => {
            // 다른 프로젝트와 값이 다르면 배경색 강조 (단순 로직)
            const others = dynamicCols.value.filter(o => o !== pNo)
            const isDiff = others.some(o => JSON.stringify(p.data[o]) !== JSON.stringify(p.data[pNo]))
            return isDiff ? { backgroundColor: '#fff0f0' } : null
          }
        }
      ]
    })
  })
  return cols
})

// --- 그리드 기본 설정 (메인) ---
const gridOptions = computed(() => ({
  columnDefs: [
    { headerName: 'Condition', field: 'CONDITION', width: 100, pinned: 'left', cellStyle: p => ({ color: p.value === 'Diff' ? 'red' : 'green', fontWeight: 'bold' }) },
    { headerName: 'Diff Info (Click)', field: 'DIFF_INFO', width: 180, pinned: 'left', cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd' } },
    { headerName: 'Mapping ID', field: 'MAP_ID', width: 220, pinned: 'left' },
    ...dynamicCols.value.map(p => ({
      headerName: p,
      children: [
        { headerName: 'Exist', valueGetter: p2 => p2.data[p]?.EXIST ? 'Y' : 'N', width: 70 },
        ...(viewMode.value === 'detail' ? COMPARE_FIELDS.map(f => ({
          headerName: f,
          valueGetter: p2 => {
            const v = p2.data[p]?.[f]
            return typeof v === 'object' ? JSON.stringify(v) : v
          },
          width: 150
        })) : [])
      ]
    }))
  ],
  rowData: gridRowData.value,
  onGridReady: p => gridApi.value = p.api,
  isExternalFilterPresent: () => attributeFilter.value !== '',
  doesExternalFilterPass: n => {
    const kws = attributeFilter.value.split(/[\s,]+/).filter(k => k).map(k => k.toLowerCase())
    return kws.length === 0 || kws.some(kw => String(n.data.MAP_ID).toLowerCase().includes(kw))
  }
}))
</script>

<style scoped>
.custom-project-dropdown { width: 300px; }
.custom-textarea-filter { width: 300px; font-size: 0.8rem; }
.toggle-label { font-size: 0.8rem; cursor: pointer; }
:deep(.ag-theme-alpine) { --ag-header-background-color: #f8f9fa; }
.modal-xl { max-width: 95%; }
</style>
