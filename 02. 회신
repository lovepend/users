<template>
  <div class="d-flex flex-column h-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Project No</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2" style="max-width: 180px">
                  {{ selectedProjNo || '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 300px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projSearchQuery"
                    placeholder="검색..."
                    @click.stop
                  />
                </li>
                <li v-for="proj in filteredProjectOptions" :key="proj.value" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 cursor-pointer" @click="selectProject(proj.value)">
                    <input
                      type="radio"
                      class="form-check-input me-2 mt-0"
                      :checked="selectedProjNo === proj.value"
                    />
                    <span class="text-truncate fw-bold text-primary">{{ proj.text }}</span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">조회 키워드</span>
            <textarea
              class="form-control form-control-sm custom-textarea-filter"
              rows="1"
              v-model="searchKeywordRef"
              placeholder="Tag No... (공백/엔터 구분)"
            ></textarea>
          </div>
          <button class="btn btn-sm btn-primary px-3 shadow-sm" @click="onSearch">
            <i class="fa fa-search me-1"></i>조회
          </button>
        </div>

        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-success text-nowrap small"><i class="fa fa-filter"></i> 결과 내 검색</span>
            <input
              type="text"
              class="form-control form-control-sm border-success"
              style="width: 150px"
              v-model="localFilterQuery"
              placeholder="검색어 입력..."
            />
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-primary text-nowrap small"><i class="fa fa-columns"></i> 컬럼 필터</span>
            <input
              type="text"
              class="form-control form-control-sm border-primary"
              style="width: 120px"
              v-model="columnFilterQuery"
              placeholder="컬럼명..."
            />
          </div>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue
        v-bind="gridBindProps"
        class="ag-theme-custom w-100 h-100"
        @grid-ready="onGridReady"
        @cell-clicked="onCellClicked"
      />
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window shadow-lg">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge shadow-sm" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">
              {{ selectedRow?.Source }}
            </span>
            <span class="fw-bold text-white">Detail View: {{ selectedRow?.TAG_NO }}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-xs btn-outline-light" @click="isJsonMode = !isJsonMode">
              {{ isJsonMode ? 'Table View' : 'JSON View' }}
            </button>
            <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
          </div>
        </div>
        <div class="modal-body-content overflow-hidden d-flex flex-column h-100">
          <div v-if="isJsonMode" class="json-wrapper p-3 overflow-auto flex-grow-1">
            <pre class="json-content"><code>{{ JSON.stringify(selectedRow, null, 2) }}</code></pre>
          </div>
          <div v-else class="ag-theme-custom flex-grow-1 p-2">
            <ag-grid-vue
              style="width: 100%; height: 100%"
              v-bind="modalGridBindProps"
              :defaultColDef="{ resizable: true, sortable: true }"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { storeToRefs } from 'pinia'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sortBy } from 'lodash-es'
import { useAppMenuStore } from '@/stores/app-menu'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

// AG Grid 스타일 임포트 (전역 오염 방지를 위해 최소화)
import 'ag-grid-enterprise'
import 'ag-grid-community/styles/ag-grid.css'

const router = useRouter()
const appMenu = useAppMenuStore()
const { currentProjNo } = storeToRefs(appMenu)

// --- 상태 관리 (A코드 로직 유지) ---
const gridApi = shallowRef()
const projectOptions = ref([])
const selectedProjNo = ref('')
const projSearchQuery = ref('')
const searchKeywordRef = ref('')
const localFilterQuery = ref('')
const columnFilterQuery = ref('')
const rawDataList = ref([])
const dynamicAttCols = ref([])
const dynamicRemainingCols = ref([])

const showModal = ref(false)
const selectedRow = ref(null)
const isJsonMode = ref(false)

// --- 데이터 페칭 및 처리 (A코드 로직 유지) ---
const fetchProjectList = async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectOptions.value = (res || []).map(p => ({ text: p.PROJ_NO, value: p.PROJ_NO }))
    if (currentProjNo.value) selectedProjNo.value = currentProjNo.value
  } catch (e) { console.error(e) }
}

const filteredProjectOptions = computed(() => {
  if (!projSearchQuery.value.trim()) return projectOptions.value
  return projectOptions.value.filter(p => p.text.toLowerCase().includes(projSearchQuery.value.toLowerCase()))
})

const selectProject = val => { selectedProjNo.value = val }

const onSearch = async () => {
  if (!selectedProjNo.value) return sAlert.Warning('Project No를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)

  try {
    const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
    let combined = []

    for (const key of searchKeys) {
      const payload = { ProjectNo: selectedProjNo.value, Keyword: key }
      const [p, w] = await Promise.allSettled([
        axiosWrapper.post('/api/Data/SearchPublishData', payload),
        axiosWrapper.post('/api/Data/SearchWorkingData', payload),
      ])
      if (p.status === 'fulfilled' && p.value) {
        const data = Array.isArray(p.value) ? p.value : [p.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Published' })))
      }
      if (w.status === 'fulfilled' && w.value) {
        const data = Array.isArray(w.value) ? w.value : [w.value]
        combined.push(...data.map(i => ({ ...i, Source: 'Working' })))
      }
    }

    const allAttIds = new Set()
    const allKeys = new Set()
    const fixedKeys = ['Source', 'DELETED', 'TAG_IDX', 'TAG_NO', 'EP_ID', 'CLS_ID', 'ATTRIBUTES', '_id']

    combined.forEach(item => {
      ;(item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
      Object.keys(item).forEach(k => { if (!fixedKeys.includes(k) && typeof item[k] !== 'object') allKeys.add(k) })
    })

    const processedData = combined.map(item => {
      const flatItem = { ...item }
      allAttIds.forEach(id => {
        const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
        flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
      })
      return flatItem
    })

    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id, field: `ATT_${id}`, minWidth: 130,
      headerClass: 'att-column-header',
      cellRenderer: highlightRenderer,
      cellStyle: p => ({ background: '#fff9db', color: p.value === 'null' ? '#adb5bd' : '#000' }),
    }))

    dynamicRemainingCols.value = Array.from(allKeys).sort().map(k => ({
      headerName: k, field: k, minWidth: 150, cellRenderer: highlightRenderer
    }))

    rawDataList.value = sortBy(processedData, ['TAG_NO', 'Source'])
  } catch (err) { sAlert.Error('조회 실패') }
  finally { gridApi.value?.setGridOption('loading', false) }
}

const highlightRenderer = p => {
  const val = p.value === null || p.value === undefined ? '' : String(p.value)
  if (!val || !localFilterQuery.value.trim()) return val
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k)
  let text = val
  kws.forEach(kw => {
    const escapedKw = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    text = text.replace(new RegExp(`(${escapedKw})`, 'gi'), `<mark class="filter-highlight">$1</mark>`)
  })
  return text
}

// --- 그리드 설정 (B코드의 UI 옵션 반영) ---
const mainColDefs = computed(() => {
  const baseCols = [
    { headerName: '', width: 50, pinned: 'left', checkboxSelection: true, headerCheckboxSelection: true, sortable: false, filter: false },
    { headerName: 'Source', field: 'Source', width: 110, pinned: 'left', 
      cellRenderer: p => `<span class="badge shadow-sm" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'};color:white;">${p.value}</span>`
    },
    { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'TAG_IDX', headerName: 'Tag Idx', width: 220, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'CLS_ID', headerName: 'Class', width: 140, pinned: 'left', cellRenderer: highlightRenderer,
      cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd', fontWeight: 'bold' }
    },
    ...dynamicAttCols.value,
    ...dynamicRemainingCols.value,
  ]
  return baseCols.filter(c => {
    if (!columnFilterQuery.value.trim()) return true
    if (!c.headerName || c.pinned) return true
    return columnFilterQuery.value.toLowerCase().split(/[\s,\n]+/).filter(k=>k).some(kw => c.headerName.toLowerCase().includes(kw))
  })
})

const gridBindProps = computed(() => ({
  columnDefs: mainColDefs.value,
  rowData: filteredData.value,
  pagination: true,
  paginationPageSize: 100,
  rowSelection: 'multiple',
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: {
    sortable: true, filter: 'agTextColumnFilter', floatingFilter: true, resizable: true,
    suppressFloatingFilterButton: true // B코드 스타일
  },
}))

const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const kws = localFilterQuery.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
  return rawDataList.value.filter(i => {
    const target = `${i.TAG_NO || ''} ${i.TAG_IDX || ''} ${i.CLS_ID || ''} ${i.Source || ''}`.toLowerCase()
    return kws.some(kw => target.includes(kw))
  })
})

const onGridReady = p => { gridApi.value = p.api }

const onCellClicked = async p => {
  const colId = p.column.getColId()
  if (colId === 'Source') {
    selectedRow.value = p.data
    showModal.value = true
    isJsonMode.value = false
  } else if (colId === 'CLS_ID' && p.value) {
    // Class 정보 조회 로직 (A코드 유지)
    sAlert.Info(`${p.value} 상세 정보를 조회합니다.`)
  }
}

const modalGridBindProps = computed(() => {
  if (!selectedRow.value) return { columnDefs: [], rowData: [] }
  const rows = []
  Object.entries(selectedRow.value).forEach(([k, v]) => {
    if (k !== 'ATTRIBUTES' && !k.startsWith('ATT_') && k !== 'Source')
      rows.push({ category: 'System', key: k, value: v ?? '-' })
  })
  if (Array.isArray(selectedRow.value.ATTRIBUTES)) {
    selectedRow.value.ATTRIBUTES.forEach(a => rows.push({ category: 'Attribute', key: a.ATT_ID, value: a.VALUE ?? 'null' }))
  }
  return {
    columnDefs: [
      { headerName: 'Category', field: 'category', width: 120, pinned: 'left', cellStyle: { fontWeight: 'bold', background: '#f8f9fa' } },
      { headerName: 'Property', field: 'key', width: 220 },
      { headerName: 'Value', field: 'value', flex: 1 },
    ],
    rowData: rows,
    headerHeight: 35, rowHeight: 32
  }
})

const closeModal = () => { showModal.value = false; selectedRow.value = null; }

onMounted(fetchProjectList)
</script>

