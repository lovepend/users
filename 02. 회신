setup() {
  // 1. 컬럼 정의를 ref로 선언
  const columnDefs = ref([
    // ... 다른 컬럼들
    { 
      field: 'TOOL_SOURCE', 
      headerName: 'Tool Source', 
      editable: true,
      cellEditor: 'agSelectCellEditor',
      cellEditorParams: { values: [] } // 초기값은 빈 배열
    },
  ]);

  const fetchToolSources = async () => {
    const response = await axios.post('/api/Dictionary/GetByKey', {
      Key: "ADAPTER_TOOLS",
      ProjectNo: "TE1002"
    });
    
    const dictionary = response.data; // ["EB", "eVCP", ...]

    // 2. 반응형 데이터의 특정 컬럼 values 업데이트
    const targetCol = columnDefs.value.find(col => col.field === 'TOOL_SOURCE');
    if (targetCol) {
      targetCol.cellEditorParams.values = dictionary;
    }
  };

  onMounted(fetchToolSources);

  return { columnDefs };
}
