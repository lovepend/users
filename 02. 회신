<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle
      icon="fa-square-check"
      :title="'Tag List 및 Attributes 정보' + (currentProjNo ? ` [ ${currentProjNo} ]` : '')"
    >
      <template #actions>
        <div class="d-flex align-items-center gap-2 me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-500">Keyword</span>
            <input
              type="text"
              placeholder="Input Keyword"
              class="form-control form-control-sm p-1"
              style="min-height: 1rem"
              v-model="searchKeywordRef"
              @keyup.enter="onSearch"
            />
          </label>
          <button class="btn btn-xs btn-primary" @click="onSearch">Search</button>
        </div>
        <div class="form-check form-switch m-0">
          <label class="form-check-label text-dark user-select-none cursor-pointer">
            <input class="form-check-input" type="checkbox" v-model="isWorkingRef" />
            {{ isWorkingLabel }}
          </label>
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>
    <div class="panel-body m-0 p-0 h-100">
      <!-- Splitter 디자인 반영 -->
      <Splitter class="h-100 custom-splitter">
        <SplitterPanel :size="55" :minSize="10">
          <div class="panel m-0 p-0 h-100 d-flex flex-column">
            <div class="panel-heading p-0 m-0">
              <div class="w-100">
                <BasicToolBar
                  @delete-data="deleteSelectedData"
                  :showCreate="false"
                  :showMultiCreate="false"
                  :showDelete="isShowDeleteBtn"
                  :isDisabledDeleteBtn="isDisabledDeleteBtn"
                  :showSave="false"
                  :isDisabledSaveBtn="false"
                />
              </div>
            </div>
            <div class="panel-body overflow-hidden m-0 p-0 flex-grow-1">
              <ag-grid-vue v-bind="gridBindTagProps" v-on="gridOnCommonProps('Tag')" />
            </div>
          </div>
        </SplitterPanel>
        
        <SplitterPanel :size="45" :minSize="10">
          <div class="panel m-0 p-0 h-100 d-flex flex-column">
            <div class="panel-body overflow-hidden m-0 p-0 flex-grow-1">
              <ag-grid-vue v-bind="gridBindAttProps" v-on="gridOnCommonProps('Att')" />
            </div>
          </div>
        </SplitterPanel>
      </Splitter>
    </div>
  </div>
</template>

<script setup>
import { ref, watch, shallowRef, onBeforeMount, computed } from 'vue'
import { useRoute } from 'vue-router'
import { storeToRefs } from 'pinia'

import Splitter from 'primevue/splitter'
import SplitterPanel from 'primevue/splitterpanel'

import { useAppPermissionStore } from '@/stores/app-permission'
import { useAppMenuStore } from '@/stores/app-menu'

import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'

import { sAlert } from '@/utils/messages/alert-common'
import * as _ from 'lodash-es'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import axios from 'axios'

import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
import PageTitle from '@/components/toolBar/PageTitle.vue'

const route = useRoute()
const appPermission = useAppPermissionStore()
const { isSetupAdmin } = storeToRefs(appPermission)
const { currentProjNo } = storeToRefs(useAppMenuStore())

const tagDataListRef = ref([])
const tagAttListRef = ref([])
const selectedTagData = ref(null)
const searchKeywordRef = ref('')
const isWorkingRef = ref(false)
const isWorkingLabel = ref('Published')
const context = ref({ customKey: 'Tag Idx : ', customValue: '' })

const isShowDeleteBtn = ref(isSetupAdmin.value)
const isDisabledDeleteBtn = ref(true)

// --- AG GRID 설정 ---
const gridApi_TagData = shallowRef()
const gridApi_Atts = shallowRef()
const themeClass = 'ag-theme-custom'

const agMultiColumnFilterParams = {
  filters: [
    { filter: 'agTextColumnFilter', filterParams: { buttons: ['reset'] } },
    { filter: 'agSetColumnFilter', filterParams: { buttons: ['reset'] } }
  ],
}

const defaultColDef = {
  editable: params => params.data.PROJ_NO === currentProjNo.value,
  filter: 'agMultiColumnFilter',
  filterParams: agMultiColumnFilterParams,
  floatingFilter: true,
  resizable: true,
  sortable: true,
}

const colDefs = [
  {
    headerCheckboxSelection: true,
    headerCheckboxSelectionFilteredOnly: true,
    checkboxSelection: params => params.data.PROJ_NO === currentProjNo.value,
    width: 40,
    pinned: 'left',
    filter: false
  },
  { field: 'TAG_NO', headerName: 'Tag No', flex: 1 },
  { field: 'TAG_IDX', headerName: 'Tag Idx', flex: 1.5 },
  { field: 'CLS_ID', headerName: 'Class ID', flex: 1 },
  { field: 'TAG_DESC', headerName: 'Description', flex: 1.5 },
]

const colDefs_Atts = [
  { 
    checkboxSelection: true, 
    headerCheckboxSelection: true, 
    width: 40, 
    pinned: 'left',
    filter: false 
  },
  { field: 'ATT_ID', headerName: 'Attribute ID', flex: 1 },
  { field: 'VALUE', headerName: 'Value', flex: 1, editable: true },
  { field: 'VALUE_DBL', headerName: 'Value(Num)', flex: 0.8, editable: true },
  { field: 'UOM_ID', headerName: 'UOM', flex: 0.8, editable: true },
]

// --- 데이터 로드 로직 ---
const getData = async () => {
  if (!currentProjNo.value) return;
  
  gridApi_TagData.value?.setGridOption('loading', true);
  tagAttListRef.value = [];

  const url = isWorkingRef.value ? '/api/Data/SearchWorkingData' : '/api/Data/SearchPublishData';

  try {
    const jsonData = await axiosWrapper.post(url, {
      ProjectNo: currentProjNo.value,
      Keyword: searchKeywordRef.value.trim(),
    });

    tagDataListRef.value = (jsonData || []).filter(item => !item.DELETED);
    
    if (tagDataListRef.value.length > 0) {
      setTimeout(() => {
        const firstNode = gridApi_TagData.value?.getDisplayedRowAtIndex(0);
        if (firstNode) {
          firstNode.setSelected(true);
          onRowClicked({ data: firstNode.data, node: firstNode });
        }
      }, 100);
    }
  } catch (error) {
    sAlert.Error('데이터 로드 실패');
  } finally {
    gridApi_TagData.value?.setGridOption('loading', false);
  }
}

const getTagDataAttList = (tagData) => {
  if (!tagData || !tagData.ATTRIBUTES) {
    tagAttListRef.value = [];
    context.value.customValue = '';
    return;
  }
  tagAttListRef.value = _.cloneDeep(tagData.ATTRIBUTES);
  context.value = {
    customKey: 'Tag Idx : ',
    customValue: `${tagData.TAG_IDX} [${tagData.TAG_NO}]`
  };
}

const onRowClicked = (event) => {
  selectedTagData.value = event.data;
  getTagDataAttList(event.data);
  isDisabledDeleteBtn.value = event.data.PROJ_NO !== currentProjNo.value;
}

const onGridReady = params => { gridApi_TagData.value = params.api; if (currentProjNo.value) getData(); }
const onGridReady_Atts = params => { gridApi_Atts.value = params.api; }
const onSearch = () => getData();

watch(isWorkingRef, () => {
  isWorkingLabel.value = isWorkingRef.value ? 'Working' : 'Published';
  getData();
});

watch(currentProjNo, () => {
  getData();
  selectedTagData.value = null;
});

const gridBindCommonProps = {
  style: 'width: 100%; height: 100%',
  class: themeClass,
  suppressLastEmptyLineOnPaste: true,
  enableRangeSelection: true,
  columnHoverHighlight: true,
  loadingOverlayComponent: AggridLoadingOverlay,
}

const gridBindTagProps = computed(() => ({
  ...gridBindCommonProps,
  rowSelection: 'multiple',
  rowData: tagDataListRef.value,
  columnDefs: colDefs,
  defaultColDef: defaultColDef,
}))

const gridBindAttProps = computed(() => ({
  ...gridBindCommonProps,
  rowSelection: 'multiple',
  rowData: tagAttListRef.value,
  columnDefs: colDefs_Atts,
  context: context.value,
  defaultColDef: defaultColDef,
}))

const gridOnCommonProps = type => {
  if (type === 'Tag') return { gridReady: onGridReady, rowClicked: onRowClicked };
  return { gridReady: onGridReady_Atts };
}

defineOptions({
  name: 'PubWrkData',
  components: { AgDetailStatusBar, AgCustomFilter },
})
</script>

