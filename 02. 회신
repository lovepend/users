<template>
  <div class="d-flex flex-column h-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <span class="text-truncate me-2">{{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}</span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input type="text" class="form-control form-control-sm" v-model="projectSearchKeyword" placeholder="검색..." @click.stop />
                </li>
                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold" style="cursor: pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :checked="isAllSelected" :indeterminate="isIndeterminate" @change="toggleAllSelection" />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100" style="cursor: pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <span class="text-truncate fw-bold text-primary">{{ proj.PROJ_NO }} <small class="text-muted">({{ proj.DESC }})</small></span>
                  </label>
                </li>
              </ul>
            </div>
          </div>
          <button class="btn btn-sm btn-primary px-3 shadow-sm" @click="onSearch" :disabled="selectedProjects.length === 0">비교 조회</button>
          
          <div class="view-mode-toggle-container ms-3">
            <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border">
              <input type="radio" class="btn-check" id="mapModeSimple" value="simple" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="mapModeSimple">간편 조회</label>
              <input type="radio" class="btn-check" id="mapModeDetail" value="detail" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="mapModeDetail">상세 조회</label>
            </div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-success text-nowrap">멀티 필터</span>
          <textarea class="form-control form-control-sm border-success custom-textarea-filter" v-model="attributeFilter" rows="1" placeholder="MAP_ID 입력"></textarea>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue
        style="width: 100%; height: 100%"
        class="ag-theme-custom"
        :columnDefs="mainColumnDefs"
        :rowData="gridRowData"
        :defaultColDef="defaultColDef"
        :loadingOverlayComponent="AggridLoadingOverlay"
        :isExternalFilterPresent="isExternalFilterPresent"
        :doesExternalFilterPass="doesExternalFilterPass"
        @grid-ready="onGridReady"
        @cell-clicked="onCellClicked"
      />
    </div>

    <div class="modal fade" id="arrayDiffModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
          <div class="modal-header py-2 bg-dark text-white">
            <h6 class="modal-title">상세 데이터 비교 [<span class="text-warning">{{ selectedMapId }}</span>]</h6>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body p-0 d-flex flex-column" style="height: 70vh;">
            <div class="bg-light p-2 border-bottom d-flex gap-2">
              <button v-for="tab in ['MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']" :key="tab" 
                      class="btn btn-sm px-3 shadow-sm"
                      :class="activeTab === tab ? 'btn-primary' : 'btn-white border'"
                      @click="activeTab = tab">{{ tab }}</button>
            </div>
            <div class="flex-grow-1">
              <ag-grid-vue 
                style="width: 100%; height: 100%;"
                class="ag-theme-custom"
                :columnDefs="modalColumnDefs"
                :rowData="modalRowData"
                :defaultColDef="defaultColDef"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
import * as bootstrap from 'bootstrap'

const route = useRoute()
let diffModal = null

const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const attributeFilter = ref('')
const viewMode = ref('simple')
const gridApi = shallowRef()
const gridRowData = ref([])
const dynamicCols = ref([])

const selectedMapId = ref('')
const activeTab = ref('MAP_ATT')
const modalRowData = ref([])
const clickedRow = ref(null)

const COMPARE_FIELDS = ['DESC', 'REG_TYPE_ID', 'CATEGORY', 'TOOL_ID', 'TOOL_TYPE', 'MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']
// 숨길 대상이 되는 배열 필드 정의
const ARRAY_FIELDS = ['MAP_ATT', 'MAP_CLS', 'MAP_TMPLS', 'MAP_RELS']
const TAB_KEY_MAP = { 'MAP_ATT': 'ATT_ID', 'MAP_CLS': 'OBJ_CLS_ID', 'MAP_TMPLS': 'TMPL_ID', 'MAP_RELS': 'REL_ID' }

const defaultColDef = { 
  sortable: true, 
  resizable: true, 
  filter: 'agTextColumnFilter',
  floatingFilter: true,
  filterParams: { debounceMs: 200, suppressAndOrCondition: true },
  suppressFloatingFilterButton: true
}

const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  return projectList.value.filter(p => !kw || p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})
const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selInFil = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selInFil > 0 && selInFil < filteredProjectList.value.length
})
const toggleAllSelection = e => {
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = e.target.checked ? [...new Set([...selectedProjects.value, ...filteredIds])] : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

onMounted(async () => {
  diffModal = new bootstrap.Modal(document.getElementById('arrayDiffModal'))
  try {
    const res = await axiosWrapper.get('/api/Project/Get', { headers: { Projectno: route.query.project_no } })
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
  } catch (e) { console.error(e) }
})

const areEqual = (v1, v2) => JSON.stringify(v1 || '') === JSON.stringify(v2 || '')

const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)
  try {
    const results = await Promise.all(selectedProjects.value.map(p => 
      axiosWrapper.post('/api/AdapterDataMapping/Get', { ProjectNo: p }, { headers: { Projectno: p } }).catch(() => [])
    ))
    const dataMap = new Map()
    results.forEach((data, idx) => {
      const pNo = selectedProjects.value[idx]
      data.forEach(item => {
        if (!dataMap.has(item.MAP_ID)) dataMap.set(item.MAP_ID, { MAP_ID: item.MAP_ID, projects: {} })
        const pData = { EXIST: true }; COMPARE_FIELDS.forEach(f => pData[f] = item[f])
        dataMap.get(item.MAP_ID).projects[pNo] = pData
      })
    })
    gridRowData.value = Array.from(dataMap.values()).map(row => {
      let diffs = []
      if (Object.keys(row.projects).length !== selectedProjects.value.length) diffs.push('Exist')
      COMPARE_FIELDS.forEach(f => {
        const activePs = selectedProjects.value.filter(p => row.projects[p])
        if (activePs.length > 1) {
          const first = row.projects[activePs[0]][f]
          if (activePs.some(p => !areEqual(first, row.projects[p][f]))) diffs.push(f)
        }
      })
      const res = { MAP_ID: row.MAP_ID, CONDITION: diffs.length > 0 ? 'Diff' : 'Pass', DIFF_INFO: diffs.join(', ') }
      selectedProjects.value.forEach(p => res[p] = row.projects[p] || { EXIST: false })
      return res
    })
    dynamicCols.value = [...selectedProjects.value]
  } finally { gridApi.value?.setGridOption('loading', false) }
}

// --- [수정] 메인 그리드 컬럼 정의: 상세 조회 시 배열 필드 숨김 ---
const mainColumnDefs = computed(() => {
  const cols = [
    { headerName: 'Condition', field: 'CONDITION', width: 110, pinned: 'left', cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) },
    { headerName: 'Diff Info (Click)', field: 'DIFF_INFO', width: 150, pinned: 'left', cellStyle: { color: '#0d6efd', textDecoration: 'underline', cursor: 'pointer', fontWeight: 'bold' } },
    { headerName: 'Mapping ID', field: 'MAP_ID', width: 200, pinned: 'left' }
  ]
  
  dynamicCols.value.forEach(proj => {
    const children = [{ headerName: 'Exist', valueGetter: p => (p.data[proj]?.EXIST ? 'Alive' : '-'), width: 80, cellStyle: { textAlign: 'center' }, cellRenderer: p => p.value === 'Alive' ? `<i class="fa fa-check-circle text-success"></i>` : `<span class="text-muted">-</span>` }]
    
    if (viewMode.value === 'detail') {
      COMPARE_FIELDS.forEach(f => {
        children.push({ 
          headerName: f, 
          valueGetter: p => { 
            const v = p.data[proj]?.[f]
            return typeof v === 'object' ? JSON.stringify(v) : (v ?? '') 
          }, 
          width: 150, 
          tooltipValueGetter: p => p.value,
          // [추가] 배열 필드는 비교는 하지만 화면에서는 보이지 않도록 처리
          hide: ARRAY_FIELDS.includes(f) 
        })
      })
    }
    cols.push({ headerName: `${proj}`, children: children, width: viewMode.value === 'simple' ? 100 : undefined })
  })
  return cols
})

const onCellClicked = (p) => {
  if (p.column.getColId() === 'DIFF_INFO' && p.value) {
    clickedRow.value = p.data; selectedMapId.value = p.data.MAP_ID; diffModal.show()
  }
}

watch([activeTab, clickedRow], () => {
  if (!clickedRow.value) return
  const keyField = TAB_KEY_MAP[activeTab.value]
  const mergeMap = new Map()
  dynamicCols.value.forEach(pNo => {
    const pRow = clickedRow.value[pNo]; if (!pRow || !pRow[activeTab.value]) return
    let items = pRow[activeTab.value]; if (activeTab.value === 'MAP_CLS' && items.ITEMS) items = items.ITEMS
    if (Array.isArray(items)) items.forEach(item => {
      const id = item[keyField]; if (id) { if (!mergeMap.has(id)) mergeMap.set(id, { [keyField]: id }); mergeMap.get(id)[pNo] = item }
    })
  })
  modalRowData.value = Array.from(mergeMap.values()).map(row => {
    const activePs = dynamicCols.value.filter(p => row[p])
    let isRowDiff = activePs.length !== dynamicCols.value.length || (activePs.length > 1 && activePs.some(p => JSON.stringify(row[p]) !== JSON.stringify(row[activePs[0]])))
    return { ...row, CONDITION: isRowDiff ? 'Diff' : 'Pass' }
  })
})

const modalColumnDefs = computed(() => {
  const keyField = TAB_KEY_MAP[activeTab.value]
  const cols = [
    { headerName: keyField, field: keyField, pinned: 'left', width: 180, cellClass: 'bg-light fw-bold' },
    { headerName: 'Diff Info', field: 'CONDITION', pinned: 'left', width: 100, cellStyle: p => ({ color: p.value === 'Diff' ? '#dc3545' : '#198754', fontWeight: 'bold', textAlign: 'center', backgroundColor: p.value === 'Diff' ? '#fff5f5' : '#f6fff8' }) }
  ]
  dynamicCols.value.forEach(pNo => {
    cols.push({
      headerName: pNo,
      valueGetter: p => { const v = p.data[pNo]; return v ? Object.entries(v).filter(([k]) => k !== keyField).map(([k, val]) => `${k}:${val}`).join(' | ') : '-' },
      width: 350, tooltipValueGetter: p => p.value,
      cellStyle: p => p.data.CONDITION === 'Diff' ? { color: '#dc3545' } : null
    })
  })
  return cols
})

const onGridReady = p => { gridApi.value = p.api }
const isExternalFilterPresent = () => attributeFilter.value.trim() !== ''
const doesExternalFilterPass = n => {
  const kws = attributeFilter.value.split(/[\s,\n]+/).filter(k => k).map(k => k.toLowerCase())
  return kws.length === 0 || kws.some(kw => String(n.data.MAP_ID || '').toLowerCase().includes(kw))
}
watch([attributeFilter, viewMode], () => gridApi.value?.onFilterChanged())
</script>

<style scoped>
.custom-project-dropdown { width: 300px !important; }
.custom-textarea-filter { width: 300px !important; font-size: 0.8rem; resize: none; }
.toggle-label { cursor: pointer; font-size: 0.82rem; padding: 4px 16px; }
.btn-check:checked + .toggle-label { background-color: #fff !important; color: #0d6efd !important; }
:deep(.ag-theme-custom) { --ag-header-background-color: #f8f9fa; --ag-font-size: 12px; }
:deep(.ag-floating-filter-input) { pointer-events: auto !important; }
:deep(.ag-floating-filter-body input) { height: 24px !important; border: 1px solid #ced4da !important; border-radius: 3px !important; padding: 0 5px !important; background-color: white !important; }
:deep(.ag-header-group-cell) { background-color: #f8f9fa !important; font-weight: bold; border-right: 1px solid #dee2e6 !important; }
</style>
