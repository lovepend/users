<template>
  <div class="d-flex flex-column h-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Project</span>
            <select class="form-select form-select-sm" v-model="selectedProjectNo" style="width: 250px">
              <option value="">프로젝트를 선택하세요</option>
              <option v-for="proj in projectList" :key="proj.PROJ_NO" :value="proj.PROJ_NO">
                {{ proj.PROJ_NO }} ({{ proj.DESC }})
              </option>
            </select>
          </div>

          <button class="btn btn-sm btn-primary px-3 shadow-sm" @click="onSearch" :disabled="!selectedProjectNo">
            <i class="fa fa-search me-1"></i>UOM 비교 조회
          </button>
        </div>

        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold text-success text-nowrap"><i class="fa fa-filter me-1"></i>TYPE 검색</span>
          <input type="text" class="form-control form-control-sm border-success" v-model="typeFilter" style="width: 200px" placeholder="TYPE_ID 입력" />
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue v-bind="gridOptions" @grid-ready="onGridReady" />
    </div>

    <div class="modal fade" id="uomDetailModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header bg-light">
            <h5 class="modal-title fw-bold">UOM 불일치 상세 비교 <small class="text-primary">[{{ currentTypeId }}]</small></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-0">
            <table class="table table-hover table-bordered mb-0 shadow-sm">
              <thead class="table-dark">
                <tr>
                  <th>Attribute ID</th>
                  <th class="text-center">Register UOM</th>
                  <th class="text-center">Master Attribute UOM</th>
                  <th class="text-center">Status</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="att in diffDetails" :key="att.ATT_ID">
                  <td class="fw-bold">{{ att.ATT_ID }}</td>
                  <td class="text-center">{{ att.REG_UOM || '-' }}</td>
                  <td class="text-center">{{ att.MST_UOM || '-' }}</td>
                  <td class="text-center">
                    <span class="badge bg-danger">Mismatch</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">닫기</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { useRoute } from 'vue-router'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'
import * as bootstrap from 'bootstrap'

const route = useRoute()

// --- State ---
const projectList = ref([])
const selectedProjectNo = ref('')
const typeFilter = ref('')
const gridApi = shallowRef()
const gridRowData = ref([])

// 모달 및 상세 데이터
const currentTypeId = ref('')
const diffDetails = ref([])
let modalInstance = null

const urlEpId = computed(() => route.query.ep_id || '')

onMounted(async () => {
  modalInstance = new bootstrap.Modal(document.getElementById('uomDetailModal'))
  await fetchProjectList()
})

const fetchProjectList = async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = Array.isArray(res) ? res.filter(p => p.USE_YN) : []
    // URL 파라미터가 있으면 우선 선택
    if (route.query.project_no) selectedProjectNo.ref = route.query.project_no
  } catch (e) { console.error(e) }
}

// --- 핵심 로직: UOM 비교 조회 ---
const onSearch = async () => {
  if (!selectedProjectNo.value) return
  if (gridApi.value) gridApi.value.setGridOption('loading', true)

  try {
    // 1. Register 정보 가져오기
    const registerList = await axiosWrapper.get('/api/Register/Get', {
      headers: { Projectno: selectedProjectNo.value, Ep_id: urlEpId.value }
    })

    // 2. 해당 프로젝트의 전체 Attribute 마스터 정보 가져오기 (비교 대상)
    const masterAttributes = await axiosWrapper.get('/api/Attribute/Get', {
      headers: { Projectno: selectedProjectNo.value, Ep_id: urlEpId.value }
    })
    
    // 비교 효율을 위해 Map으로 변환 (Key: ATT_ID)
    const attMap = new Map(masterAttributes.map(a => [a.ATT_ID, a]))

    // 3. 비교 가공
    const processedData = registerList.map(reg => {
      const lnkAtts = reg.LNK_ATT || []
      let mismatchCount = 0
      let mismatchList = []

      lnkAtts.forEach(lnk => {
        const mstAtt = attMap.get(lnk.ATT_ID)
        // LNK_ATT의 UOM_ID와 마스터의 UOM_ID 비교 (둘 다 null이 아닐 때 기준)
        if (mstAtt && lnk.UOM_ID !== mstAtt.UOM_ID) {
          mismatchCount++
          mismatchList.push({
            ATT_ID: lnk.ATT_ID,
            REG_UOM: lnk.UOM_ID,
            MST_UOM: mstAtt.UOM_ID
          })
        }
      })

      return {
        TYPE_ID: reg.TYPE_ID,
        DESC: reg.DESC,
        EP_ID: reg.EP_ID,
        TOTAL_ATT: lnkAtts.length,
        MISMATCH_COUNT: mismatchCount,
        MISMATCH_LIST: mismatchList, // 모달용 상세 데이터 포함
        CONDITION: mismatchCount > 0 ? 'Mismatch' : 'Match'
      }
    })

    gridRowData.value = processedData
  } catch (e) {
    sAlert.Error('UOM 비교 조회 중 오류가 발생했습니다.')
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

// --- 모달 오픈 ---
const openDetail = (data) => {
  if (data.MISMATCH_COUNT === 0) return
  currentTypeId.value = data.TYPE_ID
  diffDetails.value = data.MISMATCH_LIST
  modalInstance.show()
}

// --- Grid 설정 ---
const gridOptions = computed(() => ({
  columnDefs: [
    { 
      headerName: 'Status', 
      field: 'CONDITION', 
      width: 120,
      cellStyle: p => ({
        color: p.value === 'Mismatch' ? '#dc3545' : '#198754',
        fontWeight: 'bold',
        textAlign: 'center'
      }),
      cellRenderer: p => p.value === 'Mismatch' ? `<i class="fa fa-exclamation-triangle"></i> Mismatch` : `<i class="fa fa-check-circle"></i> Match`
    },
    { 
      headerName: 'Register Type ID', 
      field: 'TYPE_ID', 
      flex: 1,
      cellClass: 'text-primary fw-bold clickable-cell',
      onCellClicked: (p) => openDetail(p.data)
    },
    { headerName: 'Description', field: 'DESC', flex: 1.2 },
    { headerName: 'EP ID', field: 'EP_ID', width: 120 },
    { 
      headerName: 'LNK_ATT Count', 
      field: 'TOTAL_ATT', 
      width: 130, 
      cellStyle: { textAlign: 'center' } 
    },
    { 
      headerName: 'UOM Mismatch', 
      field: 'MISMATCH_COUNT', 
      width: 140,
      cellStyle: p => ({ 
        textAlign: 'center', 
        color: p.value > 0 ? '#dc3545' : '#6c757d',
        fontWeight: p.value > 0 ? 'bold' : 'normal',
        backgroundColor: p.value > 0 ? '#fff5f5' : 'transparent'
      })
    }
  ],
  rowData: gridRowData.value,
  defaultColDef: { sortable: true, filter: true, resizable: true },
  onGridReady: (p) => { gridApi.value = p.api },
  isExternalFilterPresent: () => typeFilter.value !== '',
  doesExternalFilterPass: (node) => node.data.TYPE_ID.toLowerCase().includes(typeFilter.value.toLowerCase())
}))

watch(typeFilter, () => {
  if (gridApi.value) gridApi.value.onFilterChanged()
})
</script>

<style scoped>
.clickable-cell {
  cursor: pointer;
  text-decoration: underline;
}
.clickable-cell:hover {
  color: #0056b3 !important;
}
:deep(.ag-theme-custom) {
  --ag-header-background-color: #f8f9fa;
  --ag-header-foreground-color: #495057;
}
</style>
