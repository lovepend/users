<template>
  <div class="d-flex flex-column h-100 bg-white">
    <div class="p-3 border-bottom shadow-sm bg-light">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">Projects</span>
            <div class="dropdown">
              <button
                class="btn btn-sm btn-outline-secondary dropdown-toggle custom-project-dropdown text-start d-flex justify-content-between align-items-center bg-white"
                type="button"
                data-bs-toggle="dropdown"
                data-bs-auto-close="outside"
              >
                <span class="text-truncate me-2">
                  {{ selectedProjects.length > 0 ? selectedProjects.join(', ') : '프로젝트를 선택하세요' }}
                </span>
              </button>
              <ul class="dropdown-menu p-2 shadow-sm" style="max-height: 400px; overflow-y: auto; width: 350px">
                <li class="px-2 pb-2 border-bottom mb-1">
                  <input
                    type="text"
                    class="form-control form-control-sm"
                    v-model="projectSearchKeyword"
                    placeholder="프로젝트 검색..."
                    @click.stop
                  />
                </li>
                <li class="dropdown-item px-2 py-1 border-bottom mb-1 bg-light">
                  <label class="form-check-label d-flex align-items-center w-100 fw-bold cursor-pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :checked="isAllSelected" :indeterminate="isIndeterminate" @change="toggleAllSelection" />
                    <span>전체 선택 / 해제</span>
                  </label>
                </li>
                <li v-for="proj in filteredProjectList" :key="proj.PROJ_NO" class="dropdown-item px-2 py-1">
                  <label class="form-check-label d-flex align-items-center w-100 cursor-pointer">
                    <input class="form-check-input me-2 mt-0" type="checkbox" :value="proj.PROJ_NO" v-model="selectedProjects" />
                    <span class="text-truncate">
                      <span class="fw-bold text-primary">{{ proj.PROJ_NO }}</span>
                      <small class="text-muted ms-1">({{ proj.DESC }})</small>
                    </span>
                  </label>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2">
            <span class="fw-bold text-dark text-nowrap">키워드</span>
            <textarea
              class="form-control form-control-sm custom-textarea-filter"
              rows="1"
              v-model="searchKeywordRef"
              placeholder="Tag No... (공백/엔터 구분)"
            ></textarea>
          </div>

          <button class="btn btn-sm btn-primary px-3 shadow-sm" @click="onSearch" :disabled="selectedProjects.length === 0">
            <i class="fa fa-search me-1"></i>조회
          </button>

          <div class="view-mode-toggle-container ms-2">
            <div class="btn-group p-1 bg-secondary bg-opacity-10 rounded-pill border" role="group">
              <input type="radio" class="btn-check" id="modeSimple" value="simple" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeSimple">간편</label>
              <input type="radio" class="btn-check" id="modeDetail" value="detail" v-model="viewMode" />
              <label class="btn btn-sm rounded-pill px-3 toggle-label" for="modeDetail">상세</label>
            </div>
          </div>
        </div>

        <div class="d-flex align-items-center gap-2">
          <div class="d-flex align-items-center gap-1">
            <span class="fw-bold text-success text-nowrap small"><i class="fa fa-filter"></i> 결과검색</span>
            <input type="text" class="form-control form-control-sm border-success" style="width: 120px" v-model="localFilterQuery" placeholder="필터..." />
          </div>
          <div class="d-flex align-items-center gap-1">
            <span class="fw-bold text-primary text-nowrap small"><i class="fa fa-columns"></i> 컬럼필터</span>
            <input type="text" class="form-control form-control-sm border-primary" style="width: 100px" v-model="columnFilterQuery" placeholder="컬럼명..." />
          </div>
        </div>
      </div>
    </div>

    <div class="flex-grow-1 overflow-hidden">
      <ag-grid-vue
        v-bind="gridBindProps"
        class="ag-theme-custom w-100 h-100"
        @grid-ready="onGridReady"
        @cell-clicked="onCellClicked"
      />
    </div>

    <div v-if="showModal" class="custom-modal-overlay" @click.self="closeModal">
      <div class="custom-modal-window shadow-lg">
        <div class="modal-header-dark">
          <div class="d-flex align-items-center gap-2">
            <span class="badge shadow-sm" :style="{ backgroundColor: selectedRow?.Source === 'Working' ? '#ed6c02' : '#0288d1' }">{{ selectedRow?.Source }}</span>
            <span class="fw-bold text-white">Detail View: {{ selectedRow?.TAG_NO }}</span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-xs btn-outline-light" @click="isJsonMode = !isJsonMode">{{ isJsonMode ? 'Table View' : 'JSON View' }}</button>
            <button @click="closeModal" class="btn btn-xs btn-danger">✕</button>
          </div>
        </div>
        <div class="modal-body-content overflow-hidden d-flex flex-column h-100">
          <div v-if="isJsonMode" class="json-wrapper p-3 overflow-auto flex-grow-1">
            <pre class="json-content"><code>{{ JSON.stringify(selectedRow, null, 2) }}</code></pre>
          </div>
          <div v-else class="ag-theme-custom flex-grow-1 p-2">
            <ag-grid-vue style="width: 100%; height: 100%" v-bind="modalGridBindProps" />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef, onMounted, watch } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sortBy } from 'lodash-es'
import { sAlert } from '@/utils/messages/alert-common'
import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'

// --- State (A와 B의 결합) ---
const gridApi = shallowRef()
const projectList = ref([])
const projectSearchKeyword = ref('')
const selectedProjects = ref([])
const searchKeywordRef = ref('') // B의 검색 키워드
const localFilterQuery = ref('') // B의 결과 내 검색
const columnFilterQuery = ref('') // B의 컬럼 필터
const viewMode = ref('simple')

const rawDataList = ref([])
const dynamicAttCols = ref([])
const dynamicRemainingCols = ref([])

const showModal = ref(false)
const selectedRow = ref(null)
const isJsonMode = ref(false)

// --- 프로젝트 선택 (A 로직) ---
const filteredProjectList = computed(() => {
  const kw = projectSearchKeyword.value.trim().toLowerCase()
  if (!kw) return projectList.value
  return projectList.value.filter(p => p.PROJ_NO.toLowerCase().includes(kw) || (p.DESC && p.DESC.toLowerCase().includes(kw)))
})
const isAllSelected = computed(() => filteredProjectList.value.length > 0 && filteredProjectList.value.every(p => selectedProjects.value.includes(p.PROJ_NO)))
const isIndeterminate = computed(() => {
  const selectedInFiltered = filteredProjectList.value.filter(p => selectedProjects.value.includes(p.PROJ_NO)).length
  return selectedInFiltered > 0 && selectedInFiltered < filteredProjectList.value.length
})
const toggleAllSelection = e => {
  const filteredIds = filteredProjectList.value.map(p => p.PROJ_NO)
  selectedProjects.value = e.target.checked ? [...new Set([...selectedProjects.value, ...filteredIds])] : selectedProjects.value.filter(id => !filteredIds.includes(id))
}

// --- 데이터 페칭 및 로직 (B 로직) ---
const onSearch = async () => {
  if (selectedProjects.value.length === 0) return sAlert.Warning('프로젝트를 선택하세요.')
  gridApi.value?.setGridOption('loading', true)

  try {
    const searchKeys = searchKeywordRef.value.split(/[\s,\n]+/).filter(k => k)
    let combined = []

    // 선택된 여러 프로젝트에 대해 B의 로직 수행
    for (const projNo of selectedProjects.value) {
      for (const key of searchKeys) {
        const payload = { ProjectNo: projNo, Keyword: key }
        const [p, w] = await Promise.allSettled([
          axiosWrapper.post('/api/Data/SearchPublishData', payload),
          axiosWrapper.post('/api/Data/SearchWorkingData', payload),
        ])
        if (p.status === 'fulfilled' && p.value) {
          const data = Array.isArray(p.value) ? p.value : [p.value]
          combined.push(...data.map(i => ({ ...i, Source: 'Published', ProjNo: projNo })))
        }
        if (w.status === 'fulfilled' && w.value) {
          const data = Array.isArray(w.value) ? w.value : [w.value]
          combined.push(...data.map(i => ({ ...i, Source: 'Working', ProjNo: projNo })))
        }
      }
    }

    // 속성 및 컬럼 가공
    const allAttIds = new Set()
    const allKeys = new Set()
    const fixedKeys = ['Source', 'DELETED', 'TAG_IDX', 'TAG_NO', 'EP_ID', 'CLS_ID', 'ATTRIBUTES', '_id', 'ProjNo']

    combined.forEach(item => {
      ;(item.ATTRIBUTES || []).forEach(a => { if (a?.ATT_ID) allAttIds.add(a.ATT_ID) })
      Object.keys(item).forEach(k => { if (!fixedKeys.includes(k) && typeof item[k] !== 'object') allKeys.add(k) })
    })

    const processedData = combined.map(item => {
      const flatItem = { ...item }
      allAttIds.forEach(id => {
        const target = (item.ATTRIBUTES || []).find(a => a?.ATT_ID === id)
        flatItem[`ATT_${id}`] = target && target.VALUE !== null ? target.VALUE : 'null'
      })
      return flatItem
    })

    // 컬럼 정의 생성 (상세 모드 대응)
    dynamicAttCols.value = Array.from(allAttIds).sort().map(id => ({
      headerName: id, field: `ATT_${id}`, minWidth: 130, headerClass: 'att-column-header',
      cellRenderer: highlightRenderer,
      cellStyle: p => ({ background: '#fff9db', color: p.value === 'null' ? '#adb5bd' : '#000' }),
      hide: viewMode.value === 'simple' // 간편 모드 시 속성 숨김 (선택 사항)
    }))

    dynamicRemainingCols.value = Array.from(allKeys).sort().map(k => ({
      headerName: k, field: k, minWidth: 150, cellRenderer: highlightRenderer
    }))

    rawDataList.value = sortBy(processedData, ['ProjNo', 'TAG_NO', 'Source'])
  } catch (err) { sAlert.Error('조회 실패') }
  finally { gridApi.value?.setGridOption('loading', false) }
}

const highlightRenderer = p => {
  const val = p.value === null || p.value === undefined ? '' : String(p.value)
  if (!val || !localFilterQuery.value.trim()) return val
  let text = val
  localFilterQuery.value.split(/[\s,\n]+/).filter(k => k).forEach(kw => {
    text = text.replace(new RegExp(`(${kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'), `<mark class="filter-highlight">$1</mark>`)
  })
  return text
}

// --- 그리드 설정 ---
const mainColDefs = computed(() => {
  const baseCols = [
    { headerName: 'Project', field: 'ProjNo', width: 120, pinned: 'left', filter: true, cellStyle: { fontWeight: 'bold' } },
    { headerName: 'Source', field: 'Source', width: 110, pinned: 'left', 
      cellRenderer: p => `<span class="badge shadow-sm" style="background-color:${p.value === 'Working' ? '#ed6c02' : '#0288d1'};color:white;">${p.value}</span>`
    },
    { field: 'TAG_NO', headerName: 'Tag No', width: 180, pinned: 'left', cellRenderer: highlightRenderer },
    { field: 'CLS_ID', headerName: 'Class', width: 140, pinned: 'left', cellRenderer: highlightRenderer,
      cellStyle: { cursor: 'pointer', textDecoration: 'underline', color: '#0d6efd', fontWeight: 'bold' }
    },
  ]

  // 상세 모드일 때만 모든 컬럼 표시
  const dynamicCols = viewMode.value === 'detail' ? [...dynamicAttCols.value, ...dynamicRemainingCols.value] : []
  
  return [...baseCols, ...dynamicCols].filter(c => {
    if (!columnFilterQuery.value.trim() || c.pinned) return true
    return columnFilterQuery.value.toLowerCase().split(/[\s,\n]+/).some(kw => c.headerName?.toLowerCase().includes(kw))
  })
})

const gridBindProps = computed(() => ({
  columnDefs: mainColDefs.value,
  rowData: filteredData.value,
  pagination: true,
  paginationPageSize: 100,
  loadingOverlayComponent: AggridLoadingOverlay,
  defaultColDef: { sortable: true, filter: true, resizable: true, floatingFilter: true },
  class: 'ag-theme-custom'
}))

const filteredData = computed(() => {
  if (!localFilterQuery.value.trim()) return rawDataList.value
  const kws = localFilterQuery.value.toLowerCase().split(/[\s,\n]+/).filter(k => k)
  return rawDataList.value.filter(i => {
    const target = `${i.TAG_NO} ${i.ProjNo} ${i.Source} ${i.CLS_ID}`.toLowerCase()
    return kws.some(kw => target.includes(kw))
  })
})

const onGridReady = p => { gridApi.value = p.api }
const onCellClicked = p => {
  if (p.column.getColId() === 'Source') {
    selectedRow.value = p.data
    showModal.value = true
  }
}

// --- 모달 로직 (B 로직) ---
const modalGridBindProps = computed(() => {
  if (!selectedRow.value) return { columnDefs: [], rowData: [] }
  const rows = []
  Object.entries(selectedRow.value).forEach(([k, v]) => {
    if (k !== 'ATTRIBUTES' && !k.startsWith('ATT_') && k !== 'Source') rows.push({ category: 'System', key: k, value: v ?? '-' })
  })
  if (Array.isArray(selectedRow.value.ATTRIBUTES)) {
    selectedRow.value.ATTRIBUTES.forEach(a => rows.push({ category: 'Attribute', key: a.ATT_ID, value: a.VALUE ?? 'null' }))
  }
  return {
    columnDefs: [
      { headerName: 'Category', field: 'category', width: 120, pinned: 'left', cellStyle: { background: '#f8f9fa', fontWeight: 'bold' } },
      { headerName: 'Property', field: 'key', width: 200 },
      { headerName: 'Value', field: 'value', flex: 1 },
    ],
    rowData: rows
  }
})
const closeModal = () => { showModal.value = false; selectedRow.value = null; }

onMounted(async () => {
  try {
    const res = await axiosWrapper.get('/api/Project/Get')
    projectList.value = (res || []).filter(p => p.USE_YN)
  } catch (e) { console.error(e) }
})

watch([localFilterQuery, viewMode], () => { gridApi.value?.onFilterChanged() })
</script>

