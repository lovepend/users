<template>
  <div class="template__stack">
    <div class="header-controls" style="margin-bottom: 10px; display: flex; gap: 10px;">
      <button @click="loadData" class="btn-primary">조회 (Load)</button>
      <button @click="saveChanges" class="btn-success">저장 (Save)</button>
    </div>

    <gc-spread-sheets-designer
      :styleInfo="designerStyle"
      @designerInitialized="onDesignerInitialized"
    >
    </gc-spread-sheets-designer>
  </div>
</template>

<script setup>
import { ref } from 'vue';
import '@grapecity/spread-sheets-designer-vue';
import '@grapecity/spread-sheets-designer/styles/gc.spread.sheets.designer.min.css';
import '@grapecity/spread-sheets/styles/gc.spread.sheets.excel2013white.css';
import GC from '@grapecity/spread-sheets';
import '@grapecity/spread-sheets-designer';

// 라이선스 키는 실제 사용 시 최상단에 추가하세요.
// GC.Spread.Sheets.LicenseKey = "YOUR_SPREAD_KEY";
// GC.Spread.Sheets.Designer.LicenseKey = "YOUR_DESIGNER_KEY";

const designerPtr = ref(null);
const spreadPtr = ref(null);
const designerStyle = { width: '100%', height: '700px' };
const tableName = "MergedDataTable";

// 1. 디자이너 초기화 완료 후 실행
const onDesignerInitialized = (designer) => {
  designerPtr.value = designer;
  // 디자이너 객체에서 실제 Spread(Workbook) 객체 추출
  spreadPtr.value = designer.getWorkbook();
  
  const sheet = spreadPtr.value.getActiveSheet();
  sheet.name("Merged Data");
};

// 2. 데이터 로드 및 뿌려주기
const loadData = async () => {
  if (!spreadPtr.value) return;
  const sheet = spreadPtr.value.getActiveSheet();

  // 이전과 동일한 API 호출 로직
  try {
    const response = await fetch('/api/Data/GetMergedData', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Projectno': 'TE1002'
      },
      body: JSON.stringify({
        "ProjectNo": "TE1002",
        "REG_TYPE_ID": "101TEST",
        "Type": "Merged"
      })
    });

    const resData = await response.json();
    const firstKey = Object.keys(resData)[0];
    const listData = resData[firstKey]?.WrkData || [];

    sheet.suspendPaint();
    
    // 초기화
    sheet.setDataSource(null);
    if (sheet.tables.findByName(tableName)) {
      sheet.tables.remove(tableName);
    }

    if (listData.length > 0) {
      // 데이터 테이블 생성
      const table = sheet.tables.addFromDataSource(tableName, 0, 0, listData, GC.Spread.Sheets.Tables.TableThemes.medium2);
      
      // 컬럼 매핑
      table.bindColumns([
        { name: "TAG_NO", displayName: "태그 번호", size: 150 },
        { name: "TAG_DESC", displayName: "설명", size: 250 },
        { name: "CLS_ID", displayName: "클래스 ID", size: 120 }
      ]);
    }

    sheet.resumePaint();
    console.log("Designer Data Bind Complete");
  } catch (error) {
    console.error(error);
  }
};

const saveChanges = () => {
  const sheet = spreadPtr.value.getActiveSheet();
  const dirtyRows = sheet.getDirtyRows();
  console.log("Modified Data:", dirtyRows.map(r => sheet.getDataSource()[r.row]));
};
</script>

