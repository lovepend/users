<template>
  <div class="modal-grid-container">
    <div class="modal-header-info" v-if="mainFocusDataRef">
      <span class="label">Target Object:</span>
      <span class="value">{{ mainFocusDataRef?.NAME }} ({{ mainFocusDataRef?.CLS_ID }})</span>
    </div>

    <div v-for="sub in referInfoRef.SUB_INFO" :key="sub.NAME" class="grid-section">
      <h3 class="section-title">{{ sub.NAME }} 리스트</h3>
      <div class="modal-grid-wrapper ag-theme-alpine">
        <ag-grid-vue
          style="width: 100%; height: 200px;"
          :columnDefs="getColumnDefs(sub.NAME)"
          :rowData="sub.DATA"
          :loading="!sub.LOAD"
          :gridOptions="gridOptions"
          @grid-ready="onGridReady"
        />
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, shallowRef, computed, watch, onMounted } from 'vue'
import { storeToRefs } from 'pinia'
import { useRouter } from 'vue-router'
import { useAppMenuStore } from '@/stores/app-menu'
import { ApiCommon } from '@/utils/axios/api-common'
import { sAlert } from '@/utils/messages/alert-common'
import { AgGridVue } from 'ag-grid-vue3'

// AG Grid 필수 CSS
import 'ag-grid-community/styles/ag-grid.css'
import 'ag-grid-community/styles/ag-theme-alpine.css'

const router = useRouter()
const { currentProjNo, currentEpId } = storeToRefs(useAppMenuStore())

const _Emits = defineEmits(['show-overlay', 'hide-overlay'])
const _Props = defineProps({
  MAIN_FOCUS_DATA: { type: Object, required: false, default: null },
  MAIN_ORG_FOCUS_DATA: { type: Object, required: false, default: null },
})

const mainFocusDataRef = computed(() => _Props.MAIN_FOCUS_DATA)
const mainOrgFocusDataRef = computed(() => _Props.MAIN_ORG_FOCUS_DATA)

// 상태 관리
const isAllLoadedRef = shallowRef(false)
const isRegLoadedRef = shallowRef(false)
const isAdpLoadedRef = shallowRef(false)
const isRelLoadedRef = shallowRef(false)

const regListRef = ref([])
const adpListRef = ref([])
const relListRef = ref([])
const allAdpListRef = shallowRef([])

// 그리드 설정
const gridOptions = {
  headerHeight: 40,
  rowHeight: 35,
  defaultColDef: {
    sortable: true,
    filter: true,
    resizable: true,
  }
}

// 하이퍼링크가 포함된 컬럼 정의 생성기 [cite: 5, 7, 9]
const getColumnDefs = (type) => [
  { headerName: 'Key', field: 'KEY', width: 120 },
  { 
    headerName: 'Description (이동)', 
    field: 'DESC', 
    flex: 1,
    cellRenderer: (params) => {
      if (!params.data) return ''
      const link = document.createElement('a')
      link.innerText = params.value
      link.style.color = '#007bff'
      link.style.cursor = 'pointer'
      link.style.textDecoration = 'underline'
      link.addEventListener('click', (e) => {
        e.preventDefault()
        // 라우터 이동 로직 [cite: 5, 7, 9]
        router.push({ path: params.data.PATH, query: params.data.QUERY })
      })
      return link
    }
  }
]

// 데이터 바인딩 (전달받은 로직 유지) [cite: 4, 5, 6, 7, 8, 9]
const referInfoRef = computed(() => ({
  SUB_INFO: [
    {
      LOAD: isRegLoadedRef.value,
      NAME: 'Register',
      DATA: regListRef.value?.map(v => ({
        INFO: v, KEY: v.TYPE_ID, DESC: `(${v.EP_ID}) ${v.DESC}`,
        PATH: '/register-mapping-setup',
        QUERY: { reg_type_id: v.TYPE_ID, proj_no: currentProjNo.value, ep_id: currentEpId.value }
      })),
    },
    {
      LOAD: isAdpLoadedRef.value,
      NAME: 'Adapter',
      DATA: adpListRef.value?.map(v => ({
        INFO: v, KEY: v.MAP_ID, DESC: `(${v.EP_ID ?? ''}) ${v.DESC}`,
        PATH: '/adapter-data-mapping-setup',
        QUERY: { map_id: v.MAP_ID, proj_no: currentProjNo.value, ep_id: currentEpId.value }
      })),
    },
    {
      LOAD: isRelLoadedRef.value,
      NAME: 'Relation',
      DATA: relListRef.value?.map(v => ({
        INFO: v, KEY: v.REL_ID, DESC: v.NAME,
        PATH: '/relation-setup',
        QUERY: { rel_id: v.REL_ID, proj_no: currentProjNo.value, ep_id: currentEpId.value }
      })),
    },
  ],
}))

// API 로직 (기존 로직 유지) [cite: 10, 14, 18, 19, 21]
onMounted(async () => {
  const key = mainOrgFocusDataRef.value?.CLS_ID
  isAllLoadedRef.value = false
  await getAllAdapter() // Adapter 전체 로드 필요
  isAllLoadedRef.value = true
  if (key) {
    await getRegisterByKey(key)
    await getRelationByKey(key)
    getAdapterByKey(key)
  }
})

watch(mainOrgFocusDataRef, async (n) => {
  const key = n?.CLS_ID
  if (key && isAllLoadedRef.value) {
    await getRegisterByKey(key)
    await getRelationByKey(key)
    getAdapterByKey(key)
  }
})

// --- API 함수들 ---
const getAllAdapter = async () => {
  const projNo = currentProjNo.value
  if (!projNo) return
  try {
    const response = await ApiCommon.postAdapterDataMappingGet({ ProjectNo: projNo })
    allAdpListRef.value = response ?? []
  } catch (error) { console.error(error) }
}

const getRegisterByKey = async (KEY) => {
  isRegLoadedRef.value = false
  try {
    const response = await ApiCommon.postRegisterGetByClassIDs({
      ProjectNo: currentProjNo.value,
      ClassIDs: [KEY],
      ContainDeleted: false,
    })
    regListRef.value = response ?? []
  } catch (error) { console.error(error) }
  isRegLoadedRef.value = true
}

const getAdapterByKey = (KEY) => {
  isAdpLoadedRef.value = false
  if (KEY && regListRef.value.length) {
    adpListRef.value = allAdpListRef.value?.filter(v => 
      regListRef.value.some(v1 => v?.REG_TYPE_ID === v1?.TYPE_ID)
    )
  }
  isAdpLoadedRef.value = true
}

const getRelationByKey = async (KEY) => {
  isRelLoadedRef.value = false
  try {
    const response = await ApiCommon.postRelationGetByClassID({
      ProjectNo: currentProjNo.value,
      ClassIDs: [KEY],
      ContainDeleted: false,
    })
    relListRef.value = response ?? []
  } catch (error) { console.error(error) }
  isRelLoadedRef.value = true
}

defineExpose({ REGISTER_LIST_IN_USE: regListRef, RELATION_LIST_IN_USE: relListRef })
</script>

