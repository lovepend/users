.modal-body-content { flex-grow: 1; min-height: 0; background: #fff; display: flex; flex-direction: column; }
.modal-grid-container { flex: 1; width: 100%; height: 100%; background: #fff; border: 1px solid #dee2e6 !important; }
.json-wrapper { flex: 1; background: #1e293b; overflow: auto; padding: 15px; }
.json-content { margin: 0; color: #f1f5f9; font-family: 'Consolas', monospace; font-size: 13px; white-space: pre-wrap; word-wrap: break-word; }
::v-deep(.filter-highlight) { background-color: #ffeb3b !important; color: #000 !important; padding: 0 2px; border-radius: 2px; font-weight: bold; }
::v-deep(.badge) { min-width: 80px; text-align: center; cursor: pointer; border: none; }
::v-deep(.att-column-header) { background-color: #fff9db !important; color: #856404 !important; font-weight: bold !important; }
</style>
