<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-check-double" :title="'Tag 규격 유효성 검사'">
      <template #actions>
        <div class="d-flex align-items-center gap-2 ms-auto me-2">
          <div class="input-group input-group-sm" style="width: 200px;">
            <span class="input-group-text bg-light fw-bold">Project</span>
            <select class="form-select" v-model="selectedProjNo" @change="fetchTagTypes">
              <option value="">선택하세요</option>
              <option v-for="proj in projectList" :key="proj.PROJ_NO" :value="proj.PROJ_NO">
                {{ proj.PROJ_NO }}
              </option>
            </select>
          </div>

          <div class="input-group input-group-sm" style="width: 220px;">
            <span class="input-group-text bg-light fw-bold">Tag Type</span>
            <select class="form-select" v-model="selectedTypeId" @change="applyTagTypeRules" :disabled="!tagTypes.length">
              <option value="">타입 선택</option>
              <option v-for="type in tagTypes" :key="type.TYPE_ID" :value="type.TYPE_ID">
                {{ type.TYPE_ID }}
              </option>
            </select>
          </div>

          <input
            type="text"
            class="form-control form-control-sm border-primary fw-bold"
            style="width: 250px"
            v-model="tagNoForValidator"
            placeholder="검증할 태그 번호 입력"
          />
        </div>
        <panel-toolbar />
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100 overflow-hidden">
      <div class="row m-0 h-100">
        <div class="col-md-5 p-0 border-end h-100 d-flex flex-column bg-white">
          <div class="panel-heading bg-light border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-primary"><i class="fa fa-cog me-2"></i>적용된 검증 규칙</span>
            <span class="badge bg-secondary" v-if="selectedTypeId">{{ selectedTypeId }} 규칙 적용됨</span>
          </div>
          <div class="flex-grow-1 overflow-auto">
            <table class="table table-sm table-hover mb-0 custom-table">
              <thead class="table-light sticky-top">
                <tr>
                  <th class="text-center" width="80">ATT_ID</th>
                  <th width="70" class="text-center">구분자</th>
                  <th>정규식 (REG_EXPS)</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="(rule, index) in tagRules" :key="index">
                  <td class="text-center align-middle font-monospace small bg-light">{{ rule.attId }}</td>
                  <td class="text-center align-middle fw-bold text-primary">{{ rule.delimiter || '(없음)' }}</td>
                  <td class="align-middle font-monospace text-muted small">{{ rule.regex }}</td>
                </tr>
                <tr v-if="tagRules.length === 0">
                  <td colspan="3" class="text-center py-5 text-muted">프로젝트와 Tag Type을 선택하면 규칙이 자동으로 로드됩니다.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="col-md-7 p-0 h-100 d-flex flex-column bg-light">
          <div class="p-3 flex-grow-1 overflow-auto">
            <div :class="['alert d-flex align-items-center shadow-sm mb-3', isTagNoValid ? 'alert-success border-success' : 'alert-danger border-danger']" v-if="tagRules.length">
              <i :class="['fa fa-2x me-3', isTagNoValid ? 'fa-check-circle' : 'fa-times-circle']"></i>
              <div>
                <h5 class="alert-heading mb-1 fw-bold">{{ isTagNoValid ? '규격 일치' : '규격 불일치' }}</h5>
                <div class="small font-monospace opacity-75">Target: {{ tagNoForValidator }}</div>
              </div>
            </div>

            <div class="card shadow-sm border-0" v-if="tagRules.length">
              <div class="card-header bg-white py-2 fw-bold text-secondary small">구조 분석 상세</div>
              <div class="card-body p-0">
                <table class="table table-sm mb-0">
                  <thead class="bg-light small">
                    <tr>
                      <th class="ps-3">Attribute</th>
                      <th>추출 값</th>
                      <th class="text-center">구분자</th>
                      <th class="text-center">매칭</th>
                      <th class="text-center">결과</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr v-for="(part, index) in tagParts" :key="index">
                      <td class="ps-3 small text-muted">{{ tagRules[index]?.attId }}</td>
                      <td class="fw-bold font-monospace">{{ part.matchedValue || '-' }}</td>
                      <td class="text-center">
                        <i :class="part.isDelimiterValid ? 'fa fa-check text-success' : 'fa fa-times text-danger'" v-if="part.hasDelimiterRule"></i>
                        <span v-else>-</span>
                      </td>
                      <td class="text-center">
                        <span :class="part.isContentValid ? 'text-success' : 'text-danger fw-bold'">{{ part.isContentValid ? 'OK' : 'ERR' }}</span>
                      </td>
                      <td class="text-center">
                        <span :class="['badge', part.isValid ? 'bg-success' : 'bg-danger']" style="width: 50px;">{{ part.isValid ? 'PASS' : 'FAIL' }}</span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
            
            <div v-if="!isTagNoValid && tagRules.length" class="mt-3 alert alert-warning border-0 py-2 small">
              <i class="fa fa-info-circle me-1"></i> 선택된 타입의 정규식 구조와 입력값이 일치하지 않습니다.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import axios from 'axios'
import PageTitle from '@/components/toolBar/PageTitle.vue'

// 데이터 상태
const projectList = ref([{ PROJ_NO: 'TE1002' }, { PROJ_NO: 'TEST-PROJ' }]) // 실제 프로젝트 리스트로 교체
const selectedProjNo = ref('TE1002')
const selectedTypeId = ref('')
const tagTypes = ref([]) // API에서 받아올 타입 리스트
const tagRules = ref([]) // 선택된 타입의 LNK_CODE 기반 규칙
const tagNoForValidator = ref('AA-1-BB-2222-C')

// API 호출: Tag Type 가져오기
const fetchTagTypes = async () => {
  if (!selectedProjNo.value) return
  try {
    const response = await axios.post('/api/TagType/Get', {
      ContainDeleted: false,
      ProjectNo: selectedProjNo.value
    })
    tagTypes.value = response.data
    selectedTypeId.value = '' // 초기화
    tagRules.value = []
  } catch (error) {
    console.error("Tag Type 로드 실패:", error)
  }
}

// 타입 선택 시 규칙 적용
const applyTagTypeRules = () => {
  const targetType = tagTypes.value.find(t => t.TYPE_ID === selectedTypeId.value)
  if (targetType && targetType.LNK_CODE) {
    // API의 LNK_CODE를 기존 검증 로직에 맞는 형식으로 매핑
    tagRules.value = targetType.LNK_CODE.map(item => ({
      attId: item.ATT_ID,
      delimiter: item.DL_VAL || '',
      regex: item.REG_EXPS || '^.*$'
    }))
  } else {
    tagRules.value = []
  }
}

// --- 검증 로직 (기존 유지) ---
const canBeEmpty = (regexStr) => {
  try {
    return new RegExp(`^(${regexStr.replace(/^\^|\$/g, '')})$`).test('')
  } catch { return false }
}

const tagParts = computed(() => {
  const results = []
  let currentStr = tagNoForValidator.value || ''
  let cursor = 0

  for (let i = 0; i < tagRules.value.length; i++) {
    const rule = tagRules.value[i]
    const delim = rule.delimiter
    const pureRegex = rule.regex.replace(/^\^|\$/g, '')
    let dOk = true, cOk = false, matchedVal = null
    const hasDelim = delim !== ''

    if (hasDelim) {
      if (currentStr.substring(cursor).startsWith(delim)) {
        cursor += delim.length
        dOk = true
      } else { dOk = canBeEmpty(rule.regex) }
    }

    try {
      const matcher = new RegExp(`^(${pureRegex})`).exec(currentStr.substring(cursor))
      if (matcher) {
        matchedVal = matcher[1]
        cursor += matchedVal.length
        cOk = true
      } else if (canBeEmpty(rule.regex)) {
        matchedVal = ''; cOk = true
      }
    } catch { cOk = false }

    results.push({
      hasDelimiterRule: hasDelim,
      isDelimiterValid: dOk,
      isContentValid: cOk,
      matchedValue: matchedVal,
      isValid: dOk && cOk,
    })
    if (!(dOk && cOk)) break
  }
  return results
})

const isTagNoValid = computed(() => {
  if (tagRules.value.length === 0) return false
  const allPartsPass = tagParts.value.length === tagRules.value.length && tagParts.value.every(p => p.isValid)
  if (!allPartsPass) return false
  
  let usedLen = 0
  tagParts.value.forEach((p, i) => {
    if (p.hasDelimiterRule && p.isDelimiterValid) {
      if (tagNoForValidator.value.substring(usedLen).startsWith(tagRules.value[i].delimiter)) {
        usedLen += tagRules.value[i].delimiter.length
      }
    }
    if (p.matchedValue) usedLen += p.matchedValue.length
  })
  return usedLen === (tagNoForValidator.value || '').length
})

onMounted(() => {
  fetchTagTypes() // 초기 로드
})

defineOptions({ name: 'TagTypeValidator' })
</script>

