// 🛠️ Class 모달 내 그리드 셀 클릭 이벤트 (새 탭으로 Register 바로가기)
const onClassGridCellClicked = (p) => {
  if (p.column.getColId() === 'TYPE_ID') {
    // 1. router.resolve를 이용해 이동할 주소(URL)를 만듭니다.
    const routeData = router.resolve({
      path: '/register-mapping-setup',
      query: {
        reg_type_id: p.data.TYPE_ID,
        proj_no: p.data.PROJ_NO || manualProjNo.value.trim(),
        ep_id: p.data.EP_ID
      }
    })
    
    // 2. 만들어진 주소를 새 탭('_blank')으로 엽니다.
    window.open(routeData.href, '_blank')
  }
}
