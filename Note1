const loadFileByid = async (svgFileId, itemIds) => {
    if (!svgFileId) {
      return false
    }

    if (viewerTabs.value) {
      // 1. URL 구성 (쿼리 스트링 제외하고 nocache만 유지)
      let url = `http://sedpwebapi.ship.samsung.co.kr/api/File/Get?nocache=${new Date().getTime()}`

      const options = {
        responseType: 'blob',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/svg+xml',
          'FileToken': 'frontserver@sh',
          'Cache-Control': 'no-store',
          // 2. 헤더에 Project no와 ep_id 추가 (route.query에서 가져옴)
          'ProjectNo': route.query.proj_no || currProjNoRef.value,
          'ep_id': route.query.ep_id || currEpIdRef.value
        },
      }

      // API 호출 시 보낼 바디 데이터
      const bodyData = {
        id: svgFileId,
      }

      try {
        // axiosWrapper 대신 직접 주소를 호출하거나 설정된 axios 인스턴스 사용
        const blobData = await axiosWrapper.post(url, bodyData, options)

        if (blobData) {
          const fileId = generateFileId(blobData)
          let svgBlobUrl = ''

          if (urlCache.has(fileId)) {
            svgBlobUrl = urlCache.get(fileId)
          } else {
            svgBlobUrl = URL.createObjectURL(blobData)
            urlCache.set(fileId, svgBlobUrl)
          }

          if (svgFileId && itemIds != null) {
            let _elementId = itemIds
            if (arrayTagNoByQueryString.value.length > 0) {
              _elementId = arrayTagNoByQueryString.value
            }

            const messageFor2DViewer = {
              detail: {
                action: 'loadAndSearchFile',
                drawing: svgBlobUrl,
                idType: 'tag',
                elementId: _elementId,
                zoom: fit2DViewer.value,
                highlight: highlightColor.value,
                title: 'Drawing Title',
              },
              bubbles: true,
              composed: true,
            }
            document.dispatchEvent(new CustomEvent('svg-viewer-command', messageFor2DViewer))
          } else {
            document.dispatchEvent(
              new CustomEvent('svg-viewer-command', {
                detail: {
                  action: 'fileOpen',
                  drawing: svgBlobUrl,
                },
                bubbles: true,
                composed: true,
              })
            )
          }
          return true
        }
      } catch (error) {
        console.log('error loadFile : ', error)
        return false
      }
    }
  }
