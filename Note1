<template>
  <div class="panel m-0 p-0 h-100" ref="_PageWrapperRef">
    <div class="panel-heading p-2" style="background-color: var(--bg17)">
      <h4 class="panel-title" style="color: var(--txt03)">
        <i class="fa fa-bars me-2"></i>
        <span>{{ $t('RevisionSetup_vue.revision_title') }}</span>
        <span v-if="currentProjNo"> [ {{ currentProjNo }} ]</span>
      </h4>
    </div>
    <span v-if="false && !isSetupAdmin" class="just-view">{{ $t('DataSettingNavBar_vue.justViewPermission') }}</span>
    <div v-else class="panel-heading m-0 p-0">
      <div class="w-100 h-100">
        <BasicToolBar v-bind="toolbarBindRef" v-on="toolbarEventsRef" />
      </div>
    </div>
    <div class="panel-body overflow-hidden m-0 p-0 h-100">
      <ag-grid-vue v-bind="gridBindRef" v-on="gridEvents" />
    </div>
  </div>
</template>
<script setup>
  // Library - Common
  import { ref, shallowRef, computed } from 'vue'
  import { storeToRefs } from 'pinia'

  // Store
  import { useAppPermissionStore } from '@/stores/app-permission'
  import { useAppAuthenticationStore } from '@/stores/app-authentication'
  import { useAppMenuStore } from '@/stores/app-menu'

  // Custom Component
  import BasicToolBar from '@/components/toolBar/BasicToolBar.vue'
  import AggridLoadingOverlay from '@/components/aggrid/AgGridLoadingOverlay.vue'
  import AgDetailStatusBar from '@/components/aggrid/AgDetailStatusBar.vue'
  import AgCustomFilter from '@/components/aggrid/AgCustomFilter.vue'
  import AgComboEditor from '@/components/aggrid/AgComboEditor.vue'

  // Helpers
  import { ApiCommon } from '@/utils/axios/api-common'
  import { dataUtil as DU } from '@/utils/functions/data-utility'
  import { sAlert } from '@/utils/messages/alert-common'
  import global from '@/constants/enums/global'
  import * as _ from 'lodash-es'

  // GLOBAL
  const { userInfo } = storeToRefs(useAppAuthenticationStore())
  const { isSetupAdmin } = storeToRefs(useAppPermissionStore())
  const { currentProjNo } = storeToRefs(useAppMenuStore())

  const _Emits = defineEmits(['show-overlay', 'hide-overlay'])
  const _Props = defineProps({
    CURRENT_REVISION: { type: Object, required: false, default: null },
    IS_NEVER_PUBLISHED: { type: Boolean, required: false, default: false },
  })

  const isNeverPublishedRef = computed(() => _Props.IS_NEVER_PUBLISHED)
  const currentRevisionRef = computed(() => _Props.CURRENT_REVISION)

  const _PageWrapperRef = shallowRef()
  const onShowOverlay = function (config) {
    const pageWrapper = _PageWrapperRef.value
    const loadConfig = pageWrapper ? { target: pageWrapper } : {}
    _Emits('show-overlay', { ...loadConfig, ...config })
  }
  const onHideOverlay = () => _Emits('hide-overlay')
  const onShowLoading = () => gridRef.value?.setGridOption('loading', true)
  const onHideLoading = () => gridRef.value?.setGridOption('loading', false)

  // TOOLBAR BUTTON
  const isShowCreateBtn = shallowRef(isSetupAdmin.value)
  const isShowSaveBtn = shallowRef(isSetupAdmin.value)
  const isShowDeleteBtn = shallowRef(isSetupAdmin.value)
  const isDisabledSaveBtn = shallowRef(true)
  const isDisabledDeleteBtn = shallowRef(true)
  const toolbarBindRef = computed(() => ({
    showCreate: isShowCreateBtn.value,
    showMultiCreate: isShowCreateBtn.value,
    showDelete: isShowDeleteBtn.value && isNeverPublishedRef.value,
    showSave: isShowSaveBtn.value,
    isDisabledDeleteBtn: isDisabledDeleteBtn.value,
    isDisabledSaveBtn: isDisabledSaveBtn.value,
    createTooltip: 'After creating data, click the Save button.',
    deleteTooltip: 'It will be deleted immediately.',
  }))
  const toolbarEventsRef = computed(() => ({
    createData: onCreateRows,
    createMultiData: onCreateMultiRows,
    deleteData: onDeleteRows,
    saveData: saveData,
  }))

  // MODIFIED DATA
  // KEY ID Update용 { [_ROW_ID]: { _ROW_ID: [_ROW_ID], KEY: '' } } // KEY - Original Key
  const modKeysRef = shallowRef({})

  // GRID
  const gridKeyRef = shallowRef(0) // Grid Refresh용
  const gridRef = shallowRef()
  const gridDataRef = shallowRef([])
  // 데이터 원본 확인용
  const gridDataOrgRef = shallowRef([])
  const gridDataOrgDictRef = shallowRef({}) // 데이터 원본 확인용 { _ROW_ID: data, ... }
  const gridDataRenderedRef = shallowRef(false)
  const dateFilterParams = {
    minValidDate: '2008-01-08',
    maxValidDate: new Date(new Date().getTime() + 24 * 60 * 60 * 1000),
    comparator: (filterLocalDateAtMidnight, cellValue) => {
      const dateStr = cellValue?.substring(0, 10)
      if (!dateStr) {
        return -1
      }
      const splitted = dateStr.split('-')
      const date = new Date(Number(splitted[0]), Number(splitted[1]) - 1, Number(splitted[2]))

      if (filterLocalDateAtMidnight.getTime() === date.getTime()) {
        return 0
      } else if (filterLocalDateAtMidnight > date) {
        return -1
      } else if (filterLocalDateAtMidnight < date) {
        return 1
      }
      return 0
    },
  }
  const gridColDefsRef = ref([
    {
      suppressHeaderMenuButton: true,
      headerCheckboxSelectionFilteredOnly: true,
      flex: 1,
      minWidth: 30,
      maxWidth: 30,
      suppressAutoSize: true,
      suppressSizeToFit: true,
      resizable: false,
      sortable: false,
      editable: false,
      filter: 'agSetColumnFilter',
      filterValueGetter: params => params.node.selected,
      filterParams: {
        suppressSorting: true,
        refreshValuesOnOpen: true,
      },
      checkboxSelection: params => !params.node.group,
      headerCheckboxSelection: true,
    },
    {
      field: 'SEQ',
      headerName: 'Order',
      cellDataType: 'number',
      flex: 1,
      minWidth: 100,
      maxWidth: 100,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      valueParser: params => (isNaN(params.newValue) ? 0 : Number(params.newValue)),
      // cellEditor: 'agNumberCellEditor',
      cellEditorParams: {
        min: 0,
        max: 10000,
        step: 1,
      },
    },
    {
      field: 'REV',
      headerName: 'Rev No',
      flex: 1,
      minWidth: 100,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
    },
    {
      field: 'PROJ_NO',
      headerName: 'Project No',
      hide: true,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      editable: false,
      cellClass: 'agReadOnly',
    },
    {
      field: 'CRTER_NO',
      headerName: 'CRTER NO',
      hide: true,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      editable: false,
      cellClass: 'agReadOnly',
    },
    {
      field: 'CRTE_DTM',
      headerName: 'CRTE DTM',
      cellDataType: 'date',
      hide: true,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      editable: false,
      cellClass: 'agReadOnly',
      filter: 'agDateColumnFilter',
      filterParams: dateFilterParams,
      valueFormatter: params => {
        return dateFullFormatter(params)
      },
    },
    {
      field: 'CHGER_NO',
      headerName: 'CHGER NO',
      hide: true,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      editable: false,
      cellClass: 'agReadOnly',
    },
    {
      field: 'CHGE_DTM',
      headerName: 'CHGE DTM',
      cellDataType: 'date',
      hide: true,
      // tooltipValueGetter: params => params.valueFormatted || params.value,
      editable: false,
      cellClass: 'agReadOnly',
      filter: 'agDateColumnFilter',
      filterParams: dateFilterParams,
      valueFormatter: params => {
        return dateFullFormatter(params)
      },
    },
    { field: '_id', headerName: 'id', hide: true, editable: false, cellClass: 'agReadOnly' },
    { field: 'STATUS', hide: true, editable: false, cellClass: 'agReadOnly' },
  ])

  const onRefresh = function () {
    gridKeyRef.value += 1
  }
  const onInitialize = async function () {
    const onFinally = function () {
      if (gridDataRenderedRef.value) {
        setTimeout(() => {
          // setFocusData()
          gridRef.value?.refreshCells({ force: true, suppressFlash: true })
        }, 10)
      }
      gridDataRenderedRef.value = true

      onHideLoading()
      // onHideOverlay()
    }

    // onShowOverlay()
    onShowLoading()

    modKeysRef.value = {}
    gridDataRef.value = []
    gridDataOrgRef.value = []
    gridDataOrgDictRef.value = {}

    if (!currentProjNo.value) {
      return onFinally()
    }

    let response
    try {
      response = await ApiCommon.postRevisionNoGetRevisions({ ProjectNo: currentProjNo.value })
    } catch (error) {
      const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
      sAlert.Error({
        title: `Load Revisions Error`, // Optional
        html: backMsg,
      })
      return onFinally()
    }

    const dataList = []
    const orgDataList = []
    const orgDataDict = {}
    ;(response ?? []).forEach((data, index) => {
      data._ROW_ID = `ROW_${String(index).padStart(6, '0')}`
      const orgData = _.cloneDeep(data)
      orgDataDict[orgData._ROW_ID] = orgData
      orgDataList.push(orgData)
      if (!data.DELETED) {
        dataList.push(data)
      }
    })
    gridDataRef.value = dataList
    gridDataOrgRef.value = orgDataList
    gridDataOrgDictRef.value = orgDataDict

    return onFinally()
  }

  const onCreateRows = function () {
    if (!currentProjNo.value) {
      sAlert.Warning(`Project를  선택해주세요`)
      return
    }

    insertRows(1)
  }

  const onCreateMultiRows = function (rowCount) {
    if (!currentProjNo.value) {
      sAlert.Warning(`Project를  선택해주세요`)
      return
    }

    insertRows(rowCount)
  }

  const insertRows = function (rowCount) {
    const grid = gridRef.value
    grid.stopEditing()
    onShowLoading()

    let maxSeq = 0
    grid.forEachNode(node => {
      const seq = Number(node.data?.SEQ)
      if (!isNaN(seq) && seq > maxSeq) {
        maxSeq = seq
      }
    })

    const addRows = []
    for (let i = 0; i < rowCount; i++) {
      const newId = `NEW_ROW_${Math.random().toString(36).substring(2, 12)}`
      addRows.push({
        STATUS: 'A',
        PROJ_NO: currentProjNo.value,
        REV: null,
        SEQ: (maxSeq += 1),
        _ROW_ID: newId,
      })
    }
    if (addRows.length) {
      const lastIndex = grid.getDisplayedRowCount()
      const result = grid.applyTransaction({ add: addRows, addIndex: lastIndex })
      grid.refreshCells({ force: true, suppressFlash: true })
      grid.setNodesSelected({
        nodes: result.add,
        newValue: true,
      })
      grid.ensureIndexVisible(lastIndex, 'bottom')
    }
    onHideLoading()
  }

  const onDeleteRows = async function () {
    const grid = gridRef.value
    const selectedRows = grid?.getSelectedRows()
    if (!selectedRows || !selectedRows.length) {
      sAlert.Warning(`Please select the data you want to delete.`)
      return
    }

    const confirmResult = await sAlert.Confirm('It will be deleted immediately. Are you sure you want to delete?')
    if (!confirmResult?.isConfirmed) {
      return
    }

    const passList = []
    const failList = []
    const promises_all = []
    const promises_race = []
    for (let i = 0; i < selectedRows.length; i++) {
      const dataItem = selectedRows[i]
      const { PROJ_NO, REV, STATUS, _id: rowId } = dataItem
      let delKeyId = REV

      if (promises_race.length >= 20) {
        await Promise.race(promises_race)
      }
      if (STATUS !== 'A') {
        let orgKeyInfo = modKeysRef.value[rowId]
        if (orgKeyInfo) {
          if (orgKeyInfo.KEY !== REV) {
            delKeyId = orgKeyInfo.KEY
          } else {
            delete modKeysRef.value[rowId]
            orgKeyInfo = null
          }
        }

        const promise = ApiCommon.postRevisionNoDeleteRevision({
          ProjectNo: PROJ_NO,
          REV: delKeyId,
        })
          .then(() => {
            passList.push(dataItem)
            delete modKeysRef.value[orgKeyInfo?._ROW_ID]
          })
          .catch(error => failList.push({ item: dataItem, error: error }))
          .finally(() => promises_race.splice(promises_race.indexOf(promise), 1))
        promises_race.push(promise)
        promises_all.push(promise)
      } else {
        passList.push(dataItem)
      }
    }
    await Promise.all(promises_all)

    let message = ''
    const passCount = passList.length
    const failCount = failList.length
    if (passCount) {
      message += `Successfully deleted ${passCount} Revisions.`
      grid.applyTransaction({ remove: passList })
      grid.refreshCells()

      gridDataRef.value = gridDataRef.value.filter(({ _ROW_ID }) => {
        return !passList.some(v => v._ROW_ID === _ROW_ID)
      })
      gridDataOrgRef.value = gridDataOrgRef.value.filter(({ _ROW_ID }) => {
        return !passList.some(v => v._ROW_ID === _ROW_ID)
      })
    }
    if (failCount) {
      if (!message) {
        message += `Failed deleted Revisions.`
      }
      message += `\nfailed to delete ${failCount} item.`
      for (let i = 0; i < failCount; i++) {
        const { item, error } = failList[i]
        const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
        message += `\n    [ Rev : ${item.REV || ''}, Reason: ${backMsg} ]`
      }
    }
    if (!passCount && failCount) {
      sAlert.Error(message)
    } else {
      sAlert.Success(message)
    }
  }

  const checkValidation = function (dataList) {
    const dupVerCheck = {}
    const dupSeqCheck = {}
    const failMsgList = []
    dataList?.forEach(dataItem => {
      const rev = dataItem.REV
      const seq = dataItem.SEQ

      if (rev) {
        dupVerCheck[rev] = !dupVerCheck[rev]
      }
      if (seq == 0 || seq) {
        dupSeqCheck[seq] = !dupSeqCheck[seq]
      }

      if (!rev) {
        failMsgList.push("'Revision' is Required.")
      } else if (!dupVerCheck[rev]) {
        failMsgList.push(`[${rev}] 'Revision' is Duplicated.`)
      } else if (seq != 0 && !seq) {
        failMsgList.push(`[${rev}] 'Order' is Required.`)
      } else if (!dupSeqCheck[seq]) {
        failMsgList.push(`[${rev}] 'Order' is Duplicated.`)
      }
    })

    if (failMsgList.length) {
      sAlert.Error(_.uniq(failMsgList).join('<br/>'))
      return false
    }
    return true
  }

  const saveData = async function () {
    onShowOverlay()
    const grid = gridRef.value
    grid.stopEditing()
    await new Promise(r => setTimeout(r, 10))

    const onFinally = function (SUCCESS) {
      if (SUCCESS === true) {
        // onInitialize()
        onRefresh()
      }
      onHideOverlay()
    }

    const selectedRows = grid.getSelectedRows()
    if (!selectedRows || !selectedRows.length) {
      sAlert.Warning('Please select the data you want to save.')
      return onFinally(false)
    } else if (!checkValidation(selectedRows)) {
      return onFinally(false)
    }

    const createData = []
    const updateData = []
    const updateIdData = []
    for (let i = 0; i < selectedRows.length; i++) {
      const dataItem = selectedRows[i]
      if (dataItem.STATUS == 'A') {
        createData.push({ ...dataItem, CRTER_NO: userInfo.value?.UserID })
      } else {
        updateData.push({ ...dataItem, CHGER_NO: userInfo.value?.UserID })
      }

      const orgKeyInfo = modKeysRef.value[dataItem._ROW_ID]
      if (orgKeyInfo) {
        if (orgKeyInfo.KEY !== dataItem.REV) {
          updateIdData.push({
            info: orgKeyInfo,
            data: {
              ProjectNo: dataItem.PROJ_NO,
              REV: orgKeyInfo.KEY,
              NEW_REV: dataItem.REV,
            },
          })
        } else {
          delete modKeysRef.value[orgKeyInfo._ROW_ID]
        }
      }
    }

    try {
      if (createData.length) {
        await ApiCommon.postRevisionNoCreateRevisions(createData)
      }
      if (updateData.length) {
        await ApiCommon.putRevisionNoUpdateRevisions(updateData)
      }
      for (let i = 0; i < updateIdData.length; i++) {
        const updateIdInfo = updateIdData[i]
        delete modKeysRef.value[updateIdInfo.info?._ROW_ID]
      }
      sAlert.Success(`
        Successfully saved.<br>
        ${createData.length ? ` Created :${createData.length}` : ''}
        ${createData.length && updateData.length ? '<br>' : ''}
        ${updateData.length ? ` Updated :${updateData.length}` : ''}
      `)

      grid.deselectAll()
    } catch (error) {
      console.error(error)
      const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
      sAlert.Error({
        title: `Error`, // Optional
        html: backMsg,
      })
      return onFinally(false)
    }
    return onFinally(true)
  }

  // GRID /////////////////////////////////////////////////////////////////////
  /////////////////////////////////////////////////////////////////////////////
  const dateFullFormatter = function (params) {
    if (params.value) {
      const date = new Date(params.value)
      if (!isNaN(date.getTime())) {
        return date.toLocaleString()
      }
    }
    return ''
  }

  const makeCellClass = function (params) {
    if (params.node.group) {
      return
    }
    const field = params.colDef?.field
    const value = params.value
    const rowIdField = '_ROW_ID'
    const orgData = gridDataOrgDictRef.value?.[params.data?.[rowIdField]]
    const orgValue = orgData?.[field]
    if (field) {
      if (orgData) {
        if (Array.isArray(orgValue)) {
          if (Array.isArray(value)) {
            if (orgValue.join(',') !== value.join(',')) {
              return 'hasWork'
            }
          } else {
            if (value) {
              return 'hasWork'
            } else {
              return 'hasWorkEmpty'
            }
          }
        } else {
          // Diff Value
          if (value != orgValue) {
            return !value ? 'hasWorkEmpty' : 'hasWork'
          }
        }
      } else {
        // New Rows
        return 'hasWorkEmpty'
      }
    }
    return
  }

  const onGetRowId = function (params) {
    return params.data?._ROW_ID
  }

  const onGridReady = function (params) {
    gridRef.value = params.api
    onInitialize()
  }

  const onRowSelected = function (params) {
    const selectedRows = params.api.getSelectedRows()
    const isDisabled = !selectedRows.length
    isDisabledSaveBtn.value = isDisabled
    isDisabledDeleteBtn.value = isDisabled
  }

  const onCellValueChanged = function (params) {
    const grid = params.api
    const node = params.node
    const dataItem = params.data
    const field = params.colDef.field
    const oldValue = params.oldValue
    const newValue = params.newValue
    const source = params.source

    const excludedFields = [''] // 제외할 필드 목록
    // 모든 필드에 대해 trim 적용
    if (dataItem) {
      Object.keys(dataItem).forEach(key => {
        if (DU.isString(dataItem[key]) && !excludedFields.includes(key)) {
          dataItem[key] = dataItem[key].trim()
        }
      })
    }

    if (field === 'REV') {
      let isDuplicate = false
      const compareVal = String(newValue ?? '')
        .trim()
        .toUpperCase()
      grid.forEachNode(n => {
        if (n.data && n.id !== node.id) {
          const baseVal = String(n.data[field] ?? '')
            .trim()
            .toUpperCase()
          if (baseVal === compareVal) {
            isDuplicate = true
          }
        }
      })
      if (isDuplicate) {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning('This is the use of duplicate Revision.')
        return
      }
    } else if (field === 'SEQ') {
      let isDuplicate = false
      const compareVal = String(newValue ?? '')
        .trim()
        .toUpperCase()
      grid.forEachNode(n => {
        if (n.data && n.id !== node.id) {
          const baseVal = String(n.data[field] ?? '')
            .trim()
            .toUpperCase()
          if (baseVal === compareVal) {
            isDuplicate = true
          }
        }
      })
      if (isDuplicate) {
        dataItem[field] = oldValue
        grid.stopEditing()
        grid.redrawRows()
        sAlert.Warning('This is the use of duplicate Order.')
        return
      }
    }

    if (!source) {
      return
    } // 코드에 의한 변경은 처리하지 않음

    if (field === 'REV') {
      if (dataItem?.STATUS !== 'A' && !modKeysRef.value[node.id]) {
        modKeysRef.value[node.id] = { _ROW_ID: node.id, KEY: oldValue }
      }
    }

    node.setSelected(true)
  }

  // Keydown 단축키 Ctrl + S 저장 단축키
  const onKeyDown = event => {
    if (event.ctrlKey && event.key === 's') {
      event.preventDefault() //브라우저 기본 저장 동작 방지
      saveData()
    }
  }

  const gridBindRef = ref({
    key: gridKeyRef,
    columnDefs: gridColDefsRef,
    rowData: gridDataRef,
    class: 'ag-theme-custom w-100 h-100',
    rowSelection: 'multiple',
    rowDragManaged: true,
    // cellSelection: true,
    enableFillHandle: true,
    enableRangeSelection: true,
    suppressRowClickSelection: true,
    rowMultiSelectWithClick: false,
    suppressLastEmptyLineOnPaste: true,
    columnHoverHighlight: true,
    tooltipShowDelay: 0,
    undoRedoCellEditing: true,
    undoRedoCellEditingLimit: 20,
    pagination: false,
    paginationPageSize: 100,
    paginationPageSizeSelector: [100, 500, 1000],
    // context: '',
    loadingOverlayComponent: AggridLoadingOverlay,
    loadingOverlayComponentParams: {
      loadingMessage: 'Loading...',
    },
    statusBar: {
      statusPanels: [
        { statusPanel: 'agTotalRowCountComponent' },
        { statusPanel: 'agFilteredRowCountComponent' },
        { statusPanel: 'agSelectedRowCountComponent' },
      ],
    },
    defaultColDef: {
      // wrapHeaderText: true,
      // autoHeaderHeight: true,
      editable: true,
      cellClass: makeCellClass,
      headerTooltip: params => params.colDef.field,
      tooltipComponent: class {
        elem = document.createElement('div')
        init(params) {
          let value = params.value
          if (params.location === 'header' && DU.isFunction(value)) {
            value = value(params)
          }
          this.elem.className = DU.isNullOrEmpty(value) ? '' : 'ag-tooltip'
          this.elem.innerHTML = value ?? ''
        }
        getGui() {
          return this.elem
        }
      },
      floatingFilter: true,
      filter: 'agMultiColumnFilter',
      filterParams: {
        filters: [
          {
            filter: 'agTextColumnFilter',
            filterParams: { buttons: ['reset'] },
          },
          {
            filter: 'agSetColumnFilter',
            filterParams: {
              buttons: ['reset'],
              valueFormatter: params => params.value,
              comparator: (a, b) => {
                const valA = parseInt(a)
                const valB = parseInt(b)
                if (valA === valB) return 0
                return valA > valB ? 1 : -1
              },
            },
          },
          {
            filter: 'AgCustomFilter',
            filterParams: { buttons: ['reset'] },
          },
        ],
      },
      filterValueGetter: params => params.data[params.colDef.field],
    },
    getRowId: onGetRowId,
  })
  const gridEvents = {
    gridReady: onGridReady,
    rowSelected: onRowSelected,
    cellValueChanged: onCellValueChanged,
    keydown: onKeyDown,
  }

  defineOptions({
    name: 'RevisionRevs',
    components: { AgDetailStatusBar, AgCustomFilter, AgComboEditor },
  })
</script>

<style scoped lang="scss">
  .just-view {
    color: var(--txt03);
    background-color: var(--bg11);
    padding: 6px 8px 6px 8px;
    width: 100%;
    text-align: center;
    font-weight: 500;
  }
</style>
