<script>
  import { shallowRef } from 'vue'
  import { ApiCommon } from '@/utils/axios/api-common'
  import vSelect from 'vue-select'
  import { useEmployees } from '@/stores/app-employees'
  import { debounce } from 'lodash' // lodash 설치가 되어있다면 추천합니다.

  const { setEmployeeInfo } = useEmployees()

  export default {
    name: 'AgUserEditor',
    components: { vSelect },
    props: {
      params: { type: Object, default: () => ({}) },
    },
    setup(props) {
      return {
        containerRef: shallowRef(null),
        vSelectRef: shallowRef(null),
        vModelRef: shallowRef(null),
        vOptionsRef: shallowRef([]),
        vValue: shallowRef(null),
        // 디바운스된 함수를 담을 변수
        debouncedFetch: null 
      }
    },
    created() {
      // 1. 컴포넌트 생성 시 디바운스 함수를 초기화합니다.
      // 300ms(0.3초) 동안 입력이 없으면 실제 API 요청을 수행합니다.
      this.debouncedFetch = debounce(async (search, loading) => {
        try {
          const userName = String(search ?? '').replaceAll(' ', '')
          if (userName.length < 2) {
            this.vOptionsRef = []
            return
          }

          loading(true)
          const response = (await ApiCommon.postOfficeFindEmployee({ Type: 'Name', Keyword: userName })) ?? []
          
          const options = response
            .filter(item => item.EMP_NO)
            .map(item => ({
              ...item,
              code: item.EMP_NO,
              label: `${item.EMP_NM ?? ''}(${item.DEPT_NAME ?? ''})`,
            }))
            .sort((n, p) => (n.EMP_NM > p.EMP_NM ? 1 : -1))

          setEmployeeInfo(options)
          this.vOptionsRef = options
        } catch (error) {
          this.vOptionsRef = []
        } finally {
          loading(false)
        }
      }, 300)
    },
    mounted() {
      this.vModelRef = this.params?.editorSelected
      this.vOptionsRef = this.params?.editorOptions ?? []
      this.vValue = this.getInitialValue()
      setTimeout(() => {
        this.vSelectRef?.searchEl.focus()
      }, 1)
    },
    methods: {
      getValue() {
        return this.vValue
      },
      getInitialValue() {
        return this.params?.value
      },
      onClosePopup() {
        try { if (this.params) this.params.stopEditing() } catch {}
      },
      setValue(USER_ID) {
        const newValue = String(USER_ID ?? '')
        this.vValue = newValue === '' ? null : newValue
      },
      getSelectedValue() {
        return this.vModelRef?.code
      },
      onKeydown(event) {
        if (event.key === 'Escape') { // ESC -> Escape가 표준입니다.
          event.preventDefault()
          this.setValue(this.getInitialValue())
          this.onClosePopup()
        } else if (event.key === 'Enter') {
          event.preventDefault()
          event.stopPropagation()
          const userId = this.getSelectedValue()
          if (userId) {
            this.setValue(userId)
            this.onClosePopup()
          }
        }
      },
      // 2. v-select에서 호출하는 함수는 디바운스된 래퍼 함수를 호출합니다.
      onSearch(search, loading) {
        if (!search.trim()) {
          this.vOptionsRef = []
          return
        }
        // 실제 API 호출 로직이 담긴 디바운스 함수 실행
        this.debouncedFetch(search, loading)
      },
      onSelected(item) {
        this.setValue(item?.code)
        setTimeout(() => this.containerRef?.focus(), 1)
      },
      dropdownShouldOpen: function (vselect) {
        return !vselect.loading && vselect.open
      },
    },
    // 컴포넌트가 사라질 때 예약된 작업을 취소해줍니다. (메모리 누수 방지)
    beforeUnmount() {
      this.debouncedFetch.cancel()
    }
  }
</script>
