<template>
  <div class="panel panel-expandable m-0 p-0 h-100">
    <PageTitle icon="fa-copy" title="Tag 데이터 비교 분석">
      <template #actions>
        <div class="d-flex align-items-center gap-3 ms-auto me-2">
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold">Project No</span>
            <input type="text" class="form-control form-control-sm" style="width: 100px;" v-model="manualProjNo" />
          </label>
          <label class="d-flex align-items-center gap-2">
            <span class="fw-bold">Register ID</span>
            <input type="text" class="form-control form-control-sm" style="width: 140px;" v-model="regTypeId" placeholder="예: PIEP_T_002_T" />
          </label>

          <div class="d-flex align-items-center gap-2 border-start ps-3">
            <span class="fw-bold text-nowrap">조회 대상:</span>
            <div class="form-check form-check-inline mb-0" v-for="opt in ['Publish', 'Working', 'MergeData']" :key="opt">
              <input class="form-check-input" type="radio" :id="opt" :value="opt" v-model="selectedType" />
              <label class="form-check-label" :for="opt">{{ opt }}</label>
            </div>
          </div>

          <div class="form-check mb-0 border-start ps-3">
            <input class="form-check-input" type="checkbox" id="delCheck" v-model="containDeleted" />
            <label class="form-check-label fw-bold" for="delCheck">삭제 포함</label>
          </div>

          <button class="btn btn-xs btn-primary shadow-sm" @click="onSearch"><i class="fa fa-search me-1"></i>조회</button>
        </div>
      </template>
    </PageTitle>

    <div class="panel-body m-0 p-0 h-100">
      <ag-grid-vue
        v-bind="gridBindProps"
        @grid-ready="onGridReady"
        :tooltipShowDelay="0" 
      />
    </div>
  </div>
</template>

<script setup>
import { ref, computed, shallowRef } from 'vue'
import { axiosWrapper } from '@/utils/axios/axios-wrapper'
import { sAlert } from '@/utils/messages/alert-common'

// 상위 스토어 등에서 값 가져오기 (기존 소스 참조)
const manualProjNo = ref('SN2661')
const regTypeId = ref('PIEP_T_002_T')
const selectedType = ref('Working')
const containDeleted = ref(false)

const gridApi = shallowRef()
const rawDataList = ref([])
const diffMap = ref(new Map()) // Diff 하이라이트용 맵
const dynamicCols = ref([])

/**
 * 🎨 셀 렌더러 및 스타일 (Diff 하이라이트 핵심)
 */
const diffCellRenderer = (p) => {
  const diffInfo = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
  if (diffInfo) {
    // 값이 다를 경우 하이라이트 처리
    return `<div class="diff-highlight" title="Pub: ${diffInfo.pub} / Wrk: ${diffInfo.wrk}">${p.value ?? ''}</div>`
  }
  return p.value ?? ''
}

const getCellStyle = (p) => {
  const diffInfo = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
  if (diffInfo) {
    return { backgroundColor: '#fff3cd', border: '1px solid #ffda6a', fontWeight: 'bold' }
  }
  return null
}

const onSearch = async () => {
  if (!manualProjNo.value || !regTypeId.value) return sAlert.Warning("필수 항목을 입력하세요.")
  
  if (gridApi.value) gridApi.value.setGridOption('loading', true)
  
  try {
    const payload = {
      ProjectNo: manualProjNo.value,
      REG_TYPE_ID: regTypeId.value,
      Type: selectedType.value,
      ContainDeleted: containDeleted.value
    }

    const res = await axiosWrapper.post('api/Data/GetMergedData', payload)
    const rootData = res[regTypeId.value] // 키워드로 데이터 접근

    if (!rootData) {
      rawDataList.value = []
      return
    }

    // 1. DiffData 맵핑 (TAG_IDX + 필드명을 키로 사용)
    const newDiffMap = new Map()
    if (rootData.DiffData) {
      rootData.DiffData.forEach(diff => {
        diff.Property.forEach(prop => {
          if (prop.PUB_VALUE !== prop.WRK_VALUE) {
            newDiffMap.set(`${diff.TAG_IDX}_${prop.PROP_ID}`, {
              pub: prop.PUB_VALUE,
              wrk: prop.WRK_VALUE
            })
          }
        })
      })
    }
    diffMap.value = newDiffMap

    // 2. 데이터 선택 (Type에 따라 추출)
    const targetData = 
      selectedType.value === 'Working' ? rootData.WrkData :
      selectedType.value === 'Publish' ? rootData.PubData : rootData.MergeData
    
    if (!targetData) {
      rawDataList.value = []
      return
    }

    // 3. 동적 컬럼 구성
    const allAttIds = new Set()
    const allKeys = new Set()
    const fixedKeys = ['ATTRIBUTES', '_id', 'DELETED']

    targetData.forEach(item => {
      (item.ATTRIBUTES || []).forEach(a => allAttIds.add(a.ATT_ID))
      Object.keys(item).forEach(k => {
        if (!fixedKeys.includes(k) && typeof item[k] !== 'object') allKeys.add(k)
      })
    })

    // 속성(ATTRIBUTES) 플랫화
    const processed = targetData.map(item => {
      const flat = { ...item }
      ;(item.ATTRIBUTES || []).forEach(a => {
        flat[a.ATT_ID] = a.VALUE
      })
      return flat
    })

    // 컬럼 정의 생성
    const colDefs = Array.from(allKeys).map(k => ({
      headerName: k,
      field: k,
      minWidth: 120,
      cellRenderer: diffCellRenderer,
      cellStyle: getCellStyle,
      tooltipValueGetter: (p) => {
        const diff = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
        return diff ? `Published: ${diff.pub}\nWorking: ${diff.wrk}` : null
      }
    }))

    const attDefs = Array.from(allAttIds).map(id => ({
      headerName: id,
      field: id,
      minWidth: 130,
      headerClass: 'bg-light-yellow',
      cellRenderer: diffCellRenderer,
      cellStyle: getCellStyle,
      tooltipValueGetter: (p) => {
        const diff = diffMap.value.get(`${p.data.TAG_IDX}_${p.colDef.field}`)
        return diff ? `Published: ${diff.pub}\nWorking: ${diff.wrk}` : null
      }
    }))

    dynamicCols.value = [...colDefs, ...attDefs]
    rawDataList.value = processed

  } catch (e) {
    sAlert.Error("데이터 로드 중 오류가 발생했습니다.")
  } finally {
    if (gridApi.value) gridApi.value.setGridOption('loading', false)
  }
}

const gridBindProps = computed(() => ({
  columnDefs: dynamicCols.value,
  rowData: rawDataList.value,
  style: 'width: 100%; height: 100%',
  class: 'ag-theme-alpine',
  defaultColDef: { sortable: true, filter: true, resizable: true, tooltipComponent: null }
}))

const onGridReady = p => { gridApi.value = p.api }
</script>

<style scoped>
::v-deep(.bg-light-yellow) {
  background-color: #fffbe6 !important;
  color: #856404 !important;
}
::v-deep(.diff-highlight) {
  width: 100%;
  height: 100%;
}
</style>
