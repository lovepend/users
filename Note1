<template>
  <div 
    ref="containerRef" 
    class="p-1 bg-white ag-user-editor-container" 
    tabindex="0" 
    @keydown="onKeydown"
  >
    <div class="d-flex flex-row my-1 justify-content-between">
      <span class="badge bg-info">ESC - 취소</span>
      <span class="badge bg-dark" style="cursor: pointer" @click="onClosePopup">X</span>
    </div>
    
    <vSelect
      ref="vSelectRef"
      v-model="vModelRef"
      :options="vOptionsRef"
      :taggable="false"
      :filterable="false"
      :placeholder="'검색어 입력 (예: 홍길동 / ㅎㄱㄷ)'"
      :dropdown-should-open="dropdownShouldOpen"
      @option:selected="onSelected"
      @search="onSearch"
      class="w-100 ag-user-editor-select"
    />
  </div>
</template>

<script>
import { shallowRef } from 'vue'
import { ApiCommon } from '@/utils/axios/api-common'
import vSelect from 'vue-select'
import { useEmployees } from '@/stores/app-employees'
import { debounce } from 'lodash'

const { setEmployeeInfo } = useEmployees()

export default {
  name: 'AgUserEditor',
  components: { vSelect },
  props: {
    // AG-Grid ICellEditorParams
    params: { type: Object, default: () => ({}) },
  },
  setup() {
    return {
      containerRef: shallowRef(null),
      vSelectRef: shallowRef(null),
      vModelRef: shallowRef(null),
      vOptionsRef: shallowRef([]),
      vValue: shallowRef(null),
      // 디바운스 인스턴스를 저장할 변수
      debouncedFetch: null 
    }
  },
  created() {
    /**
     * 실제 API를 호출하는 핵심 로직 (디바운스 적용)
     * 300ms(0.3초) 동안 추가 입력이 없을 때만 실행됩니다.
     */
    this.debouncedFetch = debounce(async (search, loading) => {
      try {
        const userName = String(search ?? '').replaceAll(' ', '')
        
        // 검색어가 너무 짧으면 호출하지 않음
        if (userName.length < 2) {
          this.vOptionsRef = []
          loading(false)
          return
        }

        loading(true)
        const response = (await ApiCommon.postOfficeFindEmployee({ 
          Type: 'Name', 
          Keyword: userName 
        })) ?? []

        const options = response
          .filter(item => item.EMP_NO)
          .map(item => ({
            ...item,
            code: item.EMP_NO,
            label: `${item.EMP_NM ?? ''}(${item.DEPT_NAME ?? ''})`,
          }))
          .sort((n, p) => (n.EMP_NM > p.EMP_NM ? 1 : -1))

        // 스토어 업데이트 및 옵션 반영
        setEmployeeInfo(options)
        this.vOptionsRef = options

      } catch (error) {
        console.error('Employee search failed:', error)
        this.vOptionsRef = []
      } finally {
        loading(false)
      }
    }, 300)
  },
  mounted() {
    this.vModelRef = this.params?.editorSelected
    this.vOptionsRef = this.params?.editorOptions ?? []
    this.vValue = this.getInitialValue()
    
    // 마운트 후 즉시 검색창에 포커스
    setTimeout(() => {
      this.vSelectRef?.searchEl?.focus()
    }, 10)
  },
  methods: {
    // AG-Grid 필수 반환 값
    getValue() {
      return this.vValue
    },
    getInitialValue() {
      return this.params?.value
    },
    onClosePopup() {
      try {
        if (this.params && typeof this.params.stopEditing === 'function') {
          this.params.stopEditing()
        }
      } catch (e) {
        // ignore error
      }
    },
    setValue(USER_ID) {
      const newValue = String(USER_ID ?? '')
      this.vValue = newValue === '' ? null : newValue
    },
    getSelectedValue() {
      return this.vModelRef?.code
    },
    onKeydown(event) {
      // ESC 키 대응 (표준 'Escape' 사용)
      if (event.key === 'Escape' || event.key === 'ESC') {
        event.preventDefault()
        this.setValue(this.getInitialValue())
        this.onClosePopup()
      } 
      // Enter 키 대응
      else if (event.key === 'Enter') {
        event.preventDefault()
        event.stopPropagation()
        const userId = this.getSelectedValue()
        if (userId) {
          this.setValue(userId)
          this.onClosePopup()
        }
      }
    },
    /**
     * v-select의 @search 이벤트 핸들러
     */
    onSearch(search, loading) {
      if (!search.trim()) {
        this.vOptionsRef = []
        return
      }
      // 디바운스된 함수 실행
      this.debouncedFetch(search, loading)
    },
    onSelected(item) {
      this.setValue(item?.code)
      // 선택 후 컨테이너로 포커스 이동 (필요 시)
      setTimeout(() => this.containerRef?.focus(), 1)
    },
    dropdownShouldOpen(vselect) {
      return !vselect.loading && vselect.open && this.vOptionsRef.length > 0
    },
  },
  /**
   * 컴포넌트 파괴 전 실행 중인 타이머 취소 (메모리 누수 방지)
   */
  beforeUnmount() {
    if (this.debouncedFetch) {
      this.debouncedFetch.cancel()
    }
  }
}
</script>

