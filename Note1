  --ag-row-hover-color: #f9fafb;
  --ag-selected-row-background-color: #eff6ff;
  border: 1px solid #d1d5db;
}

/* 필터 입력창 스타일 */
.filter-textarea { 
  width: 140px; height: 28px; resize: none; font-size: 11px; line-height: 1.2; padding: 2px 5px; overflow: hidden; 
  border-radius: 4px;
}

/* 모달 디자인 */
.custom-modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; }
.custom-modal-window { background: #fff; width: 900px; height: 80%; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; border: 1px solid #1e293b; }
.modal-header-dark { background: #1e293b; color: #fff; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; }
.modal-body-content { flex: 1; background: #0f172a; padding: 20px; overflow: auto; }
.json-content { color: #38bdf8; font-family: 'Consolas', monospace; font-size: 13px; margin: 0; white-space: pre-wrap; }
