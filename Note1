<template>
  <ReferenceList :REFERENCE="referInfoRef" />
</template>

<script setup>
  import { ref, shallowRef, computed, watch, onMounted } from 'vue'
  import { storeToRefs } from 'pinia'
  import { useAppMenuStore } from '@/stores/app-menu'
  import ReferenceList from '@/components/panels/ReferenceList.vue'
  import { ApiCommon } from '@/utils/axios/api-common'
  import { sAlert } from '@/utils/messages/alert-common'

  const { currentProjNo, currentEpId } = storeToRefs(useAppMenuStore())
  const _Emits = defineEmits(['show-overlay', 'hide-overlay'])
  const _Props = defineProps({
    MAIN_FOCUS_DATA: { type: Object, required: false, default: null },
    MAIN_ORG_FOCUS_DATA: { type: Object, required: false, default: null },
  })

  const mainFocusDataRef = computed(() => _Props.MAIN_FOCUS_DATA)
  const mainOrgFocusDataRef = computed(() => _Props.MAIN_ORG_FOCUS_DATA)
  watch(mainOrgFocusDataRef, n => {
    if (isAllLoadedRef.value) {
      const key = n?.CLS_ID
      Promise.all([
        //
        getRegisterByKey(key),
        getRelationByKey(key),
      ]).then(() => {
        Promise.all([
          //
          getAdapterByKey(key),
        ])
      })
    }
  })

  const onShowOverlay = config => _Emits('show-overlay', config)
  const onHideOverlay = () => _Emits('hide-overlay')

  const isAllLoadedRef = shallowRef(false)
  const isRegLoadedRef = shallowRef(false)
  const isAdpLoadedRef = shallowRef(false)
  const isRelLoadedRef = shallowRef(false)
  const allRegListRef = shallowRef([])
  const allAdpListRef = shallowRef([])
  const allRelListRef = shallowRef([])
  const regListRef = ref([])
  const adpListRef = ref([])
  const relListRef = ref([])
  const referInfoRef = computed(() => ({
    LOAD: isAllLoadedRef.value,
    MAIN_INFO: {
      NAME: 'Object Class',
      INFO: mainFocusDataRef.value,
      KEY: mainFocusDataRef.value?.CLS_ID,
      DESC: mainFocusDataRef.value?.DESC,
    },
    SUB_INFO: [
      {
        LOAD: isRegLoadedRef.value,
        NAME: 'Register',
        DATA: regListRef.value?.map(v => ({
          INFO: v,
          KEY: v.TYPE_ID,
          DESC: `(${v.EP_ID}) ${v.DESC}`,
          PATH: '/register-mapping-setup',
          QUERY: {
            reg_type_id: v.TYPE_ID,
            proj_no: currentProjNo.value,
            ep_id: currentEpId.value,
          },
        })),
      },
      {
        LOAD: isAdpLoadedRef.value,
        NAME: 'Adapter',
        DATA: adpListRef.value?.map(v => ({
          INFO: v,
          KEY: v.MAP_ID,
          DESC: `(${v.EP_ID ?? ''}) ${v.DESC}`,
          PATH: '/adapter-data-mapping-setup',
          QUERY: {
            map_id: v.MAP_ID,
            proj_no: currentProjNo.value,
            ep_id: currentEpId.value,
          },
        })),
      },
      {
        LOAD: isRelLoadedRef.value,
        NAME: 'Relation',
        DATA: relListRef.value?.map(v => ({
          INFO: v,
          KEY: v.REL_ID,
          DESC: v.NAME,
          PATH: '/relation-setup',
          QUERY: {
            rel_id: v.REL_ID,
            proj_no: currentProjNo.value,
            ep_id: currentEpId.value,
          },
        })),
      },
    ],
  }))

  onMounted(async () => {
    const key = mainOrgFocusDataRef.value?.CLS_ID
    isAllLoadedRef.value = false
    await Promise.all([
      //
      getAllRegister(),
      getAllAdapter(),
      getAllRelation(),
    ])
    isAllLoadedRef.value = true
    Promise.all([
      //
      getRegisterByKey(key),
      getRelationByKey(key),
    ]).then(() => {
      Promise.all([
        //
        getAdapterByKey(key),
      ])
    })
  })

  const getAllRegister = async () => {
    allRegListRef.value = []

    // const projNo = currentProjNo.value
    // if (projNo) {
    //   let response
    //   try {
    //     response = await ApiCommon.postRegisterGet({
    //       ProjectNo: projNo,
    //       ContainDeleted: false,
    //     })
    //   } catch (error) {
    //     console.error(error)
    //     const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
    //     sAlert.Error({
    //       title: `Load Register Error`, // Optional
    //       html: backMsg,
    //     })
    //   }
    //   allRegListRef.value = response ?? []
    // }
  }
  const getAllAdapter = async () => {
    allAdpListRef.value = []

    const projNo = currentProjNo.value
    if (projNo) {
      let response
      try {
        response = await ApiCommon.postAdapterDataMappingGet({
          ProjectNo: projNo,
        })
      } catch (error) {
        console.error(error)
        const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
        sAlert.Error({
          title: `Load Adapter Error`, // Optional
          html: backMsg,
        })
      }
      allAdpListRef.value = response ?? []
    }
  }
  const getAllRelation = async () => {
    allRelListRef.value = []

    // const projNo = currentProjNo.value
    // if (projNo) {
    //   let response
    //   try {
    //     response = await ApiCommon.postObjectClassGet({
    //       ProjectNo: projNo,
    //       ContainDeleted: false,
    //     })
    //   } catch (error) {
    //     console.error(error)
    //     const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
    //     sAlert.Error({
    //       title: `Load Relation Error`, // Optional
    //       html: backMsg,
    //     })
    //   }
    //   allRelListRef.value = response ?? []
    // }
  }
  const getRegisterByKey = async function (KEY) {
    isRegLoadedRef.value = false

    const projNo = currentProjNo.value
    let response
    if (projNo && KEY) {
      try {
        response = await ApiCommon.postRegisterGetByClassIDs({
          ProjectNo: projNo,
          ClassIDs: [KEY],
          ContainDeleted: false,
        })
      } catch (error) {
        console.error(error)
        const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
        sAlert.Error({
          title: `Load Register Error`, // Optional
          html: backMsg,
        })
      }
    }
    regListRef.value = response
    isRegLoadedRef.value = true
  }
  const getAdapterByKey = async function (KEY) {
    isAdpLoadedRef.value = false
    let result
    if (KEY && regListRef.value && regListRef.value.length) {
      try {
        result = allAdpListRef.value?.filter(v => {
          const regInfo = regListRef.value.find(v1 => v?.REG_TYPE_ID === v1?.TYPE_ID)
          if (regInfo) {
            v.EP_ID = regInfo.EP_ID
            return true
          }
          return false
        })
      } catch (error) {
        console.error(error)
      }
    }
    adpListRef.value = result
    isAdpLoadedRef.value = true
  }
  const getRelationByKey = async function (KEY) {
    isRelLoadedRef.value = false
    const projNo = currentProjNo.value
    let response
    if (projNo && KEY) {
      try {
        response = await ApiCommon.postRelationGetByClassID({
          ProjectNo: projNo,
          ClassIDs: [KEY],
          ContainDeleted: false,
        })
      } catch (error) {
        console.error(error)
        const backMsg = String(error.response?.data?.Message || error.message).replace(/\r\n/, '<br>')
        sAlert.Error({
          title: `Load Relation Error`, // Optional
          html: backMsg,
        })
      }
    }
    relListRef.value = response
    isRelLoadedRef.value = true
  }

  defineExpose({
    REGISTER_LIST_IN_USE: regListRef,
    RELATION_LIST_IN_USE: relListRef,
  })
</script>

